  "ConnectionStrings": {
    "DefaultConnection": "Host=${DATABASE_HOST};Port=${DATABASE_PORT};Database=${DATABASE_DATABASE};Username=${DATABASE_USERNAME};Password=${DATABASE_PASSWORD}"
