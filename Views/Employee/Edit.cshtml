@model TaskTracker.Models.ViewModels.EmployeeViewModel
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container mx-auto px-4 py-8 max-w-4xl">
    <div class="mb-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Edit Employee</h1>
                <p class="text-gray-600 mt-1">Update employee information and branch assignments</p>
            </div>
            <a href="@Url.Action("Index")" class="text-gray-600 hover:text-gray-800 transition flex items-center">
                <i class="fas fa-arrow-left mr-2"></i> Back to List
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
            <strong>Error:</strong> @TempData["ErrorMessage"]
        </div>
    }

    @if (!ViewContext.ViewData.ModelState.IsValid)
    {
        <div class="bg-yellow-100 border border-yellow-400 text-yellow-800 px-4 py-3 rounded mb-4">
            <strong>Validation Errors:</strong>
            <ul class="mt-2 list-disc list-inside">
                @foreach (var error in ViewContext.ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <div class="bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden">
        <div class="p-6">
            <form asp-action="Edit" method="post" id="editEmployeeForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 text-red-700 rounded-lg text-sm border border-red-200"></div>

                <!-- Basic Information -->
                <div class="bg-gray-50 rounded-lg p-5 mb-6">
                    <h3 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                        <i class="fas fa-user-circle text-blue-500 mr-2"></i>Basic Information
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                                Full Name <span class="text-red-500">*</span>
                            </label>
                            <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                            <span asp-validation-for="Name" class="text-xs text-red-600 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="EmployeeId" class="block text-sm font-medium text-gray-700 mb-1">
                                Employee ID <span class="text-red-500">*</span>
                            </label>
                            <input asp-for="EmployeeId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                            <span asp-validation-for="EmployeeId" class="text-xs text-red-600 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                            <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="employee@company.com" />
                            <span asp-validation-for="Email" class="text-xs text-red-600 mt-1 block"></span>
                            <p class="text-xs text-gray-400 mt-1">Leave empty if not applicable</p>
                        </div>
                        <div>
                            <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                            <input asp-for="Phone" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="+252 63 1234567" />
                            <span asp-validation-for="Phone" class="text-xs text-red-600 mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <!-- Employment Information -->
                <div class="bg-gray-50 rounded-lg p-5 mb-6">
                    <h3 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                        <i class="fas fa-briefcase text-green-500 mr-2"></i>Employment Information
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Position" class="block text-sm font-medium text-gray-700 mb-1">Position</label>
                            <input asp-for="Position" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="e.g., Cashier, Manager" />
                            <span asp-validation-for="Position" class="text-xs text-red-600 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="DepartmentId" class="block text-sm font-medium text-gray-700 mb-1">Department</label>
                            <select asp-for="DepartmentId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                <option value="">Select Department</option>
                                @if (ViewBag.Departments != null)
                                {
                                    foreach (var dept in ViewBag.Departments)
                                    {
                                        var selected = dept.Id == Model.DepartmentId ? "selected" : null;
                                        <option value="@dept.Id" selected="@selected">@dept.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-xs text-red-600 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="HireDate" class="block text-sm font-medium text-gray-700 mb-1">Hire Date</label>
                            <input asp-for="HireDate" type="date" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="@Model.HireDate?.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="HireDate" class="text-xs text-red-600 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="ManagerId" class="block text-sm font-medium text-gray-700 mb-1">Reports To (Manager)</label>
                            <select asp-for="ManagerId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                                <option value="">None (Top Level / No Manager)</option>
                                @if (ViewBag.Managers != null)
                                {
                                    foreach (var mgr in ViewBag.Managers)
                                    {
                                        if (mgr.Id != Model.Id)
                                        {
                                            var selected = mgr.Id == Model.ManagerId ? "selected" : null;
                                            <option value="@mgr.Id" selected="@selected">@mgr.Name - @mgr.Position</option>
                                        }
                                    }
                                }
                            </select>
                            <span asp-validation-for="ManagerId" class="text-xs text-red-600 mt-1 block"></span>
                            <p class="text-xs text-blue-600 mt-1">
                                <i class="fas fa-info-circle mr-1"></i>
                                Leave empty if this employee doesn't report to anyone
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Branch Assignments - Multi-Select with Pre-selected -->
                <div class="bg-gray-50 rounded-lg p-5 mb-6">
                    <h3 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                        <i class="fas fa-store text-purple-500 mr-2"></i>Branch Assignments
                    </h3>
                    <p class="text-sm text-gray-500 mb-3">Select all branches this employee is responsible for</p>
                    
                    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 max-h-60 overflow-y-auto p-2 border border-gray-200 rounded-lg bg-white">
                        @if (ViewBag.Branches != null && ((IEnumerable<object>)ViewBag.Branches).Any())
                        {
                            foreach (var branch in ViewBag.Branches)
                            {
                                var isChecked = Model.BranchIds != null && Model.BranchIds.Contains(branch.Id);
                                <label class="flex items-center space-x-2 p-2 rounded hover:bg-gray-100 cursor-pointer transition @(isChecked ? "bg-blue-50" : "")">
                                    <input type="checkbox" 
                                           name="BranchIds" 
                                           value="@branch.Id" 
                                           @(isChecked ? "checked" : "") 
                                           class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 branch-checkbox" />
                                    <span class="text-sm text-gray-700">@branch.Name</span>
                                </label>
                            }
                        }
                        else
                        {
                            <p class="text-sm text-gray-400 italic col-span-full text-center py-4">No active branches available.</p>
                        }
                    </div>
                    
                    <div class="mt-3 flex items-center justify-between">
                        <div class="text-xs text-blue-600">
                            <i class="fas fa-info-circle mr-1"></i>
                            Uncheck a branch to remove assignment
                        </div>
                        <div class="text-xs text-gray-500">
                            <i class="fas fa-check-circle mr-1"></i>
                            <span id="selectedCount">0</span> branches selected
                        </div>
                    </div>
                </div>

                <!-- Address Information -->
                <div class="bg-gray-50 rounded-lg p-5 mb-6">
                    <h3 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                        <i class="fas fa-map-marker-alt text-orange-500 mr-2"></i>Address Information
                    </h3>
                    <div>
                        <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1">Full Address</label>
                        <textarea asp-for="Address" rows="2" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Street address, city, postal code...">@Model.Address</textarea>
                        <span asp-validation-for="Address" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                </div>

                <!-- Status Section -->
                <div class="bg-gray-50 rounded-lg p-5 mb-6">
                    <h3 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                        <i class="fas fa-toggle-on text-yellow-500 mr-2"></i>Status
                    </h3>
                    <div class="flex items-center">
                        <input asp-for="IsActive" type="checkbox" class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                        <label asp-for="IsActive" class="ml-2 text-sm text-gray-700">Active Employee</label>
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Inactive employees won't appear in task assignments</p>
                </div>

                <!-- Form Actions -->
                <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200">
                    <a href="@Url.Action("Index")" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                        <i class="fas fa-times mr-2"></i>Cancel
                    </a>
                    <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center">
                        <i class="fas fa-save mr-2"></i>Update Employee
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateSelectedCount() {
            var checked = $('input[name="BranchIds"]:checked').length;
            $('#selectedCount').text(checked);
            
            $('.branch-item').removeClass('bg-blue-50');
            $('input[name="BranchIds"]:checked').each(function() {
                $(this).closest('.branch-item').addClass('bg-blue-50');
            });
        }
        
        $(document).ready(function() {
            // Initialize branch items with class for styling
            $('.grid .flex.items-center').each(function() {
                $(this).addClass('branch-item');
            });
            
            updateSelectedCount();
            
            $('input[name="BranchIds"]').on('change', function() {
                updateSelectedCount();
            });
            
            $('#editEmployeeForm').on('submit', function() {
                var selected = [];
                $('input[name="BranchIds"]:checked').each(function() {
                    selected.push($(this).val());
                });
                console.log('Submitting employee edit with branches:', selected);
            });
        });
    </script>
}