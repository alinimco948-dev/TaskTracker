@model TaskTracker.Models.ViewModels.EmployeeViewModel
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">Edit Employee</h2>
            <p class="text-blue-100 text-sm mt-1">Update employee information</p>
        </div>

        <form asp-action="Edit" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Left Column -->
                <div class="space-y-4">
                    <!-- Full Name -->
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                            Full Name <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                        <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Employee ID -->
                    <div>
                        <label asp-for="EmployeeId" class="block text-sm font-medium text-gray-700 mb-1">
                            Employee ID <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="EmployeeId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                        <span asp-validation-for="EmployeeId" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Email -->
                    <div>
                        <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">
                            Email Address
                        </label>
                        <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                        <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Phone -->
                    <div>
                        <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1">
                            Phone Number
                        </label>
                        <input asp-for="Phone" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                    </div>
                </div>

                <!-- Right Column -->
                <div class="space-y-4">
                    <!-- Position -->
                    <div>
                        <label asp-for="Position" class="block text-sm font-medium text-gray-700 mb-1">
                            Position / Title
                        </label>
                        <input asp-for="Position" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                    </div>

                    <!-- Department -->
                    <div>
                        <label asp-for="DepartmentId" class="block text-sm font-medium text-gray-700 mb-1">
                            Department
                        </label>
                        <select asp-for="DepartmentId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                            <option value="">Select Department</option>
                            @if (ViewBag.Departments != null)
                            {
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    var selected = dept.Id == Model.DepartmentId ? "selected" : null;
                                    <option value="@dept.Id" selected="@selected">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Manager -->
                    <div>
                        <label asp-for="ManagerId" class="block text-sm font-medium text-gray-700 mb-1">
                            Reports To (Manager)
                        </label>
                        <select asp-for="ManagerId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                            <option value="">Select Manager</option>
                            @if (ViewBag.Managers != null)
                            {
                                @foreach (var mgr in ViewBag.Managers)
                                {
                                    if (mgr.Id != Model.Id) // Can't be their own manager
                                    {
                                        var selected = mgr.Id == Model.ManagerId ? "selected" : null;
                                        <option value="@mgr.Id" selected="@selected">@mgr.Name - @mgr.Position</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <!-- Hire Date -->
                    <div>
                        <label asp-for="HireDate" class="block text-sm font-medium text-gray-700 mb-1">
                            Hire Date
                        </label>
                        <input asp-for="HireDate" type="date" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                               value="@Model.HireDate?.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
            </div>

            <!-- Address (Full Width) -->
            <div class="mt-4">
                <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1">
                    Address
                </label>
                <textarea asp-for="Address" rows="2" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">@Model.Address</textarea>
            </div>

            <!-- Active Status -->
            <div class="mt-6 bg-gray-50 p-4 rounded-lg">
                <label class="flex items-center space-x-3">
                    <input asp-for="IsActive" type="checkbox" class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                    <span class="text-sm font-medium text-gray-700">Active Employee</span>
                </label>
            </div>

            <!-- Form Actions -->
            <div class="flex justify-end space-x-3 mt-6 pt-4 border-t">
                <a href="@Url.Action("Index")" class="px-6 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition duration-200">
                    <i class="fas fa-times mr-2"></i>Cancel
                </a>
                <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition duration-200 flex items-center">
                    <i class="fas fa-save mr-2"></i>Update Employee
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}