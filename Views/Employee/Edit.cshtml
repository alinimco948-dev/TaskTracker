@model TaskTracker.Models.ViewModels.EmployeeViewModel
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="max-w-4xl mx-auto animate-fade-up space-y-5">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #6366f1, #7c3aed);">
                    <i class="fas fa-user-edit text-white text-sm"></i>
                </div>
                Edit Employee
            </h1>
            <p class="text-slate-400 mt-1">Update employee information and branch assignments</p>
        </div>
        <a href="@Url.Action("Index")" class="flex items-center gap-2 text-slate-400 hover:text-white transition text-sm">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-error rounded-xl p-4 flex items-center gap-3">
            <i class="fas fa-exclamation-circle text-red-400 flex-shrink-0"></i>
            <p class="text-sm">@TempData["ErrorMessage"]</p>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success rounded-xl p-4 flex items-center gap-3">
            <i class="fas fa-check-circle text-emerald-400 flex-shrink-0"></i>
            <p class="text-sm">@TempData["SuccessMessage"]</p>
        </div>
    }

    @if (!ViewContext.ViewData.ModelState.IsValid)
    {
        <div class="alert-warning rounded-xl p-4">
            <p class="font-semibold text-sm mb-2">Validation Errors:</p>
            <ul class="text-sm space-y-1 list-disc list-inside">
                @foreach (var error in ViewContext.ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <div class="glass-card overflow-hidden">
        <form asp-action="Edit" method="post" id="editEmployeeForm" class="p-6 space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EmployeeId" value="@Model.EmployeeId" />
            <input type="hidden" asp-for="HireDate" />
            <div asp-validation-summary="ModelOnly" class="alert-error rounded-xl p-4 text-sm"></div>

            <!-- Basic Information -->
            <div class="rounded-xl p-5 space-y-4" style="background: rgba(99,102,241,0.06); border: 1px solid rgba(99,102,241,0.15);">
                <h3 class="text-sm font-bold text-indigo-300 uppercase tracking-widest flex items-center gap-2">
                    <i class="fas fa-user-circle text-indigo-400"></i>Basic Information
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Name" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Full Name <span class="text-red-400">*</span></label>
                        <input asp-for="Name" class="dark-input" />
                        <span asp-validation-for="Name" class="text-xs text-red-400 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Email" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Email Address</label>
                        <input asp-for="Email" type="email" class="dark-input" placeholder="employee@company.com" />
                        <span asp-validation-for="Email" class="text-xs text-red-400 mt-1 block"></span>
                        <p class="text-xs text-slate-600 mt-1">Leave empty if not applicable</p>
                    </div>
                    <div>
                        <label asp-for="Phone" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Phone Number</label>
                        <input asp-for="Phone" class="dark-input" placeholder="+252 63 1234567" />
                    </div>
                    <div>
                        <label asp-for="Address" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Address</label>
                        <input asp-for="Address" class="dark-input" placeholder="Street address, city..." />
                    </div>
                </div>
            </div>

            <!-- Employment Information -->
            <div class="rounded-xl p-5 space-y-4" style="background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.15);">
                <h3 class="text-sm font-bold text-emerald-300 uppercase tracking-widest flex items-center gap-2">
                    <i class="fas fa-briefcase text-emerald-400"></i>Employment Information
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Position" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Position</label>
                        <input asp-for="Position" class="dark-input" placeholder="e.g., Cashier, Manager" />
                    </div>
                    <div>
                        <label asp-for="DepartmentId" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Department</label>
                        <select asp-for="DepartmentId" class="dark-input">
                            <option value="">Select Department</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var dept in ViewBag.Departments)
                                {
                                    var selected = dept.Id == Model.DepartmentId ? "selected" : null;
                                    <option value="@dept.Id" selected="@selected">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label asp-for="ManagerId" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Reports To (Manager)</label>
                        <select asp-for="ManagerId" class="dark-input">
                            <option value="">None (Top Level / No Manager)</option>
                            @if (ViewBag.Managers != null)
                            {
                                foreach (var mgr in ViewBag.Managers)
                                {
                                    if (mgr.Id != Model.Id)
                                    {
                                        var selected = mgr.Id == Model.ManagerId ? "selected" : null;
                                        <option value="@mgr.Id" selected="@selected">@mgr.Name - @mgr.Position</option>
                                    }
                                }
                            }
                        </select>
                        <p class="text-xs text-indigo-400 mt-1"><i class="fas fa-info-circle mr-1"></i>Leave empty if this employee doesn't report to anyone</p>
                    </div>
                </div>
            </div>

            <!-- Branch Assignments -->
            <div class="rounded-xl p-5" style="background: rgba(124,58,237,0.06); border: 1px solid rgba(124,58,237,0.15);">
                <h3 class="text-sm font-bold text-violet-300 uppercase tracking-widest flex items-center gap-2 mb-3">
                    <i class="fas fa-store text-violet-400"></i>Branch Assignments
                </h3>
                <p class="text-xs text-slate-400 mb-4">Select all branches this employee is responsible for. Uncheck a branch to remove assignment.</p>

                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 max-h-52 overflow-y-auto p-2 rounded-xl" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06);">
                    @if (ViewBag.Branches != null && ((IEnumerable<dynamic>)ViewBag.Branches).Any())
                    {
                        foreach (var branch in ViewBag.Branches)
                        {
                            var isChecked = Model.BranchIds != null && Model.BranchIds.Contains(branch.Id);
                            <label class="flex items-center gap-2 p-2 rounded-lg cursor-pointer transition branch-item"
                                   style="border: 1px solid @(isChecked ? "rgba(124,58,237,0.4)" : "transparent"); background: @(isChecked ? "rgba(124,58,237,0.12)" : "");">
                                <input type="checkbox" name="BranchIds" value="@branch.Id"
                                       @(isChecked ? "checked" : "")
                                       class="w-4 h-4 accent-violet-500 branch-checkbox cursor-pointer" />
                                <span class="text-sm text-slate-300">@branch.Name</span>
                            </label>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-slate-500 italic col-span-full text-center py-6">No active branches available.</p>
                    }
                </div>

                <div class="mt-3 flex justify-between text-xs">
                    <span class="text-indigo-400"><i class="fas fa-info-circle mr-1"></i>Uncheck a branch to remove assignment</span>
                    <span class="text-slate-500"><i class="fas fa-check-circle mr-1 text-emerald-400"></i><span id="selectedCount">0</span> selected</span>
                </div>
            </div>

            <!-- Status -->
            <div class="rounded-xl p-4 flex items-center gap-4" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                <input asp-for="IsActive" type="checkbox" class="w-4 h-4 accent-indigo-500 cursor-pointer" />
                <div>
                    <span class="text-sm font-semibold text-slate-200">Active Employee</span>
                    <p class="text-xs text-slate-500 mt-0.5">Inactive employees won't appear in task assignments</p>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex justify-end gap-3 pt-4 border-t" style="border-color: rgba(255,255,255,0.06);">
                <a href="@Url.Action("Index")" class="px-5 py-2.5 rounded-xl border border-white/10 text-slate-300 hover:bg-white/5 transition text-sm font-medium flex items-center gap-2">
                    <i class="fas fa-times"></i>Cancel
                </a>
                <button type="submit" class="btn-primary">
                    <i class="fas fa-save"></i>Update Employee
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateSelectedCount() {
            var checked = $('input[name="BranchIds"]:checked').length;
            $('#selectedCount').text(checked);
            $('.branch-item').each(function() {
                const cb = $(this).find('input[type="checkbox"]');
                if (cb.is(':checked')) {
                    $(this).css({ 'border-color': 'rgba(124,58,237,0.4)', 'background': 'rgba(124,58,237,0.12)' });
                } else {
                    $(this).css({ 'border-color': 'transparent', 'background': '' });
                }
            });
        }

        $(document).ready(function() {
            updateSelectedCount();
            $('input[name="BranchIds"]').on('change', updateSelectedCount);
        });
    </script>
}