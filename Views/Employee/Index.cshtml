@model IEnumerable<TaskTracker.Models.ViewModels.EmployeeListViewModel>
@using TaskTracker.Models.ViewModels
@{
    ViewData["Title"] = "Employees";
    
    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }
    
    var totalEmployees = Model.Count();
    var activeEmployees = Model.Count(e => e.IsActive);
    var departments = Model.Select(e => e.Department).Where(d => d != "Unassigned").Distinct().Count();
    var avgPerformance = Model.Any() ? Math.Round(Model.Average(e => e.PerformanceScore), 0) : 0;
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Employee Management</h1>
            <p class="text-gray-500 mt-1">Manage your workforce and track performance</p>
        </div>
        <a href="@Url.Action("Create")" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium flex items-center transition">
            <i class="fas fa-plus-circle mr-2"></i>Add Employee
        </a>
    </div>

    <input type="hidden" id="requestVerificationToken" value="@token" />

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Total Employees</p>
                    <p class="text-2xl font-bold text-gray-800" id="totalEmployees">@totalEmployees</p>
                </div>
                <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-users text-blue-600"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Active Employees</p>
                    <p class="text-2xl font-bold text-green-600" id="activeEmployees">@activeEmployees</p>
                </div>
                <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-user-check text-green-600"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Departments</p>
                    <p class="text-2xl font-bold text-purple-600" id="departmentCount">@departments</p>
                </div>
                <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-building text-purple-600"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Avg Performance</p>
                    <p class="text-2xl font-bold text-yellow-600" id="avgPerformance">@avgPerformance%</p>
                </div>
                <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-chart-line text-yellow-600"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Bar -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
        <div class="flex flex-wrap gap-4">
            <div class="flex-1 min-w-[200px]">
                <div class="relative">
                    <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-sm"></i>
                    <input type="text" id="searchInput" placeholder="Search by name or position..." 
                           class="w-full pl-9 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
            </div>
            <div>
                <select id="departmentFilter" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">All Departments</option>
                    @{
                        var uniqueDepartments = Model.Select(e => e.Department).Where(d => d != "Unassigned").Distinct().OrderBy(d => d);
                    }
                    @foreach (var dept in uniqueDepartments)
                    {
                        <option value="@dept">@dept</option>
                    }
                </select>
            </div>
            <div>
                <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            <div>
                <button onclick="resetFilters()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition">
                    <i class="fas fa-undo-alt mr-2"></i>Reset
                </button>
            </div>
        </div>
    </div>

    <!-- Employees Table -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm" id="employeesTable">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-3 text-left font-semibold text-gray-600">Employee</th>
                        <th class="px-6 py-3 text-left font-semibold text-gray-600">Position</th>
                        <th class="px-6 py-3 text-left font-semibold text-gray-600">Department</th>
                        <th class="px-6 py-3 text-left font-semibold text-gray-600">Current Branch</th>
                        <th class="px-6 py-3 text-center font-semibold text-gray-600">Performance</th>
                        <th class="px-6 py-3 text-center font-semibold text-gray-600">Status</th>
                        <th class="px-6 py-3 text-center font-semibold text-gray-600">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200" id="employeeTableBody">
                    @foreach (var employee in Model.OrderBy(e => e.Name))
                    {
                        var scoreClass = TaskTracker.Models.ViewModels.ViewHelpers.GetScoreColorClass(employee.PerformanceScore);
                        var scoreIcon = TaskTracker.Models.ViewModels.ViewHelpers.GetScoreIcon(employee.PerformanceScore);
                        var bgColor = TaskTracker.Models.ViewModels.ViewHelpers.GetScoreBgColor(employee.PerformanceScore);
                        
                        <tr class="hover:bg-gray-50 transition employee-row" 
                            data-name="@employee.Name.ToLower()" 
                            data-position="@employee.Position.ToLower()"
                            data-department="@employee.Department"
                            data-status="@(employee.IsActive ? "active" : "inactive")"
                            data-employee-id="@employee.Id">
                            <td class="px-6 py-4">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 rounded-full bg-gradient-to-r from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold">
                                        @TaskTracker.Models.ViewModels.ViewHelpers.GetInitials(employee.Name)
                                    </div>
                                    <div>
                                        <p class="font-medium text-gray-900">@employee.Name</p>
                                        <p class="text-xs text-gray-500">@employee.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">@employee.Position</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded-full text-xs">@employee.Department</span>
                            </td>
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(employee.CurrentBranch))
                                {
                                    <div class="flex flex-wrap gap-1">
                                        @foreach (var branch in employee.Branches.Take(2))
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                                                <i class="fas fa-store mr-1 text-xs"></i>@branch
                                            </span>
                                        }
                                        @if (employee.Branches.Count > 2)
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">
                                                +@(employee.Branches.Count - 2) more
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-gray-400 text-sm">Not assigned</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex flex-col items-center group relative">
                                    <div class="flex items-center gap-1">
                                        <i class="fas @scoreIcon @scoreClass text-sm"></i>
                                        <span class="font-bold @scoreClass">@employee.PerformanceScore%</span>
                                    </div>
                                    <div class="w-16 mt-1 bg-gray-200 rounded-full h-1.5">
                                        <div class="bg-@bgColor-500 h-1.5 rounded-full" style="width: @employee.PerformanceScore%"></div>
                                    </div>
                                    <!-- Tooltip -->
                                    <div class="absolute bottom-full mb-2 left-1/2 transform -translate-x-1/2 hidden group-hover:block z-10">
                                        <div class="bg-gray-900 text-white text-xs rounded-lg py-2 px-3 whitespace-nowrap shadow-lg">
                                            <div class="font-semibold mb-1 text-center">@employee.Name</div>
                                            <div class="border-t border-gray-700 my-1"></div>
                                            <div class="flex justify-between gap-4">
                                                <span>📋 Total Tasks:</span>
                                                <span class="font-bold">@employee.TotalTasks</span>
                                            </div>
                                            <div class="flex justify-between gap-4">
                                                <span>✅ Completed:</span>
                                                <span class="font-bold text-green-400">@employee.CompletedTasks</span>
                                            </div>
                                            <div class="flex justify-between gap-4">
                                                <span>📊 Completion Rate:</span>
                                                <span class="font-bold">@employee.PerformanceScore%</span>
                                            </div>
                                            <div class="border-t border-gray-700 my-1"></div>
                                            <div class="text-gray-400 text-center">
                                                @(employee.TotalTasks - employee.CompletedTasks) tasks pending
                                            </div>
                                        </div>
                                        <div class="absolute left-1/2 transform -translate-x-1/2 top-full">
                                            <div class="w-0 h-0 border-l-8 border-r-8 border-t-8 border-t-gray-900 border-l-transparent border-r-transparent"></div>
                                        </div>
                                    </div>
                                </div>
                             </td>
                            <td class="px-6 py-4 text-center">
                                @if (employee.IsActive)
                                {
                                    <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">
                                        <i class="fas fa-circle text-green-500 mr-1 text-xs"></i>Active
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs font-medium">
                                        <i class="fas fa-circle text-red-500 mr-1 text-xs"></i>Inactive
                                    </span>
                                }
                             </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex items-center justify-center space-x-2">
                                    <button onclick="viewDetails(@employee.Id)" class="p-1.5 text-blue-600 hover:bg-blue-50 rounded-lg transition" title="View Details"><i class="fas fa-eye"></i></button>
                                    <button onclick="editEmployee(@employee.Id)" class="p-1.5 text-green-600 hover:bg-green-50 rounded-lg transition" title="Edit"><i class="fas fa-edit"></i></button>
                                    <button onclick="showBranchHistory(@employee.Id, '@employee.Name.Replace("'", "\\'")')" class="p-1.5 text-purple-600 hover:bg-purple-50 rounded-lg transition" title="Branch History"><i class="fas fa-history"></i></button>
                                    <button onclick="assignBranch(@employee.Id, '@employee.Name.Replace("'", "\\'")')" class="p-1.5 text-orange-600 hover:bg-orange-50 rounded-lg transition" title="Assign Branch"><i class="fas fa-store"></i></button>
                                    <button onclick="viewPerformanceReport(@employee.Id)" class="p-1.5 text-indigo-600 hover:bg-indigo-50 rounded-lg transition" title="Performance Report"><i class="fas fa-chart-bar"></i></button>
                                    <button onclick="deleteEmployee(@employee.Id, '@employee.Name.Replace("'", "\\'")')" class="p-1.5 text-red-600 hover:bg-red-50 rounded-lg transition" title="Delete"><i class="fas fa-trash"></i></button>
                                </div>
                             </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Any())
        {
            <div class="text-center py-12">
                <i class="fas fa-users text-6xl text-gray-300 mb-4"></i>
                <h3 class="text-lg font-medium text-gray-700 mb-2">No Employees Found</h3>
                <p class="text-gray-500 mb-4">Get started by adding your first employee.</p>
                <a href="@Url.Action("Create")" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
                    <i class="fas fa-plus-circle mr-2"></i>Add Employee
                </a>
            </div>
        }
    </div>
</div>

<!-- Branch Assignment Modal -->
<div id="branchModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md">
        <div class="p-4 border-b border-gray-200 bg-gradient-to-r from-blue-600 to-blue-800 rounded-t-lg">
            <h3 class="text-lg font-semibold text-white" id="branchModalTitle">Assign Branch</h3>
        </div>
        <div class="p-4">
            <input type="hidden" id="branchEmployeeId">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Select Branch</label>
                <select id="branchSelect" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">Select a branch...</option>
                    @if (ViewBag.Branches != null)
                    {
                        foreach (var branch in ViewBag.Branches)
                        {
                            <option value="@branch.Id">@branch.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Start Date</label>
                <input type="date" id="assignmentStartDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="@DateTime.Today.ToString("yyyy-MM-dd")">
            </div>
        </div>
        <div class="p-4 border-t border-gray-200 flex justify-end space-x-2">
            <button onclick="closeBranchModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</button>
            <button onclick="saveBranchAssignment()" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700">Save Assignment</button>
        </div>
    </div>
</div>

<!-- Branch History Modal -->
<div id="branchHistoryModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl">
        <div class="p-4 border-b border-gray-200 bg-gradient-to-r from-purple-600 to-purple-800 rounded-t-lg">
            <h3 class="text-lg font-semibold text-white" id="branchHistoryTitle">Branch History</h3>
        </div>
        <div class="p-4 max-h-96 overflow-y-auto">
            <div id="branchHistoryContent" class="text-center py-8">
                <i class="fas fa-spinner fa-spin text-purple-600 text-2xl"></i>
                <p class="mt-2 text-gray-500">Loading history...</p>
            </div>
        </div>
        <div class="p-4 border-t border-gray-200 flex justify-end">
            <button onclick="closeBranchHistoryModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Close</button>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Navigation Functions
    function viewDetails(id) { window.location.href = '@Url.Action("Details", "Employee")/' + id; }
    function editEmployee(id) { window.location.href = '@Url.Action("Edit", "Employee")/' + id; }
    function viewPerformanceReport(id) { window.location.href = '@Url.Action("EmployeePerformance", "Report")?employeeId=' + id; }

    // Branch Assignment Functions
    let currentEmployeeId = null;
    let currentEmployeeName = null;

    function assignBranch(employeeId, employeeName) {
        currentEmployeeId = employeeId;
        currentEmployeeName = employeeName;
        $('#branchModalTitle').text('Assign Branch to ' + employeeName);
        $('#branchModal').removeClass('hidden').addClass('flex');
    }

    function closeBranchModal() {
        $('#branchModal').removeClass('flex').addClass('hidden');
        $('#branchSelect').val('');
        $('#assignmentStartDate').val(new Date().toISOString().split('T')[0]);
        currentEmployeeId = null;
    }

    function saveBranchAssignment() {
        const branchId = $('#branchSelect').val();
        const startDate = $('#assignmentStartDate').val();
        const token = $('#requestVerificationToken').val();

        if (!branchId) { showNotification('Please select a branch', 'error'); return; }

        $.ajax({
            url: '@Url.Action("AssignBranch", "Employee")',
            type: 'POST',
            data: { employeeId: currentEmployeeId, branchId: branchId, startDate: startDate },
            headers: { 'RequestVerificationToken': token },
            success: function(response) {
                if (response.success) {
                    showNotification(response.message, 'success');
                    closeBranchModal();
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    showNotification(response.message, 'error');
                }
            },
            error: function() { showNotification('Error assigning branch', 'error'); }
        });
    }

    // Branch History Functions
    function showBranchHistory(employeeId, employeeName) {
        $('#branchHistoryTitle').text('Branch History - ' + employeeName);
        $('#branchHistoryModal').removeClass('hidden').addClass('flex');
        
        $.ajax({
            url: '@Url.Action("GetBranchHistory", "Employee")',
            type: 'GET',
            data: { id: employeeId },
            success: function(data) { displayBranchHistory(data); },
            error: function() { $('#branchHistoryContent').html('<div class="text-center py-8"><i class="fas fa-exclamation-circle text-red-500 text-3xl mb-3"></i><p class="text-gray-500">Error loading branch history</p></div>'); }
        });
    }

    function displayBranchHistory(history) {
        if (!history || history.length === 0) {
            $('#branchHistoryContent').html('<div class="text-center py-8"><i class="fas fa-store text-gray-300 text-3xl mb-3"></i><p class="text-gray-500">No branch assignments found</p></div>');
            return;
        }
        var html = '<div class="space-y-3"><div class="grid grid-cols-4 gap-4 mb-2 pb-2 border-b font-semibold text-gray-700"><div>Branch</div><div>Start Date</div><div>End Date</div><div>Duration</div></div>';
        for (var i = 0; i < history.length; i++) {
            var item = history[i];
            var startDate = new Date(item.startDate).toLocaleDateString();
            var endDate = item.endDate ? new Date(item.endDate).toLocaleDateString() : 'Present';
            html += `<div class="grid grid-cols-4 gap-4 py-2 hover:bg-gray-50 rounded"><div class="font-medium">${escapeHtml(item.branchName || 'Unknown')}</div><div>${startDate}</div><div>${endDate}</div><div>${item.duration} days</div></div>`;
        }
        html += '</div>';
        $('#branchHistoryContent').html(html);
    }

    function closeBranchHistoryModal() {
        $('#branchHistoryModal').removeClass('flex').addClass('hidden');
        $('#branchHistoryContent').html('<div class="text-center py-8"><i class="fas fa-spinner fa-spin text-purple-600 text-2xl"></i><p class="mt-2 text-gray-500">Loading history...</p></div>');
    }

    function escapeHtml(text) {
        if (!text) return text;
        return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    // Delete Employee
    function deleteEmployee(id, name) {
        if (confirm('Are you sure you want to delete ' + name + '?')) {
            $.ajax({
                url: '@Url.Action("Delete", "Employee")/' + id,
                type: 'POST',
                headers: { 'RequestVerificationToken': $('#requestVerificationToken').val() },
                success: function(response) {
                    if (response.success) { showNotification(response.message, 'success'); setTimeout(function() { location.reload(); }, 1500); }
                    else { showNotification(response.message, 'error'); }
                },
                error: function() { showNotification('Error deleting employee', 'error'); }
            });
        }
    }

    // Filter Functions
    function filterTable() {
        var searchTerm = $('#searchInput').val().toLowerCase();
        var department = $('#departmentFilter').val();
        var status = $('#statusFilter').val();

        $('#employeeTableBody tr').each(function() {
            var name = $(this).data('name') || '';
            var position = $(this).data('position') || '';
            var employeeDepartment = $(this).data('department') || '';
            var employeeStatus = $(this).data('status') || '';

            var matchesSearch = searchTerm === '' || name.indexOf(searchTerm) !== -1 || position.indexOf(searchTerm) !== -1;
            var matchesDepartment = department === '' || employeeDepartment === department;
            var matchesStatus = status === '' || employeeStatus === status;

            if (matchesSearch && matchesDepartment && matchesStatus) { $(this).show(); }
            else { $(this).hide(); }
        });
        updateStats();
        updateDepartmentFilter();
    }

    function updateStats() {
        var visibleRows = $('#employeeTableBody tr:visible');
        var total = visibleRows.length;
        var active = 0;
        var uniqueDepartments = new Set();
        var totalScore = 0;
        
        visibleRows.each(function() {
            var $row = $(this);
            if ($row.data('status') === 'active') active++;
            var department = $row.data('department');
            if (department && department !== 'Unassigned' && department !== '') uniqueDepartments.add(department);
            var scoreText = $row.find('td:eq(4) .font-bold').text();
            totalScore += parseInt(scoreText) || 0;
        });
        
        $('#totalEmployees').text(total);
        $('#activeEmployees').text(active);
        $('#departmentCount').text(uniqueDepartments.size);
        $('#avgPerformance').text(total > 0 ? Math.round(totalScore / total) + '%' : '0%');
    }

    function updateDepartmentFilter() {
        var visibleRows = $('#employeeTableBody tr:visible');
        var uniqueDepartments = new Set();
        visibleRows.each(function() {
            var department = $(this).data('department');
            if (department && department !== 'Unassigned' && department !== '') uniqueDepartments.add(department);
        });
        
        var currentValue = $('#departmentFilter').val();
        var $filter = $('#departmentFilter');
        $filter.empty();
        $filter.append('<option value="">All Departments</option>');
        Array.from(uniqueDepartments).sort().forEach(function(dept) { $filter.append('<option value="' + dept + '">' + dept + '</option>'); });
        if (currentValue && uniqueDepartments.has(currentValue)) $filter.val(currentValue);
    }

    function resetFilters() {
        $('#searchInput').val('');
        $('#departmentFilter').val('');
        $('#statusFilter').val('');
        filterTable();
        showNotification('Filters reset', 'info');
    }

    function showNotification(message, type) {
        var colors = { success: 'bg-green-500', error: 'bg-red-500', info: 'bg-blue-500', warning: 'bg-yellow-500' };
        $('.custom-notification').remove();
        var notification = $('<div class="custom-notification fixed top-4 right-4 z-50 px-4 py-2 rounded-lg shadow-lg text-sm font-medium text-white ' + colors[type] + ' animate-slide-in flex items-center">' +
            '<i class="fas ' + (type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle') + ' mr-2"></i><span>' + escapeHtml(message) + '</span></div>');
        $('body').append(notification);
        setTimeout(function() { notification.fadeOut(300, function() { $(this).remove(); }); }, 3000);
    }

    $(document).ready(function() {
        $('#searchInput').on('keyup', filterTable);
        $('#departmentFilter').on('change', filterTable);
        $('#statusFilter').on('change', filterTable);
        $(document).keydown(function(e) { if (e.key === 'Escape') { closeBranchModal(); closeBranchHistoryModal(); } });
        $(window).click(function(e) { if ($(e.target).hasClass('fixed')) { closeBranchModal(); closeBranchHistoryModal(); } });
        updateStats();
    });
</script>

<style>
    .animate-slide-in { animation: slideIn 0.3s ease-out; }
