@model IEnumerable<TaskTracker.Models.ViewModels.EmployeeListViewModel>
@using TaskTracker.Models.ViewModels
@{
    ViewData["Title"] = "Employees";

    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }

    var totalEmployees = Model.Count();
    var activeEmployees = Model.Count(e => e.IsActive);
    var departments = Model.Select(e => e.Department).Where(d => d != "Unassigned").Distinct().Count();
    var avgPerformance = Model.Any() ? Math.Round(Model.Average(e => e.PerformanceScore), 0) : 0;
}

<input type="hidden" id="requestVerificationToken" value="@token" />

<div class="space-y-6 animate-fade-up">

    <!-- Header -->
    <div class="flex flex-wrap justify-between items-start gap-4">
        <div>
            <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #6366f1, #7c3aed);">
                    <i class="fas fa-users text-white text-sm"></i>
                </div>
                Employee Management
            </h1>
            <p class="text-slate-400 mt-1">Manage your workforce and track performance</p>
        </div>
        <a href="@Url.Action("Create")" class="btn-primary">
            <i class="fas fa-user-plus"></i>Add Employee
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="glass-card p-5 flex items-center justify-between">
            <div>
                <p class="text-xs text-slate-400 uppercase tracking-wider">Total</p>
                <p class="text-3xl font-bold text-white mt-1" id="totalEmployees">@totalEmployees</p>
            </div>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(99,102,241,0.15);">
                <i class="fas fa-users text-indigo-400 text-xl"></i>
            </div>
        </div>
        <div class="glass-card p-5 flex items-center justify-between">
            <div>
                <p class="text-xs text-slate-400 uppercase tracking-wider">Active</p>
                <p class="text-3xl font-bold text-emerald-400 mt-1" id="activeEmployees">@activeEmployees</p>
            </div>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(16,185,129,0.15);">
                <i class="fas fa-user-check text-emerald-400 text-xl"></i>
            </div>
        </div>
        <div class="glass-card p-5 flex items-center justify-between">
            <div>
                <p class="text-xs text-slate-400 uppercase tracking-wider">Departments</p>
                <p class="text-3xl font-bold text-violet-400 mt-1" id="departmentCount">@departments</p>
            </div>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(124,58,237,0.15);">
                <i class="fas fa-building text-violet-400 text-xl"></i>
            </div>
        </div>
        <div class="glass-card p-5 flex items-center justify-between">
            <div>
                <p class="text-xs text-slate-400 uppercase tracking-wider">Avg Performance</p>
                <p class="text-3xl font-bold text-amber-400 mt-1" id="avgPerformance">@avgPerformance%</p>
            </div>
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: rgba(245,158,11,0.15);">
                <i class="fas fa-chart-line text-amber-400 text-xl"></i>
            </div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="glass-card p-4">
        <div class="flex flex-wrap gap-3">
            <div class="flex-1 min-w-[200px] relative">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-sm"></i>
                <input type="text" id="searchInput" placeholder="Search by name or position..."
                       class="dark-input pl-9" style="padding-top: 0.5rem; padding-bottom: 0.5rem;" />
            </div>
            <div>
                <select id="departmentFilter" class="dark-input" style="padding-top: 0.5rem; padding-bottom: 0.5rem;">
                    <option value="">All Departments</option>
                    @{
                        var uniqueDepartments = Model.Select(e => e.Department).Where(d => d != "Unassigned").Distinct().OrderBy(d => d);
                    }
                    @foreach (var dept in uniqueDepartments)
                    {
                        <option value="@dept">@dept</option>
                    }
                </select>
            </div>
            <div>
                <select id="statusFilter" class="dark-input" style="padding-top: 0.5rem; padding-bottom: 0.5rem;">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            <button onclick="resetFilters()" class="px-4 py-2 rounded-xl border border-white/10 text-slate-300 hover:bg-white/5 transition text-sm flex items-center gap-2">
                <i class="fas fa-undo-alt"></i>Reset
            </button>
        </div>
    </div>

    <!-- Employees Table -->
    <div class="glass-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full dark-table" id="employeesTable">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Position</th>
                        <th>Department</th>
                        <th>Current Branch</th>
                        <th class="text-center">Performance</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody id="employeeTableBody">
                    @foreach (var employee in Model.OrderBy(e => e.Name))
                    {
                        var scoreClass = TaskTracker.Models.ViewModels.ViewHelpers.GetScoreColorClass(employee.PerformanceScore);
                        var scoreIcon = TaskTracker.Models.ViewModels.ViewHelpers.GetScoreIcon(employee.PerformanceScore);
                        var bgColor = TaskTracker.Models.ViewModels.ViewHelpers.GetScoreBgColor(employee.PerformanceScore);

                        <tr class="employee-row"
                            data-name="@employee.Name.ToLower()"
                            data-position="@employee.Position.ToLower()"
                            data-department="@employee.Department"
                            data-status="@(employee.IsActive ? "active" : "inactive")"
                            data-employee-id="@employee.Id">
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0"
                                         style="background: linear-gradient(135deg, #6366f1, #7c3aed);">
                                        @TaskTracker.Models.ViewModels.ViewHelpers.GetInitials(employee.Name)
                                    </div>
                                    <div>
                                        <p class="font-semibold text-white">@employee.Name</p>
                                        <p class="text-xs text-slate-500">@employee.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="text-slate-300">@employee.Position</td>
                            <td>
                                <span class="stat-badge" style="background: rgba(255,255,255,0.06); color: #94a3b8;">@employee.Department</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(employee.CurrentBranch))
                                {
                                    <div class="flex flex-wrap gap-1">
                                        @foreach (var branch in employee.Branches.Take(2))
                                        {
                                            <span class="stat-badge" style="background: rgba(99,102,241,0.12); color: #a5b4fc;">
                                                <i class="fas fa-store text-[9px]"></i>@branch
                                            </span>
                                        }
                                        @if (employee.Branches.Count > 2)
                                        {
                                            <span class="stat-badge" style="background: rgba(255,255,255,0.06); color: #64748b;">
                                                +@(employee.Branches.Count - 2)
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-slate-600 text-sm">Not assigned</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="flex flex-col items-center group relative">
                                    <div class="flex items-center gap-1">
                                        <i class="fas @scoreIcon @scoreClass text-sm"></i>
                                        <span class="font-bold @scoreClass">@employee.PerformanceScore%</span>
                                    </div>
                                    <div class="w-16 mt-1 rounded-full h-1.5" style="background: rgba(255,255,255,0.08);">
                                        <div class="bg-@bgColor-500 h-1.5 rounded-full" style="width: @employee.PerformanceScore%"></div>
                                    </div>
                                    <!-- Tooltip -->
                                    <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 hidden group-hover:block z-10">
                                        <div class="rounded-xl py-2 px-3 whitespace-nowrap shadow-lg text-xs"
                                             style="background: #0b0b18; border: 1px solid rgba(255,255,255,0.1);">
                                            <div class="font-bold text-white text-center mb-1">@employee.Name</div>
                                            <div class="border-t mb-1" style="border-color: rgba(255,255,255,0.08);"></div>
                                            <div class="flex justify-between gap-4"><span class="text-slate-400">Total Tasks:</span><span class="font-bold text-white">@employee.TotalTasks</span></div>
                                            <div class="flex justify-between gap-4"><span class="text-slate-400">Completed:</span><span class="font-bold text-emerald-400">@employee.CompletedTasks</span></div>
                                            <div class="flex justify-between gap-4"><span class="text-slate-400">Rate:</span><span class="font-bold text-white">@employee.PerformanceScore%</span></div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                @if (employee.IsActive)
                                {
                                    <span class="stat-badge" style="background: rgba(16,185,129,0.15); color: #6ee7b7;">
                                        <i class="fas fa-circle text-[8px] text-emerald-400"></i>Active
                                    </span>
                                }
                                else
                                {
                                    <span class="stat-badge" style="background: rgba(239,68,68,0.15); color: #fca5a5;">
                                        <i class="fas fa-circle text-[8px] text-red-400"></i>Inactive
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="flex items-center justify-center gap-1">
                                    <button onclick="viewDetails(@employee.Id)" class="w-7 h-7 rounded-lg flex items-center justify-center text-indigo-400 hover:bg-indigo-400/10 transition" title="View Details">
                                        <i class="fas fa-eye text-xs"></i>
                                    </button>
                                    <button onclick="editEmployee(@employee.Id)" class="w-7 h-7 rounded-lg flex items-center justify-center text-emerald-400 hover:bg-emerald-400/10 transition" title="Edit">
                                        <i class="fas fa-edit text-xs"></i>
                                    </button>
                                    <button onclick="showBranchHistory(@employee.Id, '@employee.Name.Replace("'", "\\'")')" class="w-7 h-7 rounded-lg flex items-center justify-center text-violet-400 hover:bg-violet-400/10 transition" title="Branch History">
                                        <i class="fas fa-history text-xs"></i>
                                    </button>
                                    <button onclick="assignBranch(@employee.Id, '@employee.Name.Replace("'", "\\'")')" class="w-7 h-7 rounded-lg flex items-center justify-center text-amber-400 hover:bg-amber-400/10 transition" title="Assign Branch">
                                        <i class="fas fa-store text-xs"></i>
                                    </button>
                                    <button onclick="viewPerformanceReport(@employee.Id)" class="w-7 h-7 rounded-lg flex items-center justify-center text-cyan-400 hover:bg-cyan-400/10 transition" title="Performance Report">
                                        <i class="fas fa-chart-bar text-xs"></i>
                                    </button>
                                    <button onclick="deleteEmployee(@employee.Id, '@employee.Name.Replace("'", "\\'")')" class="w-7 h-7 rounded-lg flex items-center justify-center text-red-400 hover:bg-red-400/10 transition" title="Delete">
                                        <i class="fas fa-trash text-xs"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-16">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: rgba(99,102,241,0.1);">
                    <i class="fas fa-users text-indigo-400 text-2xl"></i>
                </div>
                <h3 class="font-semibold text-slate-300 mb-1">No Employees Found</h3>
                <p class="text-slate-500 text-sm mb-4">Get started by adding your first employee.</p>
                <a href="@Url.Action("Create")" class="btn-primary inline-flex">
                    <i class="fas fa-user-plus"></i>Add Employee
                </a>
            </div>
        }
    </div>
</div>

<!-- Branch Assignment Modal -->
<div id="branchModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="w-full max-w-md rounded-2xl overflow-hidden border border-white/10 shadow-2xl animate-fade-up" style="background: #1a1a2e;">
        <div class="px-6 py-4 flex items-center gap-3" style="background: linear-gradient(135deg, rgba(99,102,241,0.4), rgba(124,58,237,0.3));">
            <i class="fas fa-store text-indigo-400"></i>
            <h3 class="font-bold text-white" id="branchModalTitle">Assign Branch</h3>
        </div>
        <div class="p-6 space-y-4">
            <input type="hidden" id="branchEmployeeId">
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Select Branch</label>
                <select id="branchSelect" class="dark-input">
                    <option value="">Select a branch...</option>
                    @if (ViewBag.Branches != null)
                    {
                        foreach (var branch in ViewBag.Branches)
                        {
                            <option value="@branch.Id">@branch.Name</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Start Date</label>
                <input type="date" id="assignmentStartDate" class="dark-input" value="@DateTime.Today.ToString("yyyy-MM-dd")">
            </div>
        </div>
        <div class="px-6 py-4 border-t flex justify-end gap-3" style="border-color: rgba(255,255,255,0.06);">
            <button onclick="closeBranchModal()" class="px-4 py-2 rounded-lg text-sm text-slate-300 border border-white/10 hover:bg-white/5 transition">Cancel</button>
            <button onclick="saveBranchAssignment()" class="btn-primary">
                <i class="fas fa-save"></i>Save Assignment
            </button>
        </div>
    </div>
</div>

<!-- Branch History Modal -->
<div id="branchHistoryModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="w-full max-w-2xl rounded-2xl overflow-hidden border border-white/10 shadow-2xl animate-fade-up" style="background: #1a1a2e;">
        <div class="px-6 py-4 flex items-center justify-between" style="background: linear-gradient(135deg, rgba(124,58,237,0.4), rgba(99,102,241,0.3));">
            <div class="flex items-center gap-3">
                <i class="fas fa-history text-violet-400"></i>
                <h3 class="font-bold text-white" id="branchHistoryTitle">Branch History</h3>
            </div>
            <button onclick="closeBranchHistoryModal()" class="text-slate-400 hover:text-white transition">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="p-5 max-h-96 overflow-y-auto">
            <div id="branchHistoryContent" class="text-center py-8">
                <div class="flex justify-center items-center gap-2">
                    <div class="w-5 h-5 border-2 border-violet-500 border-t-transparent rounded-full animate-spin"></div>
                    <span class="text-slate-500 text-sm">Loading history...</span>
                </div>
            </div>
        </div>
        <div class="px-6 py-4 border-t flex justify-end" style="border-color: rgba(255,255,255,0.06);">
            <button onclick="closeBranchHistoryModal()" class="px-4 py-2 rounded-lg text-sm text-slate-300 border border-white/10 hover:bg-white/5 transition">Close</button>
        </div>
    </div>
</div>

<script>
    function viewDetails(id) { window.location.href = '@Url.Action("Details", "Employee")/' + id; }
    function editEmployee(id) { window.location.href = '@Url.Action("Edit", "Employee")/' + id; }
    function viewPerformanceReport(id) { window.location.href = '@Url.Action("EmployeePerformance", "Report")?employeeId=' + id; }

    let currentEmployeeId = null;

    function assignBranch(employeeId, employeeName) {
        currentEmployeeId = employeeId;
        $('#branchModalTitle').text('Assign Branch to ' + employeeName);
        $('#branchModal').removeClass('hidden').addClass('flex');
    }
    function closeBranchModal() {
        $('#branchModal').removeClass('flex').addClass('hidden');
        $('#branchSelect').val('');
        $('#assignmentStartDate').val(new Date().toISOString().split('T')[0]);
        currentEmployeeId = null;
    }
    function saveBranchAssignment() {
        const branchId = $('#branchSelect').val(), startDate = $('#assignmentStartDate').val();
        const token = $('#requestVerificationToken').val();
        if (!branchId) { if (window.TaskTracker) TaskTracker.showNotification('Please select a branch', 'error'); return; }
        $.ajax({
            url: '@Url.Action("AssignBranch", "Employee")', type: 'POST',
            data: { employeeId: currentEmployeeId, branchId, startDate },
            headers: { 'RequestVerificationToken': token },
            success: function(r) {
                if (r.success) { if (window.TaskTracker) TaskTracker.showNotification(r.message, 'success'); closeBranchModal(); setTimeout(() => location.reload(), 1500); }
                else { if (window.TaskTracker) TaskTracker.showNotification(r.message, 'error'); }
            },
            error: function() { if (window.TaskTracker) TaskTracker.showNotification('Error assigning branch', 'error'); }
        });
    }

    function showBranchHistory(employeeId, employeeName) {
        $('#branchHistoryTitle').text('Branch History — ' + employeeName);
        $('#branchHistoryModal').removeClass('hidden').addClass('flex');
        $.ajax({
            url: '@Url.Action("GetBranchHistory", "Employee")', type: 'GET', data: { id: employeeId },
            success: function(data) { displayBranchHistory(data); },
            error: function() { $('#branchHistoryContent').html('<div class="text-center py-8 text-red-400 text-sm">Error loading history</div>'); }
        });
    }
    function displayBranchHistory(history) {
        if (!history || !history.length) {
            $('#branchHistoryContent').html('<div class="text-center py-8 text-slate-500 text-sm"><i class="fas fa-store text-3xl block mb-2 text-slate-600"></i>No branch assignments found</div>');
            return;
        }
        let html = '<div class="space-y-2">';
        for (const item of history) {
            const startDate = new Date(item.startDate).toLocaleDateString();
            const endDate = item.endDate ? new Date(item.endDate).toLocaleDateString() : 'Present';
            html += `<div class="grid grid-cols-4 gap-3 p-3 rounded-xl text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                <div class="font-semibold text-white">${escapeHtml(item.branchName || 'Unknown')}</div>
                <div class="text-slate-400">${startDate}</div>
                <div class="text-slate-400">${endDate}</div>
                <div class="text-slate-500">${item.duration} days</div>
            </div>`;
        }
        html += '</div>';
        $('#branchHistoryContent').html(html);
    }
    function closeBranchHistoryModal() {
        $('#branchHistoryModal').removeClass('flex').addClass('hidden');
        $('#branchHistoryContent').html('<div class="text-center py-8"><div class="flex justify-center items-center gap-2"><div class="w-5 h-5 border-2 border-violet-500 border-t-transparent rounded-full animate-spin"></div><span class="text-slate-500 text-sm">Loading history...</span></div></div>');
    }

    function deleteEmployee(id, name) {
        if (confirm('Are you sure you want to delete ' + name + '?')) {
            $.ajax({
                url: '@Url.Action("Delete", "Employee")/' + id, type: 'POST',
                headers: { 'RequestVerificationToken': $('#requestVerificationToken').val() },
                success: function(r) {
                    if (r.success) { if (window.TaskTracker) TaskTracker.showNotification(r.message, 'success'); setTimeout(() => location.reload(), 1500); }
                    else { if (window.TaskTracker) TaskTracker.showNotification(r.message, 'error'); }
                },
                error: function() { if (window.TaskTracker) TaskTracker.showNotification('Error deleting employee', 'error'); }
            });
        }
    }

    function filterTable() {
        var search = $('#searchInput').val().toLowerCase();
        var dept = $('#departmentFilter').val();
        var status = $('#statusFilter').val();
        $('#employeeTableBody tr').each(function() {
            var name = $(this).data('name') || '', pos = $(this).data('position') || '';
            var d = $(this).data('department') || '', s = $(this).data('status') || '';
            var ok = (search === '' || name.includes(search) || pos.includes(search)) &&
                     (dept === '' || d === dept) && (status === '' || s === status);
            $(this).toggle(ok);
        });
        updateStats();
    }

    function updateStats() {
        var rows = $('#employeeTableBody tr:visible');
        var total = rows.length, active = 0, depts = new Set(), score = 0;
        rows.each(function() {
            if ($(this).data('status') === 'active') active++;
            var d = $(this).data('department');
            if (d && d !== 'Unassigned') depts.add(d);
            var s = parseInt($(this).find('td:eq(4) .font-bold').text()) || 0;
            score += s;
        });
        $('#totalEmployees').text(total);
        $('#activeEmployees').text(active);
        $('#departmentCount').text(depts.size);
        $('#avgPerformance').text(total > 0 ? Math.round(score / total) + '%' : '0%');
    }

    function resetFilters() {
        $('#searchInput').val('');
        $('#departmentFilter').val('');
        $('#statusFilter').val('');
        filterTable();
        if (window.TaskTracker) TaskTracker.showNotification('Filters reset', 'info');
    }

    function escapeHtml(text) {
        if (!text) return text;
        return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

    $(document).ready(function() {
        $('#searchInput').on('keyup', filterTable);
        $('#departmentFilter, #statusFilter').on('change', filterTable);
        $(document).keydown(function(e) { if (e.key === 'Escape') { closeBranchModal(); closeBranchHistoryModal(); } });
        updateStats();
    });
</script>