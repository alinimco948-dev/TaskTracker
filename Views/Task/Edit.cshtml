@model TaskTracker.Models.ViewModels.TaskItemViewModel
@using TaskTracker.Models.Entities
@{
    ViewData["Title"] = "Edit Task";
    
    // Get existing tasks for dependencies dropdown
    var existingTasks = ViewBag.ExistingTasks as IEnumerable<TaskTracker.Models.ViewModels.TaskListViewModel> ?? new List<TaskTracker.Models.ViewModels.TaskListViewModel>();
    
    // FIX: WeeklyDays is already a List<int>, no need to parse
    var weeklyDaysList = Model.WeeklyDays ?? new List<int>();
    
    // Get execution type flags
    var isRecurringWeekly = Model.ExecutionType == TaskExecutionType.RecurringWeekly;
    var isRecurringMonthly = Model.ExecutionType == TaskExecutionType.RecurringMonthly;
    var isMultiDay = Model.ExecutionType == TaskExecutionType.MultiDay;
    var isOneTime = Model.ExecutionType == TaskExecutionType.OneTime;
    var isRecurringDaily = Model.ExecutionType == TaskExecutionType.RecurringDaily;
    
    // Parse monthly pattern
    var monthlyPattern = Model.MonthlyPattern ?? "";
    var isDayPattern = !monthlyPattern.Contains("-");
    var monthlyDayNumber = 15;
    if (isDayPattern && int.TryParse(monthlyPattern, out var dayNum))
    {
        monthlyDayNumber = dayNum;
    }
    
    var monthlyOrdinalValue = "first";
    var monthlyWeekdayValue = "monday";
    
    if (!isDayPattern && monthlyPattern.Contains("-"))
    {
        var patternParts = monthlyPattern.Split('-');
        monthlyOrdinalValue = patternParts.Length > 0 ? patternParts[0] : "first";
        monthlyWeekdayValue = patternParts.Length > 1 ? patternParts[1] : "monday";
    }
    
    // Parse deadline type
    var isSameDayChecked = Model.IsSameDay;
    
    // Day names for display
    var dayNamesArray = new[] { "Su", "Mo", "Tu", "We", "Th", "Fr", "Sa" };
    var fullDayNamesArray = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
    
    // Format dates for display
    var startDateValue = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var endDateValue = Model.EndDate?.ToString("yyyy-MM-dd") ?? "";
    var availableFromValue = Model.AvailableFrom?.ToString("yyyy-MM-dd") ?? "";
    var availableToValue = Model.AvailableTo?.ToString("yyyy-MM-dd") ?? "";
    var oneTimeDateValue = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var multiDayStartDateValue = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var deadlineTimeValue = Model.Deadline.ToString(@"hh\:mm");
}

<!-- Page Header -->
<div class="mb-8">
    <div class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-600 rounded-2xl shadow-xl p-6 text-white">
        <div class="flex items-center space-x-4">
            <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur-md flex items-center justify-center">
                <i class="fas fa-edit text-3xl"></i>
            </div>
            <div>
                <h1 class="text-3xl font-bold">Edit Task</h1>
                <p class="text-indigo-100 mt-1">Modify task configuration and scheduling</p>
            </div>
        </div>
    </div>
</div>

<!-- Main Form Card -->
<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-white">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                <i class="fas fa-calendar-alt text-indigo-600 mr-2"></i>
                Task Configuration
            </h3>
        </div>

        <form asp-action="Edit" method="post" class="p-6" id="taskForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 text-red-700 rounded-xl text-sm border border-red-200"></div>

            <!-- Task Basic Information -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-info-circle text-indigo-500 mr-2"></i>
                    Basic Information
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                            Task Name <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                               placeholder="e.g., Daily Report, Monthly Project" />
                        <span asp-validation-for="Name" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    
                    <div>
                        <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Description (Optional)</label>
                        <textarea asp-for="Description" rows="1" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                                  placeholder="Brief description of the task...">@Model.Description</textarea>
                    </div>
                </div>
            </div>

            <!-- Task Type Selection -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-tasks text-indigo-500 mr-2"></i>
                    Task Type
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                    <!-- Recurring Daily Task -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringDaily" class="sr-only peer" 
                               @(isRecurringDaily ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-calendar-day text-2xl text-blue-500"></i>
                                <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full">Daily</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">Recurring Daily</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each day</p>
                            <p class="text-[10px] text-gray-400 mt-2">Appears every day. Must be completed each occurrence.</p>
                        </div>
                    </label>
                    
                    <!-- Multi-Day Task -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="MultiDay" class="sr-only peer" 
                               @(isMultiDay ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-calendar-range text-2xl text-green-500"></i>
                                <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Multi-Day</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">Multi-Day Task</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete once</p>
                            <p class="text-[10px] text-gray-400 mt-2">Spans multiple days. Complete once at the end.</p>
                        </div>
                    </label>
                    
                    <!-- Recurring Weekly -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringWeekly" class="sr-only peer" 
                               @(isRecurringWeekly ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-calendar-week text-2xl text-purple-500"></i>
                                <span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full">Weekly</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">Recurring Weekly</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each week</p>
                            <p class="text-[10px] text-gray-400 mt-2">Appears on selected days. Complete each occurrence.</p>
                        </div>
                    </label>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Recurring Monthly -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringMonthly" class="sr-only peer" 
                               @(isRecurringMonthly ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-calendar-alt text-2xl text-yellow-500"></i>
                                <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-1 rounded-full">Monthly</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">Recurring Monthly</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each month</p>
                            <p class="text-[10px] text-gray-400 mt-2">Appears monthly. Complete each occurrence.</p>
                        </div>
                    </label>
                    
                    <!-- One-Time Task -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="OneTime" class="sr-only peer" 
                               @(isOneTime ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-hourglass-start text-2xl text-red-500"></i>
                                <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">One-Time</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">One-Time Task</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete once</p>
                            <p class="text-[10px] text-gray-400 mt-2">Appears once. Complete on the scheduled date.</p>
                        </div>
                    </label>
                </div>
            </div>

            <!-- ========== COMMON SCHEDULING SECTION ========== -->
            <div id="commonScheduleSection" class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-calendar-alt text-blue-500 mr-2"></i>
                    Schedule Settings
                </h4>
                
                <!-- Task Schedule Date Range (with No End Date) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Task Start Date</label>
                        <input type="date" name="StartDate" id="startDate" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" 
                               value="@startDateValue" />
                        <p class="text-xs text-gray-500 mt-1">When does this task become active?</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Task End Date</label>
                        <div class="flex items-center gap-2">
                            <input type="date" name="EndDate" id="endDate" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" 
                                   value="@endDateValue" />
                            <label class="flex items-center cursor-pointer whitespace-nowrap">
                                <input type="checkbox" id="noTaskEndDate" class="mr-2 w-4 h-4 text-indigo-600" 
                                       @(Model.EndDate == null ? "checked" : "") onchange="toggleTaskEndDate(); updateCombinedPreview();" />
                                <span class="text-sm text-gray-600">No End Date</span>
                            </label>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Check for tasks that repeat forever</p>
                    </div>
                </div>
                
                <!-- Forever Task Indicator -->
                <div id="foreverTaskIndicator" class="hidden mb-4 p-3 bg-green-50 border border-green-200 rounded-lg">
                    <div class="flex items-center">
                        <i class="fas fa-infinity text-green-600 mr-2"></i>
                        <span class="text-sm text-green-700">This task will repeat forever with no end date.</span>
                    </div>
                </div>
                
                <!-- Availability Date Range (with No End Date option) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Available From</label>
                        <input type="date" name="AvailableFrom" id="availableFrom" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" 
                               value="@availableFromValue" />
                        <p class="text-xs text-gray-500 mt-1">Earliest date this task can be assigned</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Available To</label>
                        <div class="flex items-center gap-2">
                            <input type="date" name="AvailableTo" id="availableTo" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" 
                                   value="@availableToValue" />
                            <label class="flex items-center cursor-pointer whitespace-nowrap">
                                <input type="checkbox" id="noAvailableEndDate" class="mr-2 w-4 h-4 text-indigo-600" 
                                       @(Model.AvailableTo == null ? "checked" : "") onchange="toggleAvailableEndDate(); updateCombinedPreview();" />
                                <span class="text-sm text-gray-600">No End Date</span>
                            </label>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Check for tasks that are available forever</p>
                    </div>
                </div>
                
                <!-- Forever Available Indicator -->
                <div id="foreverAvailableIndicator" class="hidden mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg">
                    <div class="flex items-center">
                        <i class="fas fa-infinity text-blue-600 mr-2"></i>
                        <span class="text-sm text-blue-700">This task is available forever with no end date.</span>
                    </div>
                </div>
                
                <!-- Max Occurrences -->
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Max Occurrences</label>
                    <div class="flex items-center gap-2">
                        <input type="number" name="MaxOccurrences" id="maxOccurrences" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" 
                               value="@Model.MaxOccurrences" placeholder="Leave empty for unlimited" min="1" />
                        <label class="flex items-center cursor-pointer whitespace-nowrap">
                            <input type="checkbox" id="unlimitedOccurrences" class="mr-2 w-4 h-4 text-indigo-600" 
                                   @(Model.MaxOccurrences == null ? "checked" : "") onchange="toggleMaxOccurrences(); updateCombinedPreview();" />
                            <span class="text-sm text-gray-600">Unlimited</span>
                        </label>
                    </div>
                    <p class="text-xs text-gray-500 mt-1">Maximum number of times this task should appear</p>
                </div>
            </div>

            <!-- ========== WEEKLY TASK SECTION ========== -->
            <div id="weeklyTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 @(!isRecurringWeekly ? "hidden" : "")">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-calendar-week text-purple-500 mr-2"></i>
                    Weekly Schedule
                </h4>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Repeat On</label>
                    <div class="grid grid-cols-7 gap-2">
                        @for (int idx = 0; idx < 7; idx++)
                        {
                            var isDaySelected = weeklyDaysList.Contains(idx);
                            <label class="flex flex-col items-center cursor-pointer">
                                <input type="checkbox" name="WeeklyDays" value="@idx" class="weekly-day-checkbox w-6 h-6" 
                                       @(isDaySelected ? "checked" : "") onchange="updateCombinedPreview();" />
                                <span class="text-xs mt-1">@dayNamesArray[idx]</span>
                            </label>
                        }
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Select the days when this task should appear</p>
                </div>
            </div>

            <!-- ========== MONTHLY TASK SECTION ========== -->
            <div id="monthlyTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 @(!isRecurringMonthly ? "hidden" : "")">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-calendar-alt text-yellow-500 mr-2"></i>
                    Monthly Schedule
                </h4>
                
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Monthly Pattern</label>
                    <div class="grid grid-cols-2 gap-2 mb-3">
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="day" class="mr-2" 
                                   @(isDayPattern ? "checked" : "") onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span>Specific Day of Month</span>
                        </label>
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="weekday" class="mr-2" 
                                   @(!isDayPattern ? "checked" : "") onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span>Nth Weekday of Month</span>
                        </label>
                    </div>
                    
                    <div id="monthlyDayPattern" class="@(!isDayPattern ? "hidden" : "")">
                        <select name="MonthlyDay" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" onchange="updateCombinedPreview();">
                            @for (int d = 1; d <= 31; d++)
                            {
                                if (monthlyDayNumber == d)
                                {
                                    <option value="@d" selected="selected">Day @d</option>
                                }
                                else
                                {
                                    <option value="@d">Day @d</option>
                                }
                            }
                        </select>
                        <p class="text-xs text-gray-500 mt-1">Task appears on this day of the month</p>
                    </div>
                    
                    <div id="monthlyWeekdayPattern" class="@(isDayPattern ? "hidden" : "")">
                        <div class="flex gap-2">
                            <select name="MonthlyOrdinal" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" onchange="updateMonthlyPattern(); updateCombinedPreview();">
                                @if (monthlyOrdinalValue == "first")
                                {
                                    <option value="first" selected="selected">First</option>
                                    <option value="second">Second</option>
                                    <option value="third">Third</option>
                                    <option value="fourth">Fourth</option>
                                    <option value="last">Last</option>
                                }
                                else if (monthlyOrdinalValue == "second")
                                {
                                    <option value="first">First</option>
                                    <option value="second" selected="selected">Second</option>
                                    <option value="third">Third</option>
                                    <option value="fourth">Fourth</option>
                                    <option value="last">Last</option>
                                }
                                else if (monthlyOrdinalValue == "third")
                                {
                                    <option value="first">First</option>
                                    <option value="second">Second</option>
                                    <option value="third" selected="selected">Third</option>
                                    <option value="fourth">Fourth</option>
                                    <option value="last">Last</option>
                                }
                                else if (monthlyOrdinalValue == "fourth")
                                {
                                    <option value="first">First</option>
                                    <option value="second">Second</option>
                                    <option value="third">Third</option>
                                    <option value="fourth" selected="selected">Fourth</option>
                                    <option value="last">Last</option>
                                }
                                else
                                {
                                    <option value="first">First</option>
                                    <option value="second">Second</option>
                                    <option value="third">Third</option>
                                    <option value="fourth">Fourth</option>
                                    <option value="last" selected="selected">Last</option>
                                }
                            </select>
                            <select name="MonthlyWeekday" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" onchange="updateMonthlyPattern(); updateCombinedPreview();">
                                @for (int w = 0; w < fullDayNamesArray.Length; w++)
                                {
                                    var weekdayVal = fullDayNamesArray[w].ToLower();
                                    var weekdayNameDisplay = fullDayNamesArray[w];
                                    if (monthlyWeekdayValue == weekdayVal)
                                    {
                                        <option value="@weekdayVal" selected="selected">@weekdayNameDisplay</option>
                                    }
                                    else
                                    {
                                        <option value="@weekdayVal">@weekdayNameDisplay</option>
                                    }
                                }
                            </select>
                        </div>
                        <input type="hidden" id="MonthlyPattern" name="MonthlyPattern" value="@Model.MonthlyPattern" />
                        <p class="text-xs text-gray-500 mt-1">Example: "First Monday" or "Last Friday"</p>
                    </div>
                </div>
            </div>

            <!-- ========== MULTI-DAY TASK SECTION ========== -->
            <div id="multiDayTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 @(!isMultiDay ? "hidden" : "")">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-calendar-range text-green-500 mr-2"></i>
                    Multi-Day Settings
                </h4>
                
                <div class="bg-blue-50 p-4 rounded-lg border border-blue-200 mb-4">
                    <div class="flex items-center mb-2">
                        <i class="fas fa-info-circle text-blue-600 mr-2"></i>
                        <span class="text-sm font-medium text-blue-800">Multi-Day Task Information</span>
                    </div>
                    <p class="text-xs text-blue-700">
                        This task will appear on the dashboard from the start date until the end date.
                        You only need to complete it ONCE by the deadline (end date + deadline time).
                    </p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Start Date</label>
                        <input type="date" id="multiDayStartDate" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" 
                               value="@multiDayStartDateValue" onchange="updateCombinedPreview();" />
                        <p class="text-xs text-gray-500 mt-1">When does this task begin?</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Duration (Days)</label>
                        <input type="number" id="multiDayDuration" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500"
                               placeholder="e.g., 3" min="1" value="@Model.DurationDays" oninput="updateCombinedPreview();" />
                        <p class="text-xs text-gray-500 mt-1">Number of days this task spans</p>
                    </div>
                </div>
                
                <div class="mt-3 p-3 bg-gray-100 rounded-lg">
                    <div class="text-sm text-gray-700">
                        <span class="font-medium">Task Period:</span>
                        <span id="taskPeriodPreview" class="ml-2 text-indigo-600">Select dates to see preview</span>
                    </div>
                    <div class="text-sm text-gray-700 mt-1">
                        <span class="font-medium">Final Deadline:</span>
                        <span id="finalDeadlinePreview" class="ml-2 text-amber-600">Will be calculated</span>
                    </div>
                </div>
            </div>

            <!-- ========== ONE-TIME TASK SECTION ========== -->
            <div id="oneTimeTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 @(!isOneTime ? "hidden" : "")">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-hourglass-start text-red-500 mr-2"></i>
                    One-Time Schedule
                </h4>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Task Date</label>
                    <input type="date" id="oneTimeDate" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" 
                           value="@oneTimeDateValue" onchange="updateCombinedPreview();" />
                    <p class="text-xs text-gray-500 mt-1">The date when this task should appear</p>
                </div>
            </div>

            <!-- ========== COMBINED PREVIEW ========== -->
            <div id="combinedPreview" class="mt-4 p-4 bg-indigo-50 border border-indigo-200 rounded-lg hidden mb-6">
                <div class="flex items-start">
                    <i class="fas fa-chart-line text-indigo-500 mt-0.5 mr-3 text-lg"></i>
                    <div class="flex-1">
                        <span class="text-sm font-semibold text-indigo-800">📋 Task Schedule Preview</span>
                        <div id="combinedPreviewContent" class="text-sm text-indigo-700 mt-1 font-medium">
                            Select options to see preview
                        </div>
                    </div>
                </div>
            </div>

            <!-- ========== DEADLINE CONFIGURATION ========== -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-hourglass-half text-blue-500 mr-2"></i>
                    Deadline Configuration
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Deadline" class="block text-sm font-medium text-gray-700 mb-1">
                            Deadline Time <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Deadline" type="time" id="deadlineTime" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                               value="@deadlineTimeValue" onchange="updateCombinedPreview();" />
                        <p class="text-xs text-gray-500 mt-2">When should this task be completed?</p>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Deadline Type</label>
                        <div class="flex space-x-4 mt-2">
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="deadlineType" value="same-day" class="mr-2" 
                                       @(isSameDayChecked ? "checked" : "") onchange="updateCombinedPreview(); syncIsSameDay();" />
                                <span class="text-sm">Same Day</span>
                            </label>
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="deadlineType" value="next-day" class="mr-2" 
                                       @(!isSameDayChecked ? "checked" : "") onchange="updateCombinedPreview(); syncIsSameDay();" />
                                <span class="text-sm">Next Day</span>
                            </label>
                        </div>
                        <input type="hidden" asp-for="IsSameDay" id="IsSameDayHidden" />
                    </div>
                </div>
            </div>

            <!-- ========== ORGANIZATION & PRIORITY ========== -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-chart-line text-purple-500 mr-2"></i>
                    Organization & Priority
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="DisplayOrder" class="block text-sm font-medium text-gray-700 mb-1">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" min="0" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                        <p class="text-xs text-gray-500 mt-2">Order in which tasks appear on the dashboard</p>
                    </div>
                </div>
            </div>

            <!-- ========== ACTIVE STATUS TOGGLE ========== -->
            <div class="bg-gradient-to-r from-gray-50 to-white p-5 rounded-xl border border-gray-200 mb-6">
                <label class="flex items-center justify-between cursor-pointer">
                    <div>
                        <span class="text-sm font-medium text-gray-700">Active Task</span>
                        <p class="text-xs text-gray-500 mt-1">Inactive tasks won't appear in daily task boards</p>
                    </div>
                    <div class="relative">
                        <input asp-for="IsActive" type="checkbox" class="sr-only" id="IsActive" 
                               @@(Model.IsActive ? "checked" : "") onchange="updateToggleDisplay('IsActive')" />
                        <div class="w-14 h-8 bg-gray-300 rounded-full transition cursor-pointer toggle-indicator" onclick="toggleCheckbox('IsActive')">
                            <div class="absolute w-6 h-6 bg-white rounded-full shadow-md transform transition translate-x-1"></div>
                        </div>
                    </div>
                </label>
            </div>

            <!-- ========== FORM ACTIONS ========== -->
            <div class="flex justify-end space-x-3 pt-4 border-t">
                <a href="@Url.Action("Index")" class="px-6 py-3 border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                    <i class="fas fa-times mr-2"></i>Cancel
                </a>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl text-sm font-medium hover:from-indigo-700 hover:to-purple-700 transition shadow-md flex items-center">
                    <i class="fas fa-save mr-2"></i>Update Task
                </button>
            </div>
        </form>
    </div>

    <!-- Help Card -->
    <div class="mt-6 bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl border border-indigo-200 p-6">
        <div class="flex items-start space-x-4">
            <div class="w-10 h-10 rounded-xl bg-indigo-100 flex items-center justify-center text-indigo-600">
                <i class="fas fa-lightbulb"></i>
            </div>
            <div>
                <h4 class="font-semibold text-gray-900 mb-2">Task Type & Forever Options Guide</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-gray-600">
                    <ul class="space-y-2">
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Recurring Daily:</span> Appears every day. Must be completed each day.</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Multi-Day:</span> Spans multiple days. Complete once at the end.</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Recurring Weekly:</span> Appears on selected days. Complete each occurrence.</span>
                        </li>
                    </ul>
                    <ul class="space-y-2">
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Recurring Monthly:</span> Appears monthly. Complete each occurrence.</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">One-Time:</span> Appears once. Complete on the scheduled date.</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-infinity text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Forever Options:</span> Check "No End Date" for tasks or availability that run forever.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Initialize toggles
            updateToggleDisplay('IsActive');
            
            // Sync IsSameDay with hidden field
            syncIsSameDay();
            
            // Initialize task type
            toggleTaskType();
            toggleMonthlyPattern();
            
            // Initialize forever options
            toggleTaskEndDate();
            toggleAvailableEndDate();
            toggleMaxOccurrences();
            
            // Setup combined preview listeners
            setupCombinedPreviewListeners();
            
            // Trigger initial preview
            setTimeout(updateCombinedPreview, 100);
        });

        // ========== Toggle Functions ==========
        function toggleCheckbox(id) {
            var checkbox = document.getElementById(id);
            checkbox.checked = !checkbox.checked;
            updateToggleDisplay(id);
        }
        
        function updateToggleDisplay(id) {
            var checkbox = document.getElementById(id);
            var toggleDiv = checkbox.nextElementSibling;
            var circle = toggleDiv.querySelector('.absolute');
            
            if (checkbox.checked) {
                toggleDiv.classList.remove('bg-gray-300');
                toggleDiv.classList.add('bg-green-600');
                circle.style.transform = 'translateX(28px)';
            } else {
                toggleDiv.classList.remove('bg-green-600');
                toggleDiv.classList.add('bg-gray-300');
                circle.style.transform = 'translateX(4px)';
            }
        }
        
        function syncIsSameDay() {
            var deadlineType = document.querySelector('input[name="deadlineType"]:checked');
            if (deadlineType) {
                var isSameDayHidden = document.getElementById('IsSameDayHidden');
                if (isSameDayHidden) {
                    isSameDayHidden.value = (deadlineType.value === 'same-day');
                }
            }
        }

        // ========== Forever Task Functions ==========
        function toggleTaskEndDate() {
            var noEndDateCheckbox = document.getElementById('noTaskEndDate');
            var endDateInput = document.getElementById('endDate');
            var foreverTaskIndicator = document.getElementById('foreverTaskIndicator');
            
            if (noEndDateCheckbox && noEndDateCheckbox.checked) {
                if (endDateInput) {
                    endDateInput.disabled = true;
                    endDateInput.value = '';
                }
                if (foreverTaskIndicator) foreverTaskIndicator.classList.remove('hidden');
            } else {
                if (endDateInput) endDateInput.disabled = false;
                if (foreverTaskIndicator) foreverTaskIndicator.classList.add('hidden');
            }
            
            updateCombinedPreview();
        }
        
        function toggleAvailableEndDate() {
            var noAvailableEndDate = document.getElementById('noAvailableEndDate');
            var availableToInput = document.getElementById('availableTo');
            var foreverAvailableIndicator = document.getElementById('foreverAvailableIndicator');
            
            if (noAvailableEndDate && noAvailableEndDate.checked) {
                if (availableToInput) {
                    availableToInput.disabled = true;
                    availableToInput.value = '';
                }
                if (foreverAvailableIndicator) foreverAvailableIndicator.classList.remove('hidden');
            } else {
                if (availableToInput) availableToInput.disabled = false;
                if (foreverAvailableIndicator) foreverAvailableIndicator.classList.add('hidden');
            }
            
            updateCombinedPreview();
        }
        
        function toggleMaxOccurrences() {
            var unlimitedCheckbox = document.getElementById('unlimitedOccurrences');
            var maxOccurrencesInput = document.getElementById('maxOccurrences');
            
            if (unlimitedCheckbox && unlimitedCheckbox.checked) {
                if (maxOccurrencesInput) {
                    maxOccurrencesInput.disabled = true;
                    maxOccurrencesInput.value = '';
                }
            } else {
                if (maxOccurrencesInput) maxOccurrencesInput.disabled = false;
            }
            
            updateCombinedPreview();
        }

        // ========== Task Type Functions ==========
        function toggleTaskType() {
            var selectedType = document.querySelector('input[name="ExecutionType"]:checked');
            if (!selectedType) return;
            
            var type = selectedType.value;
            
            // Hide all task-type-specific sections
            var weeklySection = document.getElementById('weeklyTaskSection');
            var monthlySection = document.getElementById('monthlyTaskSection');
            var multiDaySection = document.getElementById('multiDayTaskSection');
            var oneTimeSection = document.getElementById('oneTimeTaskSection');
            
            if (weeklySection) weeklySection.classList.add('hidden');
            if (monthlySection) monthlySection.classList.add('hidden');
            if (multiDaySection) multiDaySection.classList.add('hidden');
            if (oneTimeSection) oneTimeSection.classList.add('hidden');
            
            // Show appropriate section
            switch(type) {
                case 'RecurringWeekly':
                    if (weeklySection) weeklySection.classList.remove('hidden');
                    break;
                case 'RecurringMonthly':
                    if (monthlySection) monthlySection.classList.remove('hidden');
                    break;
                case 'MultiDay':
                    if (multiDaySection) multiDaySection.classList.remove('hidden');
                    setupMultiDayPreview();
                    break;
                case 'OneTime':
                    if (oneTimeSection) oneTimeSection.classList.remove('hidden');
                    break;
                case 'RecurringDaily':
                    // No additional config needed
                    break;
            }
            
            updateCombinedPreview();
        }
        
        // ========== Monthly Pattern Functions ==========
        function toggleMonthlyPattern() {
            var patternType = document.querySelector('input[name="MonthlyPatternType"]:checked');
            if (!patternType) return;
            
            var type = patternType.value;
            var dayPattern = document.getElementById('monthlyDayPattern');
            var weekdayPattern = document.getElementById('monthlyWeekdayPattern');
            var monthlyPatternHidden = document.getElementById('MonthlyPattern');
            
            if (type === 'day') {
                if (dayPattern) dayPattern.classList.remove('hidden');
                if (weekdayPattern) weekdayPattern.classList.add('hidden');
                if (monthlyPatternHidden) {
                    var monthlyDay = document.querySelector('select[name="MonthlyDay"]');
                    monthlyPatternHidden.value = monthlyDay ? monthlyDay.value : '15';
                }
            } else {
                if (dayPattern) dayPattern.classList.add('hidden');
                if (weekdayPattern) weekdayPattern.classList.remove('hidden');
                updateMonthlyPattern();
            }
            
            updateCombinedPreview();
        }
        
        function updateMonthlyPattern() {
            var ordinal = document.querySelector('select[name="MonthlyOrdinal"]');
            var weekday = document.querySelector('select[name="MonthlyWeekday"]');
            var monthlyPatternHidden = document.getElementById('MonthlyPattern');
            
            if (ordinal && weekday && monthlyPatternHidden) {
                monthlyPatternHidden.value = ordinal.value + '-' + weekday.value;
            }
        }
        
        // ========== Multi-Day Preview ==========
        function setupMultiDayPreview() {
            var startDateInput = document.getElementById('multiDayStartDate');
            var durationInput = document.getElementById('multiDayDuration');
            var deadlineTime = document.getElementById('deadlineTime');
            
            function updatePreview() {
                var startDate = startDateInput ? startDateInput.value : '';
                var duration = durationInput ? parseInt(durationInput.value) : 0;
                var deadlineTimeValue = deadlineTime ? deadlineTime.value : '21:00';
                
                if (startDate && duration > 0) {
                    var start = new Date(startDate);
                    var end = new Date(start);
                    end.setDate(end.getDate() + duration - 1);
                    
                    var startFormatted = start.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                    var endFormatted = end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                    
                    var periodPreview = document.getElementById('taskPeriodPreview');
                    if (periodPreview) {
                        periodPreview.innerHTML = startFormatted + ' → ' + endFormatted + ' (' + duration + ' days)';
                    }
                    
                    var isSameDay = document.querySelector('input[name="deadlineType"]:checked');
                    var isSameDayValue = isSameDay ? isSameDay.value === 'same-day' : true;
                    var deadlineTimeObj = new Date('2000-01-01T' + deadlineTimeValue);
                    
                    var finalPreview = document.getElementById('finalDeadlinePreview');
                    if (finalPreview) {
                        if (isSameDayValue) {
                            var deadline = new Date(end);
                            deadline.setHours(deadlineTimeObj.getHours(), deadlineTimeObj.getMinutes());
                            var deadlineFormatted = deadline.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) +
                                                   ' at ' + deadlineTimeValue;
                            finalPreview.innerHTML = deadlineFormatted;
                        } else {
                            var nextDay = new Date(end);
                            nextDay.setDate(nextDay.getDate() + 1);
                            nextDay.setHours(deadlineTimeObj.getHours(), deadlineTimeObj.getMinutes());
                            var deadlineFormatted = nextDay.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) +
                                                   ' at ' + deadlineTimeValue;
                            finalPreview.innerHTML = deadlineFormatted + ' (next day)';
                        }
                    }
                }
            }
            
            if (startDateInput) startDateInput.addEventListener('change', updatePreview);
            if (durationInput) durationInput.addEventListener('input', updatePreview);
            if (deadlineTime) deadlineTime.addEventListener('change', updatePreview);
            var deadlineRadios = document.querySelectorAll('input[name="deadlineType"]');
            deadlineRadios.forEach(function(radio) {
                radio.addEventListener('change', updatePreview);
            });
            
            updatePreview();
        }
        
        // ========== Combined Preview Function ==========
        function updateCombinedPreview() {
            var previewDiv = document.getElementById('combinedPreview');
            var previewContent = document.getElementById('combinedPreviewContent');
            
            if (!previewDiv || !previewContent) return;
            
            var taskType = document.querySelector('input[name="ExecutionType"]:checked');
            if (!taskType) return;
            
            // Task Schedule
            var taskStartDate = document.getElementById('startDate');
            var noTaskEndDate = document.getElementById('noTaskEndDate');
            var taskEndDate = document.getElementById('endDate');
            
            if (!taskStartDate || !taskStartDate.value) {
                previewDiv.classList.add('hidden');
                return;
            }
            
            previewDiv.classList.remove('hidden');
            
            var start = new Date(taskStartDate.value);
            var startFormatted = start.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            
            // Build Task Schedule Description
            var taskScheduleText = '';
            if (noTaskEndDate && noTaskEndDate.checked) {
                taskScheduleText = '📅 Task Schedule: From ' + startFormatted + ' → FOREVER';
            } else if (taskEndDate && taskEndDate.value) {
                var end = new Date(taskEndDate.value);
                var endFormatted = end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                taskScheduleText = '📅 Task Schedule: From ' + startFormatted + ' → ' + endFormatted;
            } else {
                taskScheduleText = '📅 Task Schedule: From ' + startFormatted;
            }
            
            // Build Task Type Description
            var typeText = getTaskTypeDescription(taskType.value);
            
            // Combine
            var fullText = typeText + ' • ' + taskScheduleText;
            previewContent.innerHTML = fullText;
        }
        
        function getTaskTypeDescription(taskType) {
            switch(taskType) {
                case 'RecurringDaily':
                    return '📅 Daily Task';
                case 'RecurringWeekly':
                    var selectedDays = [];
                    var weeklyCheckboxes = document.querySelectorAll('input[name="WeeklyDays"]:checked');
                    weeklyCheckboxes.forEach(function(cb) {
                        var dayNamesList = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                        selectedDays.push(dayNamesList[parseInt(cb.value)]);
                    });
                    var daysText = selectedDays.length > 0 ? selectedDays.join(', ') : 'no days';
                    return '📆 Weekly on ' + daysText;
                case 'RecurringMonthly':
                    var patternType = document.querySelector('input[name="MonthlyPatternType"]:checked');
                    if (patternType && patternType.value === 'day') {
                        var monthlyDay = document.querySelector('select[name="MonthlyDay"]');
                        var dayOfMonth = monthlyDay ? monthlyDay.value : '15';
                        return '📅 Monthly on day ' + dayOfMonth;
                    } else {
                        var ordinal = document.querySelector('select[name="MonthlyOrdinal"]');
                        var weekday = document.querySelector('select[name="MonthlyWeekday"]');
                        var ordinalVal = ordinal ? ordinal.value : 'first';
                        var weekdayVal = weekday ? weekday.value : 'monday';
                        return '📅 Monthly on ' + ordinalVal + ' ' + weekdayVal;
                    }
                case 'MultiDay':
                    var duration = document.getElementById('multiDayDuration');
                    var durationVal = duration ? duration.value : '';
                    return durationVal ? '⏱️ Multi-Day (' + durationVal + ' days)' : '⏱️ Multi-Day Task';
                case 'OneTime':
                    return '🎯 One-Time Task';
                default:
                    return '📋 Task';
            }
        }
        
        // ========== Setup Preview Listeners ==========
        function setupCombinedPreviewListeners() {
            // Task schedule
            var startDate = document.getElementById('startDate');
            if (startDate) startDate.addEventListener('change', updateCombinedPreview);
            var endDate = document.getElementById('endDate');
            if (endDate) endDate.addEventListener('change', updateCombinedPreview);
            var noTaskEndDate = document.getElementById('noTaskEndDate');
            if (noTaskEndDate) noTaskEndDate.addEventListener('change', updateCombinedPreview);
            
            // Task type
            var taskTypeRadios = document.querySelectorAll('input[name="ExecutionType"]');
            taskTypeRadios.forEach(function(radio) {
                radio.addEventListener('change', updateCombinedPreview);
            });
            
            // Weekly days
            var weeklyCheckboxes = document.querySelectorAll('input[name="WeeklyDays"]');
            weeklyCheckboxes.forEach(function(cb) {
                cb.addEventListener('change', updateCombinedPreview);
            });
            
            // Monthly pattern
            var monthlyDay = document.querySelector('select[name="MonthlyDay"]');
            if (monthlyDay) monthlyDay.addEventListener('change', updateCombinedPreview);
            var monthlyOrdinal = document.querySelector('select[name="MonthlyOrdinal"]');
            if (monthlyOrdinal) monthlyOrdinal.addEventListener('change', updateCombinedPreview);
            var monthlyWeekday = document.querySelector('select[name="MonthlyWeekday"]');
            if (monthlyWeekday) monthlyWeekday.addEventListener('change', updateCombinedPreview);
            var monthlyPatternRadios = document.querySelectorAll('input[name="MonthlyPatternType"]');
            monthlyPatternRadios.forEach(function(radio) {
                radio.addEventListener('change', updateCombinedPreview);
            });
            
            // Multi-day
            var multiDayDuration = document.getElementById('multiDayDuration');
            if (multiDayDuration) multiDayDuration.addEventListener('input', updateCombinedPreview);
            var multiDayStartDate = document.getElementById('multiDayStartDate');
            if (multiDayStartDate) multiDayStartDate.addEventListener('change', updateCombinedPreview);
            
            // One-time
            var oneTimeDate = document.getElementById('oneTimeDate');
            if (oneTimeDate) oneTimeDate.addEventListener('change', updateCombinedPreview);
            
            // Deadline
            var deadlineTime = document.getElementById('deadlineTime');
            if (deadlineTime) deadlineTime.addEventListener('change', updateCombinedPreview);
            var deadlineRadios = document.querySelectorAll('input[name="deadlineType"]');
            deadlineRadios.forEach(function(radio) {
                radio.addEventListener('change', function() {
                    updateCombinedPreview();
                    syncIsSameDay();
                });
            });
        }
    </script>
}

<style>
    .toggle-indicator {
        transition: background-color 0.2s ease;
        cursor: pointer;
    }
    
    .toggle-indicator .absolute {
        transition: transform 0.2s ease;
        top: 0.25rem;
        left: 0.25rem;
    }
    
    input[type="radio"]:checked + div {
        border-color: #6366f1;
        background-color: #eef2ff;
    }
    
    input:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }
    
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }
    
    .weekly-day-checkbox {
        cursor: pointer;
        transition: all 0.2s ease;
        accent-color: #6366f1;
    }
    
    .weekly-day-checkbox:hover {
        transform: scale(1.1);
    }
    
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        opacity: 0.5;
    }
    
    @@media (max-width: 768px) {
        .grid-cols-7 {
            grid-template-columns: repeat(7, 1fr);
        }
        
        .weekly-day-checkbox {
            width: 32px;
            height: 32px;
        }
    }
    
    input:disabled, select:disabled {
        background-color: #f3f4f6;
        cursor: not-allowed;
        opacity: 0.6;
    }
</style>