@model TaskTracker.Models.ViewModels.TaskItemViewModel
@using TaskTracker.Models.Entities
@{
    ViewData["Title"] = "Edit Task";
    
    var existingTasks = ViewBag.ExistingTasks as IEnumerable<TaskTracker.Models.ViewModels.TaskListViewModel> ?? new List<TaskTracker.Models.ViewModels.TaskListViewModel>();
    
    var weeklyDaysList = Model.WeeklyDays ?? new List<int>();
    
    var isRecurringWeekly = Model.ExecutionType == TaskExecutionType.RecurringWeekly;
    var isRecurringMonthly = Model.ExecutionType == TaskExecutionType.RecurringMonthly;
    var isMultiDay = Model.ExecutionType == TaskExecutionType.MultiDay;
    var isOneTime = Model.ExecutionType == TaskExecutionType.OneTime;
    var isRecurringDaily = Model.ExecutionType == TaskExecutionType.RecurringDaily;
    
    // Parse monthly pattern - support for first4days
    var monthlyPattern = Model.MonthlyPattern ?? "";
    var isDayPattern = monthlyPattern == "first4days" ? false : !monthlyPattern.Contains("-");
    var isFirst4Days = monthlyPattern == "first4days";
    var monthlyDayNumber = 15;
    if (isDayPattern && int.TryParse(monthlyPattern, out var dayNum))
    {
        monthlyDayNumber = dayNum;
    }
    
    var monthlyOrdinalValue = "first";
    var monthlyWeekdayValue = "monday";
    
    if (!isDayPattern && monthlyPattern.Contains("-") && !isFirst4Days)
    {
        var patternParts = monthlyPattern.Split('-');
        monthlyOrdinalValue = patternParts.Length > 0 ? patternParts[0] : "first";
        monthlyWeekdayValue = patternParts.Length > 1 ? patternParts[1] : "monday";
    }
    
    var isSameDayChecked = Model.IsSameDay;
    
    var dayNamesArray = new[] { "Su", "Mo", "Tu", "We", "Th", "Fr", "Sa" };
    var fullDayNamesArray = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
    
    var startDateValue = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var endDateValue = Model.EndDate?.ToString("yyyy-MM-dd") ?? "";
    var availableFromValue = Model.AvailableFrom?.ToString("yyyy-MM-dd") ?? "";
    var availableToValue = Model.AvailableTo?.ToString("yyyy-MM-dd") ?? "";
    var oneTimeDateValue = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var multiDayStartDateValue = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var deadlineTimeValue = Model.Deadline.ToString(@"hh\:mm");
    
    // Pre-compute selected values for options to avoid Razor syntax errors
    var isFirstSelected = monthlyOrdinalValue == "first";
    var isSecondSelected = monthlyOrdinalValue == "second";
    var isThirdSelected = monthlyOrdinalValue == "third";
    var isFourthSelected = monthlyOrdinalValue == "fourth";
    var isLastSelected = monthlyOrdinalValue == "last";
    
    var isSundaySelected = monthlyWeekdayValue == "sunday";
    var isMondaySelected = monthlyWeekdayValue == "monday";
    var isTuesdaySelected = monthlyWeekdayValue == "tuesday";
    var isWednesdaySelected = monthlyWeekdayValue == "wednesday";
    var isThursdaySelected = monthlyWeekdayValue == "thursday";
    var isFridaySelected = monthlyWeekdayValue == "friday";
    var isSaturdaySelected = monthlyWeekdayValue == "saturday";
    
    var isActiveChecked = Model.IsActive ? "checked" : "";
}

<div class="mb-8">
    <div class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-600 rounded-2xl shadow-xl p-6 text-white">
        <div class="flex items-center space-x-4">
            <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur-md flex items-center justify-center">
                <i class="fas fa-edit text-3xl"></i>
            </div>
            <div>
                <h1 class="text-3xl font-bold">Edit Task</h1>
                <p class="text-indigo-100 mt-1">Modify task configuration and scheduling</p>
            </div>
        </div>
    </div>
</div>

<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-white">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                <i class="fas fa-calendar-alt text-indigo-600 mr-2"></i>
                Task Configuration
            </h3>
        </div>

        <form asp-action="Edit" method="post" class="p-6" id="taskForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 text-red-700 rounded-xl text-sm border border-red-200"></div>

            <!-- Basic Information -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-info-circle text-indigo-500 mr-2"></i>
                    Basic Information
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                            Task Name <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500" />
                        <span asp-validation-for="Name" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Description (Optional)</label>
                        <textarea asp-for="Description" rows="1" class="w-full px-4 py-2 border border-gray-300 rounded-lg">@Model.Description</textarea>
                    </div>
                </div>
            </div>

            <!-- Task Type Selection -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-tasks text-indigo-500 mr-2"></i>
                    Task Type
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringDaily" class="sr-only peer" @(isRecurringDaily ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2"><i class="fas fa-calendar-day text-2xl text-blue-500"></i><span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full">Daily</span></div>
                            <h5 class="font-semibold text-gray-900">Recurring Daily</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each day</p>
                        </div>
                    </label>
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="MultiDay" class="sr-only peer" @(isMultiDay ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2"><i class="fas fa-calendar-range text-2xl text-green-500"></i><span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Multi-Day</span></div>
                            <h5 class="font-semibold text-gray-900">Multi-Day Task</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete once</p>
                        </div>
                    </label>
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringWeekly" class="sr-only peer" @(isRecurringWeekly ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2"><i class="fas fa-calendar-week text-2xl text-purple-500"></i><span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full">Weekly</span></div>
                            <h5 class="font-semibold text-gray-900">Recurring Weekly</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each week</p>
                        </div>
                    </label>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringMonthly" class="sr-only peer" @(isRecurringMonthly ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2"><i class="fas fa-calendar-alt text-2xl text-yellow-500"></i><span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-1 rounded-full">Monthly</span></div>
                            <h5 class="font-semibold text-gray-900">Recurring Monthly</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each month</p>
                        </div>
                    </label>
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="OneTime" class="sr-only peer" @(isOneTime ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2"><i class="fas fa-hourglass-start text-2xl text-red-500"></i><span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">One-Time</span></div>
                            <h5 class="font-semibold text-gray-900">One-Time Task</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete once</p>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Common Scheduling Section -->
            <div id="commonScheduleSection" class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center"><i class="fas fa-calendar-alt text-blue-500 mr-2"></i>Schedule Settings</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Task Start Date</label><input type="date" name="StartDate" id="startDate" class="w-full px-4 py-2 border rounded-lg" value="@startDateValue" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Task End Date</label><div class="flex items-center gap-2"><input type="date" name="EndDate" id="endDate" class="flex-1 px-4 py-2 border rounded-lg" value="@endDateValue" /><label class="flex items-center cursor-pointer whitespace-nowrap"><input type="checkbox" id="noTaskEndDate" class="mr-2 w-4 h-4 text-indigo-600" @(Model.EndDate == null ? "checked" : "") onchange="toggleTaskEndDate(); updateCombinedPreview();" /><span class="text-sm text-gray-600">No End Date</span></label></div></div>
                </div>
                <div id="foreverTaskIndicator" class="hidden mb-4 p-3 bg-green-50 border border-green-200 rounded-lg"><div class="flex items-center"><i class="fas fa-infinity text-green-600 mr-2"></i><span class="text-sm text-green-700">This task will repeat forever with no end date.</span></div></div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Available From</label><input type="date" name="AvailableFrom" id="availableFrom" class="w-full px-4 py-2 border rounded-lg" value="@availableFromValue" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Available To</label><div class="flex items-center gap-2"><input type="date" name="AvailableTo" id="availableTo" class="flex-1 px-4 py-2 border rounded-lg" value="@availableToValue" /><label class="flex items-center cursor-pointer whitespace-nowrap"><input type="checkbox" id="noAvailableEndDate" class="mr-2 w-4 h-4 text-indigo-600" @(Model.AvailableTo == null ? "checked" : "") onchange="toggleAvailableEndDate(); updateCombinedPreview();" /><span class="text-sm text-gray-600">No End Date</span></label></div></div>
                </div>
                <div id="foreverAvailableIndicator" class="hidden mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg"><div class="flex items-center"><i class="fas fa-infinity text-blue-600 mr-2"></i><span class="text-sm text-blue-700">This task is available forever with no end date.</span></div></div>
                <div class="mb-4"><label class="block text-sm font-medium text-gray-700 mb-1">Max Occurrences</label><div class="flex items-center gap-2"><input type="number" name="MaxOccurrences" id="maxOccurrences" class="flex-1 px-4 py-2 border rounded-lg" value="@Model.MaxOccurrences" placeholder="Leave empty for unlimited" min="1" /><label class="flex items-center cursor-pointer whitespace-nowrap"><input type="checkbox" id="unlimitedOccurrences" class="mr-2 w-4 h-4 text-indigo-600" @(Model.MaxOccurrences == null ? "checked" : "") onchange="toggleMaxOccurrences(); updateCombinedPreview();" /><span class="text-sm text-gray-600">Unlimited</span></label></div></div>
            </div>

            <!-- Weekly Task Section -->
            <div id="weeklyTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 @(!isRecurringWeekly ? "hidden" : "")">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center"><i class="fas fa-calendar-week text-purple-500 mr-2"></i>Weekly Schedule</h4>
                <div><label class="block text-sm font-medium text-gray-700 mb-2">Repeat On</label><div class="grid grid-cols-7 gap-2">
                    @for (int idx = 0; idx < 7; idx++)
                    {
                        var isDaySelected = weeklyDaysList.Contains(idx);
                        <label class="flex flex-col items-center cursor-pointer">
                            <input type="checkbox" name="WeeklyDays" value="@idx" class="weekly-day-checkbox w-6 h-6" @(isDaySelected ? "checked" : "") onchange="updateCombinedPreview();" />
                            <span class="text-xs mt-1">@dayNamesArray[idx]</span>
                        </label>
                    }
                </div></div>
            </div>

            <!-- Monthly Task Section (with First 4 Days) -->
            <div id="monthlyTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 @(!isRecurringMonthly ? "hidden" : "")">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center"><i class="fas fa-calendar-alt text-yellow-500 mr-2"></i>Monthly Schedule</h4>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Monthly Pattern</label>
                    <div class="grid grid-cols-3 gap-2 mb-3">
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="day" class="mr-2" @(isDayPattern && !isFirst4Days ? "checked" : "") onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span>Specific Day</span>
                        </label>
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="weekday" class="mr-2" @(!isDayPattern && !isFirst4Days ? "checked" : "") onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span>Nth Weekday</span>
                        </label>
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="first4days" class="mr-2" @(isFirst4Days ? "checked" : "") onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span>First 4 Days</span>
                        </label>
                    </div>
                    
                    <div id="monthlyDayPattern" class="@(!isDayPattern || isFirst4Days ? "hidden" : "")">
                        <select name="MonthlyDay" class="w-full px-4 py-2 border rounded-lg" onchange="updateCombinedPreview();">
                            @for (int d = 1; d <= 31; d++)
                            {
                                <option value="@d" selected="@(monthlyDayNumber == d ? "selected" : null)">Day @d</option>
                            }
                        </select>
                        <p class="text-xs text-gray-500 mt-1">Task appears on this specific day each month</p>
                    </div>
                    
                    <div id="monthlyWeekdayPattern" class="@(isDayPattern || isFirst4Days ? "hidden" : "")">
                        <div class="flex gap-2">
                            <select name="MonthlyOrdinal" class="flex-1 px-4 py-2 border rounded-lg" onchange="updateMonthlyPattern(); updateCombinedPreview();">
                                <option value="first" selected="@(isFirstSelected ? "selected" : null)">First</option>
                                <option value="second" selected="@(isSecondSelected ? "selected" : null)">Second</option>
                                <option value="third" selected="@(isThirdSelected ? "selected" : null)">Third</option>
                                <option value="fourth" selected="@(isFourthSelected ? "selected" : null)">Fourth</option>
                                <option value="last" selected="@(isLastSelected ? "selected" : null)">Last</option>
                            </select>
                            <select name="MonthlyWeekday" class="flex-1 px-4 py-2 border rounded-lg" onchange="updateMonthlyPattern(); updateCombinedPreview();">
                                <option value="sunday" selected="@(isSundaySelected ? "selected" : null)">Sunday</option>
                                <option value="monday" selected="@(isMondaySelected ? "selected" : null)">Monday</option>
                                <option value="tuesday" selected="@(isTuesdaySelected ? "selected" : null)">Tuesday</option>
                                <option value="wednesday" selected="@(isWednesdaySelected ? "selected" : null)">Wednesday</option>
                                <option value="thursday" selected="@(isThursdaySelected ? "selected" : null)">Thursday</option>
                                <option value="friday" selected="@(isFridaySelected ? "selected" : null)">Friday</option>
                                <option value="saturday" selected="@(isSaturdaySelected ? "selected" : null)">Saturday</option>
                            </select>
                        </div>
                        <input type="hidden" id="MonthlyPattern" name="MonthlyPattern" value="@Model.MonthlyPattern" />
                        <p class="text-xs text-gray-500 mt-1">Example: "First Monday" or "Last Friday"</p>
                    </div>
                    
                    <div id="monthlyFirst4DaysPattern" class="@(!isFirst4Days ? "hidden" : "")">
                        <div class="bg-blue-50 p-3 rounded-lg mt-2">
                            <p class="text-sm text-blue-700"><i class="fas fa-info-circle mr-1"></i>This task will appear on days 1, 2, 3, and 4 of every month.</p>
                        </div>
                        <input type="hidden" id="MonthlyPatternFirst4Days" name="MonthlyPattern" value="first4days" />
                    </div>
                </div>
            </div>

            <!-- Multi-Day Task Section -->
            <div id="multiDayTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 @(!isMultiDay ? "hidden" : "")">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center"><i class="fas fa-calendar-range text-green-500 mr-2"></i>Multi-Day Settings</h4>
                <div class="bg-blue-50 p-4 rounded-lg border border-blue-200 mb-4"><div class="flex items-center mb-2"><i class="fas fa-info-circle text-blue-600 mr-2"></i><span class="text-sm font-medium text-blue-800">Multi-Day Task Information</span></div><p class="text-xs text-blue-700">This task will appear on the dashboard from the start date until the end date. You only need to complete it ONCE by the deadline (end date + deadline time).</p></div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4"><div><label class="block text-sm font-medium text-gray-700 mb-1">Start Date</label><input type="date" id="multiDayStartDate" class="w-full px-4 py-2 border rounded-lg" value="@multiDayStartDateValue" onchange="updateCombinedPreview();" /></div><div><label class="block text-sm font-medium text-gray-700 mb-1">Duration (Days)</label><input type="number" id="multiDayDuration" class="w-full px-4 py-2 border rounded-lg" placeholder="e.g., 3" min="1" value="@Model.DurationDays" oninput="updateCombinedPreview();" /></div></div>
                <div class="mt-3 p-3 bg-gray-100 rounded-lg"><div class="text-sm text-gray-700"><span class="font-medium">Task Period:</span> <span id="taskPeriodPreview" class="ml-2 text-indigo-600">Select dates to see preview</span></div><div class="text-sm text-gray-700 mt-1"><span class="font-medium">Final Deadline:</span> <span id="finalDeadlinePreview" class="ml-2 text-amber-600">Will be calculated</span></div></div>
            </div>

            <!-- One-Time Task Section -->
            <div id="oneTimeTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 @(!isOneTime ? "hidden" : "")">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center"><i class="fas fa-hourglass-start text-red-500 mr-2"></i>One-Time Schedule</h4>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Task Date</label><input type="date" id="oneTimeDate" class="w-full px-4 py-2 border rounded-lg" value="@oneTimeDateValue" onchange="updateCombinedPreview();" /></div>
            </div>

            <!-- Combined Preview -->
            <div id="combinedPreview" class="mt-4 p-4 bg-indigo-50 border border-indigo-200 rounded-lg hidden mb-6">
                <div class="flex items-start"><i class="fas fa-chart-line text-indigo-500 mt-0.5 mr-3 text-lg"></i><div class="flex-1"><span class="text-sm font-semibold text-indigo-800">📋 Task Schedule Preview</span><div id="combinedPreviewContent" class="text-sm text-indigo-700 mt-1 font-medium">Select options to see preview</div></div></div>
            </div>

            <!-- Deadline Configuration -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center"><i class="fas fa-hourglass-half text-blue-500 mr-2"></i>Deadline Configuration</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div><label asp-for="Deadline" class="block text-sm font-medium text-gray-700 mb-1">Deadline Time <span class="text-red-500">*</span></label><input asp-for="Deadline" type="time" id="deadlineTime" class="w-full px-4 py-2 border rounded-lg" value="@deadlineTimeValue" onchange="updateCombinedPreview();" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Deadline Type</label><div class="flex space-x-4 mt-2"><label class="flex items-center"><input type="radio" name="deadlineType" value="same-day" class="mr-2" @(isSameDayChecked ? "checked" : "") onchange="updateCombinedPreview(); syncIsSameDay();" /><span>Same Day</span></label><label class="flex items-center"><input type="radio" name="deadlineType" value="next-day" class="mr-2" @(!isSameDayChecked ? "checked" : "") onchange="updateCombinedPreview(); syncIsSameDay();" /><span>Next Day</span></label></div><input type="hidden" asp-for="IsSameDay" id="IsSameDayHidden" /></div>
                </div>
            </div>

            <!-- Organization -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center"><i class="fas fa-chart-line text-purple-500 mr-2"></i>Organization</h4>
                <div><label asp-for="DisplayOrder" class="block text-sm font-medium text-gray-700 mb-1">Display Order</label><input asp-for="DisplayOrder" type="number" min="0" class="w-full px-4 py-2 border rounded-lg" /></div>
            </div>

            <!-- Active Status Toggle -->
            <div class="bg-gradient-to-r from-gray-50 to-white p-5 rounded-xl border border-gray-200 mb-6">
                <label class="flex items-center justify-between cursor-pointer">
                    <div><span class="text-sm font-medium text-gray-700">Active Task</span><p class="text-xs text-gray-500 mt-1">Inactive tasks won't appear in daily task boards</p></div>
                    <div class="relative">
                        <input type="checkbox" asp-for="IsActive" id="IsActive" class="sr-only" onchange="updateToggleDisplay('IsActive');" />
                        <div class="w-14 h-8 bg-gray-300 rounded-full transition cursor-pointer toggle-indicator" onclick="toggleCheckbox('IsActive')">
                            <div class="absolute w-6 h-6 bg-white rounded-full shadow-md transform transition translate-x-1"></div>
                        </div>
                    </div>
                </label>
            </div>

            <div class="flex justify-end space-x-3 pt-4 border-t">
                <a href="@Url.Action("Index")" class="px-6 py-3 border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition">Cancel</a>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl text-sm font-medium hover:from-indigo-700 hover:to-purple-700 transition shadow-md flex items-center">Update Task</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            updateToggleDisplay('IsActive');
            syncIsSameDay();
            toggleTaskType();
            toggleMonthlyPattern();
            toggleTaskEndDate();
            toggleAvailableEndDate();
            toggleMaxOccurrences();
            setupCombinedPreviewListeners();
            setTimeout(updateCombinedPreview, 100);
        });

        function toggleCheckbox(id) {
            var checkbox = document.getElementById(id);
            checkbox.checked = !checkbox.checked;
            updateToggleDisplay(id);
        }
        
        function updateToggleDisplay(id) {
            var checkbox = document.getElementById(id);
            var toggleDiv = checkbox.nextElementSibling;
            var circle = toggleDiv.querySelector('.absolute');
            if (checkbox.checked) {
                toggleDiv.classList.remove('bg-gray-300');
                toggleDiv.classList.add('bg-green-600');
                circle.style.transform = 'translateX(28px)';
            } else {
                toggleDiv.classList.remove('bg-green-600');
                toggleDiv.classList.add('bg-gray-300');
                circle.style.transform = 'translateX(4px)';
            }
        }
        
        function syncIsSameDay() {
            var deadlineType = document.querySelector('input[name="deadlineType"]:checked');
            if (deadlineType) {
                var isSameDayHidden = document.getElementById('IsSameDayHidden');
                if (isSameDayHidden) { isSameDayHidden.value = (deadlineType.value === 'same-day'); }
            }
        }

        function toggleTaskEndDate() {
            var noEndDate = $('#noTaskEndDate').is(':checked');
            $('#endDate').prop('disabled', noEndDate);
            if (noEndDate) $('#endDate').val('');
            $('#foreverTaskIndicator').toggleClass('hidden', !noEndDate);
            updateCombinedPreview();
        }
        
        function toggleAvailableEndDate() {
            var noEndDate = $('#noAvailableEndDate').is(':checked');
            $('#availableTo').prop('disabled', noEndDate);
            if (noEndDate) $('#availableTo').val('');
            $('#foreverAvailableIndicator').toggleClass('hidden', !noEndDate);
            updateCombinedPreview();
        }
        
        function toggleMaxOccurrences() {
            var unlimited = $('#unlimitedOccurrences').is(':checked');
            $('#maxOccurrences').prop('disabled', unlimited);
            if (unlimited) $('#maxOccurrences').val('');
            updateCombinedPreview();
        }

        function toggleTaskType() {
            var type = $('input[name="ExecutionType"]:checked').val();
            $('#weeklyTaskSection, #monthlyTaskSection, #multiDayTaskSection, #oneTimeTaskSection').addClass('hidden');
            if (type === 'RecurringWeekly') $('#weeklyTaskSection').removeClass('hidden');
            if (type === 'RecurringMonthly') { $('#monthlyTaskSection').removeClass('hidden'); toggleMonthlyPattern(); }
            if (type === 'MultiDay') { $('#multiDayTaskSection').removeClass('hidden'); setupMultiDayPreview(); }
            if (type === 'OneTime') $('#oneTimeTaskSection').removeClass('hidden');
            updateCombinedPreview();
        }
        
        function toggleMonthlyPattern() {
            var type = $('input[name="MonthlyPatternType"]:checked').val();
            $('#monthlyDayPattern, #monthlyWeekdayPattern, #monthlyFirst4DaysPattern').addClass('hidden');
            if (type === 'day') {
                $('#monthlyDayPattern').removeClass('hidden');
                $('#MonthlyPattern').val($('select[name="MonthlyDay"]').val());
            } else if (type === 'weekday') {
                $('#monthlyWeekdayPattern').removeClass('hidden');
                updateMonthlyPattern();
            } else if (type === 'first4days') {
                $('#monthlyFirst4DaysPattern').removeClass('hidden');
                $('#MonthlyPattern').val('first4days');
            }
            updateCombinedPreview();
        }
        
        function updateMonthlyPattern() {
            var ordinal = $('select[name="MonthlyOrdinal"]').val();
            var weekday = $('select[name="MonthlyWeekday"]').val();
            $('#MonthlyPattern').val(ordinal + '-' + weekday);
        }
        
        function setupMultiDayPreview() {
            function update() {
                var startDate = $('#multiDayStartDate').val();
                var duration = parseInt($('#multiDayDuration').val()) || 0;
                var deadlineTime = $('#deadlineTime').val() || '21:00';
                if (startDate && duration > 0) {
                    var start = new Date(startDate);
                    var end = new Date(start);
                    end.setDate(end.getDate() + duration - 1);
                    $('#taskPeriodPreview').html(start.toLocaleDateString() + ' → ' + end.toLocaleDateString() + ' (' + duration + ' days)');
                    var isSameDay = $('input[name="deadlineType"]:checked').val() === 'same-day';
                    var timeObj = new Date('2000-01-01T' + deadlineTime);
                    if (isSameDay) {
                        var deadline = new Date(end);
                        deadline.setHours(timeObj.getHours(), timeObj.getMinutes());
                        $('#finalDeadlinePreview').html(deadline.toLocaleDateString() + ' at ' + deadlineTime);
                    } else {
                        var nextDay = new Date(end);
                        nextDay.setDate(nextDay.getDate() + 1);
                        nextDay.setHours(timeObj.getHours(), timeObj.getMinutes());
                        $('#finalDeadlinePreview').html(nextDay.toLocaleDateString() + ' at ' + deadlineTime + ' (next day)');
                    }
                }
            }
            $('#multiDayStartDate, #multiDayDuration, #deadlineTime, input[name="deadlineType"]').on('change input', update);
            update();
        }
        
        function updateCombinedPreview() {
            var taskStartDate = $('#startDate').val();
            if (!taskStartDate) { $('#combinedPreview').addClass('hidden'); return; }
            $('#combinedPreview').removeClass('hidden');
            var start = new Date(taskStartDate);
            var type = $('input[name="ExecutionType"]:checked').val();
            var noEndDate = $('#noTaskEndDate').is(':checked');
            var endDate = $('#endDate').val();
            var scheduleText = '📅 From ' + start.toLocaleDateString();
            if (noEndDate) scheduleText += ' → FOREVER';
            else if (endDate) scheduleText += ' → ' + new Date(endDate).toLocaleDateString();
            var typeText = getTaskTypeDescription(type);
            $('#combinedPreviewContent').html(typeText + ' • ' + scheduleText);
        }
        
        function getTaskTypeDescription(type) {
            switch(type) {
                case 'RecurringDaily': return '📅 Daily Task';
                case 'RecurringWeekly':
                    var days = [];
                    $('input[name="WeeklyDays"]:checked').each(function() {
                        var dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
                        days.push(dayNames[parseInt($(this).val())]);
                    });
                    return '📆 Weekly on ' + (days.length ? days.join(', ') : 'no days');
                case 'RecurringMonthly':
                    var patternType = $('input[name="MonthlyPatternType"]:checked').val();
                    if (patternType === 'day') return '📅 Monthly on day ' + $('select[name="MonthlyDay"]').val();
                    if (patternType === 'weekday') return '📅 Monthly on ' + $('select[name="MonthlyOrdinal"]').val() + ' ' + $('select[name="MonthlyWeekday"]').val();
                    return '📅 Monthly on first 4 days (Days 1-4)';
                case 'MultiDay':
                    var dur = $('#multiDayDuration').val();
                    return dur ? '⏱️ Multi-Day (' + dur + ' days)' : '⏱️ Multi-Day Task';
                case 'OneTime': return '🎯 One-Time Task';
                default: return '📋 Task';
            }
        }
        
        function setupCombinedPreviewListeners() {
            $('#startDate, #endDate, #noTaskEndDate, #availableFrom, #availableTo, #noAvailableEndDate, #unlimitedOccurrences, #maxOccurrences, #deadlineTime, input[name="deadlineType"], input[name="ExecutionType"], input[name="WeeklyDays"], select[name="MonthlyDay"], select[name="MonthlyOrdinal"], select[name="MonthlyWeekday"], input[name="MonthlyPatternType"], #multiDayDuration, #multiDayStartDate, #oneTimeDate').on('change input', updateCombinedPreview);
        }
    </script>
}
<style>
    .toggle-indicator { transition: background-color 0.2s ease; cursor: pointer; }
    .toggle-indicator .absolute { transition: transform 0.2s ease; top: 0.25rem; left: 0.25rem; }
    input[type="radio"]:checked + div { border-color: #6366f1; background-color: #eef2ff; }
    input:focus { outline: none; border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2); }
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0; }
    .weekly-day-checkbox { cursor: pointer; accent-color: #6366f1; }
    .weekly-day-checkbox:hover { transform: scale(1.1); }
    input:disabled, select:disabled { background-color: #f3f4f6; cursor: not-allowed; opacity: 0.6; }
</style>