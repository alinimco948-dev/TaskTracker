@model TaskTracker.Models.ViewModels.TaskItemViewModel
@using TaskTracker.Models.Entities
@{
    ViewData["Title"] = "Edit Task";

    var existingTasks = ViewBag.ExistingTasks as IEnumerable<TaskTracker.Models.ViewModels.TaskListViewModel> ?? new List<TaskTracker.Models.ViewModels.TaskListViewModel>();

    var weeklyDaysList = Model.WeeklyDays ?? new List<int>();

    var isRecurringWeekly  = Model.ExecutionType == TaskExecutionType.RecurringWeekly;
    var isRecurringMonthly = Model.ExecutionType == TaskExecutionType.RecurringMonthly;
    var isMultiDay         = Model.ExecutionType == TaskExecutionType.MultiDay;
    var isOneTime          = Model.ExecutionType == TaskExecutionType.OneTime;
    var isRecurringDaily   = Model.ExecutionType == TaskExecutionType.RecurringDaily;

    var monthlyPattern    = Model.MonthlyPattern ?? "";
    var isFirst4Days      = monthlyPattern == "first4days";
    var isDayPattern      = !isFirst4Days && !monthlyPattern.Contains("-");
    var monthlyDayNumber  = 15;
    if (isDayPattern && int.TryParse(monthlyPattern, out var dayNum)) monthlyDayNumber = dayNum;

    var monthlyOrdinalValue = "first";
    var monthlyWeekdayValue = "monday";
    if (!isDayPattern && monthlyPattern.Contains("-") && !isFirst4Days) {
        var parts = monthlyPattern.Split('-');
        monthlyOrdinalValue = parts.Length > 0 ? parts[0] : "first";
        monthlyWeekdayValue = parts.Length > 1 ? parts[1] : "monday";
    }

    var startDateValue       = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var endDateValue         = Model.EndDate?.ToString("yyyy-MM-dd") ?? "";
    var availableFromValue   = Model.AvailableFrom?.ToString("yyyy-MM-dd") ?? "";
    var availableToValue     = Model.AvailableTo?.ToString("yyyy-MM-dd") ?? "";
    var oneTimeDateValue     = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var multiDayStartValue   = Model.StartDate?.ToString("yyyy-MM-dd") ?? "";
    var deadlineTimeValue    = Model.Deadline.ToString(@"hh\:mm");
    var isSameDayChecked     = Model.IsSameDay;

    var dayNamesShort = new[] { "Su", "Mo", "Tu", "We", "Th", "Fr", "Sa" };

    bool Sel(string a, string b) => a == b;
}

<div class="animate-fade-up space-y-6">


    <div class="glass-card overflow-hidden">
        <div class="px-6 py-5 bg-gradient-to-r from-amber-500/10 via-violet-500/10 to-transparent flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: 0 4px 15px rgba(245,158,11,0.35);">
                <i class="fas fa-edit text-white text-lg"></i>
            </div>
            <div>
                <div class="flex items-center gap-2 mb-0.5">
                    <a href="@Url.Action("Index")" class="text-xs text-slate-500 hover:text-amber-400 transition">Tasks</a>
                    <i class="fas fa-chevron-right text-slate-600 text-[10px]"></i>
                    <span class="text-xs text-slate-400 font-medium">Edit</span>
                </div>
                <h1 class="text-2xl font-black text-white tracking-tight">Edit Task</h1>
                <p class="text-slate-400 text-sm mt-0.5">Modify task configuration and scheduling</p>
            </div>
        </div>
    </div>

    <div class="max-w-4xl mx-auto">
        <div class="glass-card overflow-hidden">
            <div class="px-6 py-4 flex items-center gap-3" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
                <i class="fas fa-calendar-alt text-indigo-400"></i>
                <h3 class="text-base font-semibold text-white">Task Configuration</h3>
            </div>

            <form asp-action="Edit" method="post" class="p-6 space-y-5" id="taskForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="alert-error rounded-xl p-4 text-sm"></div>


                <div class="form-section">
                    <h4 class="section-heading"><i class="fas fa-info-circle text-indigo-400 mr-2"></i>Basic Information</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Name" class="field-label">Task Name <span class="text-red-400">*</span></label>
                            <input asp-for="Name" class="dark-input" />
                            <span asp-validation-for="Name" class="text-xs text-red-400 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Description" class="field-label">Description <span class="text-slate-600">(Optional)</span></label>
                            <textarea asp-for="Description" rows="1" class="dark-input">@Model.Description</textarea>
                        </div>
                    </div>
                </div>


                <div class="form-section">
                    <h4 class="section-heading"><i class="fas fa-tasks text-violet-400 mr-2"></i>Task Type</h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
                        <label class="cursor-pointer">
                            <input type="radio" name="ExecutionType" value="RecurringDaily" class="sr-only peer" @(isRecurringDaily ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2"><i class="fas fa-calendar-day text-xl text-blue-400"></i><span class="type-badge bg-blue-500/20 text-blue-400">Daily</span></div>
                                <h5 class="font-semibold text-white text-sm">Recurring Daily</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete each day</p>
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="ExecutionType" value="MultiDay" class="sr-only peer" @(isMultiDay ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2"><i class="fas fa-calendar-range text-xl text-emerald-400"></i><span class="type-badge bg-emerald-500/20 text-emerald-400">Multi-Day</span></div>
                                <h5 class="font-semibold text-white text-sm">Multi-Day Task</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete once in range</p>
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="ExecutionType" value="RecurringWeekly" class="sr-only peer" @(isRecurringWeekly ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2"><i class="fas fa-calendar-week text-xl text-violet-400"></i><span class="type-badge bg-violet-500/20 text-violet-400">Weekly</span></div>
                                <h5 class="font-semibold text-white text-sm">Recurring Weekly</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete each week</p>
                            </div>
                        </label>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <label class="cursor-pointer">
                            <input type="radio" name="ExecutionType" value="RecurringMonthly" class="sr-only peer" @(isRecurringMonthly ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2"><i class="fas fa-calendar-alt text-xl text-amber-400"></i><span class="type-badge bg-amber-500/20 text-amber-400">Monthly</span></div>
                                <h5 class="font-semibold text-white text-sm">Recurring Monthly</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete each month</p>
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="ExecutionType" value="OneTime" class="sr-only peer" @(isOneTime ? "checked" : "") onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2"><i class="fas fa-hourglass-start text-xl text-red-400"></i><span class="type-badge bg-red-500/20 text-red-400">One-Time</span></div>
                                <h5 class="font-semibold text-white text-sm">One-Time Task</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete once</p>
                            </div>
                        </label>
                    </div>
                </div>


                <div id="commonScheduleSection" class="form-section">
                    <h4 class="section-heading"><i class="fas fa-calendar-alt text-blue-400 mr-2"></i>Schedule Settings</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="field-label">Task Start Date</label>
                            <input type="date" name="StartDate" id="startDate" class="dark-input" value="@startDateValue" />
                        </div>
                        <div>
                            <label class="field-label">Task End Date</label>
                            <div class="flex items-center gap-2">
                                <input type="date" name="EndDate" id="endDate" class="dark-input flex-1" value="@endDateValue" />
                                <label class="flex items-center cursor-pointer whitespace-nowrap gap-1.5">
                                    <input type="checkbox" id="noTaskEndDate" class="w-4 h-4 accent-indigo-500" @(Model.EndDate == null ? "checked" : "") onchange="toggleTaskEndDate(); updateCombinedPreview();" />
                                    <span class="text-xs text-slate-400">No End</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="foreverTaskIndicator" class="hidden mb-4 p-3 rounded-lg" style="background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2);">
                        <div class="flex items-center gap-2"><i class="fas fa-infinity text-emerald-400"></i><span class="text-sm text-emerald-400">This task will repeat forever with no end date.</span></div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="field-label">Available From</label>
                            <input type="date" name="AvailableFrom" id="availableFrom" class="dark-input" value="@availableFromValue" />
                        </div>
                        <div>
                            <label class="field-label">Available To</label>
                            <div class="flex items-center gap-2">
                                <input type="date" name="AvailableTo" id="availableTo" class="dark-input flex-1" value="@availableToValue" />
                                <label class="flex items-center cursor-pointer whitespace-nowrap gap-1.5">
                                    <input type="checkbox" id="noAvailableEndDate" class="w-4 h-4 accent-indigo-500" @(Model.AvailableTo == null ? "checked" : "") onchange="toggleAvailableEndDate(); updateCombinedPreview();" />
                                    <span class="text-xs text-slate-400">No End</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="foreverAvailableIndicator" class="hidden mb-4 p-3 rounded-lg" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);">
                        <div class="flex items-center gap-2"><i class="fas fa-infinity text-blue-400"></i><span class="text-sm text-blue-400">This task is available forever with no end date.</span></div>
                    </div>
                    <div>
                        <label class="field-label">Max Occurrences</label>
                        <div class="flex items-center gap-2">
                            <input type="number" name="MaxOccurrences" id="maxOccurrences" class="dark-input flex-1" value="@Model.MaxOccurrences" placeholder="Leave empty for unlimited" min="1" />
                            <label class="flex items-center cursor-pointer whitespace-nowrap gap-1.5">
                                <input type="checkbox" id="unlimitedOccurrences" class="w-4 h-4 accent-indigo-500" @(Model.MaxOccurrences == null ? "checked" : "") onchange="toggleMaxOccurrences(); updateCombinedPreview();" />
                                <span class="text-xs text-slate-400">Unlimited</span>
                            </label>
                        </div>
                    </div>
                </div>


                <div id="weeklyTaskSection" class="form-section @(!isRecurringWeekly ? "hidden" : "")">
                    <h4 class="section-heading"><i class="fas fa-calendar-week text-violet-400 mr-2"></i>Weekly Schedule</h4>
                    <label class="field-label">Repeat On</label>
                    <div class="grid grid-cols-7 gap-2 mt-2">
                        @for (int idx = 0; idx < 7; idx++) {
                            var isDaySel = weeklyDaysList.Contains(idx);
                            <label class="flex flex-col items-center cursor-pointer">
                                <input type="checkbox" name="WeeklyDays" value="@idx" class="weekly-day-checkbox w-5 h-5 accent-indigo-500" @(isDaySel ? "checked" : "") onchange="updateCombinedPreview();" />
                                <span class="text-xs text-slate-400 mt-1">@dayNamesShort[idx]</span>
                            </label>
                        }
                    </div>
                </div>


                <div id="monthlyTaskSection" class="form-section @(!isRecurringMonthly ? "hidden" : "")">
                    <h4 class="section-heading"><i class="fas fa-calendar-alt text-amber-400 mr-2"></i>Monthly Schedule</h4>
                    <label class="field-label mb-2">Monthly Pattern</label>
                    <div class="grid grid-cols-3 gap-2 mb-3">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="day" class="w-4 h-4 accent-indigo-500" @(isDayPattern && !isFirst4Days ? "checked" : "") onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span class="text-sm text-slate-300">Specific Day</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="weekday" class="w-4 h-4 accent-indigo-500" @(!isDayPattern && !isFirst4Days ? "checked" : "") onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span class="text-sm text-slate-300">Nth Weekday</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="first4days" class="w-4 h-4 accent-indigo-500" @(isFirst4Days ? "checked" : "") onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span class="text-sm text-slate-300">First 4 Days</span>
                        </label>
                    </div>
                    <div id="monthlyDayPattern" class="@(!isDayPattern || isFirst4Days ? "hidden" : "")">
                        <select name="MonthlyDay" class="dark-input" onchange="updateCombinedPreview();">
                            @for (int d = 1; d <= 31; d++) {
                                <option value="@d" selected="@(monthlyDayNumber == d ? "selected" : null)">Day @d</option>
                            }
                        </select>
                        <p class="text-xs text-slate-500 mt-1.5">Task appears on this specific day each month</p>
                    </div>
                    <div id="monthlyWeekdayPattern" class="@(isDayPattern || isFirst4Days ? "hidden" : "")">
                        <div class="flex gap-2">
                            <select name="MonthlyOrdinal" class="dark-input flex-1" onchange="updateMonthlyPattern(); updateCombinedPreview();">
                                <option value="first"  selected="@(Sel(monthlyOrdinalValue,"first")  ? "selected" : null)">First</option>
                                <option value="second" selected="@(Sel(monthlyOrdinalValue,"second") ? "selected" : null)">Second</option>
                                <option value="third"  selected="@(Sel(monthlyOrdinalValue,"third")  ? "selected" : null)">Third</option>
                                <option value="fourth" selected="@(Sel(monthlyOrdinalValue,"fourth") ? "selected" : null)">Fourth</option>
                                <option value="last"   selected="@(Sel(monthlyOrdinalValue,"last")   ? "selected" : null)">Last</option>
                            </select>
                            <select name="MonthlyWeekday" class="dark-input flex-1" onchange="updateMonthlyPattern(); updateCombinedPreview();">
                                <option value="sunday"    selected="@(Sel(monthlyWeekdayValue,"sunday")    ? "selected" : null)">Sunday</option>
                                <option value="monday"    selected="@(Sel(monthlyWeekdayValue,"monday")    ? "selected" : null)">Monday</option>
                                <option value="tuesday"   selected="@(Sel(monthlyWeekdayValue,"tuesday")   ? "selected" : null)">Tuesday</option>
                                <option value="wednesday" selected="@(Sel(monthlyWeekdayValue,"wednesday") ? "selected" : null)">Wednesday</option>
                                <option value="thursday"  selected="@(Sel(monthlyWeekdayValue,"thursday")  ? "selected" : null)">Thursday</option>
                                <option value="friday"    selected="@(Sel(monthlyWeekdayValue,"friday")    ? "selected" : null)">Friday</option>
                                <option value="saturday"  selected="@(Sel(monthlyWeekdayValue,"saturday")  ? "selected" : null)">Saturday</option>
                            </select>
                        </div>
                        <input type="hidden" id="MonthlyPattern" name="MonthlyPattern" value="@Model.MonthlyPattern" />
                        <p class="text-xs text-slate-500 mt-1.5">Example: "First Monday" or "Last Friday"</p>
                    </div>
                    <div id="monthlyFirst4DaysPattern" class="@(!isFirst4Days ? "hidden" : "")">
                        <div class="p-3 rounded-lg mt-2" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);">
                            <div class="flex items-center gap-2">
                                <i class="fas fa-info-circle text-blue-400"></i>
                                <span class="text-sm text-blue-400">This task will appear on days 1, 2, 3, and 4 of every month.</span>
                            </div>
                        </div>
                        <input type="hidden" id="MonthlyPatternFirst4Days" name="MonthlyPattern" value="first4days" />
                    </div>
                </div>


                <div id="multiDayTaskSection" class="form-section @(!isMultiDay ? "hidden" : "")">
                    <h4 class="section-heading"><i class="fas fa-calendar-range text-emerald-400 mr-2"></i>Multi-Day Settings</h4>
                    <div class="p-4 rounded-lg mb-4" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);">
                        <div class="flex items-center gap-2 mb-1"><i class="fas fa-info-circle text-blue-400"></i><span class="text-sm font-semibold text-blue-300">Multi-Day Task Information</span></div>
                        <p class="text-xs text-blue-400">This task appears from the start date until the end date. Complete it ONCE by the deadline.</p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
                        <div>
                            <label class="field-label">Start Date</label>
                            <input type="date" id="multiDayStartDate" class="dark-input" value="@multiDayStartValue" onchange="updateCombinedPreview();" />
                        </div>
                        <div>
                            <label class="field-label">Duration (Days)</label>
                            <input type="number" id="multiDayDuration" class="dark-input" placeholder="e.g., 3" min="1" value="@Model.DurationDays" oninput="updateCombinedPreview();" />
                        </div>
                    </div>
                    <div class="p-3 rounded-lg" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
                        <div class="text-sm text-slate-400"><span class="font-medium text-slate-300">Task Period:</span> <span id="taskPeriodPreview" class="ml-1 text-indigo-400">Select dates to see preview</span></div>
                        <div class="text-sm text-slate-400 mt-1"><span class="font-medium text-slate-300">Final Deadline:</span> <span id="finalDeadlinePreview" class="ml-1 text-amber-400">Will be calculated</span></div>
                    </div>
                </div>


                <div id="oneTimeTaskSection" class="form-section @(!isOneTime ? "hidden" : "")">
                    <h4 class="section-heading"><i class="fas fa-hourglass-start text-red-400 mr-2"></i>One-Time Schedule</h4>
                    <div>
                        <label class="field-label">Task Date</label>
                        <input type="date" id="oneTimeDate" class="dark-input" value="@oneTimeDateValue" onchange="updateCombinedPreview();" />
                    </div>
                </div>


                <div id="combinedPreview" class="p-4 rounded-xl hidden" style="background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2);">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-chart-line text-indigo-400 mt-0.5"></i>
                        <div class="flex-1">
                            <span class="text-sm font-semibold text-indigo-300">ðŸ“‹ Task Schedule Preview</span>
                            <div id="combinedPreviewContent" class="text-sm text-indigo-400 mt-1">Select options to see preview</div>
                        </div>
                    </div>
                </div>


                <div class="form-section">
                    <h4 class="section-heading"><i class="fas fa-hourglass-half text-cyan-400 mr-2"></i>Deadline Configuration</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Deadline" class="field-label">Deadline Time <span class="text-red-400">*</span></label>
                            <input asp-for="Deadline" type="time" id="deadlineTime" class="dark-input" value="@deadlineTimeValue" onchange="updateCombinedPreview();" />
                        </div>
                        <div>
                            <label class="field-label">Deadline Type</label>
                            <div class="flex gap-4 mt-2">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="deadlineType" value="same-day" class="w-4 h-4 accent-indigo-500" @(isSameDayChecked ? "checked" : "") onchange="updateCombinedPreview(); syncIsSameDay();" />
                                    <span class="text-sm text-slate-300">Same Day</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="deadlineType" value="next-day" class="w-4 h-4 accent-indigo-500" @(!isSameDayChecked ? "checked" : "") onchange="updateCombinedPreview(); syncIsSameDay();" />
                                    <span class="text-sm text-slate-300">Next Day</span>
                                </label>
                            </div>
                            <input type="hidden" asp-for="IsSameDay" id="IsSameDayHidden" />
                        </div>
                    </div>
                </div>


                <div class="form-section">
                    <h4 class="section-heading"><i class="fas fa-sort-numeric-up text-slate-400 mr-2"></i>Organization</h4>
                    <div>
                        <label asp-for="DisplayOrder" class="field-label">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" min="0" class="dark-input" />
                        <p class="text-xs text-slate-500 mt-1.5">Order tasks appear on the dashboard</p>
                    </div>
                </div>


                <div class="form-section flex items-center justify-between">
                    <div>
                        <span class="text-sm font-semibold text-white">Active Task</span>
                        <p class="text-xs text-slate-500 mt-0.5">Inactive tasks won't appear in daily boards</p>
                    </div>
                    <div class="relative">
                        <input type="checkbox" asp-for="IsActive" id="IsActive" class="sr-only" onchange="updateToggleDisplay('IsActive');" />
                        <div class="w-14 h-8 rounded-full transition cursor-pointer toggle-indicator @(Model.IsActive ? "bg-emerald-500" : "bg-white/10")" onclick="toggleCheckbox('IsActive')">
                            <div class="absolute w-6 h-6 bg-white rounded-full shadow-md transition" style="top:0.25rem; left:0.25rem; transform: @(Model.IsActive ? "translateX(24px)" : "translateX(0px)");"></div>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-4" style="border-top: 1px solid rgba(255,255,255,0.06);">
                    <a href="@Url.Action("Index")" class="px-5 py-2.5 rounded-xl text-sm font-medium text-slate-300 border border-white/10 hover:bg-white/5 transition">
                        Cancel
                    </a>
                    <button type="submit" class="btn-primary">
                        <i class="fas fa-save"></i>Update Task
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
<style>
    .form-section {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 0.875rem;
        padding: 1.25rem;
    }
    .section-heading {
        font-size: 0.8125rem;
        font-weight: 700;
        color: #e2e8f0;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .field-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 0.375rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .type-card {
        padding: 1rem;
        border: 2px solid rgba(255,255,255,0.08);
        border-radius: 0.875rem;
        background: rgba(255,255,255,0.03);
        transition: all 0.2s;
        height: 100%;
    }
    .type-card:hover { border-color: rgba(99,102,241,0.3); background: rgba(255,255,255,0.05); }
    .type-card-active { border-color: #6366f1 !important; background: rgba(99,102,241,0.1) !important; }
    .type-badge {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 9999px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .weekly-day-checkbox { cursor: pointer; }
    .weekly-day-checkbox:hover { transform: scale(1.15); }
    .toggle-indicator { transition: background-color 0.2s ease; }
    .toggle-indicator .absolute { transition: transform 0.2s ease; }
    input:disabled, select:disabled { background: rgba(255,255,255,0.02) !important; cursor: not-allowed; opacity: 0.35; }
    select.dark-input option { background: #1a1a2e; color: #e2e8f0; }
    .dark-input[type="date"]::-webkit-calendar-picker-indicator,
    .dark-input[type="time"]::-webkit-calendar-picker-indicator { filter: invert(0.7); cursor: pointer; }
</style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            syncIsSameDay();
            updateToggleDisplay('IsActive');
            toggleTaskType();
            toggleMonthlyPattern();
            toggleTaskEndDate();
            toggleAvailableEndDate();
            toggleMaxOccurrences();
            setupCombinedPreviewListeners();
            setTimeout(updateCombinedPreview, 100);
        });

        function toggleCheckbox(id) {
            var cb = document.getElementById(id);
            cb.checked = !cb.checked;
            updateToggleDisplay(id);
        }

        function updateToggleDisplay(id) {
            var cb = document.getElementById(id);
            var tog = cb.nextElementSibling;
            var circle = tog.querySelector('.absolute');
            if (cb.checked) {
                tog.classList.remove('bg-white/10');
                tog.classList.add('bg-emerald-500');
                circle.style.transform = 'translateX(24px)';
            } else {
                tog.classList.remove('bg-emerald-500');
                tog.classList.add('bg-white/10');
                circle.style.transform = 'translateX(0px)';
            }
        }

        function syncIsSameDay() {
            var dt = document.querySelector('input[name="deadlineType"]:checked');
            if (dt) { var h = document.getElementById('IsSameDayHidden'); if (h) h.value = (dt.value === 'same-day'); }
        }

        function toggleTaskEndDate() {
            var noEnd = $('#noTaskEndDate').is(':checked');
            $('#endDate').prop('disabled', noEnd);
            if (noEnd) $('#endDate').val('');
            $('#foreverTaskIndicator').toggleClass('hidden', !noEnd);
        }

        function toggleAvailableEndDate() {
            var noEnd = $('#noAvailableEndDate').is(':checked');
            $('#availableTo').prop('disabled', noEnd);
            if (noEnd) $('#availableTo').val('');
            $('#foreverAvailableIndicator').toggleClass('hidden', !noEnd);
        }

        function toggleMaxOccurrences() {
            var unlimited = $('#unlimitedOccurrences').is(':checked');
            $('#maxOccurrences').prop('disabled', unlimited);
            if (unlimited) $('#maxOccurrences').val('');
        }

        function toggleTaskType() {
            var type = $('input[name="ExecutionType"]:checked').val();
            $('#weeklyTaskSection, #monthlyTaskSection, #multiDayTaskSection, #oneTimeTaskSection').addClass('hidden');
            if (type === 'RecurringWeekly') $('#weeklyTaskSection').removeClass('hidden');
            if (type === 'RecurringMonthly') { $('#monthlyTaskSection').removeClass('hidden'); toggleMonthlyPattern(); }
            if (type === 'MultiDay') { $('#multiDayTaskSection').removeClass('hidden'); setupMultiDayPreview(); }
            if (type === 'OneTime') $('#oneTimeTaskSection').removeClass('hidden');
            updateCombinedPreview();
        }

        function toggleMonthlyPattern() {
            var type = $('input[name="MonthlyPatternType"]:checked').val();
            $('#monthlyDayPattern, #monthlyWeekdayPattern, #monthlyFirst4DaysPattern').addClass('hidden');
            if (type === 'day') { $('#monthlyDayPattern').removeClass('hidden'); $('#MonthlyPattern').val($('select[name="MonthlyDay"]').val()); }
            else if (type === 'weekday') { $('#monthlyWeekdayPattern').removeClass('hidden'); updateMonthlyPattern(); }
            else if (type === 'first4days') { $('#monthlyFirst4DaysPattern').removeClass('hidden'); $('#MonthlyPattern').val('first4days'); }
            updateCombinedPreview();
        }

        function updateMonthlyPattern() {
            $('#MonthlyPattern').val($('select[name="MonthlyOrdinal"]').val() + '-' + $('select[name="MonthlyWeekday"]').val());
        }

        function setupMultiDayPreview() {
            function update() {
                var s = $('#multiDayStartDate').val(), dur = parseInt($('#multiDayDuration').val()) || 0, dt = $('#deadlineTime').val() || '21:00';
                if (s && dur > 0) {
                    var start = new Date(s), end = new Date(start);
                    end.setDate(end.getDate() + dur - 1);
                    $('#taskPeriodPreview').text(start.toLocaleDateString() + ' â†’ ' + end.toLocaleDateString() + ' (' + dur + ' days)');
                    var sameDay = $('input[name="deadlineType"]:checked').val() === 'same-day';
                    var tObj = new Date('2000-01-01T' + dt);
                    var target = new Date(end);
                    if (!sameDay) target.setDate(target.getDate() + 1);
                    target.setHours(tObj.getHours(), tObj.getMinutes());
                    $('#finalDeadlinePreview').text(target.toLocaleDateString() + ' at ' + dt + (!sameDay ? ' (next day)' : ''));
                }
            }
            $('#multiDayStartDate, #multiDayDuration, #deadlineTime, input[name="deadlineType"]').off('change input.mdp').on('change input.mdp', update);
            update();
        }

        function updateCombinedPreview() {
            var s = $('#startDate').val();
            if (!s) { $('#combinedPreview').addClass('hidden'); return; }
            $('#combinedPreview').removeClass('hidden');
            var type = $('input[name="ExecutionType"]:checked').val();
            var noEnd = $('#noTaskEndDate').is(':checked'), endDate = $('#endDate').val();
            var sched = 'ðŸ“… From ' + new Date(s).toLocaleDateString();
            if (noEnd) sched += ' â†’ FOREVER';
            else if (endDate) sched += ' â†’ ' + new Date(endDate).toLocaleDateString();
            $('#combinedPreviewContent').text(getTaskTypeDescription(type) + ' â€¢ ' + sched);
        }

        function getTaskTypeDescription(type) {
            switch(type) {
                case 'RecurringDaily': return 'ðŸ“… Daily Task';
                case 'RecurringWeekly':
                    var days = []; $('input[name="WeeklyDays"]:checked').each(function() { days.push(['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][parseInt($(this).val())]); });
                    return 'ðŸ“† Weekly on ' + (days.length ? days.join(', ') : 'no days');
                case 'RecurringMonthly':
                    var pt = $('input[name="MonthlyPatternType"]:checked').val();
                    if (pt === 'day') return 'ðŸ“… Monthly on day ' + $('select[name="MonthlyDay"]').val();
                    if (pt === 'weekday') return 'ðŸ“… Monthly on ' + $('select[name="MonthlyOrdinal"]').val() + ' ' + $('select[name="MonthlyWeekday"]').val();
                    return 'ðŸ“… Monthly on first 4 days';
                case 'MultiDay': var dur = $('#multiDayDuration').val(); return dur ? 'â±ï¸ Multi-Day (' + dur + ' days)' : 'â±ï¸ Multi-Day Task';
                case 'OneTime': return 'ðŸŽ¯ One-Time Task';
                default: return 'ðŸ“‹ Task';
            }
        }

        function setupCombinedPreviewListeners() {
            $('#startDate, #endDate, #noTaskEndDate, #availableFrom, #availableTo, #noAvailableEndDate, #unlimitedOccurrences, #maxOccurrences, #deadlineTime, input[name="deadlineType"], input[name="ExecutionType"], input[name="WeeklyDays"], select[name="MonthlyDay"], select[name="MonthlyOrdinal"], select[name="MonthlyWeekday"], input[name="MonthlyPatternType"], #multiDayDuration, #multiDayStartDate, #oneTimeDate')
                .on('change input', updateCombinedPreview);
        }
    </script>
}
