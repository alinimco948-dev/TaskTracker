@model IEnumerable<TaskTracker.Models.ViewModels.TaskListViewModel>
@{
    ViewData["Title"] = "Tasks";
    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }
    var branchesList = ViewBag.Branches as IEnumerable<TaskTracker.Models.ViewModels.BranchListViewModel>;
    var hasBranches = branchesList != null && branchesList.Any();
}

<input type="hidden" id="requestVerificationToken" value="@token" />

<div class="space-y-6 animate-fade-up">

    <!-- Header -->
    <div class="flex flex-wrap justify-between items-start gap-4">
        <div>
            <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                    <i class="fas fa-tasks text-white text-sm"></i>
                </div>
                Task Management
            </h1>
            <p class="text-slate-400 mt-1">Configure tasks and manage their visibility per branch</p>
        </div>
        <a href="@Url.Action("Create")" class="btn-primary">
            <i class="fas fa-plus-circle"></i>Add Task
        </a>
    </div>

    <!-- Tasks Table -->
    <div class="glass-card overflow-hidden">
        <div class="px-5 py-3 flex items-center gap-2 border-b" style="border-color: rgba(255,255,255,0.06);">
            <i class="fas fa-grip-vertical text-slate-600 text-sm"></i>
            <span class="text-xs text-slate-500">Drag rows to reorder tasks</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full dark-table" id="tasksTable">
                <thead>
                    <tr>
                        <th class="w-10"></th>
                        <th>Task Name</th>
                        <th>Deadline</th>
                        <th>Type</th>
                        <th class="text-center">Display Order</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody id="sortable">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var task in Model.OrderBy(t => t.DisplayOrder))
                        {
                            <tr class="cursor-move" data-id="@task.Id">
                                <td class="text-center text-slate-600">
                                    <i class="fas fa-grip-vertical"></i>
                                </td>
                                <td class="font-semibold text-white">@task.Name</td>
                                <td class="font-mono text-cyan-400">@DateTime.Today.Add(task.Deadline).ToString("h:mm tt")</td>
                                <td>
                                    @if (task.Type == "Same Day")
                                    {
                                        <span class="stat-badge" style="background: rgba(99,102,241,0.15); color: #a5b4fc;">Same Day</span>
                                    }
                                    else
                                    {
                                        <span class="stat-badge" style="background: rgba(124,58,237,0.15); color: #c4b5fd;">Next Day</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="stat-badge" style="background: rgba(255,255,255,0.06); color: #94a3b8;">@task.DisplayOrder</span>
                                </td>
                                <td class="text-center">
                                    @if (task.IsActive)
                                    {
                                        <span class="stat-badge" style="background: rgba(16,185,129,0.15); color: #6ee7b7;">
                                            <i class="fas fa-circle text-[8px] text-emerald-400"></i>Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="stat-badge" style="background: rgba(239,68,68,0.15); color: #fca5a5;">
                                            <i class="fas fa-circle text-[8px] text-red-400"></i>Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="flex items-center justify-center gap-1">
                                        <a href="@Url.Action("Edit", new { id = task.Id })"
                                           class="w-8 h-8 rounded-lg flex items-center justify-center text-emerald-400 hover:bg-emerald-400/10 transition" title="Edit">
                                            <i class="fas fa-edit text-sm"></i>
                                        </a>
                                        <button type="button" onclick="deleteTask(@task.Id, '@task.Name')"
                                                class="w-8 h-8 rounded-lg flex items-center justify-center text-red-400 hover:bg-red-400/10 transition" title="Delete">
                                            <i class="fas fa-trash text-sm"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="py-16 text-center">
                                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                                     style="background: rgba(245,158,11,0.1);">
                                    <i class="fas fa-tasks text-amber-400 text-2xl"></i>
                                </div>
                                <p class="text-slate-300 font-semibold mb-1">No tasks found</p>
                                <a href="@Url.Action("Create")" class="text-indigo-400 hover:underline text-sm">Create your first task</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Branch Task Visibility -->
    <div class="glass-card overflow-hidden">
        <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06);">
            <h3 class="font-bold text-white text-base flex items-center gap-2">
                <i class="fas fa-eye text-indigo-400"></i>Branch Task Visibility
            </h3>
            <p class="text-sm text-slate-400 mt-0.5">Configure which tasks are visible for each branch.
                <span class="text-xs text-slate-500">(Checked = Visible, Unchecked = Hidden)</span></p>
        </div>

        @if (hasBranches && Model != null && Model.Any())
        {
            <div class="p-5">
                <div class="overflow-x-auto">
                    <table class="w-full dark-table">
                        <thead>
                            <tr>
                                <th>Branch</th>
                                @foreach (var task in Model.Where(t => t.IsActive).OrderBy(t => t.DisplayOrder))
                                {
                                    <th class="text-center">@task.Name</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var branch in branchesList ?? Enumerable.Empty<TaskTracker.Models.ViewModels.BranchListViewModel>())
                            {
                                <tr>
                                    <td class="font-semibold text-white">@branch.Name</td>
                                    @foreach (var task in Model.Where(t => t.IsActive).OrderBy(t => t.DisplayOrder))
                                    {
                                        var isVisible = !( branch.HiddenTasks != null && branch.HiddenTasks.Contains(task.Name));
                                        <td class="text-center">
                                            <input type="checkbox"
                                                   class="task-visibility w-5 h-5 accent-indigo-500 cursor-pointer"
                                                   data-branch-id="@branch.Id"
                                                   data-task-name="@task.Name"
                                                   @(isVisible ? "checked" : "") />
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="mt-5 flex justify-end">
                    <button type="button" onclick="saveTaskVisibility()" class="btn-primary">
                        <i class="fas fa-save"></i>Save Visibility Settings
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="p-12 text-center">
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4"
                     style="background: rgba(255,255,255,0.04);">
                    <i class="fas fa-info-circle text-slate-500 text-2xl"></i>
                </div>
                <p class="text-slate-400">No branches or tasks available to configure visibility.</p>
                @if (!hasBranches)
                {
                    <a href="@Url.Action("Create", "Branch")" class="text-indigo-400 hover:underline text-sm mt-2 inline-block">Create a branch first</a>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
        $(document).ready(function() {
            if (document.getElementById('sortable')) {
                new Sortable(document.getElementById('sortable'), {
                    animation: 150,
                    handle: '.fa-grip-vertical',
                    ghostClass: 'opacity-40',
                    onEnd: function() { updateTaskOrder(); }
                });
            }
        });

        function updateTaskOrder() {
            const taskIds = [];
            $('#sortable tr').each(function() { taskIds.push($(this).data('id')); });
            const token = $('#requestVerificationToken').val();
            $.ajax({
                url: '@Url.Action("Reorder", "Task")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(taskIds),
                headers: { 'RequestVerificationToken': token },
                success: function(response) {
                    if (window.TaskTracker) TaskTracker.showNotification(response.success ? 'Task order updated' : 'Error updating order', response.success ? 'success' : 'error');
                }
            });
        }

        function deleteTask(id, name) {
            if (confirm(`Are you sure you want to delete "${name}"?`)) {
                const token = $('#requestVerificationToken').val();
                $.ajax({
                    url: '@Url.Action("Delete", "Task")/' + id,
                    type: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    success: function(response) {
                        if (window.TaskTracker) TaskTracker.showNotification(response.message, response.success ? 'success' : 'error');
                        if (response.success) setTimeout(() => location.reload(), 1000);
                    }
                });
            }
        }

        function saveTaskVisibility() {
            const updates = [];
            $('.task-visibility').each(function() {
                updates.push({ branchId: $(this).data('branch-id'), taskName: $(this).data('task-name'), visible: $(this).is(':checked') });
            });
            if (updates.length === 0) { if (window.TaskTracker) TaskTracker.showNotification('No changes to save', 'warning'); return; }

            const saveBtn = $('button[onclick="saveTaskVisibility()"]');
            const origHtml = saveBtn.html();
            saveBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i>Saving...');
            const token = $('#requestVerificationToken').val();

            $.ajax({
                url: '@Url.Action("SaveVisibility", "Branch")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(updates),
                headers: { 'RequestVerificationToken': token },
                success: function(response) {
                    if (window.TaskTracker) TaskTracker.showNotification(response.success ? 'Visibility settings saved!' : (response.message || 'Error saving visibility'), response.success ? 'success' : 'error');
                    if (response.success) setTimeout(() => location.reload(), 1500);
                    else saveBtn.prop('disabled', false).html(origHtml);
                },
                error: function(xhr) {
                    let msg = 'Error saving visibility settings';
                    try { msg = JSON.parse(xhr.responseText).message || msg; } catch(e) {}
                    if (window.TaskTracker) TaskTracker.showNotification(msg, 'error');
                    saveBtn.prop('disabled', false).html(origHtml);
                }
            });
        }
    </script>
}