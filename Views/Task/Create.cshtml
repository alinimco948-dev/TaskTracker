@model TaskTracker.Models.ViewModels.TaskItemViewModel
@{
    ViewData["Title"] = "Create Task";
    var existingTasks = ViewBag.ExistingTasks as IEnumerable<TaskTracker.Models.ViewModels.TaskListViewModel> ?? new List<TaskTracker.Models.ViewModels.TaskListViewModel>();
}

<div class="animate-fade-up space-y-6">


    <div class="glass-card overflow-hidden">
        <div class="px-6 py-5 bg-gradient-to-r from-indigo-500/10 via-violet-500/10 to-transparent flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: linear-gradient(135deg, #6366f1, #7c3aed); box-shadow: 0 4px 15px rgba(99,102,241,0.4);">
                <i class="fas fa-plus-circle text-white text-lg"></i>
            </div>
            <div>
                <div class="flex items-center gap-2 mb-0.5">
                    <a href="@Url.Action("Index")" class="text-xs text-slate-500 hover:text-indigo-400 transition">Tasks</a>
                    <i class="fas fa-chevron-right text-slate-600 text-[10px]"></i>
                    <span class="text-xs text-slate-400 font-medium">Create</span>
                </div>
                <h1 class="text-2xl font-black text-white tracking-tight">Create New Task</h1>
                <p class="text-slate-400 text-sm mt-0.5">Configure task with full scheduling options</p>
            </div>
        </div>
    </div>

    <div class="max-w-4xl mx-auto">
        <div class="glass-card overflow-hidden">
            <div class="px-6 py-4 flex items-center gap-3" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
                <i class="fas fa-calendar-alt text-indigo-400"></i>
                <h3 class="text-base font-semibold text-white">Task Configuration</h3>
            </div>

            <form asp-action="Create" method="post" class="p-6 space-y-5" id="taskForm">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert-error rounded-xl p-4 text-sm"></div>


                <div class="form-section">
                    <h4 class="section-heading">
                        <i class="fas fa-info-circle text-indigo-400 mr-2"></i>Basic Information
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Name" class="field-label">Task Name <span class="text-red-400">*</span></label>
                            <input asp-for="Name" class="dark-input" placeholder="e.g., Daily Report" />
                            <span asp-validation-for="Name" class="text-xs text-red-400 mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Description" class="field-label">Description <span class="text-slate-600">(Optional)</span></label>
                            <textarea asp-for="Description" rows="1" class="dark-input" placeholder="Brief description..."></textarea>
                        </div>
                    </div>
                </div>


                <div class="form-section">
                    <h4 class="section-heading">
                        <i class="fas fa-tasks text-violet-400 mr-2"></i>Task Type
                    </h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
                        <label class="cursor-pointer group">
                            <input type="radio" name="ExecutionType" value="RecurringDaily" class="sr-only peer" checked onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2">
                                    <i class="fas fa-calendar-day text-xl text-blue-400"></i>
                                    <span class="type-badge bg-blue-500/20 text-blue-400">Daily</span>
                                </div>
                                <h5 class="font-semibold text-white text-sm">Recurring Daily</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete each day</p>
                            </div>
                        </label>
                        <label class="cursor-pointer group">
                            <input type="radio" name="ExecutionType" value="MultiDay" class="sr-only peer" onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2">
                                    <i class="fas fa-calendar-range text-xl text-emerald-400"></i>
                                    <span class="type-badge bg-emerald-500/20 text-emerald-400">Multi-Day</span>
                                </div>
                                <h5 class="font-semibold text-white text-sm">Multi-Day Task</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete once in range</p>
                            </div>
                        </label>
                        <label class="cursor-pointer group">
                            <input type="radio" name="ExecutionType" value="RecurringWeekly" class="sr-only peer" onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2">
                                    <i class="fas fa-calendar-week text-xl text-violet-400"></i>
                                    <span class="type-badge bg-violet-500/20 text-violet-400">Weekly</span>
                                </div>
                                <h5 class="font-semibold text-white text-sm">Recurring Weekly</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete each week</p>
                            </div>
                        </label>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <label class="cursor-pointer group">
                            <input type="radio" name="ExecutionType" value="RecurringMonthly" class="sr-only peer" onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2">
                                    <i class="fas fa-calendar-alt text-xl text-amber-400"></i>
                                    <span class="type-badge bg-amber-500/20 text-amber-400">Monthly</span>
                                </div>
                                <h5 class="font-semibold text-white text-sm">Recurring Monthly</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete each month</p>
                            </div>
                        </label>
                        <label class="cursor-pointer group">
                            <input type="radio" name="ExecutionType" value="OneTime" class="sr-only peer" onchange="toggleTaskType(); updateCombinedPreview();">
                            <div class="type-card peer-checked:type-card-active">
                                <div class="flex items-center justify-between mb-2">
                                    <i class="fas fa-hourglass-start text-xl text-red-400"></i>
                                    <span class="type-badge bg-red-500/20 text-red-400">One-Time</span>
                                </div>
                                <h5 class="font-semibold text-white text-sm">One-Time Task</h5>
                                <p class="text-xs text-slate-500 mt-1">Complete once</p>
                            </div>
                        </label>
                    </div>
                </div>


                <div id="commonScheduleSection" class="form-section">
                    <h4 class="section-heading"><i class="fas fa-calendar-alt text-blue-400 mr-2"></i>Schedule Settings</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="field-label">Task Start Date</label>
                            <input type="date" name="StartDate" id="startDate" class="dark-input" />
                        </div>
                        <div>
                            <label class="field-label">Task End Date</label>
                            <div class="flex items-center gap-2">
                                <input type="date" name="EndDate" id="endDate" class="dark-input flex-1" />
                                <label class="flex items-center cursor-pointer whitespace-nowrap gap-1.5">
                                    <input type="checkbox" id="noTaskEndDate" class="w-4 h-4 accent-indigo-500" onchange="toggleTaskEndDate(); updateCombinedPreview();" />
                                    <span class="text-xs text-slate-400">No End</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="foreverTaskIndicator" class="hidden mb-4 p-3 rounded-lg" style="background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2);">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-infinity text-emerald-400"></i>
                            <span class="text-sm text-emerald-400">This task will repeat forever with no end date.</span>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label class="field-label">Available From</label>
                            <input type="date" name="AvailableFrom" id="availableFrom" class="dark-input" />
                        </div>
                        <div>
                            <label class="field-label">Available To</label>
                            <div class="flex items-center gap-2">
                                <input type="date" name="AvailableTo" id="availableTo" class="dark-input flex-1" />
                                <label class="flex items-center cursor-pointer whitespace-nowrap gap-1.5">
                                    <input type="checkbox" id="noAvailableEndDate" class="w-4 h-4 accent-indigo-500" onchange="toggleAvailableEndDate(); updateCombinedPreview();" />
                                    <span class="text-xs text-slate-400">No End</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="foreverAvailableIndicator" class="hidden mb-4 p-3 rounded-lg" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-infinity text-blue-400"></i>
                            <span class="text-sm text-blue-400">This task is available forever with no end date.</span>
                        </div>
                    </div>
                    <div>
                        <label class="field-label">Max Occurrences</label>
                        <div class="flex items-center gap-2">
                            <input type="number" name="MaxOccurrences" id="maxOccurrences" class="dark-input flex-1" placeholder="Leave empty for unlimited" min="1" />
                            <label class="flex items-center cursor-pointer whitespace-nowrap gap-1.5">
                                <input type="checkbox" id="unlimitedOccurrences" class="w-4 h-4 accent-indigo-500" checked onchange="toggleMaxOccurrences(); updateCombinedPreview();" />
                                <span class="text-xs text-slate-400">Unlimited</span>
                            </label>
                        </div>
                    </div>
                </div>


                <div id="weeklyTaskSection" class="form-section hidden">
                    <h4 class="section-heading"><i class="fas fa-calendar-week text-violet-400 mr-2"></i>Weekly Schedule</h4>
                    <label class="field-label">Repeat On</label>
                    <div class="grid grid-cols-7 gap-2 mt-2">
                        @for (int i = 0; i < 7; i++) {
                            <label class="flex flex-col items-center cursor-pointer">
                                <input type="checkbox" name="WeeklyDays" value="@i" class="weekly-day-checkbox w-5 h-5 accent-indigo-500" onchange="updateCombinedPreview();" />
                                <span class="text-xs text-slate-400 mt-1">@(new[]{"Su","Mo","Tu","We","Th","Fr","Sa"}[i])</span>
                            </label>
                        }
                    </div>
                </div>


                <div id="monthlyTaskSection" class="form-section hidden">
                    <h4 class="section-heading"><i class="fas fa-calendar-alt text-amber-400 mr-2"></i>Monthly Schedule</h4>
                    <div>
                        <label class="field-label mb-2">Monthly Pattern</label>
                        <div class="grid grid-cols-3 gap-2 mb-3">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="MonthlyPatternType" value="day" class="w-4 h-4 accent-indigo-500" checked onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                                <span class="text-sm text-slate-300">Specific Day</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="MonthlyPatternType" value="weekday" class="w-4 h-4 accent-indigo-500" onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                                <span class="text-sm text-slate-300">Nth Weekday</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="MonthlyPatternType" value="first4days" class="w-4 h-4 accent-indigo-500" onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                                <span class="text-sm text-slate-300">First 4 Days</span>
                            </label>
                        </div>
                        <div id="monthlyDayPattern">
                            <select name="MonthlyDay" class="dark-input" onchange="updateCombinedPreview();">
                                @for (int d = 1; d <= 31; d++) { <option value="@d">Day @d</option> }
                            </select>
                            <p class="text-xs text-slate-500 mt-1.5">Task appears on this specific day each month</p>
                        </div>
                        <div id="monthlyWeekdayPattern" class="hidden">
                            <div class="flex gap-2">
                                <select name="MonthlyOrdinal" class="dark-input flex-1" onchange="updateMonthlyPattern(); updateCombinedPreview();">
                                    <option value="first">First</option><option value="second">Second</option>
                                    <option value="third">Third</option><option value="fourth">Fourth</option>
                                    <option value="last">Last</option>
                                </select>
                                <select name="MonthlyWeekday" class="dark-input flex-1" onchange="updateMonthlyPattern(); updateCombinedPreview();">
                                    <option value="sunday">Sunday</option><option value="monday">Monday</option>
                                    <option value="tuesday">Tuesday</option><option value="wednesday">Wednesday</option>
                                    <option value="thursday">Thursday</option><option value="friday">Friday</option>
                                    <option value="saturday">Saturday</option>
                                </select>
                            </div>
                            <input type="hidden" id="MonthlyPattern" name="MonthlyPattern" value="15" />
                            <p class="text-xs text-slate-500 mt-1.5">Example: "First Monday" or "Last Friday"</p>
                        </div>
                        <div id="monthlyFirst4DaysPattern" class="hidden">
                            <div class="p-3 rounded-lg mt-2" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-info-circle text-blue-400"></i>
                                    <span class="text-sm text-blue-400">This task will appear on days 1, 2, 3, and 4 of every month.</span>
                                </div>
                            </div>
                            <input type="hidden" id="MonthlyPatternFirst4Days" name="MonthlyPattern" value="first4days" />
                        </div>
                    </div>
                </div>


                <div id="multiDayTaskSection" class="form-section hidden">
                    <h4 class="section-heading"><i class="fas fa-calendar-range text-emerald-400 mr-2"></i>Multi-Day Settings</h4>
                    <div class="p-4 rounded-lg mb-4" style="background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2);">
                        <div class="flex items-center gap-2 mb-1">
                            <i class="fas fa-info-circle text-blue-400"></i>
                            <span class="text-sm font-semibold text-blue-300">Multi-Day Task Information</span>
                        </div>
                        <p class="text-xs text-blue-400">This task appears from the start date until the end date. Complete it ONCE by the deadline.</p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
                        <div>
                            <label class="field-label">Start Date</label>
                            <input type="date" id="multiDayStartDate" class="dark-input" onchange="updateCombinedPreview();" />
                        </div>
                        <div>
                            <label class="field-label">Duration (Days)</label>
                            <input type="number" id="multiDayDuration" class="dark-input" placeholder="e.g., 3" min="1" oninput="updateCombinedPreview();" />
                        </div>
                    </div>
                    <div class="p-3 rounded-lg" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
                        <div class="text-sm text-slate-400"><span class="font-medium text-slate-300">Task Period:</span> <span id="taskPeriodPreview" class="ml-1 text-indigo-400">Select dates to see preview</span></div>
                        <div class="text-sm text-slate-400 mt-1"><span class="font-medium text-slate-300">Final Deadline:</span> <span id="finalDeadlinePreview" class="ml-1 text-amber-400">Will be calculated</span></div>
                    </div>
                </div>


                <div id="oneTimeTaskSection" class="form-section hidden">
                    <h4 class="section-heading"><i class="fas fa-hourglass-start text-red-400 mr-2"></i>One-Time Schedule</h4>
                    <div>
                        <label class="field-label">Task Date</label>
                        <input type="date" id="oneTimeDate" class="dark-input" onchange="updateCombinedPreview();" />
                    </div>
                </div>


                <div id="combinedPreview" class="p-4 rounded-xl hidden" style="background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2);">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-chart-line text-indigo-400 mt-0.5"></i>
                        <div class="flex-1">
                            <span class="text-sm font-semibold text-indigo-300">ðŸ“‹ Task Schedule Preview</span>
                            <div id="combinedPreviewContent" class="text-sm text-indigo-400 mt-1">Select options to see preview</div>
                        </div>
                    </div>
                </div>


                <div class="form-section">
                    <h4 class="section-heading"><i class="fas fa-hourglass-half text-cyan-400 mr-2"></i>Deadline Configuration</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Deadline" class="field-label">Deadline Time <span class="text-red-400">*</span></label>
                            <input asp-for="Deadline" type="time" id="deadlineTime" class="dark-input" value="@DateTime.Today.AddHours(21).ToString("HH:mm")" onchange="updateCombinedPreview();" />
                        </div>
                        <div>
                            <label class="field-label">Deadline Type</label>
                            <div class="flex gap-4 mt-2">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="deadlineType" value="same-day" class="w-4 h-4 accent-indigo-500" checked onchange="updateCombinedPreview(); syncIsSameDay();" />
                                    <span class="text-sm text-slate-300">Same Day</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="deadlineType" value="next-day" class="w-4 h-4 accent-indigo-500" onchange="updateCombinedPreview(); syncIsSameDay();" />
                                    <span class="text-sm text-slate-300">Next Day</span>
                                </label>
                            </div>
                            <input type="hidden" asp-for="IsSameDay" id="IsSameDayHidden" value="true" />
                        </div>
                    </div>
                </div>


                <div class="form-section">
                    <h4 class="section-heading"><i class="fas fa-sort-numeric-up text-slate-400 mr-2"></i>Organization</h4>
                    <div>
                        <label asp-for="DisplayOrder" class="field-label">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" min="0" class="dark-input" value="0" />
                        <p class="text-xs text-slate-500 mt-1.5">Order tasks appear on the dashboard (0 = auto)</p>
                    </div>
                </div>


                <div class="form-section flex items-center justify-between">
                    <div>
                        <span class="text-sm font-semibold text-white">Active Task</span>
                        <p class="text-xs text-slate-500 mt-0.5">Inactive tasks won't appear in daily boards</p>
                    </div>
                    <div class="relative">
                        <input type="checkbox" asp-for="IsActive" id="IsActive" class="sr-only" onchange="updateToggleDisplay('IsActive');" checked />
                        <div class="w-14 h-8 rounded-full transition cursor-pointer toggle-indicator bg-emerald-500" onclick="toggleCheckbox('IsActive')">
                            <div class="absolute w-6 h-6 bg-white rounded-full shadow-md transform transition" style="top:0.25rem; left:0.25rem; transform: translateX(24px);"></div>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-4" style="border-top: 1px solid rgba(255,255,255,0.06);">
                    <a href="@Url.Action("Index")" class="px-5 py-2.5 rounded-xl text-sm font-medium text-slate-300 border border-white/10 hover:bg-white/5 transition">
                        Cancel
                    </a>
                    <button type="submit" class="btn-primary">
                        <i class="fas fa-plus-circle"></i>Create Task
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
<style>
    .form-section {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 0.875rem;
        padding: 1.25rem;
    }
    .section-heading {
        font-size: 0.8125rem;
        font-weight: 700;
        color: #e2e8f0;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .field-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 0.375rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .type-card {
        padding: 1rem;
        border: 2px solid rgba(255,255,255,0.08);
        border-radius: 0.875rem;
        background: rgba(255,255,255,0.03);
        transition: all 0.2s;
    }
    .type-card:hover { border-color: rgba(99,102,241,0.3); background: rgba(255,255,255,0.05); }
    .type-card-active { border-color: #6366f1 !important; background: rgba(99,102,241,0.1) !important; }
    .type-badge {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 9999px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .weekly-day-checkbox { cursor: pointer; }
    .weekly-day-checkbox:hover { transform: scale(1.15); }
    .toggle-indicator { transition: background-color 0.2s ease; }
    .toggle-indicator .absolute { transition: transform 0.2s ease; }
    input:disabled, select:disabled { background: rgba(255,255,255,0.02) !important; cursor: not-allowed; opacity: 0.35; }
    select.dark-input option { background: #1a1a2e; color: #e2e8f0; }
    .dark-input[type="date"]::-webkit-calendar-picker-indicator,
    .dark-input[type="time"]::-webkit-calendar-picker-indicator { filter: invert(0.7); cursor: pointer; }
</style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            toggleTaskType();
            toggleMonthlyPattern();
            toggleTaskEndDate();
            toggleAvailableEndDate();
            toggleMaxOccurrences();
            setupCombinedPreviewListeners();
            var today = new Date().toISOString().split('T')[0];
            document.getElementById('startDate').value = today;
            document.getElementById('multiDayStartDate').value = today;
            document.getElementById('oneTimeDate').value = today;
            setTimeout(updateCombinedPreview, 100);
        });

        function toggleCheckbox(id) {
            var cb = document.getElementById(id);
            cb.checked = !cb.checked;
            updateToggleDisplay(id);
        }

        function updateToggleDisplay(id) {
            var cb = document.getElementById(id);
            var tog = cb.nextElementSibling;
            var circle = tog.querySelector('.absolute');
            if (cb.checked) {
                tog.classList.remove('bg-white/10');
                tog.classList.add(id === 'IsActive' ? 'bg-emerald-500' : 'bg-indigo-500');
                circle.style.transform = 'translateX(24px)';
            } else {
                tog.classList.remove('bg-emerald-500', 'bg-indigo-500');
                tog.classList.add('bg-white/10');
                circle.style.transform = 'translateX(0px)';
            }
        }

        function syncIsSameDay() {
            var dt = document.querySelector('input[name="deadlineType"]:checked');
            if (dt) document.getElementById('IsSameDayHidden').value = (dt.value === 'same-day');
        }

        function toggleTaskEndDate() {
            var noEnd = document.getElementById('noTaskEndDate').checked;
            var endIn = document.getElementById('endDate');
            endIn.disabled = noEnd;
            if (noEnd) endIn.value = '';
            document.getElementById('foreverTaskIndicator').classList.toggle('hidden', !noEnd);
        }

        function toggleAvailableEndDate() {
            var noEnd = document.getElementById('noAvailableEndDate').checked;
            var endIn = document.getElementById('availableTo');
            endIn.disabled = noEnd;
            if (noEnd) endIn.value = '';
            document.getElementById('foreverAvailableIndicator').classList.toggle('hidden', !noEnd);
        }

        function toggleMaxOccurrences() {
            var unlimited = document.getElementById('unlimitedOccurrences').checked;
            var maxIn = document.getElementById('maxOccurrences');
            maxIn.disabled = unlimited;
            if (unlimited) maxIn.value = '';
        }

        function toggleTaskType() {
            var type = document.querySelector('input[name="ExecutionType"]:checked').value;
            ['weeklyTaskSection','monthlyTaskSection','multiDayTaskSection','oneTimeTaskSection'].forEach(function(id) {
                document.getElementById(id).classList.add('hidden');
            });
            if (type === 'RecurringWeekly') document.getElementById('weeklyTaskSection').classList.remove('hidden');
            if (type === 'RecurringMonthly') document.getElementById('monthlyTaskSection').classList.remove('hidden');
            if (type === 'MultiDay') { document.getElementById('multiDayTaskSection').classList.remove('hidden'); setupMultiDayPreview(); }
            if (type === 'OneTime') document.getElementById('oneTimeTaskSection').classList.remove('hidden');
            updateCombinedPreview();
        }

        function toggleMonthlyPattern() {
            var type = document.querySelector('input[name="MonthlyPatternType"]:checked').value;
            var mp = document.getElementById('MonthlyPattern');
            ['monthlyDayPattern','monthlyWeekdayPattern','monthlyFirst4DaysPattern'].forEach(function(id) {
                var el = document.getElementById(id); if (el) el.classList.add('hidden');
            });
            if (type === 'day') {
                document.getElementById('monthlyDayPattern').classList.remove('hidden');
                if (mp) mp.value = document.querySelector('select[name="MonthlyDay"]').value;
            } else if (type === 'weekday') {
                document.getElementById('monthlyWeekdayPattern').classList.remove('hidden');
                updateMonthlyPattern();
            } else if (type === 'first4days') {
                var f4 = document.getElementById('monthlyFirst4DaysPattern');
                if (f4) f4.classList.remove('hidden');
                if (mp) mp.value = 'first4days';
            }
            updateCombinedPreview();
        }

        function updateMonthlyPattern() {
            var ordinal = document.querySelector('select[name="MonthlyOrdinal"]').value;
            var weekday = document.querySelector('select[name="MonthlyWeekday"]').value;
            var mp = document.getElementById('MonthlyPattern');
            if (mp && ordinal && weekday) mp.value = ordinal + '-' + weekday;
        }

        function setupMultiDayPreview() {
            function update() {
                var startDate = document.getElementById('multiDayStartDate').value;
                var duration = parseInt(document.getElementById('multiDayDuration').value) || 0;
                var deadlineTime = document.getElementById('deadlineTime').value || '21:00';
                if (startDate && duration > 0) {
                    var start = new Date(startDate);
                    var end = new Date(start);
                    end.setDate(end.getDate() + duration - 1);
                    document.getElementById('taskPeriodPreview').textContent =
                        start.toLocaleDateString() + ' â†’ ' + end.toLocaleDateString() + ' (' + duration + ' days)';
                    var isSameDay = document.querySelector('input[name="deadlineType"]:checked').value === 'same-day';
                    var tObj = new Date('2000-01-01T' + deadlineTime);
                    var target = isSameDay ? new Date(end) : new Date(end);
                    if (!isSameDay) target.setDate(target.getDate() + 1);
                    target.setHours(tObj.getHours(), tObj.getMinutes());
                    document.getElementById('finalDeadlinePreview').textContent =
                        target.toLocaleDateString() + ' at ' + deadlineTime + (!isSameDay ? ' (next day)' : '');
                }
            }
            document.getElementById('multiDayStartDate').addEventListener('change', update);
            document.getElementById('multiDayDuration').addEventListener('input', update);
            document.getElementById('deadlineTime').addEventListener('change', update);
            document.querySelectorAll('input[name="deadlineType"]').forEach(function(r) { r.addEventListener('change', update); });
            update();
        }

        function updateCombinedPreview() {
            var startDate = document.getElementById('startDate').value;
            var previewDiv = document.getElementById('combinedPreview');
            if (!startDate) { previewDiv.classList.add('hidden'); return; }
            previewDiv.classList.remove('hidden');
            var type = document.querySelector('input[name="ExecutionType"]:checked').value;
            var noEnd = document.getElementById('noTaskEndDate').checked;
            var endDate = document.getElementById('endDate').value;
            var schedText = 'ðŸ“… From ' + new Date(startDate).toLocaleDateString();
            if (noEnd) schedText += ' â†’ FOREVER';
            else if (endDate) schedText += ' â†’ ' + new Date(endDate).toLocaleDateString();
            document.getElementById('combinedPreviewContent').textContent = getTaskTypeDescription(type) + ' â€¢ ' + schedText;
        }

        function getTaskTypeDescription(type) {
            switch(type) {
                case 'RecurringDaily': return 'ðŸ“… Daily Task';
                case 'RecurringWeekly':
                    var days = [];
                    document.querySelectorAll('input[name="WeeklyDays"]:checked').forEach(function(cb) {
                        days.push(['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][parseInt(cb.value)]);
                    });
                    return 'ðŸ“† Weekly on ' + (days.length ? days.join(', ') : 'no days');
                case 'RecurringMonthly':
                    var pt = document.querySelector('input[name="MonthlyPatternType"]:checked').value;
                    if (pt === 'day') return 'ðŸ“… Monthly on day ' + document.querySelector('select[name="MonthlyDay"]').value;
                    if (pt === 'weekday') return 'ðŸ“… Monthly on ' + document.querySelector('select[name="MonthlyOrdinal"]').value + ' ' + document.querySelector('select[name="MonthlyWeekday"]').value;
                    return 'ðŸ“… Monthly on first 4 days';
                case 'MultiDay':
                    var dur = document.getElementById('multiDayDuration').value;
                    return dur ? 'â±ï¸ Multi-Day (' + dur + ' days)' : 'â±ï¸ Multi-Day Task';
                case 'OneTime': return 'ðŸŽ¯ One-Time Task';
                default: return 'ðŸ“‹ Task';
            }
        }

        function setupCombinedPreviewListeners() {
            var ids = ['startDate','endDate','noTaskEndDate','availableFrom','availableTo','noAvailableEndDate','unlimitedOccurrences','maxOccurrences','deadlineTime','multiDayDuration','multiDayStartDate','oneTimeDate'];
            ids.forEach(function(id) { var el = document.getElementById(id); if (el) el.addEventListener('change', updateCombinedPreview); el && el.addEventListener('input', updateCombinedPreview); });
            document.querySelectorAll('input[name="ExecutionType"], input[name="WeeklyDays"], input[name="deadlineType"], input[name="MonthlyPatternType"]').forEach(function(el) { el.addEventListener('change', updateCombinedPreview); });
        }

        document.querySelectorAll('input[name="MonthlyPatternType"]').forEach(function(r) { r.addEventListener('change', toggleMonthlyPattern); });
        var monthlyDay = document.querySelector('select[name="MonthlyDay"]');
        if (monthlyDay) monthlyDay.addEventListener('change', function() { var mp = document.getElementById('MonthlyPattern'); if (mp) mp.value = this.value; });
        var ordinal = document.querySelector('select[name="MonthlyOrdinal"]');
        var weekday = document.querySelector('select[name="MonthlyWeekday"]');
        if (ordinal) ordinal.addEventListener('change', updateMonthlyPattern);
        if (weekday) weekday.addEventListener('change', updateMonthlyPattern);
    </script>
}
