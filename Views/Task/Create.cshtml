@model TaskTracker.Models.ViewModels.TaskItemViewModel
@{
    ViewData["Title"] = "Create Task";
    
    // Get existing tasks for dependencies dropdown
    var existingTasks = ViewBag.ExistingTasks as IEnumerable<TaskTracker.Models.ViewModels.TaskListViewModel> ?? new List<TaskTracker.Models.ViewModels.TaskListViewModel>();
}

<!-- Page Header -->
<div class="mb-8">
    <div class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-600 rounded-2xl shadow-xl p-6 text-white">
        <div class="flex items-center space-x-4">
            <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur-md flex items-center justify-center">
                <i class="fas fa-plus-circle text-3xl"></i>
            </div>
            <div>
                <h1 class="text-3xl font-bold">Create New Task</h1>
                <p class="text-indigo-100 mt-1">Configure task with full scheduling options</p>
            </div>
        </div>
    </div>
</div>

<!-- Main Form Card -->
<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-white">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                <i class="fas fa-calendar-alt text-indigo-600 mr-2"></i>
                Task Configuration
            </h3>
        </div>

        <form asp-action="Create" method="post" class="p-6" id="taskForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 text-red-700 rounded-xl text-sm border border-red-200"></div>

            <!-- Task Basic Information -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-info-circle text-indigo-500 mr-2"></i>
                    Basic Information
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                            Task Name <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                               placeholder="e.g., Daily Report, Monthly Project" />
                        <span asp-validation-for="Name" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    
                    <div>
                        <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Description (Optional)</label>
                        <textarea asp-for="Description" rows="1" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                                  placeholder="Brief description of the task..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Task Type Selection -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-tasks text-indigo-500 mr-2"></i>
                    Task Type
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                    <!-- Recurring Daily Task -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringDaily" class="sr-only peer" checked onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-calendar-day text-2xl text-blue-500"></i>
                                <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full">Daily</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">Recurring Daily</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each day</p>
                            <p class="text-[10px] text-gray-400 mt-2">Appears every day. Must be completed each occurrence.</p>
                        </div>
                    </label>
                    
                    <!-- Multi-Day Task -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="MultiDay" class="sr-only peer" onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-calendar-range text-2xl text-green-500"></i>
                                <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Multi-Day</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">Multi-Day Task</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete once</p>
                            <p class="text-[10px] text-gray-400 mt-2">Spans multiple days. Complete once at the end.</p>
                        </div>
                    </label>
                    
                    <!-- Recurring Weekly -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringWeekly" class="sr-only peer" onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-calendar-week text-2xl text-purple-500"></i>
                                <span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full">Weekly</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">Recurring Weekly</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each week</p>
                            <p class="text-[10px] text-gray-400 mt-2">Appears on selected days. Complete each occurrence.</p>
                        </div>
                    </label>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Recurring Monthly -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="RecurringMonthly" class="sr-only peer" onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-calendar-alt text-2xl text-yellow-500"></i>
                                <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-1 rounded-full">Monthly</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">Recurring Monthly</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete each month</p>
                            <p class="text-[10px] text-gray-400 mt-2">Appears monthly. Complete each occurrence.</p>
                        </div>
                    </label>
                    
                    <!-- One-Time Task -->
                    <label class="cursor-pointer">
                        <input type="radio" name="ExecutionType" value="OneTime" class="sr-only peer" onchange="toggleTaskType(); updateCombinedPreview();">
                        <div class="p-4 border-2 rounded-xl peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                            <div class="flex items-center justify-between mb-2">
                                <i class="fas fa-hourglass-start text-2xl text-red-500"></i>
                                <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">One-Time</span>
                            </div>
                            <h5 class="font-semibold text-gray-900">One-Time Task</h5>
                            <p class="text-xs text-gray-500 mt-1">Complete once</p>
                            <p class="text-[10px] text-gray-400 mt-2">Appears once. Complete on the scheduled date.</p>
                        </div>
                    </label>
                </div>
            </div>

            <!-- ========== COMMON SCHEDULING SECTION ========== -->
            <div id="commonScheduleSection" class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-calendar-alt text-blue-500 mr-2"></i>
                    Schedule Settings
                </h4>
                
                <!-- Task Schedule Date Range (with No End Date) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Task Start Date</label>
                        <input type="date" name="StartDate" id="startDate" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" />
                        <p class="text-xs text-gray-500 mt-1">When does this task become active?</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Task End Date</label>
                        <div class="flex items-center gap-2">
                            <input type="date" name="EndDate" id="endDate" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" />
                            <label class="flex items-center cursor-pointer whitespace-nowrap">
                                <input type="checkbox" id="noTaskEndDate" class="mr-2 w-4 h-4 text-indigo-600" onchange="toggleTaskEndDate(); updateCombinedPreview();" />
                                <span class="text-sm text-gray-600">No End Date</span>
                            </label>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Check for tasks that repeat forever</p>
                    </div>
                </div>
                
                <!-- Forever Task Indicator -->
                <div id="foreverTaskIndicator" class="hidden mb-4 p-3 bg-green-50 border border-green-200 rounded-lg">
                    <div class="flex items-center">
                        <i class="fas fa-infinity text-green-600 mr-2"></i>
                        <span class="text-sm text-green-700">This task will repeat forever with no end date.</span>
                    </div>
                </div>
                
                <!-- Availability Date Range (with No End Date option) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Available From</label>
                        <input type="date" name="AvailableFrom" id="availableFrom" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" />
                        <p class="text-xs text-gray-500 mt-1">Earliest date this task can be assigned</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Available To</label>
                        <div class="flex items-center gap-2">
                            <input type="date" name="AvailableTo" id="availableTo" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" />
                            <label class="flex items-center cursor-pointer whitespace-nowrap">
                                <input type="checkbox" id="noAvailableEndDate" class="mr-2 w-4 h-4 text-indigo-600" onchange="toggleAvailableEndDate(); updateCombinedPreview();" />
                                <span class="text-sm text-gray-600">No End Date</span>
                            </label>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Check for tasks that are available forever</p>
                    </div>
                </div>
                
                <!-- Forever Available Indicator -->
                <div id="foreverAvailableIndicator" class="hidden mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg">
                    <div class="flex items-center">
                        <i class="fas fa-infinity text-blue-600 mr-2"></i>
                        <span class="text-sm text-blue-700">This task is available forever with no end date.</span>
                    </div>
                </div>
                
                <!-- Max Occurrences -->
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Max Occurrences</label>
                    <div class="flex items-center gap-2">
                        <input type="number" name="MaxOccurrences" id="maxOccurrences" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" placeholder="Leave empty for unlimited" min="1" />
                        <label class="flex items-center cursor-pointer whitespace-nowrap">
                            <input type="checkbox" id="unlimitedOccurrences" class="mr-2 w-4 h-4 text-indigo-600" checked onchange="toggleMaxOccurrences(); updateCombinedPreview();" />
                            <span class="text-sm text-gray-600">Unlimited</span>
                        </label>
                    </div>
                    <p class="text-xs text-gray-500 mt-1">Maximum number of times this task should appear</p>
                </div>
            </div>

            <!-- ========== WEEKLY TASK SECTION ========== -->
            <div id="weeklyTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 hidden">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-calendar-week text-purple-500 mr-2"></i>
                    Weekly Schedule
                </h4>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Repeat On</label>
                    <div class="grid grid-cols-7 gap-2">
                        <label class="flex flex-col items-center cursor-pointer">
                            <input type="checkbox" name="WeeklyDays" value="0" class="weekly-day-checkbox w-6 h-6" onchange="updateCombinedPreview();" />
                            <span class="text-xs mt-1">Su</span>
                        </label>
                        <label class="flex flex-col items-center cursor-pointer">
                            <input type="checkbox" name="WeeklyDays" value="1" class="weekly-day-checkbox w-6 h-6" onchange="updateCombinedPreview();" />
                            <span class="text-xs mt-1">Mo</span>
                        </label>
                        <label class="flex flex-col items-center cursor-pointer">
                            <input type="checkbox" name="WeeklyDays" value="2" class="weekly-day-checkbox w-6 h-6" onchange="updateCombinedPreview();" />
                            <span class="text-xs mt-1">Tu</span>
                        </label>
                        <label class="flex flex-col items-center cursor-pointer">
                            <input type="checkbox" name="WeeklyDays" value="3" class="weekly-day-checkbox w-6 h-6" onchange="updateCombinedPreview();" />
                            <span class="text-xs mt-1">We</span>
                        </label>
                        <label class="flex flex-col items-center cursor-pointer">
                            <input type="checkbox" name="WeeklyDays" value="4" class="weekly-day-checkbox w-6 h-6" onchange="updateCombinedPreview();" />
                            <span class="text-xs mt-1">Th</span>
                        </label>
                        <label class="flex flex-col items-center cursor-pointer">
                            <input type="checkbox" name="WeeklyDays" value="5" class="weekly-day-checkbox w-6 h-6" onchange="updateCombinedPreview();" />
                            <span class="text-xs mt-1">Fr</span>
                        </label>
                        <label class="flex flex-col items-center cursor-pointer">
                            <input type="checkbox" name="WeeklyDays" value="6" class="weekly-day-checkbox w-6 h-6" onchange="updateCombinedPreview();" />
                            <span class="text-xs mt-1">Sa</span>
                        </label>
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Select the days when this task should appear</p>
                </div>
            </div>

            <!-- ========== MONTHLY TASK SECTION ========== -->
            <div id="monthlyTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 hidden">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-calendar-alt text-yellow-500 mr-2"></i>
                    Monthly Schedule
                </h4>
                
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">Monthly Pattern</label>
                    <div class="grid grid-cols-2 gap-2 mb-3">
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="day" class="mr-2" checked onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span>Specific Day of Month</span>
                        </label>
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="MonthlyPatternType" value="weekday" class="mr-2" onchange="toggleMonthlyPattern(); updateCombinedPreview();">
                            <span>Nth Weekday of Month</span>
                        </label>
                    </div>
                    
                    <div id="monthlyDayPattern">
                        <select name="MonthlyDay" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" onchange="updateCombinedPreview();">
                            @for (int i = 1; i <= 31; i++)
                            {
                                <option value="@i">Day @i</option>
                            }
                        </select>
                        <p class="text-xs text-gray-500 mt-1">Task appears on this day of the month</p>
                    </div>
                    
                    <div id="monthlyWeekdayPattern" class="hidden">
                        <div class="flex gap-2">
                            <select name="MonthlyOrdinal" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" onchange="updateCombinedPreview();">
                                <option value="first">First</option>
                                <option value="second">Second</option>
                                <option value="third">Third</option>
                                <option value="fourth">Fourth</option>
                                <option value="last">Last</option>
                            </select>
                            <select name="MonthlyWeekday" class="flex-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" onchange="updateCombinedPreview();">
                                <option value="sunday">Sunday</option>
                                <option value="monday">Monday</option>
                                <option value="tuesday">Tuesday</option>
                                <option value="wednesday">Wednesday</option>
                                <option value="thursday">Thursday</option>
                                <option value="friday">Friday</option>
                                <option value="saturday">Saturday</option>
                            </select>
                        </div>
                        <input type="hidden" id="MonthlyPattern" name="MonthlyPattern" value="15" />
                        <p class="text-xs text-gray-500 mt-1">Example: "First Monday" or "Last Friday"</p>
                    </div>
                </div>
            </div>

            <!-- ========== MULTI-DAY TASK SECTION ========== -->
            <div id="multiDayTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 hidden">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-calendar-range text-green-500 mr-2"></i>
                    Multi-Day Settings
                </h4>
                
                <div class="bg-blue-50 p-4 rounded-lg border border-blue-200 mb-4">
                    <div class="flex items-center mb-2">
                        <i class="fas fa-info-circle text-blue-600 mr-2"></i>
                        <span class="text-sm font-medium text-blue-800">Multi-Day Task Information</span>
                    </div>
                    <p class="text-xs text-blue-700">
                        This task will appear on the dashboard from the start date until the end date.
                        You only need to complete it ONCE by the deadline (end date + deadline time).
                    </p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Start Date</label>
                        <input type="date" id="multiDayStartDate" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" onchange="updateCombinedPreview();" />
                        <p class="text-xs text-gray-500 mt-1">When does this task begin?</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Duration (Days)</label>
                        <input type="number" id="multiDayDuration" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500"
                               placeholder="e.g., 3" min="1" oninput="updateCombinedPreview();" />
                        <p class="text-xs text-gray-500 mt-1">Number of days this task spans</p>
                    </div>
                </div>
                
                <div class="mt-3 p-3 bg-gray-100 rounded-lg">
                    <div class="text-sm text-gray-700">
                        <span class="font-medium">Task Period:</span>
                        <span id="taskPeriodPreview" class="ml-2 text-indigo-600">Select dates to see preview</span>
                    </div>
                    <div class="text-sm text-gray-700 mt-1">
                        <span class="font-medium">Final Deadline:</span>
                        <span id="finalDeadlinePreview" class="ml-2 text-amber-600">Will be calculated</span>
                    </div>
                </div>
            </div>

            <!-- ========== ONE-TIME TASK SECTION ========== -->
            <div id="oneTimeTaskSection" class="bg-gray-50 rounded-xl p-5 mb-6 hidden">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-hourglass-start text-red-500 mr-2"></i>
                    One-Time Schedule
                </h4>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Task Date</label>
                    <input type="date" id="oneTimeDate" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-500" onchange="updateCombinedPreview();" />
                    <p class="text-xs text-gray-500 mt-1">The date when this task should appear</p>
                </div>
            </div>

            <!-- ========== COMBINED PREVIEW ========== -->
            <div id="combinedPreview" class="mt-4 p-4 bg-indigo-50 border border-indigo-200 rounded-lg hidden mb-6">
                <div class="flex items-start">
                    <i class="fas fa-chart-line text-indigo-500 mt-0.5 mr-3 text-lg"></i>
                    <div class="flex-1">
                        <span class="text-sm font-semibold text-indigo-800">📋 Task Schedule Preview</span>
                        <div id="combinedPreviewContent" class="text-sm text-indigo-700 mt-1 font-medium">
                            Select options to see preview
                        </div>
                    </div>
                </div>
            </div>

            <!-- ========== DEADLINE CONFIGURATION ========== -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-hourglass-half text-blue-500 mr-2"></i>
                    Deadline Configuration
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Deadline" class="block text-sm font-medium text-gray-700 mb-1">
                            Deadline Time <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Deadline" type="time" id="deadlineTime" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                               value="@DateTime.Today.AddHours(21).ToString("HH:mm")" onchange="updateCombinedPreview();" />
                        <p class="text-xs text-gray-500 mt-2">When should this task be completed?</p>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Deadline Type</label>
                        <div class="flex space-x-4 mt-2">
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="deadlineType" value="same-day" class="mr-2" checked onchange="updateCombinedPreview();" />
                                <span class="text-sm">Same Day</span>
                            </label>
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="deadlineType" value="next-day" class="mr-2" onchange="updateCombinedPreview();" />
                                <span class="text-sm">Next Day</span>
                            </label>
                            <label class="flex items-center cursor-pointer">
                                <input type="radio" name="deadlineType" value="next-business-day" class="mr-2" onchange="updateCombinedPreview();" />
                                <span class="text-sm">Next Business Day</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ========== ORGANIZATION & PRIORITY ========== -->
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center">
                    <i class="fas fa-chart-line text-purple-500 mr-2"></i>
                    Organization & Priority
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="DisplayOrder" class="block text-sm font-medium text-gray-700 mb-1">Display Order</label>
                        <div class="relative">
                            <input asp-for="DisplayOrder"
                                   type="text"
                                   id="DisplayOrderText"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                                   placeholder="Auto (e.g., 1, 2, 3 or 'top', 'bottom')" />
                            <div class="absolute right-2 top-1/2 transform -translate-y-1/2">
                                <button type="button" onclick="suggestOrder()" class="text-xs text-indigo-600 hover:text-indigo-800" title="Suggest position">
                                    <i class="fas fa-magic"></i>
                                </button>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 mt-2">
                            <span class="text-indigo-600">💡 Tips:</span>
                            Enter a number (1, 2, 3...) OR text like "top", "first", "bottom", "last", or "after:TaskName", "before:TaskName"
                        </p>
                        <div id="orderSuggestion" class="text-xs text-gray-400 mt-1 hidden"></div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Priority Level</label>
                        <select id="priority" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                            <option value="low">🟢 Low</option>
                            <option value="medium" selected>🟡 Medium</option>
                            <option value="high">🟠 High</option>
                            <option value="critical">🔴 Critical</option>
                        </select>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Estimated Duration</label>
                        <div class="flex gap-2">
                            <input type="number" id="estDuration" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500" value="30" min="1" />
                            <select id="estDurationUnit" class="w-32 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500">
                                <option value="minutes" selected>Minutes</option>
                                <option value="hours">Hours</option>
                            </select>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tags</label>
                        <input type="text" id="tags" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500" placeholder="e.g., daily, critical, reporting" />
                    </div>
                </div>
            </div>

            <!-- ========== TASK TYPE TOGGLES ========== -->
            <div class="bg-gradient-to-r from-gray-50 to-white p-5 rounded-xl border border-gray-200 mb-6">
                <label class="flex items-center justify-between cursor-pointer">
                    <div>
                        <span class="text-sm font-medium text-gray-700">Same Day Deadline</span>
                        <p class="text-xs text-gray-500 mt-1">When checked: Due same day • When unchecked: Due next day</p>
                    </div>
                    <div class="relative">
                        <input asp-for="IsSameDay" type="checkbox" class="sr-only" id="IsSameDay" checked onchange="updateCombinedPreview();" />
                        <div class="w-14 h-8 bg-gray-300 rounded-full transition cursor-pointer toggle-indicator" onclick="toggleCheckbox('IsSameDay')">
                            <div class="absolute w-6 h-6 bg-white rounded-full shadow-md transform transition translate-x-1"></div>
                        </div>
                    </div>
                </label>
            </div>

            <!-- ========== ACTIVE STATUS TOGGLE ========== -->
            <div class="bg-gradient-to-r from-gray-50 to-white p-5 rounded-xl border border-gray-200 mb-6">
                <label class="flex items-center justify-between cursor-pointer">
                    <div>
                        <span class="text-sm font-medium text-gray-700">Active Task</span>
                        <p class="text-xs text-gray-500 mt-1">Inactive tasks won't appear in daily task boards</p>
                    </div>
                    <div class="relative">
                        <input asp-for="IsActive" type="checkbox" class="sr-only" id="IsActive" checked />
                        <div class="w-14 h-8 bg-gray-300 rounded-full transition cursor-pointer toggle-indicator" onclick="toggleCheckbox('IsActive')">
                            <div class="absolute w-6 h-6 bg-white rounded-full shadow-md transform transition translate-x-1"></div>
                        </div>
                    </div>
                </label>
            </div>

            <!-- ========== FORM ACTIONS ========== -->
            <div class="flex justify-end space-x-3 pt-4 border-t">
                <a href="@Url.Action("Index")" class="px-6 py-3 border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                    <i class="fas fa-times mr-2"></i>Cancel
                </a>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl text-sm font-medium hover:from-indigo-700 hover:to-purple-700 transition shadow-md flex items-center">
                    <i class="fas fa-save mr-2"></i>Create Task
                </button>
            </div>
        </form>
    </div>

    <!-- Help Card -->
    <div class="mt-6 bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl border border-indigo-200 p-6">
        <div class="flex items-start space-x-4">
            <div class="w-10 h-10 rounded-xl bg-indigo-100 flex items-center justify-center text-indigo-600">
                <i class="fas fa-lightbulb"></i>
            </div>
            <div>
                <h4 class="font-semibold text-gray-900 mb-2">Task Type & Forever Options Guide</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-gray-600">
                    <ul class="space-y-2">
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Recurring Daily:</span> Appears every day. Must be completed each day.</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Multi-Day:</span> Spans multiple days. Complete once at the end.</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Recurring Weekly:</span> Appears on selected days. Complete each occurrence.</span>
                        </li>
                    </ul>
                    <ul class="space-y-2">
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Recurring Monthly:</span> Appears monthly. Complete each occurrence.</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check-circle text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">One-Time:</span> Appears once. Complete on the scheduled date.</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-infinity text-green-500 mt-0.5 mr-2 text-xs"></i>
                            <span><span class="font-medium">Forever Options:</span> Check "No End Date" for tasks or availability that run forever.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Initialize toggles
            updateToggleDisplay('IsSameDay');
            updateToggleDisplay('IsActive');
            
            // Initialize task type
            toggleTaskType();
            toggleMonthlyPattern();
            
            // Initialize forever options
            toggleTaskEndDate();
            toggleAvailableEndDate();
            toggleMaxOccurrences();
            
            // Setup combined preview listeners
            setupCombinedPreviewListeners();
            
            // Initialize date inputs with default values
            var today = new Date().toISOString().split('T')[0];
            document.getElementById('startDate').value = today;
            document.getElementById('multiDayStartDate').value = today;
            document.getElementById('oneTimeDate').value = today;
            
            // Setup display order suggestion
            setupDisplayOrderSuggestion();
            
            // Trigger initial preview
            setTimeout(updateCombinedPreview, 100);
        });

        // ========== Display Order Functions ==========
        function setupDisplayOrderSuggestion() {
            const orderInput = document.getElementById('DisplayOrderText');
            if (!orderInput) return;
            
            orderInput.addEventListener('input', function() {
                const value = this.value.trim();
                const suggestionDiv = document.getElementById('orderSuggestion');
                
                if (!value) {
                    suggestionDiv.classList.add('hidden');
                    return;
                }
                
                // Parse the display order text
                const parsed = parseDisplayOrder(value);
                if (parsed) {
                    suggestionDiv.classList.remove('hidden');
                    suggestionDiv.innerHTML = `<i class="fas fa-check-circle text-green-500 mr-1"></i> Will be placed: ${parsed.description}`;
                    suggestionDiv.className = 'text-xs text-green-600 mt-1';
                } else {
                    suggestionDiv.classList.remove('hidden');
                    suggestionDiv.innerHTML = `<i class="fas fa-exclamation-triangle text-yellow-500 mr-1"></i> Invalid format. Use number, "top", "bottom", or "before:TaskName"`;
                    suggestionDiv.className = 'text-xs text-yellow-600 mt-1';
                }
            });
        }
        
        function parseDisplayOrder(value) {
            const lowerValue = value.toLowerCase().trim();
            
            // Number
            if (/^\d+$/.test(lowerValue)) {
                const num = parseInt(lowerValue);
                return { type: 'number', value: num, description: `at position ${num}` };
            }
            
            // Top / First
            if (lowerValue === 'top' || lowerValue === 'first') {
                return { type: 'top', value: 1, description: `at the top (position 1)` };
            }
            
            // Bottom / Last
            if (lowerValue === 'bottom' || lowerValue === 'last') {
                return { type: 'bottom', value: null, description: `at the bottom (after all existing tasks)` };
            }
            
            // After:TaskName
            const afterMatch = lowerValue.match(/^after:(.+)$/);
            if (afterMatch) {
                return { type: 'after', afterTask: afterMatch[1], description: `after "${afterMatch[1]}"` };
            }
            
            // Before:TaskName
            const beforeMatch = lowerValue.match(/^before:(.+)$/);
            if (beforeMatch) {
                return { type: 'before', beforeTask: beforeMatch[1], description: `before "${beforeMatch[1]}"` };
            }
            
            return null;
        }
        
        async function suggestOrder() {
            const orderInput = document.getElementById('DisplayOrderText');
            const currentValue = orderInput.value.trim();
            
            if (currentValue) {
                // If user already entered something, show suggestions based on that
                const parsed = parseDisplayOrder(currentValue);
                if (parsed) {
                    showNotification(`Task will be placed ${parsed.description}`, 'info');
                } else {
                    showNotification('Please enter a valid order (number, top, bottom, after:TaskName, before:TaskName)', 'warning');
                }
                return;
            }
            
            // Suggest next available order number
            try {
                const response = await $.ajax({
                    url: '@Url.Action("GetNextDisplayOrder", "Task")',
                    type: 'GET'
                });
                
                if (response.success) {
                    orderInput.value = response.nextOrder;
                    showNotification(`Suggested order: ${response.nextOrder} (after existing tasks)`, 'success');
                    triggerInputEvent(orderInput);
                }
            } catch (error) {
                console.error('Error getting next order:', error);
                showNotification('Could not suggest order. Enter manually.', 'error');
            }
        }
        
        function triggerInputEvent(element) {
            const event = new Event('input', { bubbles: true });
            element.dispatchEvent(event);
        }
        
        // Override form submission to convert text to number
        $('#taskForm').on('submit', function(e) {
            const orderInput = document.getElementById('DisplayOrderText');
            const orderValue = orderInput.value.trim();
            const hiddenOrderInput = document.getElementById('DisplayOrder');
            
            if (!orderValue) {
                // Empty - let server assign auto order
                hiddenOrderInput.value = '0';
                return;
            }
            
            const parsed = parseDisplayOrder(orderValue);
            if (parsed && parsed.type === 'number') {
                hiddenOrderInput.value = parsed.value;
            } else if (parsed && (parsed.type === 'top' || parsed.type === 'bottom')) {
                // For text-based orders, we'll let the server handle conversion
                hiddenOrderInput.value = '0';
                // Store the text order in a hidden field
                if (!$('#textOrder').length) {
                    $('<input>').attr({
                        type: 'hidden',
                        id: 'textOrder',
                        name: 'TextOrder',
                        value: orderValue
                    }).appendTo('#taskForm');
                } else {
                    $('#textOrder').val(orderValue);
                }
            } else if (parsed && (parsed.type === 'after' || parsed.type === 'before')) {
                hiddenOrderInput.value = '0';
                if (!$('#textOrder').length) {
                    $('<input>').attr({
                        type: 'hidden',
                        id: 'textOrder',
                        name: 'TextOrder',
                        value: orderValue
                    }).appendTo('#taskForm');
                } else {
                    $('#textOrder').val(orderValue);
                }
            }
        });

        // ========== Toggle Functions ==========
        function toggleCheckbox(id) {
            var checkbox = document.getElementById(id);
            checkbox.checked = !checkbox.checked;
            updateToggleDisplay(id);
        }
        
        function updateToggleDisplay(id) {
            var checkbox = document.getElementById(id);
            var toggleDiv = checkbox.nextElementSibling;
            var circle = toggleDiv.querySelector('.absolute');
            
            if (checkbox.checked) {
                if (id === 'IsActive') {
                    toggleDiv.classList.remove('bg-gray-300');
                    toggleDiv.classList.add('bg-green-600');
                } else {
                    toggleDiv.classList.remove('bg-gray-300');
                    toggleDiv.classList.add('bg-indigo-600');
                }
                circle.style.transform = 'translateX(28px)';
            } else {
                toggleDiv.classList.remove('bg-indigo-600', 'bg-green-600');
                toggleDiv.classList.add('bg-gray-300');
                circle.style.transform = 'translateX(4px)';
            }
        }

        // ========== Forever Task Functions ==========
        function toggleTaskEndDate() {
            var noEndDateCheckbox = document.getElementById('noTaskEndDate');
            var endDateInput = document.getElementById('endDate');
            var foreverTaskIndicator = document.getElementById('foreverTaskIndicator');
            
            if (noEndDateCheckbox.checked) {
                endDateInput.disabled = true;
                endDateInput.value = '';
                foreverTaskIndicator.classList.remove('hidden');
            } else {
                endDateInput.disabled = false;
                foreverTaskIndicator.classList.add('hidden');
            }
            
            updateCombinedPreview();
        }
        
        function toggleAvailableEndDate() {
            var noAvailableEndDate = document.getElementById('noAvailableEndDate');
            var availableToInput = document.getElementById('availableTo');
            var foreverAvailableIndicator = document.getElementById('foreverAvailableIndicator');
            
            if (noAvailableEndDate.checked) {
                availableToInput.disabled = true;
                availableToInput.value = '';
                foreverAvailableIndicator.classList.remove('hidden');
            } else {
                availableToInput.disabled = false;
                foreverAvailableIndicator.classList.add('hidden');
            }
            
            updateCombinedPreview();
        }
        
        function toggleMaxOccurrences() {
            var unlimitedCheckbox = document.getElementById('unlimitedOccurrences');
            var maxOccurrencesInput = document.getElementById('maxOccurrences');
            
            if (unlimitedCheckbox.checked) {
                maxOccurrencesInput.disabled = true;
                maxOccurrencesInput.value = '';
            } else {
                maxOccurrencesInput.disabled = false;
            }
            
            updateCombinedPreview();
        }

        // ========== Task Type Functions ==========
        function toggleTaskType() {
            var type = document.querySelector('input[name="ExecutionType"]:checked').value;
            
            // Hide all task-type-specific sections
            document.getElementById('weeklyTaskSection').classList.add('hidden');
            document.getElementById('monthlyTaskSection').classList.add('hidden');
            document.getElementById('multiDayTaskSection').classList.add('hidden');
            document.getElementById('oneTimeTaskSection').classList.add('hidden');
            
            // Show appropriate section
            switch(type) {
                case 'RecurringWeekly':
                    document.getElementById('weeklyTaskSection').classList.remove('hidden');
                    break;
                case 'RecurringMonthly':
                    document.getElementById('monthlyTaskSection').classList.remove('hidden');
                    break;
                case 'MultiDay':
                    document.getElementById('multiDayTaskSection').classList.remove('hidden');
                    setupMultiDayPreview();
                    break;
                case 'OneTime':
                    document.getElementById('oneTimeTaskSection').classList.remove('hidden');
                    break;
                case 'RecurringDaily':
                    // No additional config needed
                    break;
            }
            
            updateCombinedPreview();
        }
        
        // ========== Monthly Pattern Functions ==========
        function toggleMonthlyPattern() {
            var type = document.querySelector('input[name="MonthlyPatternType"]:checked').value;
            var dayPattern = document.getElementById('monthlyDayPattern');
            var weekdayPattern = document.getElementById('monthlyWeekdayPattern');
            var monthlyPatternHidden = document.getElementById('MonthlyPattern');
            
            if (type === 'day') {
                dayPattern.classList.remove('hidden');
                weekdayPattern.classList.add('hidden');
                monthlyPatternHidden.value = document.querySelector('select[name="MonthlyDay"]').value;
            } else {
                dayPattern.classList.add('hidden');
                weekdayPattern.classList.remove('hidden');
                updateMonthlyPattern();
            }
            
            updateCombinedPreview();
        }
        
        function updateMonthlyPattern() {
            var ordinal = document.querySelector('select[name="MonthlyOrdinal"]').value;
            var weekday = document.querySelector('select[name="MonthlyWeekday"]').value;
            var monthlyPatternHidden = document.getElementById('MonthlyPattern');
            
            if (ordinal && weekday) {
                monthlyPatternHidden.value = ordinal + '-' + weekday;
            }
        }
        
        // ========== Multi-Day Preview ==========
        function setupMultiDayPreview() {
            var startDateInput = document.getElementById('multiDayStartDate');
            var durationInput = document.getElementById('multiDayDuration');
            var deadlineTime = document.getElementById('deadlineTime');
            var isSameDay = document.getElementById('IsSameDay').checked;
            
            function updatePreview() {
                var startDate = startDateInput.value;
                var duration = parseInt(durationInput.value);
                var deadlineTimeValue = deadlineTime ? deadlineTime.value : '21:00';
                
                if (startDate && duration > 0) {
                    var start = new Date(startDate);
                    var end = new Date(start);
                    end.setDate(end.getDate() + duration - 1);
                    
                    var startFormatted = start.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                    var endFormatted = end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                    
                    document.getElementById('taskPeriodPreview').innerHTML =
                        `${startFormatted} → ${endFormatted} (${duration} days)`;
                    
                    var deadlineDate = new Date(end);
                    var deadlineTimeObj = new Date(`2000-01-01T${deadlineTimeValue}`);
                    
                    if (isSameDay) {
                        var deadline = new Date(end);
                        deadline.setHours(deadlineTimeObj.getHours(), deadlineTimeObj.getMinutes());
                        var deadlineFormatted = deadline.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) +
                                               ' at ' + deadlineTimeValue;
                        document.getElementById('finalDeadlinePreview').innerHTML = deadlineFormatted;
                    } else {
                        var nextDay = new Date(end);
                        nextDay.setDate(nextDay.getDate() + 1);
                        nextDay.setHours(deadlineTimeObj.getHours(), deadlineTimeObj.getMinutes());
                        var deadlineFormatted = nextDay.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) +
                                               ' at ' + deadlineTimeValue;
                        document.getElementById('finalDeadlinePreview').innerHTML = deadlineFormatted + ' (next day)';
                    }
                }
            }
            
            if (startDateInput) startDateInput.addEventListener('change', updatePreview);
            if (durationInput) durationInput.addEventListener('input', updatePreview);
            if (deadlineTime) deadlineTime.addEventListener('change', updatePreview);
            document.getElementById('IsSameDay').addEventListener('change', updatePreview);
            
            updatePreview();
        }
        
        // ========== Combined Preview Function ==========
        function updateCombinedPreview() {
            var previewDiv = document.getElementById('combinedPreview');
            var previewContent = document.getElementById('combinedPreviewContent');
            var taskType = document.querySelector('input[name="ExecutionType"]:checked').value;
            
            // Task Schedule
            var taskStartDate = document.getElementById('startDate').value;
            var noTaskEndDate = document.getElementById('noTaskEndDate').checked;
            var taskEndDate = document.getElementById('endDate').value;
            
            // Availability
            var availableFrom = document.getElementById('availableFrom').value;
            var noAvailableEndDate = document.getElementById('noAvailableEndDate').checked;
            var availableTo = document.getElementById('availableTo').value;
            
            // Occurrences
            var unlimitedOccurrences = document.getElementById('unlimitedOccurrences').checked;
            var maxOccurrences = document.getElementById('maxOccurrences').value;
            
            if (!taskStartDate) {
                previewDiv.classList.add('hidden');
                return;
            }
            
            previewDiv.classList.remove('hidden');
            
            var start = new Date(taskStartDate);
            var startFormatted = start.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            
            // Build Task Schedule Description
            var taskScheduleText = '';
            if (noTaskEndDate) {
                taskScheduleText = `📅 Task Schedule: From ${startFormatted} → FOREVER`;
            } else if (taskEndDate) {
                var end = new Date(taskEndDate);
                var endFormatted = end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                taskScheduleText = `📅 Task Schedule: From ${startFormatted} → ${endFormatted}`;
            } else {
                taskScheduleText = `📅 Task Schedule: From ${startFormatted}`;
            }
            
            // Build Availability Description
            var availabilityText = '';
            var hasAvailability = false;
            
            if (availableFrom && noAvailableEndDate) {
                var from = new Date(availableFrom);
                var fromFormatted = from.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                availabilityText = `✅ Available: From ${fromFormatted} → FOREVER`;
                hasAvailability = true;
            } else if (availableFrom && availableTo) {
                var from = new Date(availableFrom);
                var to = new Date(availableTo);
                var fromFormatted = from.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                var toFormatted = to.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                availabilityText = `✅ Available: From ${fromFormatted} → ${toFormatted}`;
                hasAvailability = true;
            } else if (availableFrom) {
                var from = new Date(availableFrom);
                var fromFormatted = from.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                availabilityText = `✅ Available: From ${fromFormatted}`;
                hasAvailability = true;
            } else if (availableTo && !noAvailableEndDate) {
                var to = new Date(availableTo);
                var toFormatted = to.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                availabilityText = `✅ Available: Until ${toFormatted}`;
                hasAvailability = true;
            } else if (noAvailableEndDate) {
                availabilityText = `✅ Available: FOREVER (no end date)`;
                hasAvailability = true;
            }
            
            // Build Occurrence Description
            var occurrenceText = '';
            if (!unlimitedOccurrences && maxOccurrences) {
                occurrenceText = `📊 Max Occurrences: ${maxOccurrences}`;
            } else if (unlimitedOccurrences) {
                occurrenceText = `📊 Occurrences: Unlimited`;
            }
            
            // Build Task Type Description
            var typeText = getTaskTypeDescription(taskType);
            
            // Combine all
            var fullText = `${typeText} • ${taskScheduleText}`;
            if (hasAvailability) fullText += ` • ${availabilityText}`;
            if (occurrenceText) fullText += ` • ${occurrenceText}`;
            
            previewContent.innerHTML = fullText;
        }
        
        function getTaskTypeDescription(taskType) {
            switch(taskType) {
                case 'RecurringDaily':
                    return '📅 Daily Task';
                case 'RecurringWeekly':
                    var selectedDays = [];
                    document.querySelectorAll('input[name="WeeklyDays"]:checked').forEach(function(cb) {
                        var dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                        selectedDays.push(dayNames[parseInt(cb.value)]);
                    });
                    var daysText = selectedDays.length > 0 ? selectedDays.join(', ') : 'no days';
                    return `📆 Weekly on ${daysText}`;
                case 'RecurringMonthly':
                    var patternType = document.querySelector('input[name="MonthlyPatternType"]:checked').value;
                    if (patternType === 'day') {
                        var dayOfMonth = document.querySelector('select[name="MonthlyDay"]').value;
                        return `📅 Monthly on day ${dayOfMonth}`;
                    } else {
                        var ordinal = document.querySelector('select[name="MonthlyOrdinal"]').value;
                        var weekday = document.querySelector('select[name="MonthlyWeekday"]').value;
                        return `📅 Monthly on ${ordinal} ${weekday}`;
                    }
                case 'MultiDay':
                    var duration = document.getElementById('multiDayDuration').value;
                    return duration ? `⏱️ Multi-Day (${duration} days)` : '⏱️ Multi-Day Task';
                case 'OneTime':
                    return `🎯 One-Time Task`;
                default:
                    return '📋 Task';
            }
        }
        
        // ========== Setup Preview Listeners ==========
        function setupCombinedPreviewListeners() {
            // Task schedule
            document.getElementById('startDate').addEventListener('change', updateCombinedPreview);
            document.getElementById('endDate').addEventListener('change', updateCombinedPreview);
            document.getElementById('noTaskEndDate').addEventListener('change', updateCombinedPreview);
            
            // Availability
            document.getElementById('availableFrom').addEventListener('change', updateCombinedPreview);
            document.getElementById('availableTo').addEventListener('change', updateCombinedPreview);
            document.getElementById('noAvailableEndDate').addEventListener('change', updateCombinedPreview);
            
            // Occurrences
            document.getElementById('unlimitedOccurrences').addEventListener('change', updateCombinedPreview);
            document.getElementById('maxOccurrences').addEventListener('input', updateCombinedPreview);
            
            // Task type
            document.querySelectorAll('input[name="ExecutionType"]').forEach(function(radio) {
                radio.addEventListener('change', updateCombinedPreview);
            });
            
            // Weekly days
            document.querySelectorAll('input[name="WeeklyDays"]').forEach(function(cb) {
                cb.addEventListener('change', updateCombinedPreview);
            });
            
            // Monthly pattern
            document.querySelector('select[name="MonthlyDay"]')?.addEventListener('change', updateCombinedPreview);
            document.querySelector('select[name="MonthlyOrdinal"]')?.addEventListener('change', updateCombinedPreview);
            document.querySelector('select[name="MonthlyWeekday"]')?.addEventListener('change', updateCombinedPreview);
            document.querySelectorAll('input[name="MonthlyPatternType"]').forEach(function(radio) {
                radio.addEventListener('change', updateCombinedPreview);
            });
            
            // Multi-day
            document.getElementById('multiDayDuration')?.addEventListener('input', updateCombinedPreview);
            document.getElementById('multiDayStartDate')?.addEventListener('change', updateCombinedPreview);
            
            // One-time
            document.getElementById('oneTimeDate')?.addEventListener('change', updateCombinedPreview);
            
            // Deadline
            document.getElementById('deadlineTime').addEventListener('change', updateCombinedPreview);
            document.querySelectorAll('input[name="deadlineType"]').forEach(function(radio) {
                radio.addEventListener('change', updateCombinedPreview);
            });
            document.getElementById('IsSameDay').addEventListener('change', updateCombinedPreview);
        }
        
        // ========== Notification Function ==========
        function showNotification(message, type) {
            const colors = {
                success: 'bg-green-500',
                error: 'bg-red-500',
                warning: 'bg-yellow-500',
                info: 'bg-blue-500'
            };
            
            $('.custom-notification').remove();
            const notification = $(`<div class="custom-notification fixed top-4 right-4 z-50 px-4 py-2 rounded-lg shadow-lg text-sm font-medium text-white ${colors[type]} animate-slide-in flex items-center">
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'} mr-2"></i>
                <span>${message}</span>
            </div>`);
            
            $('body').append(notification);
            setTimeout(() => notification.fadeOut(300, () => notification.remove()), 3000);
        }
        
        // ========== Event Listeners for Monthly Pattern ==========
        document.querySelectorAll('input[name="MonthlyPatternType"]').forEach(function(radio) {
            radio.addEventListener('change', toggleMonthlyPattern);
        });
        
        document.querySelector('select[name="MonthlyDay"]')?.addEventListener('change', function() {
            document.getElementById('MonthlyPattern').value = this.value;
        });
        
        document.querySelector('select[name="MonthlyOrdinal"]')?.addEventListener('change', updateMonthlyPattern);
        document.querySelector('select[name="MonthlyWeekday"]')?.addEventListener('change', updateMonthlyPattern);
    </script>
}

