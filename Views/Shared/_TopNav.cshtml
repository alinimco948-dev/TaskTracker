@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<header class="bg-white/80 backdrop-blur-md shadow-sm border-b border-gray-200 sticky top-0 z-30">
    <div class="px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
        <!-- Mobile Menu Button -->
        <div class="flex items-center space-x-3 lg:hidden">
            <button onclick="openMobileSidebar()" class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all duration-200">
                <i class="fas fa-bars text-xl"></i>
            </button>
            <div class="flex items-center space-x-2">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-md">
                    <i class="fas fa-tasks text-white text-sm"></i>
                </div>
                <span class="font-bold text-gray-800">TaskTracker</span>
            </div>
        </div>
        
        <!-- Search Bar - Desktop -->
        <div class="hidden lg:flex items-center flex-1 max-w-md ml-4">
            <div class="relative w-full">
                <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-sm"></i>
                <input type="text" id="globalSearch" placeholder="Search employees, branches, tasks..." 
                       class="w-full pl-10 pr-4 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-gray-50 hover:bg-white transition-all duration-200">
            </div>
        </div>
        
        <div class="flex items-center space-x-2 sm:space-x-4">
            <!-- Quick Actions Dropdown -->
            <div class="relative">
                <button onclick="toggleQuickActions()" 
                        class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-all duration-200 relative group">
                    <i class="fas fa-plus-circle text-xl"></i>
                    <span class="absolute -top-1 -right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
                <div id="quick-actions-dropdown" class="dropdown-menu hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-xl border border-gray-100 z-50 overflow-hidden">
                    <div class="p-2 space-y-1">
                        <div class="px-3 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Quick Actions</div>
                        <a href="@Url.Action("Create", "Employee")" class="flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition-all duration-200">
                            <i class="fas fa-user-plus mr-3 w-4 text-blue-500"></i>Add Employee
                        </a>
                        <a href="@Url.Action("Create", "Branch")" class="flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition-all duration-200">
                            <i class="fas fa-store mr-3 w-4 text-green-500"></i>Add Branch
                        </a>
                        <a href="@Url.Action("Create", "Department")" class="flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition-all duration-200">
                            <i class="fas fa-building mr-3 w-4 text-purple-500"></i>Add Department
                        </a>
                        <a href="@Url.Action("Create", "Task")" class="flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition-all duration-200">
                            <i class="fas fa-tasks mr-3 w-4 text-yellow-500"></i>Add Task
                        </a>
                        <div class="border-t border-gray-100 my-1"></div>
                        <a href="@Url.Action("EmployeeRanking", "Report")" class="flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition-all duration-200">
                            <i class="fas fa-chart-line mr-3 w-4 text-indigo-500"></i>View Rankings
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Notifications -->
            <div class="relative">
                <button onclick="toggleNotifications()" class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-all duration-200">
                    <i class="fas fa-bell text-xl"></i>
                </button>
                <div id="notifications-dropdown" class="dropdown-menu hidden absolute right-0 mt-2 w-80 bg-white rounded-xl shadow-xl border border-gray-100 z-50 overflow-hidden">
                    <div class="p-3 border-b border-gray-100">
                        <h3 class="font-semibold text-gray-800">Notifications</h3>
                    </div>
                    <div class="max-h-96 overflow-y-auto">
                        <div class="p-4 text-center text-gray-500 text-sm">
                            <i class="fas fa-bell-slash text-2xl mb-2 text-gray-300"></i>
                            <p>No new notifications</p>
                        </div>
                    </div>
                    <div class="p-2 border-t border-gray-100">
                        <a href="#" class="block text-center text-xs text-blue-600 hover:text-blue-700">View all</a>
                    </div>
                </div>
            </div>
            
            <!-- User Menu -->
            <div class="relative">
                <button onclick="toggleUserMenu()" class="flex items-center space-x-2 focus:outline-none group">
                    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white shadow-md transition-transform duration-200 group-hover:scale-105">
                        <span class="text-sm font-bold">AD</span>
                    </div>
                    <div class="hidden sm:block text-left">
                        <p class="text-sm font-medium text-gray-700">Admin User</p>
                        <p class="text-xs text-gray-400">Administrator</p>
                    </div>
                    <i class="fas fa-chevron-down text-xs text-gray-400 transition-transform duration-200 hidden sm:block" id="user-menu-chevron"></i>
                </button>
                <div id="user-menu-dropdown" class="dropdown-menu hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-xl border border-gray-100 z-50 overflow-hidden">
                    <div class="p-3 border-b border-gray-100 flex items-center space-x-3">
                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white">
                            <span class="text-sm font-bold">AD</span>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-gray-800">Admin User</p>
                            <p class="text-xs text-gray-500">admin@tasktracker.com</p>
                        </div>
                    </div>
                    <div class="p-2 space-y-1">
                        <a href="#" class="flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-lg transition-all duration-200">
                            <i class="fas fa-user mr-3 w-4 text-gray-400"></i>Profile
                        </a>
                        <a href="#" class="flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-lg transition-all duration-200">
                            <i class="fas fa-cog mr-3 w-4 text-gray-400"></i>Settings
                        </a>
                        <div class="border-t border-gray-100 my-1"></div>
                        <a href="#" class="flex items-center px-3 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg transition-all duration-200">
                            <i class="fas fa-sign-out-alt mr-3 w-4"></i>Sign Out
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Mobile Search Bar -->
    <div class="lg:hidden px-4 pb-3">
        <div class="relative">
            <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-sm"></i>
            <input type="text" id="mobileGlobalSearch" placeholder="Search..." 
                   class="w-full pl-10 pr-4 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-gray-50">
        </div>
    </div>
</header>

<script>
    function toggleQuickActions() {
        $('#quick-actions-dropdown').slideToggle(200);
        $('#user-menu-dropdown').slideUp(200);
        $('#notifications-dropdown').slideUp(200);
    }
    
    function toggleUserMenu() {
        $('#user-menu-dropdown').slideToggle(200);
        $('#quick-actions-dropdown').slideUp(200);
        $('#notifications-dropdown').slideUp(200);
        $('#user-menu-chevron').toggleClass('rotate-180');
    }
    
    function toggleNotifications() {
        $('#notifications-dropdown').slideToggle(200);
        $('#quick-actions-dropdown').slideUp(200);
        $('#user-menu-dropdown').slideUp(200);
    }
    
    // Close dropdowns when clicking outside
    $(document).click(function(event) {
        if (!$(event.target).closest('.relative').length) {
            $('#quick-actions-dropdown').slideUp(200);
            $('#user-menu-dropdown').slideUp(200);
            $('#notifications-dropdown').slideUp(200);
        }
    });
    
    // Global search functionality
    function performSearch(searchTerm) {
        if (!$('#employeeTableBody').length) return;
        
        $('#employeeTableBody tr').each(function() {
            var text = $(this).text().toLowerCase();
            if (text.indexOf(searchTerm) > -1) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
        
        // Update stats if filterTable function exists
        if (typeof filterTable === 'function') {
            filterTable();
        }
    }
    
    $('#globalSearch, #mobileGlobalSearch').on('keyup', function() {
        var searchTerm = $(this).val().toLowerCase();
        performSearch(searchTerm);
    });
</script>

<style>
    .rotate-180 {
        transform: rotate(180deg);
    }
    
    .dropdown-menu {
        animation: fadeInDown 0.2s ease-out;
    }
    
    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Backdrop blur support */
    .backdrop-blur-md {
        backdrop-filter: blur(12px);
    }
</style>