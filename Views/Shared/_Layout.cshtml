<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskTracker</title>
    
    <!-- Tailwind CSS -->
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        dark: {
                            base: '#0b0b18',
                            surface: '#12121f',
                            card: 'rgba(255,255,255,0.04)',
                        }
                    }
                }
            }
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Global Styles -->
    <style>
        :root {
            --bg-base:       #000000;
            --bg-surface:    #0a0a0a;
            --bg-card:       rgba(255,255,255,0.02);
            --bg-card-hover: rgba(255,255,255,0.05);
            --border:        rgba(255,255,255,0.1);
            --border-hover:  rgba(255,255,255,0.25);
            --primary:       #3b82f6;
            --primary-dark:  #2563eb;
            --primary-light: #60a5fa;
            --accent:        #8b5cf6;
            --accent2:       #d946ef;
            --success:       #10b981;
            --warning:       #f59e0b;
            --danger:        #ef4444;
            --text-primary:  #ffffff;
            --text-muted:    #94a3b8;
            --text-subtle:   #64748b;
        }

        * { font-family: 'Inter', sans-serif; box-sizing: border-box; }

        html {
            color-scheme: dark;
        }

        body {
            background-color: var(--bg-base);
            color: var(--text-primary);
        }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-surface); }
        ::-webkit-scrollbar-thumb { background: rgba(99,102,241,0.4); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--primary); }

        /* ── Sidebar transitions ── */
        .sidebar { transition: width 0.3s cubic-bezier(0.4,0,0.2,1); }
        .sidebar-text { transition: opacity 0.2s ease-in-out; }
        #main-content { transition: margin-left 0.3s cubic-bezier(0.4,0,0.2,1); }

        /* ── Sidebar collapsed ── */
        .sidebar.collapsed { width: 72px; }
        .sidebar.collapsed .sidebar-text { display: none !important; }
        .sidebar.collapsed nav ul li a,
        .sidebar.collapsed nav ul li button { justify-content: center; padding-left: 0; padding-right: 0; }
        .sidebar.collapsed nav ul li a i,
        .sidebar.collapsed nav ul li button i { margin-right: 0; }
        .sidebar.collapsed .flex.items-center.space-x-3 { justify-content: center; }

        /* ── Mobile sidebar ── */
        #mobileSidebar {
            transition: transform 0.3s ease-in-out;
            transform: translateX(-100%);
        }
        #mobileSidebar.open { transform: translateX(0); }

        /* ── Glass card ── */
        .glass-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 0.875rem;
            transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
        }
        .glass-card:hover {
            border-color: var(--border-hover);
            background: var(--bg-card-hover);
        }

        /* ── Gradient text ── */
        .gradient-text {
            background: linear-gradient(135deg, var(--primary-light), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ── Gradient button ── */
        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--accent2));
            color: #fff;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 0.625rem;
            font-weight: 600;
            font-size: 0.875rem;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
            box-shadow: 0 4px 15px rgba(99,102,241,0.3);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        .btn-primary:hover {
            opacity: 0.92;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(99,102,241,0.45);
        }

        /* ── Animations ── */
        .animate-slide-in { animation: slideIn 0.3s ease-out; }
        @@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

        .animate-fade-in { animation: fadeIn 0.2s ease-out; }
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .animate-fade-up { animation: fadeUp 0.3s ease-out; }
        @@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

        /* ── Dropdown ── */
        .dropdown-menu { animation: fadeInDown 0.2s ease-out; }
        @@keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Loading spinner ── */
        .loading-spinner {
            display: inline-block;
            width: 20px; height: 20px;
            border: 2px solid rgba(255,255,255,0.1);
            border-top: 2px solid var(--primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        /* ── Modal backdrop ── */
        .modal-backdrop {
            backdrop-filter: blur(6px);
            background: rgba(0,0,0,0.65);
        }

        /* ── Dark form inputs ── */
        .dark-input {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            color: var(--text-primary);
            border-radius: 0.625rem;
            padding: 0.6rem 0.875rem;
            font-size: 0.875rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            width: 100%;
        }
        .dark-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
        }
        .dark-input::placeholder { color: var(--text-muted); }
        .dark-input option {
            background-color: var(--bg-surface);
            color: var(--text-primary);
        }

        /* ── Stats badge ── */
        .stat-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
        }

        /* ── Glow effect ── */
        .glow-indigo { box-shadow: 0 0 20px rgba(99,102,241,0.25); }
        .glow-cyan   { box-shadow: 0 0 20px rgba(6,182,212,0.25); }

        /* ── Alert/message overrides ── */
        .alert-success { background: rgba(16,185,129,0.1); border-left: 4px solid #10b981; color: #6ee7b7; }
        .alert-error   { background: rgba(239,68,68,0.1);  border-left: 4px solid #ef4444; color: #fca5a5; }
        .alert-info    { background: rgba(99,102,241,0.1); border-left: 4px solid #6366f1; color: #a5b4fc; }
        .alert-warning { background: rgba(245,158,11,0.1); border-left: 4px solid #f59e0b; color: #fcd34d; }

        /* ── Table styles ── */
        .dark-table thead th {
            background: rgba(99,102,241,0.08);
            color: var(--text-subtle);
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 0.875rem 1rem;
            border-bottom: 1px solid var(--border);
        }
        .dark-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.15s;
        }
        .dark-table tbody tr:hover { background: rgba(99,102,241,0.06); }
        .dark-table tbody td { padding: 0.875rem 1rem; color: var(--text-primary); font-size: 0.875rem; }

        /* Rotate for chevrons */
        .rotate-180 { transform: rotate(180deg); }

        /* Truncate 2 lines */
        .truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* Background mesh animation */
        .bg-mesh {
            background-image:
                radial-gradient(circle at 20% 20%, rgba(99,102,241,0.07) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(6,182,212,0.05) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(124,58,237,0.04) 0%, transparent 60%);
        }
    </style>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body id="pageBody" class="bg-mesh">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        @await Html.PartialAsync("_Sidebar")
        
        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden" id="main-content">
            @await Html.PartialAsync("_TopNav")
            
            <main class="flex-1 overflow-x-hidden overflow-y-auto p-5">
                <div class="container mx-auto max-w-7xl">
                    <!-- Alert Container -->
                    <div id="alert-container"></div>
                    
                    <!-- TempData Messages -->
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert-success rounded-xl p-4 mb-4 flex items-center justify-between animate-slide-in">
                            <div class="flex items-center gap-3">
                                <i class="fas fa-check-circle text-emerald-400"></i>
                                <p class="text-sm font-medium">@TempData["SuccessMessage"]</p>
                            </div>
                            <button type="button" onclick="$(this).closest('.alert-success').fadeOut()" class="text-emerald-400 hover:text-white transition">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert-error rounded-xl p-4 mb-4 flex items-center justify-between animate-slide-in">
                            <div class="flex items-center gap-3">
                                <i class="fas fa-exclamation-circle text-red-400"></i>
                                <p class="text-sm font-medium">@TempData["ErrorMessage"]</p>
                            </div>
                            <button type="button" onclick="$(this).closest('.alert-error').fadeOut()" class="text-red-400 hover:text-white transition">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    }
                    @if (TempData["InfoMessage"] != null)
                    {
                        <div class="alert-info rounded-xl p-4 mb-4 flex items-center justify-between animate-slide-in">
                            <div class="flex items-center gap-3">
                                <i class="fas fa-info-circle text-indigo-400"></i>
                                <p class="text-sm font-medium">@TempData["InfoMessage"]</p>
                            </div>
                            <button type="button" onclick="$(this).closest('.alert-info').fadeOut()" class="text-indigo-400 hover:text-white transition">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    }
                    @if (TempData["WarningMessage"] != null)
                    {
                        <div class="alert-warning rounded-xl p-4 mb-4 flex items-center justify-between animate-slide-in">
                            <div class="flex items-center gap-3">
                                <i class="fas fa-exclamation-triangle text-amber-400"></i>
                                <p class="text-sm font-medium">@TempData["WarningMessage"]</p>
                            </div>
                            <button type="button" onclick="$(this).closest('.alert-warning').fadeOut()" class="text-amber-400 hover:text-white transition">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    }
                    
                    @RenderBody()
                </div>
            </main>
            
            <footer class="border-t border-white/5 bg-[#0f0f1a]/80 backdrop-blur px-6 py-3 text-xs text-slate-500 flex flex-wrap justify-between items-center gap-2">
                <div>&copy; @DateTime.Now.Year — TaskTracker v1.0.0</div>
                <div class="flex items-center gap-4">
                    <span class="flex items-center gap-1.5"><i class="fas fa-database text-indigo-500"></i>PostgreSQL</span>
                    <span class="flex items-center gap-1.5"><i class="fas fa-bolt text-cyan-500"></i>Real-time</span>
                    <span>@DateTime.Now.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
            </footer>
        </div>
    </div>
    
    <!-- Notification Container -->
    <div id="notification-container" class="fixed top-4 right-4 z-[100] space-y-2"></div>
    
    <!-- Global Confirmation Modal -->
    <div id="globalConfirmationModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-[90]">
        <div class="glass-card w-full max-w-md transform transition-all animate-fade-up border border-white/10 shadow-2xl" style="background:#1a1a2e;">
            <div class="bg-gradient-to-r from-red-600 to-rose-700 px-6 py-4 rounded-t-[0.875rem] flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center">
                    <i class="fas fa-exclamation-triangle text-white text-sm"></i>
                </div>
                <h3 class="text-base font-semibold text-white" id="confirmationTitle">Confirm Action</h3>
            </div>
            <div class="p-6">
                <p id="confirmationMessage" class="text-slate-300 text-sm">Are you sure you want to proceed?</p>
            </div>
            <div class="px-6 py-4 border-t border-white/5 flex justify-end gap-3">
                <button type="button" onclick="window.globalConfirmClose()"
                        class="px-4 py-2 rounded-lg text-sm font-medium text-slate-300 border border-white/10 hover:bg-white/5 transition">
                    Cancel
                </button>
                <button type="button" onclick="window.globalConfirmExecute()"
                        class="px-4 py-2 rounded-lg text-sm font-medium bg-red-600 text-white hover:bg-red-700 transition flex items-center gap-2">
                    <i class="fas fa-check"></i>Confirm
                </button>
            </div>
        </div>
    </div>
    
    <!-- Global Loading Overlay -->
    <div id="globalLoadingOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden items-center justify-center z-[90]">
        <div class="glass-card p-8 flex flex-col items-center gap-4" style="background:#1a1a2e; border-color:rgba(99,102,241,0.3);">
            <div class="loading-spinner w-10 h-10 border-4"></div>
            <span id="loadingMessage" class="text-slate-300 font-medium">Loading...</span>
        </div>
    </div>
    
    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    
    <script>
        // ============================================
        // GLOBAL CHART.JS CONFIGURATION
        // High DPI / Retina Display Support
        // ============================================
        (function() {
            // Set global Chart.js defaults for high quality rendering
            const dpr = window.devicePixelRatio || 1;
            
            // Override default configuration for all charts
            const originalLineDraw = Chart.prototype.draw;
            Chart.prototype.draw = function() {
                if (this.canvas) {
                    const ctx = this.canvas.getContext('2d');
                    ctx.scale(dpr, dpr);
                }
                originalLineDraw.apply(this, arguments);
            };
            
            // Set global defaults
            Chart.defaults.font.family = "'Inter', 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif";
            Chart.defaults.font.size = 12;
            Chart.defaults.color = '#94a3b8';
            
            // Global device pixel ratio for all charts
            Chart.defaults.devicePixelRatio = dpr;
            
            // Improve anti-aliasing
            if (Chart.defaults.animation) {
                Chart.defaults.animation.duration = 0;
            }
            
            // Responsive with proper scaling
            Chart.defaults.responsive = true;
            Chart.defaults.maintainAspectRatio = false;
            
            console.log('Chart.js initialized with devicePixelRatio:', dpr);
        })();
    </script>
    
    <script>
        // ============================================
        // TASKTRACKER CORE APPLICATION
        // ============================================
        (function() {
            'use strict';
            
            window.TaskTracker = {
                token: null,
                
                init: function(token) {
                    this.token = token;
                    this.setupAjaxDefaults();
                    this.setupGlobalEventListeners();
                },
                
                setupAjaxDefaults: function() {
                    $.ajaxSetup({ headers: { 'RequestVerificationToken': this.token } });
                },
                
                setupGlobalEventListeners: function() {
                    $(document).keydown(function(e) {
                        if (e.key === 'Escape') {
                            window.globalConfirmClose();
                            $('.modal:visible').each(function() {
                                $(this).addClass('hidden').removeClass('flex');
                            });
                        }
                    });
                    $(window).click(function(e) {
                        if ($(e.target).hasClass('modal-backdrop')) {
                            window.globalConfirmClose();
                        }
                    });
                },
                
                showNotification: function(message, type) {
                    var config = {
                        success: { bg: 'from-emerald-600 to-emerald-700', icon: 'fa-check-circle' },
                        error:   { bg: 'from-red-600 to-rose-700',       icon: 'fa-exclamation-circle' },
                        info:    { bg: 'from-indigo-600 to-violet-700',  icon: 'fa-info-circle' },
                        warning: { bg: 'from-amber-500 to-orange-600',   icon: 'fa-exclamation-triangle' }
                    };
                    var c = config[type] || config.info;
                    
                    var notification = $('<div class="tasktracker-notification flex items-center gap-3 px-4 py-3 rounded-xl shadow-2xl text-white text-sm font-medium animate-slide-in bg-gradient-to-r ' + c.bg + '" style="backdrop-filter:blur(12px); min-width:280px;">' +
                        '<i class="fas ' + c.icon + ' text-white/90"></i>' +
                        '<span>' + this.escapeHtml(message) + '</span>' +
                        '</div>');
                    
                    $('#notification-container').append(notification);
                    setTimeout(function() {
                        notification.fadeOut(300, function() { $(this).remove(); });
                    }, 3500);
                },
                
                confirm: function(options) {
                    $('#confirmationTitle').text(options.title || 'Confirm Action');
                    $('#confirmationMessage').text(options.message || 'Are you sure you want to proceed?');
                    window._confirmCallback = options.onConfirm;
                    window._confirmCancelCallback = options.onCancel;
                    $('#globalConfirmationModal').removeClass('hidden').addClass('flex');
                },
                
                showLoading: function(message) {
                    $('#loadingMessage').text(message || 'Loading...');
                    $('#globalLoadingOverlay').removeClass('hidden').addClass('flex');
                },
                
                hideLoading: function() {
                    $('#globalLoadingOverlay').addClass('hidden').removeClass('flex');
                },
                
                escapeHtml: function(text) {
                    if (!text) return text;
                    return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
                },
                
                formatDate: function(date, format) {
                    var d = new Date(date);
                    if (isNaN(d.getTime())) return '';
                    if (format === 'short')  return d.toLocaleDateString('en-US', { month:'short', day:'numeric' });
                    if (format === 'medium') return d.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
                    if (format === 'long')   return d.toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
                    return d.toLocaleDateString();
                },
                
                formatTime: function(date) {
                    var d = new Date(date);
                    if (isNaN(d.getTime())) return '--:--';
                    return d.toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit' });
                },
                
                getScoreColor: function(score) {
                    if (score >= 90) return { text: 'text-emerald-400', bg: 'bg-emerald-400/10', border: 'border-emerald-500', bar: '#10b981', icon: 'fa-trophy' };
                    if (score >= 75) return { text: 'text-indigo-400',  bg: 'bg-indigo-400/10',  border: 'border-indigo-500',  bar: '#6366f1', icon: 'fa-chart-line' };
                    if (score >= 60) return { text: 'text-amber-400',   bg: 'bg-amber-400/10',   border: 'border-amber-500',   bar: '#f59e0b', icon: 'fa-chart-simple' };
                    return { text: 'text-red-400', bg: 'bg-red-400/10', border: 'border-red-500', bar: '#ef4444', icon: 'fa-exclamation-triangle' };
                },
                
                exportToExcel: function(data, filename) {
                    var ws = XLSX.utils.json_to_sheet(data);
                    var wb = XLSX.utils.book_new();
                    XLSX.utils.book_append_sheet(wb, ws, 'Report');
                    XLSX.writeFile(wb, filename + '_' + this.formatDate(new Date(), 'short').replace(/\//g, '-') + '.xlsx');
                },
                
                exportToCSV: function(data, filename) {
                    var ws = XLSX.utils.json_to_sheet(data);
                    var csv = XLSX.utils.sheet_to_csv(ws);
                    var blob = new Blob([csv], { type: 'text/csv' });
                    var link = document.createElement('a');
                    link.href = URL.createObjectURL(blob);
                    link.download = filename + '_' + this.formatDate(new Date(), 'short').replace(/\//g, '-') + '.csv';
                    link.click();
                    URL.revokeObjectURL(link.href);
                },
                
                printReport: function(elementId) {
                    var printContents = $('#' + elementId).html();
                    var originalContents = document.body.innerHTML;
                    document.body.innerHTML = printContents;
                    window.print();
                    document.body.innerHTML = originalContents;
                    location.reload();
                }
            };
        })();
        
        // ── Global Confirmation ──
        window.globalConfirmExecute = function() {
            if (window._confirmCallback) window._confirmCallback();
            window.globalConfirmClose();
        };
        window.globalConfirmClose = function() {
            if (window._confirmCancelCallback) window._confirmCancelCallback();
            $('#globalConfirmationModal').addClass('hidden').removeClass('flex');
            window._confirmCallback = null;
            window._confirmCancelCallback = null;
        };
        
        // ── Sidebar ──
        function toggleSidebar() {
            var sidebar = $('#sidebar');
            sidebar.toggleClass('collapsed');
            var icon = $('#sidebar-toggle-icon');
            if (sidebar.hasClass('collapsed')) {
                icon.removeClass('fa-chevron-left').addClass('fa-chevron-right');
                localStorage.setItem('sidebarCollapsed', 'true');
            } else {
                icon.removeClass('fa-chevron-right').addClass('fa-chevron-left');
                localStorage.setItem('sidebarCollapsed', 'false');
            }
        }

        function openMobileSidebar() {
            $('#mobileSidebar').addClass('open');
            $('#mobileSidebarOverlay').removeClass('hidden');
            $('body').addClass('overflow-hidden');
        }
        
        function closeMobileSidebar() {
            $('#mobileSidebar').removeClass('open');
            $('#mobileSidebarOverlay').addClass('hidden');
            $('body').removeClass('overflow-hidden');
        }
        
        function toggleReportsDropdown() {
            $('#reports-dropdown').slideToggle(200);
            $('#reports-chevron').toggleClass('rotate-180');
        }
        
        function toggleQuickActions() {
            $('#quick-actions-dropdown').slideToggle(200);
            $('#user-menu-dropdown').slideUp(200);
            $('#notifications-dropdown').slideUp(200);
        }
        
        function toggleUserMenu() {
            $('#user-menu-dropdown').slideToggle(200);
            $('#quick-actions-dropdown').slideUp(200);
            $('#notifications-dropdown').slideUp(200);
            $('#user-menu-chevron').toggleClass('rotate-180');
        }
        
        function toggleNotifications() {
            $('#notifications-dropdown').slideToggle(200);
            $('#quick-actions-dropdown').slideUp(200);
            $('#user-menu-dropdown').slideUp(200);
        }
        
        function resetFilters() {
            $('input[type="text"].filter-input, input[type="search"].filter-input').val('');
            $('select.filter-select').val('');
            $('input.filter-input, select.filter-select').trigger('change');
            if (window.TaskTracker) TaskTracker.showNotification('Filters reset', 'info');
        }
        
        // ── Document Ready ──
        $(document).ready(function() {
            var token = $('input[name="__RequestVerificationToken"]').val() ||
                        $('#requestVerificationToken').val() || '';
            if (window.TaskTracker) TaskTracker.init(token);
            
            if (localStorage.getItem('sidebarCollapsed') === 'true') {
                $('#sidebar').addClass('collapsed');
                $('#sidebar-toggle-icon').removeClass('fa-chevron-left').addClass('fa-chevron-right');
            }
            
            $(document).click(function(event) {
                if (!$(event.target).closest('.relative, .dropdown-trigger').length) {
                    $('.dropdown-menu').slideUp(200);
                }
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>