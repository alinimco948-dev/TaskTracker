@model TaskTracker.Models.ViewModels.DepartmentDetailsViewModel
@{
    ViewData["Title"] = "Department Details";
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <div class="text-center mb-4">
                <div class="w-20 h-20 mx-auto rounded-full bg-blue-100 flex items-center justify-center mb-4">
                    <i class="fas fa-building text-3xl text-blue-600"></i>
                </div>
                <h2 class="text-xl font-bold">@Model.Name</h2>
                <p class="text-gray-500">@Model.Code</p>
                <div class="mt-2">
                    @if (Model.IsActive)
                    {
                        <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-xs">Active</span>
                    }
                    else
                    {
                        <span class="px-3 py-1 bg-red-100 text-red-800 rounded-full text-xs">Inactive</span>
                    }
                </div>
            </div>
            <div class="border-t pt-4">
                <h3 class="font-semibold mb-2">Description</h3>
                <p class="text-sm text-gray-600">@Model.Description</p>
            </div>
            <div class="border-t pt-4 mt-4">
                <h3 class="font-semibold mb-2">Statistics</h3>
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <span class="text-gray-600">Created:</span>
                        <span>@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="lg:col-span-2 space-y-6">
        <div class="grid grid-cols-2 gap-4">
            <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200">
                <div class="text-2xl font-bold text-blue-600">@Model.BranchCount</div>
                <div class="text-sm text-gray-500">Total Branches</div>
            </div>
            <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200">
                <div class="text-2xl font-bold text-green-600">@Model.EmployeeCount</div>
                <div class="text-sm text-gray-500">Total Employees</div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border border-gray-200">
            <div class="p-4 border-b border-gray-200">
                <h3 class="font-semibold">Branches</h3>
            </div>
            <div class="p-4">
                @if (Model.Branches.Any())
                {
                    <div class="grid grid-cols-1 gap-2">
                        @foreach (var branch in Model.Branches)
                        {
                            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                <div>
                                    <div class="font-medium">@branch.Name</div>
                                    <div class="text-xs text-gray-500">@branch.Address</div>
                                </div>
                                <div class="text-sm text-green-600">@branch.CompletionRate%</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 text-center py-4">No branches in this department</p>
                }
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm border border-gray-200">
            <div class="p-4 border-b border-gray-200">
                <h3 class="font-semibold">Employees</h3>
            </div>
            <div class="p-4">
                @if (Model.Employees.Any())
                {
                    <div class="grid grid-cols-1 gap-2">
                        @foreach (var emp in Model.Employees)
                        {
                            <div class="flex items-center space-x-3 p-3 bg-gray-50 rounded-lg">
                                <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                                    <span class="text-xs font-semibold text-blue-600">@emp.Initials</span>
                                </div>
                                <div>
                                    <div class="font-medium">@emp.Name</div>
                                    <div class="text-xs text-gray-500">@emp.Position</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 text-center py-4">No employees in this department</p>
                }
            </div>
        </div>
    </div>
</div>