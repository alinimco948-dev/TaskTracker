@model TaskTracker.Models.ViewModels.DepartmentViewModel
@{
    ViewData["Title"] = "Edit Department";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">Edit Department</h2>
            <p class="text-blue-100 text-sm mt-1">Update department information</p>
        </div>

        <form asp-action="Edit" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 text-red-700 rounded-lg text-sm border border-red-200"></div>

            <div class="space-y-6">
                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                        Department Name <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
                    <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
                    <p class="text-xs text-gray-400 mt-1">Department name must be unique</p>
                </div>

                <div>
                    <label asp-for="Code" class="block text-sm font-medium text-gray-700 mb-1">
                        Department Code
                    </label>
                    <input asp-for="Code" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
                    <span asp-validation-for="Code" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">
                        Description
                    </label>
                    <textarea asp-for="Description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition">@Model.Description</textarea>
                    <span asp-validation-for="Description" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="bg-gray-50 p-4 rounded-lg">
                    <label class="flex items-center space-x-3">
                        <input asp-for="IsActive" type="checkbox" class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                        <span class="text-sm font-medium text-gray-700">Active Department</span>
                    </label>
                    <p class="text-xs text-gray-500 mt-1 ml-7">Inactive departments won't appear in dropdown menus and reports</p>
                </div>

                <div class="flex justify-end space-x-3 pt-4 border-t">
                    <a href="@Url.Action("Index")" class="px-6 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                        <i class="fas fa-times mr-2"></i>Cancel
                    </a>
                    <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition flex items-center shadow-sm">
                        <i class="fas fa-save mr-2"></i>Update Department
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}