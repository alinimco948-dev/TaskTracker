@model TaskTracker.Models.ViewModels.DepartmentViewModel
@{
    ViewData["Title"] = "Edit Department";
}

<div class="max-w-2xl mx-auto animate-fade-up">
    <div class="glass-card overflow-hidden">
        <!-- Header -->
        <div class="px-6 py-5 flex items-center gap-4" style="background: linear-gradient(135deg, rgba(99,102,241,0.3), rgba(124,58,237,0.2)); border-bottom: 1px solid rgba(255,255,255,0.08);">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: linear-gradient(135deg, #6366f1, #7c3aed); box-shadow: 0 4px 15px rgba(99,102,241,0.4);">
                <i class="fas fa-edit text-white"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-white">Edit Department</h2>
                <p class="text-slate-400 text-sm mt-0.5">Update department information</p>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="p-6 space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="alert-error rounded-xl p-4 text-sm"></div>

            <div>
                <label asp-for="Name" class="block text-sm font-semibold text-slate-300 mb-2">
                    Department Name <span class="text-red-400">*</span>
                </label>
                <input asp-for="Name" class="dark-input" />
                <span asp-validation-for="Name" class="text-xs text-red-400 mt-1 block"></span>
                <p class="text-xs text-slate-500 mt-1">Department name must be unique</p>
            </div>

            <div>
                <label asp-for="Code" class="block text-sm font-semibold text-slate-300 mb-2">Department Code</label>
                <input asp-for="Code" class="dark-input" />
                <span asp-validation-for="Code" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-semibold text-slate-300 mb-2">Description</label>
                <textarea asp-for="Description" rows="4" class="dark-input resize-none">@Model.Description</textarea>
                <span asp-validation-for="Description" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <div class="rounded-xl p-4 flex items-center gap-4" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                <input asp-for="IsActive" type="checkbox" class="w-4 h-4 accent-indigo-500 cursor-pointer" />
                <div>
                    <span class="text-sm font-semibold text-slate-200">Active Department</span>
                    <p class="text-xs text-slate-500 mt-0.5">Inactive departments won't appear in dropdown menus and reports</p>
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t" style="border-color: rgba(255,255,255,0.06);">
                <a href="@Url.Action("Index")" class="px-5 py-2.5 rounded-xl border border-white/10 text-slate-300 hover:bg-white/5 transition text-sm font-medium flex items-center gap-2">
                    <i class="fas fa-times"></i>Cancel
                </a>
                <button type="submit" class="btn-primary">
                    <i class="fas fa-save"></i>Update Department
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}