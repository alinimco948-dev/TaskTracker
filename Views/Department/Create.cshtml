@model TaskTracker.Models.ViewModels.DepartmentViewModel
@{
    ViewData["Title"] = "Create Department";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">Create New Department</h2>
            <p class="text-blue-100 text-sm mt-1">Add a new department to organize branches and employees</p>
        </div>

        <form asp-action="Create" method="post" class="p-6">
            @Html.AntiForgeryToken()

            <div class="space-y-6">
                <!-- Department Name -->
                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                        Department Name <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           placeholder="e.g., Operations, Finance, IT" />
                    <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Department Code -->
                <div>
                    <label asp-for="Code" class="block text-sm font-medium text-gray-700 mb-1">
                        Department Code
                    </label>
                    <input asp-for="Code" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           placeholder="e.g., OPS, FIN, ITD" />
                    <p class="text-xs text-gray-500 mt-1">A unique code to identify the department (optional)</p>
                    <span asp-validation-for="Code" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Description -->
                <div>
                    <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">
                        Description
                    </label>
                    <textarea asp-for="Description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                              placeholder="Enter a brief description of the department's purpose and responsibilities..."></textarea>
                    <span asp-validation-for="Description" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Active Status -->
                <div class="bg-gray-50 p-4 rounded-lg">
                    <label class="flex items-center space-x-3">
                        <input asp-for="IsActive" type="checkbox" class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" checked />
                        <span class="text-sm font-medium text-gray-700">Active Department</span>
                    </label>
                    <p class="text-xs text-gray-500 mt-1 ml-7">Inactive departments won't appear in dropdown menus and reports</p>
                </div>

                <!-- Form Actions -->
                <div class="flex justify-end space-x-3 pt-4 border-t">
                    <a href="@Url.Action("Index")" class="px-6 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition duration-200">
                        <i class="fas fa-times mr-2"></i>Cancel
                    </a>
                    <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition duration-200 flex items-center">
                        <i class="fas fa-save mr-2"></i>Create Department
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Help Card -->
    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
        <div class="flex items-start space-x-3">
            <div class="flex-shrink-0">
                <i class="fas fa-info-circle text-blue-600 mt-1"></i>
            </div>
            <div class="text-sm text-blue-800">
                <p class="font-medium mb-1">About Departments</p>
                <p>Departments help you organize your branches and employees into logical groups. Each department can have multiple branches and employees assigned to it.</p>
                <ul class="list-disc list-inside mt-2 text-blue-700">
                    <li>Departments are optional - branches and employees can exist without a department</li>
                    <li>You can change a department's status anytime</li>
                    <li>Department codes should be unique for easy identification</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}