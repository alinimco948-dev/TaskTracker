@model TaskTracker.Models.Entities.Holiday
@{
    ViewData["Title"] = "Holiday Details";

    var weekdays = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-purple-600 to-purple-800 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">Holiday Details</h2>
        </div>

        <div class="p-6">
            <div class="flex items-center justify-center mb-6">
                <div class="w-24 h-24 rounded-full bg-purple-100 flex items-center justify-center">
                    <i class="fas fa-calendar-alt text-4xl text-purple-600"></i>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-4">
                <div class="border-b pb-3">
                    <div class="text-sm text-gray-500">Holiday Type</div>
                    <div class="font-medium">
                        @if (Model.IsWeekly)
                        {
                            <span class="px-3 py-1 bg-purple-100 text-purple-800 rounded-full text-sm">Weekly Recurring</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">Specific Date</span>
                        }
                    </div>
                </div>

                @if (Model.IsWeekly)
                {
                    <div class="border-b pb-3">
                        <div class="text-sm text-gray-500">Day of Week</div>
                        <div class="font-medium text-lg">@(Model.WeekDay.HasValue? weekdays[Model.WeekDay.Value] : "Not specified")</div>
                    </div>
                }
                else
                {
                    <div class="border-b pb-3">
                        <div class="text-sm text-gray-500">Date</div>
                        <div class="font-medium text-lg">@Model.HolidayDate.ToString("dddd, MMMM dd, yyyy")</div>
                    </div>
                }

                <div class="border-b pb-3">
                    <div class="text-sm text-gray-500">Description</div>
                    <div class="font-medium">@(!string.IsNullOrEmpty(Model.Description) ? Model.Description : "No description provided")</div>
                </div>

                <div class="grid grid-cols-2 gap-4 pt-4">
                    <div>
                        <div class="text-sm text-gray-500">Created</div>
                        <div class="font-medium">@DateTime.Now.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div>
                        <div class="text-sm text-gray-500">Last Updated</div>
                        <div class="font-medium">@DateTime.Now.ToString("MMM dd, yyyy")</div>
                    </div>
                </div>
            </div>

            <div class="flex justify-end space-x-2 mt-6 pt-4 border-t">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="px-4 py-2 bg-purple-600 text-white rounded-lg text-sm hover:bg-purple-700">
                    <i class="fas fa-edit mr-2"></i>Edit
                </a>
                <a href="@Url.Action("Index")" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
                    <i class="fas fa-arrow-left mr-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>