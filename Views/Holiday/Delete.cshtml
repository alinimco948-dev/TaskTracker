@model TaskTracker.Models.Entities.Holiday
@{
    ViewData["Title"] = "Delete Holiday";

    var weekdays = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-red-600 to-red-800 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">Delete Holiday</h2>
        </div>

        <div class="p-6">
            <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-triangle text-yellow-400"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-yellow-700">
                            Are you sure you want to delete this holiday? This action cannot be undone.
                        </p>
                    </div>
                </div>
            </div>

            <div class="space-y-4">
                <div class="border rounded-lg p-4 bg-gray-50">
                    <h3 class="font-medium text-lg mb-2">@(Model.IsWeekly ? "Weekly Holiday" : "Specific Holiday")</h3>

                    @if (Model.IsWeekly)
                    {
                        <p><span class="font-medium">Day:</span> @(Model.WeekDay.HasValue? weekdays[Model.WeekDay.Value] : "Not specified")</p>
                    }
                    else
                    {
                        <p><span class="font-medium">Date:</span> @Model.HolidayDate.ToString("dddd, MMMM dd, yyyy")</p>
                    }

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="mt-2"><span class="font-medium">Description:</span> @Model.Description</p>
                    }
                </div>
            </div>

            <form asp-action="Delete" method="post" class="flex justify-end space-x-2 mt-6 pt-4 border-t">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <a href="@Url.Action("Index")" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</a>
                <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm hover:bg-red-700">
                    <i class="fas fa-trash mr-2"></i>Delete Holiday
                </button>
            </form>
        </div>
    </div>
</div>