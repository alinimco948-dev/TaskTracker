@model TaskTracker.Models.Entities.Holiday
@{
    ViewData["Title"] = "Delete Holiday";
    var weekdays = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}

<div class="max-w-2xl mx-auto animate-fade-up">
    <div class="glass-card overflow-hidden" style="border-color: rgba(239,68,68,0.3);">
        <!-- Header -->
        <div class="px-6 py-4 flex items-center gap-3" style="background: linear-gradient(135deg, #dc2626, #b91c1c);">
            <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
                <i class="fas fa-exclamation-triangle text-white"></i>
            </div>
            <h2 class="text-xl font-bold text-white">Delete Holiday</h2>
        </div>

        <div class="p-6">
            <!-- Warning -->
            <div class="rounded-xl p-4 mb-6 flex items-start gap-3" style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25);">
                <i class="fas fa-exclamation-triangle text-amber-400 mt-0.5 flex-shrink-0"></i>
                <p class="text-sm text-amber-300">Are you sure you want to delete this holiday? This action cannot be undone.</p>
            </div>

            <!-- Holiday Info -->
            <div class="rounded-xl p-5" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                <h3 class="font-bold text-white mb-3 flex items-center gap-2">
                    <i class="fas @(Model.IsWeekly ? "fa-calendar-week text-violet-400" : "fa-calendar-day text-indigo-400")"></i>
                    @(Model.IsWeekly ? "Weekly Holiday" : "Specific Holiday")
                </h3>

                @if (Model.IsWeekly)
                {
                    <div class="flex items-center gap-2 text-sm">
                        <span class="text-slate-400">Day:</span>
                        <span class="stat-badge font-semibold" style="background: rgba(124,58,237,0.15); color: #c4b5fd;">
                            @(Model.WeekDay.HasValue ? weekdays[Model.WeekDay.Value] : "Not specified")
                        </span>
                    </div>
                }
                else
                {
                    <div class="flex items-center gap-2 text-sm">
                        <span class="text-slate-400">Date:</span>
                        <span class="text-white font-semibold">@Model.HolidayDate.ToString("dddd, MMMM dd, yyyy")</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="flex items-start gap-2 text-sm mt-2">
                        <span class="text-slate-400">Description:</span>
                        <span class="text-slate-300">@Model.Description</span>
                    </div>
                }
            </div>

            <form asp-action="Delete" method="post" class="flex justify-end gap-3 mt-6 pt-5 border-t" style="border-color: rgba(255,255,255,0.06);">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <a href="@Url.Action("Index")" class="px-5 py-2.5 rounded-xl border border-white/10 text-slate-300 hover:bg-white/5 transition text-sm font-medium flex items-center gap-2">
                    <i class="fas fa-times"></i>Cancel
                </a>
                <button type="submit" class="px-5 py-2.5 rounded-xl text-sm font-medium text-white flex items-center gap-2 transition"
                        style="background: linear-gradient(135deg, #dc2626, #b91c1c); box-shadow: 0 4px 15px rgba(239,68,68,0.3);">
                    <i class="fas fa-trash"></i>Delete Holiday
                </button>
            </form>
        </div>
    </div>
</div>