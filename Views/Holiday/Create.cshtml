@model TaskTracker.Models.Entities.Holiday
@{
    ViewData["Title"] = "Create Holiday";
}

<div class="max-w-2xl mx-auto animate-fade-up">
    <div class="glass-card overflow-hidden">
        <!-- Header -->
        <div class="px-6 py-5 flex items-center gap-4" style="background: linear-gradient(135deg, rgba(124,58,237,0.25), rgba(99,102,241,0.15)); border-bottom: 1px solid rgba(255,255,255,0.08);">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: linear-gradient(135deg, #7c3aed, #6366f1); box-shadow: 0 4px 15px rgba(124,58,237,0.4);">
                <i class="fas fa-calendar-plus text-white"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-white">Create New Holiday</h2>
                <p class="text-slate-400 text-sm mt-0.5">Add a holiday to the schedule</p>
            </div>
        </div>

        <form asp-action="Create" method="post" class="p-6 space-y-5">
            @Html.AntiForgeryToken()

            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Holiday Type</label>
                <div class="grid grid-cols-2 gap-3">
                    <label class="cursor-pointer">
                        <input type="radio" name="holidayType" value="specific" class="sr-only peer" checked onchange="toggleHolidayType()">
                        <div class="p-4 rounded-xl border-2 transition peer-checked:border-indigo-500 text-center"
                             style="border-color: rgba(255,255,255,0.08); background: rgba(255,255,255,0.04);">
                            <i class="fas fa-calendar-day text-indigo-400 text-xl mb-2 block"></i>
                            <span class="text-sm font-semibold text-slate-300">Specific Date</span>
                            <p class="text-xs text-slate-500 mt-0.5">One-time holiday</p>
                        </div>
                    </label>
                    <label class="cursor-pointer">
                        <input type="radio" name="holidayType" value="weekly" class="sr-only peer" onchange="toggleHolidayType()">
                        <div class="p-4 rounded-xl border-2 transition peer-checked:border-violet-500 text-center"
                             style="border-color: rgba(255,255,255,0.08); background: rgba(255,255,255,0.04);">
                            <i class="fas fa-calendar-week text-violet-400 text-xl mb-2 block"></i>
                            <span class="text-sm font-semibold text-slate-300">Weekly Recurring</span>
                            <p class="text-xs text-slate-500 mt-0.5">Repeats every week</p>
                        </div>
                    </label>
                </div>
            </div>

            <div id="specificDateSection">
                <label asp-for="HolidayDate" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Date <span class="text-red-400">*</span></label>
                <input asp-for="HolidayDate" type="date" class="dark-input"
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="HolidayDate" class="text-xs text-red-400 mt-1 block"></span>
            </div>

            <div id="weeklySection" class="hidden">
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Day of Week <span class="text-red-400">*</span></label>
                <select id="WeekDay" name="WeekDay" class="dark-input">
                    <option value="">Select a day</option>
                    <option value="0">Sunday</option>
                    <option value="1">Monday</option>
                    <option value="2">Tuesday</option>
                    <option value="3">Wednesday</option>
                    <option value="4">Thursday</option>
                    <option value="5">Friday</option>
                    <option value="6">Saturday</option>
                </select>
            </div>

            <div>
                <label asp-for="Description" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Description (Optional)</label>
                <textarea asp-for="Description" rows="2" class="dark-input resize-none"
                          placeholder="e.g., New Year's Day, Christmas, etc."></textarea>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t" style="border-color: rgba(255,255,255,0.06);">
                <a href="@Url.Action("Index")" class="px-5 py-2.5 rounded-xl border border-white/10 text-slate-300 hover:bg-white/5 transition text-sm font-medium flex items-center gap-2">
                    <i class="fas fa-times"></i>Cancel
                </a>
                <button type="submit" class="btn-primary" style="background: linear-gradient(135deg, #7c3aed, #6366f1);">
                    <i class="fas fa-calendar-plus"></i>Create Holiday
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleHolidayType() {
        var type = document.querySelector('input[name="holidayType"]:checked').value;
        var specificSection = document.getElementById('specificDateSection');
        var weeklySection = document.getElementById('weeklySection');
        var specificInput = document.getElementById('HolidayDate');
        var weeklySelect = document.getElementById('WeekDay');
        if (type === 'specific') {
            specificSection.classList.remove('hidden');
            weeklySection.classList.add('hidden');
            weeklySelect.disabled = true;
            if (specificInput) specificInput.disabled = false;
        } else {
            specificSection.classList.add('hidden');
            weeklySection.classList.remove('hidden');
            weeklySelect.disabled = false;
            if (specificInput) specificInput.disabled = true;
        }
    }
    document.addEventListener('DOMContentLoaded', toggleHolidayType);
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}