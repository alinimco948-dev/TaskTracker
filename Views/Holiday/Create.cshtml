@model TaskTracker.Models.Entities.Holiday
@{
    ViewData["Title"] = "Create Holiday";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold mb-4">Create New Holiday</h2>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Holiday Type</label>
                <div class="flex space-x-4">
                    <label class="flex items-center">
                        <input type="radio" name="holidayType" value="specific" class="mr-2" checked onchange="toggleHolidayType()">
                        <span class="text-sm">Specific Date</span>
                    </label>
                    <label class="flex items-center">
                        <input type="radio" name="holidayType" value="weekly" class="mr-2" onchange="toggleHolidayType()">
                        <span class="text-sm">Weekly Recurring</span>
                    </label>
                </div>
            </div>

            <div id="specificDateSection">
                <div class="mb-4">
                    <label asp-for="HolidayDate" class="block text-sm font-medium text-gray-700 mb-1">Date *</label>
                    <input asp-for="HolidayDate" type="date" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")">
                    <span asp-validation-for="HolidayDate" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div id="weeklySection" class="hidden">
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Day of Week *</label>
                    <select id="WeekDay" name="WeekDay" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500">
                        <option value="">Select a day</option>
                        <option value="0">Sunday</option>
                        <option value="1">Monday</option>
                        <option value="2">Tuesday</option>
                        <option value="3">Wednesday</option>
                        <option value="4">Thursday</option>
                        <option value="5">Friday</option>
                        <option value="6">Saturday</option>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Description (Optional)</label>
                <textarea asp-for="Description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500"
                          placeholder="e.g., New Year's Day, Christmas, etc."></textarea>
            </div>

            <div class="flex justify-end space-x-2">
                <a href="@Url.Action("Index")" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Cancel</a>
                <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg text-sm hover:bg-purple-700">Create Holiday</button>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleHolidayType() {
        var type = document.querySelector('input[name="holidayType"]:checked').value;
        var specificSection = document.getElementById('specificDateSection');
        var weeklySection = document.getElementById('weeklySection');
        var specificInput = document.getElementById('HolidayDate');
        var weeklySelect = document.getElementById('WeekDay');

        if (type === 'specific') {
            specificSection.classList.remove('hidden');
            weeklySection.classList.add('hidden');
            weeklySelect.disabled = true;
            specificInput.disabled = false;
        } else {
            specificSection.classList.add('hidden');
            weeklySection.classList.remove('hidden');
            weeklySelect.disabled = false;
            specificInput.disabled = true;
        }
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
        toggleHolidayType();
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}