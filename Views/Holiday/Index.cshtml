@model IEnumerable<TaskTracker.Models.Entities.Holiday>
@{
    ViewData["Title"] = "Holiday Management";

    var holidaysList = Model?.ToList() ?? new List<TaskTracker.Models.Entities.Holiday>();
    var weeklyHolidays = holidaysList.Where(h => h.IsWeekly).Select(h => h.WeekDay).ToList();
    var specificHolidays = holidaysList.Where(h => !h.IsWeekly).OrderBy(h => h.HolidayDate).ToList();

    var weekdays = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };

    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }
}

<input type="hidden" id="requestVerificationToken" value="@token" />

<div class="space-y-6 animate-fade-up">

    <!-- Header -->
    <div class="flex flex-wrap justify-between items-start gap-4">
        <div>
            <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #7c3aed, #6366f1);">
                    <i class="fas fa-calendar-alt text-white text-sm"></i>
                </div>
                Holiday Management
            </h1>
            <p class="text-slate-400 mt-1">Configure weekly recurring holidays and specific date holidays</p>
        </div>
        <div class="stat-badge" style="background: rgba(99,102,241,0.15); color: #a5b4fc; padding: 0.5rem 1rem;">
            <i class="fas fa-calendar-alt"></i> Holidays affect task deadlines
        </div>
    </div>

    <div id="alertContainer"></div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Weekly Holidays -->
        <div class="glass-card overflow-hidden">
            <div class="px-5 py-4 border-b flex items-center gap-3" style="border-color: rgba(255,255,255,0.06); background: rgba(124,58,237,0.1);">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(124,58,237,0.3);">
                    <i class="fas fa-calendar-week text-violet-400 text-sm"></i>
                </div>
                <div>
                    <h3 class="font-bold text-white text-sm">Weekly Holidays</h3>
                    <p class="text-xs text-slate-500">Holidays that repeat every week on the same day</p>
                </div>
            </div>

            <div class="p-5">
                <!-- Day Toggle Buttons -->
                <div class="grid grid-cols-4 gap-2 mb-5">
                    @for (int i = 0; i < weekdays.Length; i++)
                    {
                        var isActive = weeklyHolidays.Contains(i);
                        <button type="button"
                                onclick="toggleWeeklyHoliday(@i, '@weekdays[i]')"
                                class="weekly-holiday-btn px-2 py-2.5 rounded-xl text-xs font-semibold transition-all duration-200"
                                data-day="@i"
                                data-active="@isActive.ToString().ToLower()"
                                style="@(isActive ? "background: linear-gradient(135deg, #7c3aed, #6366f1); color: white; box-shadow: 0 4px 12px rgba(124,58,237,0.4);" : "background: rgba(255,255,255,0.04); color: #94a3b8; border: 1px solid rgba(255,255,255,0.08);")">
                            @weekdays[i]
                            @if (isActive) { <i class="fas fa-check ml-1 text-[10px]"></i> }
                        </button>
                    }
                </div>

                <!-- Weekly Holiday List -->
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                    <i class="fas fa-list text-violet-500"></i>Configured Weekly Holidays
                </h4>
                @if (weeklyHolidays.Any())
                {
                    <div class="space-y-2">
                        @foreach (var day in weeklyHolidays.OrderBy(d => d))
                        {
                            var holiday = holidaysList.FirstOrDefault(h => h.IsWeekly && h.WeekDay == day);
                            <div class="flex items-center justify-between p-3 rounded-xl" style="background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.25);">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(124,58,237,0.25);">
                                        <i class="fas fa-calendar-week text-violet-400 text-xs"></i>
                                    </div>
                                    <div>
                                        <span class="font-semibold text-white text-sm">@weekdays[day!.Value]</span>
                                        @if (!string.IsNullOrEmpty(holiday?.Description) && holiday.Description != weekdays[day.Value])
                                        {
                                            <p class="text-xs text-slate-500">@holiday.Description</p>
                                        }
                                    </div>
                                </div>
                                <div class="flex items-center gap-1">
                                    <button type="button"
                                            onclick="editWeeklyHoliday(@day.Value, '@weekdays[day.Value]', '@(holiday?.Description ?? weekdays[day.Value])')"
                                            class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:text-violet-400 hover:bg-violet-400/10 transition">
                                        <i class="fas fa-edit text-xs"></i>
                                    </button>
                                    <button type="button"
                                            onclick="removeWeeklyHoliday(@day.Value, '@weekdays[day.Value]')"
                                            class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:text-red-400 hover:bg-red-400/10 transition">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-8 rounded-xl border border-dashed" style="border-color: rgba(255,255,255,0.08);">
                        <i class="fas fa-calendar-week text-3xl text-slate-600 mb-2 block"></i>
                        <p class="text-sm text-slate-500">No weekly holidays configured</p>
                        <p class="text-xs text-slate-600 mt-1">Click on any day above to add a weekly holiday</p>
                    </div>
                }
            </div>
        </div>

        <!-- Specific Date Holidays -->
        <div class="glass-card overflow-hidden">
            <div class="px-5 py-4 border-b flex items-center gap-3" style="border-color: rgba(255,255,255,0.06); background: rgba(99,102,241,0.1);">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(99,102,241,0.3);">
                    <i class="fas fa-calendar-day text-indigo-400 text-sm"></i>
                </div>
                <div>
                    <h3 class="font-bold text-white text-sm">Specific Date Holidays</h3>
                    <p class="text-xs text-slate-500">One-time holidays on specific dates</p>
                </div>
            </div>

            <div class="p-5">
                <!-- Add Specific Holiday Form -->
                <form id="addSpecificHolidayForm" class="mb-5">
                    @Html.AntiForgeryToken()
                    <div class="space-y-3">
                        <div>
                            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Date</label>
                            <input type="date" name="date" id="specificDate" class="dark-input"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Description (Optional)</label>
                            <div class="flex gap-2">
                                <input type="text" name="description" id="specificDescription" class="dark-input flex-1"
                                       placeholder="e.g., New Year's Day, Christmas..." />
                                <button type="button" onclick="addSpecificHoliday()" class="btn-primary whitespace-nowrap">
                                    <i class="fas fa-plus text-xs"></i>Add
                                </button>
                            </div>
                        </div>
                    </div>
                </form>

                <!-- Specific Holidays List -->
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                    <i class="fas fa-list text-indigo-500"></i>
                    Configured Specific Holidays
                    @if (specificHolidays.Any()) { <span class="text-slate-600">(@specificHolidays.Count)</span> }
                </h4>

                @if (specificHolidays.Any())
                {
                    <div class="space-y-2 max-h-80 overflow-y-auto pr-1">
                        @foreach (var holiday in specificHolidays)
                        {
                            <div class="flex items-center justify-between p-3 rounded-xl transition group"
                                 style="background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.15);"
                                 onmouseover="this.style.borderColor='rgba(99,102,241,0.3)'"
                                 onmouseout="this.style.borderColor='rgba(99,102,241,0.15)'">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(99,102,241,0.2);">
                                        <i class="fas fa-calendar-day text-indigo-400 text-xs"></i>
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-2">
                                            <span class="font-semibold text-white text-sm">@holiday.HolidayDate.ToString("dddd, MMMM d, yyyy")</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(holiday.Description) && holiday.Description != $"Holiday on {holiday.HolidayDate:MMMM d, yyyy}")
                                        {
                                            <p class="text-xs text-slate-400">@holiday.Description</p>
                                        }
                                        else
                                        {
                                            <p class="text-xs text-slate-600">No description</p>
                                        }
                                    </div>
                                </div>
                                <div class="flex items-center gap-1">
                                    <button type="button"
                                            onclick="editSpecificHoliday('@holiday.HolidayDate.ToString("yyyy-MM-dd")', '@holiday.Description?.Replace("'", "\\'")')"
                                            class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:text-indigo-400 hover:bg-indigo-400/10 transition opacity-0 group-hover:opacity-100">
                                        <i class="fas fa-edit text-xs"></i>
                                    </button>
                                    <button type="button"
                                            onclick="removeSpecificHoliday('@holiday.HolidayDate.ToString("yyyy-MM-dd")', '@holiday.Description?.Replace("'", "\\'")')"
                                            class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:text-red-400 hover:bg-red-400/10 transition">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-10 rounded-xl border border-dashed" style="border-color: rgba(255,255,255,0.08);">
                        <i class="fas fa-calendar-day text-3xl text-slate-600 mb-2 block"></i>
                        <p class="text-sm text-slate-500">No specific holidays configured</p>
                        <p class="text-xs text-slate-600 mt-1">Use the form above to add a holiday on a specific date</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Edit Weekly Holiday Modal -->
<div id="editWeeklyModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="w-full max-w-md rounded-2xl overflow-hidden border border-white/10 shadow-2xl animate-fade-up" style="background: #1a1a2e;">
        <div class="px-6 py-4 flex items-center gap-3" style="background: linear-gradient(135deg, rgba(124,58,237,0.4), rgba(99,102,241,0.3));">
            <i class="fas fa-calendar-week text-violet-400"></i>
            <h3 class="font-bold text-white">Edit Weekly Holiday</h3>
        </div>
        <div class="p-6 space-y-4">
            <input type="hidden" id="editWeekDay" />
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Day</label>
                <input type="text" id="editWeekDayName" readonly class="dark-input opacity-60" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Description</label>
                <textarea id="editWeeklyDescription" rows="2" class="dark-input resize-none" placeholder="Description for this holiday..."></textarea>
            </div>
        </div>
        <div class="px-6 py-4 border-t flex justify-end gap-3" style="border-color: rgba(255,255,255,0.06);">
            <button onclick="closeEditWeeklyModal()" class="px-4 py-2 rounded-lg text-sm text-slate-300 border border-white/10 hover:bg-white/5 transition">Cancel</button>
            <button onclick="saveWeeklyDescription()" class="btn-primary" style="background: linear-gradient(135deg, #7c3aed, #6366f1);">
                <i class="fas fa-save"></i>Save
            </button>
        </div>
    </div>
</div>

<!-- Edit Specific Holiday Modal -->
<div id="editSpecificModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="w-full max-w-md rounded-2xl overflow-hidden border border-white/10 shadow-2xl animate-fade-up" style="background: #1a1a2e;">
        <div class="px-6 py-4 flex items-center gap-3" style="background: linear-gradient(135deg, rgba(99,102,241,0.4), rgba(124,58,237,0.3));">
            <i class="fas fa-calendar-day text-indigo-400"></i>
            <h3 class="font-bold text-white">Edit Specific Holiday</h3>
        </div>
        <div class="p-6 space-y-4">
            <input type="hidden" id="editSpecificDate" />
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Date</label>
                <input type="text" id="editSpecificDateDisplay" readonly class="dark-input opacity-60" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">Description</label>
                <textarea id="editSpecificDescription" rows="2" class="dark-input resize-none" placeholder="Description for this holiday..."></textarea>
            </div>
        </div>
        <div class="px-6 py-4 border-t flex justify-end gap-3" style="border-color: rgba(255,255,255,0.06);">
            <button onclick="closeEditSpecificModal()" class="px-4 py-2 rounded-lg text-sm text-slate-300 border border-white/10 hover:bg-white/5 transition">Cancel</button>
            <button onclick="saveSpecificDescription()" class="btn-primary">
                <i class="fas fa-save"></i>Save
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showAlert(message, type) {
            const configs = {
                success: { cls: 'alert-success', icon: 'fa-check-circle' },
                error:   { cls: 'alert-error',   icon: 'fa-exclamation-circle' },
                warning: { cls: 'alert-warning',  icon: 'fa-exclamation-triangle' },
                info:    { cls: 'alert-info',     icon: 'fa-info-circle' }
            };
            const c = configs[type] || configs.info;
            const alert = $(`<div class="${c.cls} rounded-xl p-4 mb-3 flex items-center justify-between animate-slide-in">
                <div class="flex items-center gap-3"><i class="fas ${c.icon}"></i><span class="text-sm">${message}</span></div>
                <button onclick="$(this).closest('div.rounded-xl').fadeOut()" class="ml-3 opacity-70 hover:opacity-100"><i class="fas fa-times"></i></button>
            </div>`);
            $('#alertContainer').prepend(alert);
            setTimeout(() => alert.fadeOut(300, () => alert.remove()), 5000);
        }

        async function toggleWeeklyHoliday(weekDay, dayName) {
            const btn = $(`.weekly-holiday-btn[data-day="${weekDay}"]`);
            const isActive = btn.data('active') === 'true';
            const token = $('#requestVerificationToken').val();
            btn.html('<i class="fas fa-spinner fa-spin"></i>').prop('disabled', true);
            try {
                const response = await $.ajax({ url: '@Url.Action("ToggleWeekly", "Holiday")', type: 'POST', data: { weekDay }, headers: { 'RequestVerificationToken': token } });
                if (response.success) { if (window.TaskTracker) TaskTracker.showNotification(response.message, 'success'); setTimeout(() => location.reload(), 1000); }
                else { if (window.TaskTracker) TaskTracker.showNotification(response.message || 'Error', 'error'); btn.prop('disabled', false); }
            } catch(e) { if (window.TaskTracker) TaskTracker.showNotification('Error toggling holiday', 'error'); btn.prop('disabled', false); }
        }

        function editWeeklyHoliday(weekDay, dayName, description) {
            $('#editWeekDay').val(weekDay); $('#editWeekDayName').val(dayName);
            $('#editWeeklyDescription').val(description !== dayName ? description : '');
            $('#editWeeklyModal').removeClass('hidden').addClass('flex');
        }
        async function saveWeeklyDescription() {
            const weekDay = $('#editWeekDay').val(), description = $('#editWeeklyDescription').val(), token = $('#requestVerificationToken').val();
            closeEditWeeklyModal();
            try {
                await $.ajax({ url: '@Url.Action("RemoveWeekly", "Holiday")', type: 'POST', data: { weekDay }, headers: { 'RequestVerificationToken': token } });
                await $.ajax({ url: '@Url.Action("AddWeeklyWithDescription", "Holiday")', type: 'POST', data: { weekDay, description }, headers: { 'RequestVerificationToken': token } });
                if (window.TaskTracker) TaskTracker.showNotification('Description updated', 'success');
                setTimeout(() => location.reload(), 1000);
            } catch(e) { if (window.TaskTracker) TaskTracker.showNotification('Error updating', 'error'); }
        }
        function closeEditWeeklyModal() { $('#editWeeklyModal').addClass('hidden').removeClass('flex'); }
        async function removeWeeklyHoliday(weekDay, dayName) {
            if (!confirm(`Remove "${dayName}" as a weekly holiday?`)) return;
            const token = $('#requestVerificationToken').val();
            const response = await $.ajax({ url: '@Url.Action("RemoveWeekly", "Holiday")', type: 'POST', data: { weekDay }, headers: { 'RequestVerificationToken': token } });
            if (response.success) { if (window.TaskTracker) TaskTracker.showNotification(response.message, 'success'); setTimeout(() => location.reload(), 1000); }
        }

        async function addSpecificHoliday() {
            const date = $('#specificDate').val(), description = $('#specificDescription').val(), token = $('#requestVerificationToken').val();
            if (!date) { showAlert('Please select a date', 'warning'); return; }
            const btn = $('#addSpecificHolidayForm button'), orig = btn.html();
            btn.html('<i class="fas fa-spinner fa-spin"></i> Adding...').prop('disabled', true);
            try {
                const response = await $.ajax({ url: '@Url.Action("AddSpecific", "Holiday")', type: 'POST', data: { date, description }, headers: { 'RequestVerificationToken': token } });
                if (response.success) { if (window.TaskTracker) TaskTracker.showNotification(response.message, 'success'); $('#specificDescription').val(''); setTimeout(() => location.reload(), 1000); }
                else { showAlert(response.message || 'Error adding holiday', 'error'); btn.html(orig).prop('disabled', false); }
            } catch(e) { let msg='Error'; try{msg=JSON.parse(e.responseText).message||msg;}catch(x){} showAlert(msg,'error'); btn.html(orig).prop('disabled', false); }
        }
        function editSpecificHoliday(date, description) {
            $('#editSpecificDate').val(date);
            $('#editSpecificDateDisplay').val(new Date(date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }));
            $('#editSpecificDescription').val(description);
            $('#editSpecificModal').removeClass('hidden').addClass('flex');
        }
        async function saveSpecificDescription() {
            const date = $('#editSpecificDate').val(), description = $('#editSpecificDescription').val(), token = $('#requestVerificationToken').val();
            closeEditSpecificModal();
            try {
                await $.ajax({ url: '@Url.Action("RemoveSpecific", "Holiday")', type: 'POST', data: { date }, headers: { 'RequestVerificationToken': token } });
                await $.ajax({ url: '@Url.Action("AddSpecific", "Holiday")', type: 'POST', data: { date, description }, headers: { 'RequestVerificationToken': token } });
                if (window.TaskTracker) TaskTracker.showNotification('Description updated', 'success');
                setTimeout(() => location.reload(), 1000);
            } catch(e) { if (window.TaskTracker) TaskTracker.showNotification('Error updating', 'error'); }
        }
        function closeEditSpecificModal() { $('#editSpecificModal').addClass('hidden').removeClass('flex'); }
        async function removeSpecificHoliday(date, description) {
            const displayDate = new Date(date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
            if (!confirm(`Remove holiday on ${displayDate}?`)) return;
            const token = $('#requestVerificationToken').val();
            const response = await $.ajax({ url: '@Url.Action("RemoveSpecific", "Holiday")', type: 'POST', data: { date }, headers: { 'RequestVerificationToken': token } });
            if (response.success) { if (window.TaskTracker) TaskTracker.showNotification(response.message, 'success'); setTimeout(() => location.reload(), 1000); }
        }
    </script>
}