@model IEnumerable<TaskTracker.Models.Entities.Holiday>
@{
    ViewData["Title"] = "Holiday Management";

    // Process the data
    var holidaysList = Model?.ToList() ?? new List<TaskTracker.Models.Entities.Holiday>();
    var weeklyHolidays = holidaysList.Where(h => h.IsWeekly).Select(h => h.WeekDay).ToList();
    var specificHolidays = holidaysList.Where(h => !h.IsWeekly).OrderBy(h => h.HolidayDate).ToList();

    var weekdays = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold mb-6">Holiday Management</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Weekly Holidays Section -->
        <div class="border rounded-lg p-6 bg-gray-50">
            <h3 class="font-medium text-lg mb-4 flex items-center">
                <i class="fas fa-calendar-week text-purple-600 mr-2"></i>
                Weekly Holidays
            </h3>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
                @for (int i = 0; i < weekdays.Length; i++)
                {
                    var isActive = weeklyHolidays.Contains(i);
                    <form asp-action="ToggleWeekly" method="post" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="weekDay" value="@i" />
                        <button type="submit"
                                class="w-full px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200
                                           @(isActive ? "bg-purple-600 text-white hover:bg-purple-700" : "bg-white text-gray-700 border border-gray-300 hover:bg-gray-100")">
                            @weekdays[i]
                            @if (isActive)
                            {
                                <i class="fas fa-check ml-1"></i>
                            }
                        </button>
                    </form>
                }
            </div>

            <div class="mt-4">
                <h4 class="text-sm font-medium text-gray-700 mb-2">Current Weekly Holidays:</h4>
                @if (weeklyHolidays.Any())
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var day in weeklyHolidays.OrderBy(d => d))
                        {
                            <div class="flex items-center bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm">
                                <span>@weekdays[day.Value]</span>
                                <form asp-action="RemoveWeekly" method="post" class="ml-2" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="weekDay" value="@day" />
                                    <button type="submit" class="text-purple-600 hover:text-purple-800">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 text-sm">No weekly holidays set</p>
                }
            </div>
        </div>

        <!-- Specific Dates Section -->
        <div class="border rounded-lg p-6 bg-gray-50">
            <h3 class="font-medium text-lg mb-4 flex items-center">
                <i class="fas fa-calendar-day text-blue-600 mr-2"></i>
                Specific Dates
            </h3>

            <form asp-action="AddSpecific" method="post" class="mb-6">
                @Html.AntiForgeryToken()
                <div class="flex space-x-2">
                    <input type="date" name="date" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700 transition flex items-center">
                        <i class="fas fa-plus mr-1"></i>Add
                    </button>
                </div>
            </form>

            <div class="mt-4">
                <h4 class="text-sm font-medium text-gray-700 mb-2">Current Specific Holidays:</h4>
                @if (specificHolidays.Any())
                {
                    <div class="space-y-2 max-h-60 overflow-y-auto">
                        @foreach (var holiday in specificHolidays)
                        {
                            <div class="flex justify-between items-center p-3 bg-white rounded-lg border border-gray-200">
                                <div>
                                    <span class="font-medium">@holiday.HolidayDate.ToString("MMM dd, yyyy")</span>
                                    @if (!string.IsNullOrEmpty(holiday.Description) && holiday.Description != $"Holiday on {holiday.HolidayDate:MMMM d, yyyy}")
                                    {
                                        <span class="text-xs text-gray-500 block">@holiday.Description</span>
                                    }
                                </div>
                                <form asp-action="RemoveSpecific" method="post" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="date" value="@holiday.HolidayDate.ToString("yyyy-MM-dd")" />
                                    <button type="submit" class="text-red-600 hover:text-red-800 p-1">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 text-sm">No specific holidays set</p>
                }
            </div>
        </div>
    </div>

    <!-- Combined Holiday List (Optional) -->
    @if (holidaysList.Any())
    {
        <div class="mt-8 border-t pt-6">
            <h3 class="font-medium text-lg mb-4">All Holidays</h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-100">
                        <tr>
                            <th class="px-4 py-2 text-left">Type</th>
                            <th class="px-4 py-2 text-left">Date/Day</th>
                            <th class="px-4 py-2 text-left">Description</th>
                            <th class="px-4 py-2 text-left">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        @foreach (var holiday in holidaysList.OrderBy(h => h.IsWeekly).ThenBy(h => h.HolidayDate))
                        {
                            <tr>
                                <td class="px-4 py-2">
                                    @if (holiday.IsWeekly)
                                    {
                                        <span class="px-2 py-1 bg-purple-100 text-purple-800 rounded-full text-xs">Weekly</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs">Specific</span>
                                    }
                                </td>
                                <td class="px-4 py-2">
                                    @if (holiday.IsWeekly && holiday.WeekDay.HasValue)
                                    {
                                        @weekdays[holiday.WeekDay.Value]
                                    }
                                    else
                                    {
                                        @holiday.HolidayDate.ToString("MMM dd, yyyy")
                                    }
                                </td>
                                <td class="px-4 py-2">@holiday.Description</td>
                                <td class="px-4 py-2">
                                    <form asp-action="Delete" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@holiday.Id" />
                                        <button type="submit" class="text-red-600 hover:text-red-800" onclick="return confirm('Delete this holiday?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('Holiday page loaded');
        });
    </script>
}