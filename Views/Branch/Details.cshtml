@model TaskTracker.Models.ViewModels.BranchDetailsViewModel
@{
    ViewData["Title"] = "Branch Details";

    var initials = "?";
    if (!string.IsNullOrEmpty(Model.Name))
    {
        var nameParts = Model.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (nameParts.Length == 1)
            initials = nameParts[0].Substring(0, 1).ToUpper();
        else if (nameParts.Length >= 2)
            initials = (nameParts[0][0].ToString() + nameParts[^1][0].ToString()).ToUpper();
    }

    var recentTasksList = Model.RecentTasks ?? new List<BranchTaskItem>();
    var completedRecentTasks = recentTasksList.Count(t => t.IsCompleted);
    var recentCompletionRate = recentTasksList.Any() ? Math.Round((double)completedRecentTasks / recentTasksList.Count * 100, 1) : 0;
    var completedTasks = recentTasksList.Where(t => t.IsCompleted).OrderByDescending(t => t.Date).Take(5).ToList();
    var pendingTasks = recentTasksList.Where(t => !t.IsCompleted).OrderBy(t => t.Date).Take(5).ToList();

    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }
}

<input type="hidden" id="requestVerificationToken" value="@token" />

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-fade-up">

    <!-- Left Column — Branch Info Card -->
    <div class="lg:col-span-1">
        <div class="glass-card overflow-hidden sticky top-4">
            <!-- Card Header -->
            <div class="px-5 py-4 flex items-center justify-between" style="background: linear-gradient(135deg, rgba(16,185,129,0.3), rgba(5,150,105,0.2)); border-bottom: 1px solid rgba(255,255,255,0.08);">
                <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-store text-emerald-400"></i>Branch Information</h3>
                <span class="text-xs px-2 py-1 rounded-lg text-slate-300" style="background: rgba(255,255,255,0.1);">ID: @Model.Id</span>
            </div>

            <!-- Avatar -->
            <div class="p-6 text-center border-b" style="border-color: rgba(255,255,255,0.06);">
                <div class="w-24 h-24 mx-auto rounded-2xl flex items-center justify-center mb-4 shadow-lg"
                     style="background: linear-gradient(135deg, #10b981, #059669);">
                    <span class="text-3xl font-bold text-white">@initials</span>
                </div>
                <h2 class="text-xl font-bold text-white">@Model.Name</h2>
                <p class="text-slate-400 text-sm">@Model.Code</p>
                <div class="mt-3">
                    @if (Model.IsActive)
                    {
                        <span class="stat-badge" style="background: rgba(16,185,129,0.15); color: #6ee7b7;">
                            <i class="fas fa-circle text-[8px] text-emerald-400"></i>Active
                        </span>
                    }
                    else
                    {
                        <span class="stat-badge" style="background: rgba(239,68,68,0.15); color: #fca5a5;">
                            <i class="fas fa-circle text-[8px] text-red-400"></i>Inactive
                        </span>
                    }
                </div>
            </div>

            <!-- Contact Info -->
            <div class="p-5 border-b" style="border-color: rgba(255,255,255,0.06);">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                    <i class="fas fa-map-marker-alt text-emerald-500 text-xs"></i>Contact Information
                </h4>
                <div class="space-y-2 text-sm">
                    <div class="flex items-start gap-2">
                        <i class="fas fa-map-pin text-slate-600 w-4 mt-0.5 text-xs flex-shrink-0"></i>
                        <span class="text-slate-400">@(!string.IsNullOrEmpty(Model.Address) ? Model.Address : "No address provided")</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fas fa-phone text-slate-600 w-4 text-xs flex-shrink-0"></i>
                        <span class="text-slate-400">@(!string.IsNullOrEmpty(Model.Phone) ? Model.Phone : "No phone provided")</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fas fa-envelope text-slate-600 w-4 text-xs flex-shrink-0"></i>
                        <span class="text-slate-400 truncate">@(!string.IsNullOrEmpty(Model.Email) ? Model.Email : "No email provided")</span>
                    </div>
                </div>
            </div>

            <!-- Department -->
            <div class="p-5 border-b" style="border-color: rgba(255,255,255,0.06);">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"><i class="fas fa-building mr-1"></i>Department</h4>
                <div class="rounded-xl p-3" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                    <span class="text-sm font-medium text-slate-200">@Model.Department</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="p-5 border-b" style="border-color: rgba(255,255,255,0.06);">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"><i class="fas fa-sticky-note mr-1"></i>Notes</h4>
                    <div class="rounded-xl p-3 text-sm text-slate-400 border-l-4" style="background: rgba(245,158,11,0.08); border-color: #f59e0b;">
                        @Model.Notes
                    </div>
                </div>
            }

            <!-- Additional Info -->
            <div class="p-5 border-b" style="border-color: rgba(255,255,255,0.06);">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Additional Info</h4>
                <div class="space-y-2 text-xs">
                    <div class="flex justify-between">
                        <span class="text-slate-500">Created:</span>
                        <span class="text-slate-300 font-medium">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="p-4 flex gap-2" style="background: rgba(255,255,255,0.02);">
                <a href="@Url.Action("Edit", new { id = Model.Id })"
                   class="flex-1 py-2.5 rounded-xl text-sm font-medium text-white text-center flex items-center justify-center gap-2 transition"
                   style="background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 4px 12px rgba(16,185,129,0.3);">
                    <i class="fas fa-edit text-xs"></i>Edit
                </a>
                <a href="@Url.Action("BranchPerformance", "Report", new { branchId = Model.Id })"
                   class="flex-1 py-2.5 rounded-xl text-sm font-medium text-slate-300 text-center flex items-center justify-center gap-2 transition"
                   style="border: 1px solid rgba(255,255,255,0.10);"
                   onmouseover="this.style.background='rgba(255,255,255,0.05)'"
                   onmouseout="this.style.background=''">
                    <i class="fas fa-chart-line text-xs"></i>Reports
                </a>
            </div>
        </div>
    </div>

    <!-- Right Column -->
    <div class="lg:col-span-2 space-y-5">

        <!-- Stats Row -->
        <div class="grid grid-cols-3 gap-4">
            <div class="glass-card p-5 text-center">
                <p class="text-3xl font-bold text-emerald-400">@Model.EmployeeCount</p>
                <p class="text-xs text-slate-400 mt-1">Employees</p>
            </div>
            <div class="glass-card p-5 text-center">
                <p class="text-3xl font-bold text-cyan-400">@Model.CompletionRate%</p>
                <p class="text-xs text-slate-400 mt-1">Completion Rate</p>
                <div class="mt-2 w-full rounded-full h-1" style="background: rgba(255,255,255,0.08);">
                    <div class="h-1 rounded-full" style="width: @Model.CompletionRate%; background: linear-gradient(90deg, #06b6d4, #0891b2);"></div>
                </div>
            </div>
            <div class="glass-card p-5 text-center">
                <p class="text-3xl font-bold text-violet-400">@Model.TotalTasks</p>
                <p class="text-xs text-slate-400 mt-1">Total Tasks</p>
            </div>
        </div>

        <!-- Current Employees -->
        <div class="glass-card overflow-hidden">
            <div class="px-5 py-4 flex justify-between items-center border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(16,185,129,0.08);">
                <div>
                    <h3 class="font-bold text-white flex items-center gap-2">
                        <i class="fas fa-users text-emerald-400"></i>Current Employees
                        <span class="stat-badge" style="background: rgba(16,185,129,0.15); color: #6ee7b7;">@Model.EmployeeCount Active</span>
                    </h3>
                    <p class="text-xs text-slate-500 mt-0.5">Employees assigned to this branch</p>
                </div>
                <button onclick="showAssignEmployeeModal(@Model.Id)" class="btn-primary text-xs py-1.5 px-3" style="background: linear-gradient(135deg,#10b981,#059669); box-shadow: 0 2px 8px rgba(16,185,129,0.3);">
                    <i class="fas fa-plus-circle"></i>Assign
                </button>
            </div>
            <div class="p-5">
                @if (Model.CurrentEmployees != null && Model.CurrentEmployees.Any())
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        @foreach (var emp in Model.CurrentEmployees)
                        {
                            <div class="flex items-center justify-between p-3 rounded-xl transition group"
                                 style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);"
                                 onmouseover="this.style.borderColor='rgba(16,185,129,0.3)'"
                                 onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl flex items-center justify-center text-white font-bold text-sm"
                                         style="background: linear-gradient(135deg,#10b981,#059669);">
                                        @emp.Initials
                                    </div>
                                    <div>
                                        <div class="font-semibold text-white text-sm">@emp.Name</div>
                                        <div class="text-xs text-slate-500">@emp.Position</div>
                                        @if (emp.AssignedSince.HasValue)
                                        {
                                            <div class="text-[10px] text-emerald-500 mt-0.5">
                                                <i class="fas fa-calendar-alt mr-1"></i>Since @emp.AssignedSince.Value.ToString("MMM dd, yyyy")
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition">
                                    <a href="@Url.Action("Details", "Employee", new { id = emp.Id })"
                                       class="w-7 h-7 rounded-lg flex items-center justify-center text-indigo-400 hover:bg-indigo-400/10 transition">
                                        <i class="fas fa-eye text-xs"></i>
                                    </a>
                                    <button onclick="endAssignment(@emp.Id, '@emp.Name.Replace("'", "\\'")')"
                                            class="w-7 h-7 rounded-lg flex items-center justify-center text-red-400 hover:bg-red-400/10 transition">
                                        <i class="fas fa-times-circle text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12">
                        <div class="w-14 h-14 mx-auto rounded-2xl flex items-center justify-center mb-3" style="background: rgba(255,255,255,0.04);">
                            <i class="fas fa-user-plus text-slate-500 text-2xl"></i>
                        </div>
                        <p class="text-slate-400 font-medium">No employees assigned</p>
                        <p class="text-xs text-slate-600 mt-1">Click "Assign" to add staff</p>
                    </div>
                }
            </div>
        </div>

        <!-- Assignment History -->
        <div class="glass-card overflow-hidden">
            <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(99,102,241,0.08);">
                <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-history text-indigo-400"></i>Assignment History</h3>
                <p class="text-xs text-slate-500 mt-0.5">Complete history of employee assignments</p>
            </div>
            <div class="p-5">
                <div id="assignmentHistoryContent" class="text-center py-8">
                    <div class="flex justify-center items-center gap-2">
                        <div class="w-5 h-5 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
                        <span class="text-slate-500 text-sm">Loading history...</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Tasks -->
        <div class="glass-card overflow-hidden">
            <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(124,58,237,0.08);">
                <div class="flex justify-between items-center">
                    <div>
                        <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-tasks text-violet-400"></i>Recent Tasks</h3>
                        <p class="text-xs text-slate-500 mt-0.5">Last 10 tasks for this branch</p>
                    </div>
                    <div class="flex items-center gap-4 text-xs text-right">
                        <div>
                            <div class="font-bold text-violet-400">@recentCompletionRate%</div>
                            <div class="text-slate-500">Rate</div>
                        </div>
                        <div>
                            <div class="font-bold text-emerald-400">@completedRecentTasks</div>
                            <div class="text-slate-500">Done</div>
                        </div>
                        <div>
                            <div class="font-bold text-amber-400">@(recentTasksList.Count - completedRecentTasks)</div>
                            <div class="text-slate-500">Pending</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="p-5">
                @if (recentTasksList.Any())
                {
                    <!-- Tabs -->
                    <div class="flex border-b mb-4" style="border-color: rgba(255,255,255,0.06);">
                        <button onclick="showTab('completed')" id="completedTabBtn"
                                class="py-2 px-4 text-sm font-medium text-violet-400 border-b-2 border-violet-500 transition -mb-px">
                            <i class="fas fa-check-circle mr-1 text-xs"></i>Completed (@completedTasks.Count)
                        </button>
                        <button onclick="showTab('pending')" id="pendingTabBtn"
                                class="py-2 px-4 text-sm font-medium text-slate-500 border-b-2 border-transparent hover:text-slate-300 transition -mb-px">
                            <i class="fas fa-clock mr-1 text-xs"></i>Pending (@pendingTasks.Count)
                        </button>
                    </div>

                    <!-- Completed Tasks -->
                    <div id="completedTasksList" class="space-y-2">
                        @if (completedTasks.Any())
                        {
                            foreach (var task in completedTasks)
                            {
                                <div class="flex items-center justify-between p-3 rounded-xl transition"
                                     style="background: rgba(16,185,129,0.06); border-left: 3px solid #10b981; border-right: 1px solid transparent; border-top: 1px solid rgba(16,185,129,0.15); border-bottom: 1px solid rgba(16,185,129,0.15);">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(16,185,129,0.15);">
                                            <i class="fas fa-check-circle text-emerald-400 text-xs"></i>
                                        </div>
                                        <div>
                                            <div class="font-medium text-white text-sm">@task.TaskName</div>
                                            <div class="text-xs text-slate-500">@task.Date.ToString("dddd, MMMM d, yyyy")</div>
                                        </div>
                                    </div>
                                    <span class="stat-badge" style="background: rgba(16,185,129,0.15); color: #6ee7b7; font-size: 10px;">
                                        <i class="fas fa-check mr-0.5"></i>Done
                                    </span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-8 text-slate-500 text-sm">No completed tasks in recent history</div>
                        }
                    </div>

                    <!-- Pending Tasks -->
                    <div id="pendingTasksList" class="space-y-2 hidden">
                        @if (pendingTasks.Any())
                        {
                            foreach (var task in pendingTasks)
                            {
                                <div class="flex items-center justify-between p-3 rounded-xl transition"
                                     style="background: rgba(245,158,11,0.06); border-left: 3px solid #f59e0b; border-right: 1px solid transparent; border-top: 1px solid rgba(245,158,11,0.15); border-bottom: 1px solid rgba(245,158,11,0.15);">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(245,158,11,0.15);">
                                            <i class="fas fa-clock text-amber-400 text-xs"></i>
                                        </div>
                                        <div>
                                            <div class="font-medium text-white text-sm">@task.TaskName</div>
                                            <div class="text-xs text-slate-500">@task.Date.ToString("dddd, MMMM d, yyyy")</div>
                                        </div>
                                    </div>
                                    <span class="stat-badge" style="background: rgba(245,158,11,0.15); color: #fcd34d; font-size: 10px;">
                                        <i class="fas fa-hourglass-half mr-0.5"></i>Pending
                                    </span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-8 text-emerald-400 text-sm">✓ All tasks completed!</div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12">
                        <div class="w-14 h-14 mx-auto rounded-2xl flex items-center justify-center mb-3" style="background: rgba(255,255,255,0.04);">
                            <i class="fas fa-tasks text-slate-500 text-2xl"></i>
                        </div>
                        <p class="text-slate-400 font-medium">No tasks found</p>
                    </div>
                }
            </div>
        </div>

        <!-- Task Visibility -->
        <div class="glass-card overflow-hidden">
            <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(6,182,212,0.08);">
                <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-eye text-cyan-400"></i>Task Visibility</h3>
                <p class="text-xs text-slate-500 mt-0.5">Which tasks are visible for this branch</p>
            </div>
            <div class="p-5">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                    <i class="fas fa-eye text-emerald-500 text-xs"></i>Visible Tasks
                </h4>
                <div class="flex flex-wrap gap-2 mb-5">
                    @if (ViewBag.AllTasks != null)
                    {
                        var visibleTasks = ((IEnumerable<TaskTracker.Models.ViewModels.TaskListViewModel>)ViewBag.AllTasks)
                            .Where(t => !Model.HiddenTasks.Contains(t.Name));
                        if (visibleTasks.Any())
                        {
                            @foreach (var task in visibleTasks)
                            {
                                <span class="stat-badge" style="background: rgba(16,185,129,0.15); color: #6ee7b7;">
                                    <i class="fas fa-check-circle text-[9px]"></i>@task.Name
                                </span>
                            }
                        }
                        else
                        {
                            <p class="text-slate-500 text-sm">No visible tasks</p>
                        }
                    }
                </div>

                @if (Model.HiddenTasks.Any())
                {
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                        <i class="fas fa-eye-slash text-red-500 text-xs"></i>Hidden Tasks
                    </h4>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var task in Model.HiddenTasks)
                        {
                            <span class="stat-badge" style="background: rgba(239,68,68,0.15); color: #fca5a5;">
                                <i class="fas fa-eye-slash text-[9px]"></i>@task
                            </span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Assign Employee Modal -->
<div id="assignModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="w-full max-w-md rounded-2xl overflow-hidden border border-white/10 shadow-2xl animate-fade-up" style="background: #1a1a2e;">
        <div class="px-6 py-4 flex items-center gap-3" style="background: linear-gradient(135deg, rgba(16,185,129,0.4), rgba(5,150,105,0.3));">
            <i class="fas fa-user-plus text-emerald-400"></i>
            <h3 class="font-bold text-white">Assign Employee</h3>
        </div>
        <div class="p-6 space-y-4">
            <input type="hidden" id="assignBranchId" value="@Model.Id">
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Select Employee</label>
                <select id="assignEmployeeId" class="dark-input">
                    <option value="">Loading employees...</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Start Date</label>
                <input type="date" id="assignStartDate" class="dark-input" value="@DateTime.Today.ToString("yyyy-MM-dd")">
            </div>
            <p class="text-xs p-3 rounded-xl" style="background: rgba(99,102,241,0.1); color: #a5b4fc;">
                <i class="fas fa-info-circle mr-1"></i>Employee will be able to complete tasks for this branch from the start date.
            </p>
        </div>
        <div class="px-6 py-4 border-t flex justify-end gap-3" style="border-color: rgba(255,255,255,0.06);">
            <button onclick="closeAssignModal()" class="px-4 py-2 rounded-lg text-sm text-slate-300 border border-white/10 hover:bg-white/5 transition">Cancel</button>
            <button onclick="saveAssignment()" class="btn-primary" style="background: linear-gradient(135deg, #10b981, #059669);">
                <i class="fas fa-save"></i>Assign
            </button>
        </div>
    </div>
</div>

<!-- End Assignment Modal -->
<div id="endAssignmentModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="w-full max-w-md rounded-2xl overflow-hidden border border-white/10 shadow-2xl animate-fade-up" style="background: #1a1a2e;">
        <div class="px-6 py-4 flex items-center gap-3" style="background: linear-gradient(135deg, rgba(220,38,38,0.4), rgba(185,28,28,0.3));">
            <i class="fas fa-user-minus text-red-400"></i>
            <h3 class="font-bold text-white">End Assignment</h3>
        </div>
        <div class="p-6">
            <p id="endAssignmentMessage" class="text-slate-300">Are you sure you want to end this assignment?</p>
            <p class="text-xs text-red-400 mt-2">The employee will no longer have access to this branch's tasks.</p>
            <input type="hidden" id="endAssignmentId" />
        </div>
        <div class="px-6 py-4 border-t flex justify-end gap-3" style="border-color: rgba(255,255,255,0.06);">
            <button onclick="closeEndAssignmentModal()" class="px-4 py-2 rounded-lg text-sm text-slate-300 border border-white/10 hover:bg-white/5 transition">Cancel</button>
            <button onclick="confirmEndAssignment()" class="px-4 py-2 rounded-xl text-sm font-medium text-white transition flex items-center gap-2"
                    style="background: linear-gradient(135deg, #dc2626, #b91c1c);">
                <i class="fas fa-check"></i>End Assignment
            </button>
        </div>
    </div>
</div>

<script>
    let currentBranchId = @Model.Id;
    let pendingEndAssignmentId = null;

    $(document).ready(function() { loadAssignmentHistory(); });

    function showTab(tab) {
        if (tab === 'completed') {
            $('#completedTasksList').removeClass('hidden');
            $('#pendingTasksList').addClass('hidden');
            $('#completedTabBtn').addClass('text-violet-400 border-violet-500').removeClass('text-slate-500 border-transparent');
            $('#pendingTabBtn').removeClass('text-violet-400 border-violet-500').addClass('text-slate-500 border-transparent');
        } else {
            $('#completedTasksList').addClass('hidden');
            $('#pendingTasksList').removeClass('hidden');
            $('#pendingTabBtn').addClass('text-violet-400 border-violet-500').removeClass('text-slate-500 border-transparent');
            $('#completedTabBtn').removeClass('text-violet-400 border-violet-500').addClass('text-slate-500 border-transparent');
        }
    }

    async function loadAssignmentHistory() {
        try {
            const response = await fetch(`@Url.Action("GetAssignmentHistory", "Branch")/${currentBranchId}`);
            const history = await response.json();
            displayAssignmentHistory(history);
        } catch (e) {
            $('#assignmentHistoryContent').html('<div class="text-center py-8 text-red-400 text-sm"><i class="fas fa-exclamation-circle text-2xl mb-2 block"></i>Error loading history</div>');
        }
    }

    function displayAssignmentHistory(history) {
        if (!history || history.length === 0) {
            $('#assignmentHistoryContent').html('<div class="text-center py-8 text-slate-500 text-sm"><i class="fas fa-history text-2xl mb-2 block text-slate-600"></i>No assignment history</div>');
            return;
        }
        let html = '<div class="space-y-2 max-h-80 overflow-y-auto pr-1">';
        for (const item of history) {
            const isActive = item.isActive;
            html += `<div class="flex items-center justify-between p-3 rounded-xl" style="background: ${isActive ? 'rgba(16,185,129,0.08)' : 'rgba(255,255,255,0.04)'}; border: 1px solid ${isActive ? 'rgba(16,185,129,0.2)' : 'rgba(255,255,255,0.06)'};">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background: ${isActive ? 'rgba(16,185,129,0.2)' : 'rgba(255,255,255,0.06)'};">
                        <i class="fas fa-user ${isActive ? 'text-emerald-400' : 'text-slate-500'} text-sm"></i>
                    </div>
                    <div>
                        <div class="font-semibold text-white text-sm">${escapeHtml(item.employeeName)}</div>
                        <div class="text-xs text-slate-500">ID: ${escapeHtml(item.employeeId)}</div>
                        <div class="text-xs text-slate-600 mt-0.5"><i class="fas fa-calendar-alt mr-1"></i>${item.startDate} → ${item.endDate || 'Present'} <span class="ml-1">(${item.duration} days)</span></div>
                    </div>
                </div>
                <span class="stat-badge" style="font-size:10px; ${isActive ? 'background:rgba(16,185,129,0.15);color:#6ee7b7' : 'background:rgba(255,255,255,0.06);color:#94a3b8'}">${isActive ? '<i class="fas fa-circle text-[6px] mr-1 text-emerald-400"></i>Active' : 'Ended'}</span>
            </div>`;
        }
        html += '</div>';
        $('#assignmentHistoryContent').html(html);
    }

    async function showAssignEmployeeModal(branchId) {
        $('#assignBranchId').val(branchId);
        $('#assignModal').removeClass('hidden').addClass('flex');
        try {
            const response = await fetch(`@Url.Action("GetAvailableEmployees", "Branch")?branchId=${branchId}`);
            const employees = await response.json();
            let options = '<option value="">Select an employee...</option>';
            for (const emp of employees) {
                options += `<option value="${emp.id}">${escapeHtml(emp.name)} - ${escapeHtml(emp.position || 'No position')} (${emp.employeeId})</option>`;
            }
            $('#assignEmployeeId').html(options);
        } catch (e) { $('#assignEmployeeId').html('<option value="">Error loading employees</option>'); }
    }

    function closeAssignModal() { $('#assignModal').addClass('hidden').removeClass('flex'); }

    async function saveAssignment() {
        const branchId = $('#assignBranchId').val(), employeeId = $('#assignEmployeeId').val(), startDate = $('#assignStartDate').val();
        const token = $('#requestVerificationToken').val();
        if (!employeeId) { if (window.TaskTracker) TaskTracker.showNotification('Please select an employee', 'error'); return; }
        const btn = $('#assignModal button[onclick="saveAssignment()"]');
        const orig = btn.html();
        btn.html('<i class="fas fa-spinner fa-spin mr-1"></i>Assigning...').prop('disabled', true);
        try {
            const response = await $.ajax({ url: '@Url.Action("AssignEmployee", "Branch")', type: 'POST', data: { branchId, employeeId, startDate }, headers: { 'RequestVerificationToken': token } });
            if (response.success) { if (window.TaskTracker) TaskTracker.showNotification(response.message, 'success'); closeAssignModal(); setTimeout(() => location.reload(), 1500); }
            else { if (window.TaskTracker) TaskTracker.showNotification(response.message, 'error'); btn.html(orig).prop('disabled', false); }
        } catch(e) { if (window.TaskTracker) TaskTracker.showNotification('Error assigning employee', 'error'); btn.html(orig).prop('disabled', false); }
    }

    function endAssignment(assignmentId, employeeName) {
        pendingEndAssignmentId = assignmentId;
        $('#endAssignmentMessage').html(`End assignment for <strong class="text-white">${escapeHtml(employeeName)}</strong>?`);
        $('#endAssignmentModal').removeClass('hidden').addClass('flex');
    }
    function closeEndAssignmentModal() { $('#endAssignmentModal').addClass('hidden').removeClass('flex'); pendingEndAssignmentId = null; }

    async function confirmEndAssignment() {
        if (!pendingEndAssignmentId) return;
        const token = $('#requestVerificationToken').val();
        const btn = $('#endAssignmentModal button[onclick="confirmEndAssignment()"]');
        const orig = btn.html(); btn.html('<i class="fas fa-spinner fa-spin mr-1"></i>Ending...').prop('disabled', true);
        try {
            const r = await $.ajax({ url: '@Url.Action("EndAssignment", "Branch")/' + pendingEndAssignmentId, type: 'POST', headers: { 'RequestVerificationToken': token } });
            if (r.success) { if (window.TaskTracker) TaskTracker.showNotification(r.message, 'success'); closeEndAssignmentModal(); setTimeout(() => location.reload(), 1500); }
            else { if (window.TaskTracker) TaskTracker.showNotification(r.message, 'error'); btn.html(orig).prop('disabled', false); closeEndAssignmentModal(); }
        } catch(e) { if (window.TaskTracker) TaskTracker.showNotification('Error ending assignment', 'error'); btn.html(orig).prop('disabled', false); closeEndAssignmentModal(); }
    }

    function escapeHtml(text) {
        if (!text) return text;
        return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
</script>