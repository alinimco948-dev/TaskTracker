@model TaskTracker.Models.ViewModels.BranchDetailsViewModel
@{
    ViewData["Title"] = "Branch Details";

    var initials = "?";
    if (!string.IsNullOrEmpty(Model.Name))
    {
        var nameParts = Model.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (nameParts.Length == 1)
            initials = nameParts[0].Substring(0, 1).ToUpper();
        else if (nameParts.Length >= 2)
            initials = (nameParts[0][0].ToString() + nameParts[^1][0].ToString()).ToUpper();
    }
    
    // Calculate performance metrics for recent tasks
    var recentTasksList = Model.RecentTasks ?? new List<BranchTaskItem>();
    var completedRecentTasks = recentTasksList.Count(t => t.IsCompleted);
    var recentCompletionRate = recentTasksList.Any() ? Math.Round((double)completedRecentTasks / recentTasksList.Count * 100, 1) : 0;
    
    // Group recent tasks by status
    var completedTasks = recentTasksList.Where(t => t.IsCompleted).OrderByDescending(t => t.Date).Take(5).ToList();
    var pendingTasks = recentTasksList.Where(t => !t.IsCompleted).OrderBy(t => t.Date).Take(5).ToList();
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left Column - Branch Info Card (Sticky) -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden sticky top-4">
            <div class="bg-gradient-to-r from-green-600 to-green-800 px-6 py-5">
                <div class="flex items-center justify-between">
                    <h3 class="text-lg font-semibold text-white">Branch Information</h3>
                    <div class="px-2 py-1 bg-white/20 rounded-lg text-white text-xs font-medium">
                        ID: @Model.Id
                    </div>
                </div>
            </div>

            <div class="p-6 text-center border-b">
                <div class="w-24 h-24 mx-auto rounded-full bg-gradient-to-r from-green-100 to-green-200 flex items-center justify-center mb-4 shadow-inner">
                    <span class="text-3xl font-bold text-green-700">@initials</span>
                </div>
                <h2 class="text-xl font-bold text-gray-900">@Model.Name</h2>
                <p class="text-gray-500 text-sm">@Model.Code</p>
                <div class="mt-3">
                    @if (Model.IsActive)
                    {
                        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">
                            <i class="fas fa-circle text-green-500 mr-1 text-[8px]"></i>Active
                        </span>
                    }
                    else
                    {
                        <span class="px-3 py-1 bg-red-100 text-red-700 rounded-full text-xs font-medium">
                            <i class="fas fa-circle text-red-500 mr-1 text-[8px]"></i>Inactive
                        </span>
                    }
                </div>
            </div>

            <div class="p-5 border-b">
                <h4 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                    <i class="fas fa-map-marker-alt text-green-500 mr-2 text-xs"></i>
                    Contact Information
                </h4>
                <div class="space-y-3 text-sm">
                    <div class="flex items-start">
                        <i class="fas fa-map-pin text-gray-400 w-5 mt-0.5 text-xs"></i>
                        <span class="text-gray-600 flex-1">@(!string.IsNullOrEmpty(Model.Address) ? Model.Address : "No address provided")</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-phone text-gray-400 w-5 text-xs"></i>
                        <span class="text-gray-600">@(!string.IsNullOrEmpty(Model.Phone) ? Model.Phone : "No phone provided")</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-envelope text-gray-400 w-5 text-xs"></i>
                        <span class="text-gray-600 truncate">@(!string.IsNullOrEmpty(Model.Email) ? Model.Email : "No email provided")</span>
                    </div>
                </div>
            </div>

            <div class="p-5 border-b">
                <h4 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                    <i class="fas fa-building text-green-500 mr-2 text-xs"></i>
                    Department
                </h4>
                <div class="bg-gray-50 p-3 rounded-lg">
                    <div class="font-medium text-gray-800">@Model.Department</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="p-5 border-b">
                    <h4 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                        <i class="fas fa-sticky-note text-green-500 mr-2 text-xs"></i>
                        Notes
                    </h4>
                    <div class="bg-yellow-50 p-3 rounded-lg border-l-4 border-yellow-400">
                        <p class="text-sm text-gray-700">@Model.Notes</p>
                    </div>
                </div>
            }

            <div class="p-5 border-b">
                <h4 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                    <i class="fas fa-calendar-alt text-green-500 mr-2 text-xs"></i>
                    Additional Info
                </h4>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-500">Created:</span>
                        <span class="font-medium text-gray-700">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Last Updated:</span>
                        <span class="font-medium text-gray-700">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
            </div>

            <div class="p-5 bg-gray-50 flex space-x-2">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="flex-1 px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm font-medium transition text-center flex items-center justify-center gap-2">
                    <i class="fas fa-edit"></i> Edit Branch
                </a>
                <a href="@Url.Action("BranchPerformance", "Report", new { branchId = Model.Id })" class="flex-1 px-4 py-2.5 border border-gray-300 bg-white hover:bg-gray-50 rounded-lg text-sm font-medium transition text-center flex items-center justify-center gap-2">
                    <i class="fas fa-chart-line"></i> Reports
                </a>
            </div>
        </div>
    </div>

    <!-- Right Column - Stats and Data -->
    <div class="lg:col-span-2 space-y-6">
        <!-- Quick Stats Row -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200 hover:shadow-md transition">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Current Employees</p>
                        <p class="text-3xl font-bold text-green-600">@Model.EmployeeCount</p>
                    </div>
                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-users text-green-600 text-xl"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200 hover:shadow-md transition">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Completion Rate</p>
                        <p class="text-3xl font-bold text-blue-600">@Model.CompletionRate%</p>
                    </div>
                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-chart-line text-blue-600 text-xl"></i>
                    </div>
                </div>
                <div class="mt-2 w-full bg-gray-200 rounded-full h-1.5">
                    <div class="bg-blue-500 h-1.5 rounded-full" style="width: @Model.CompletionRate%"></div>
                </div>
            </div>
            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200 hover:shadow-md transition">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500">Total Tasks</p>
                        <p class="text-3xl font-bold text-purple-600">@Model.TotalTasks</p>
                    </div>
                    <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-tasks text-purple-600 text-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Current Employees Section - Enhanced -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b bg-gradient-to-r from-green-50 to-white flex justify-between items-center">
                <div>
                    <h3 class="text-lg font-semibold text-gray-800 flex items-center">
                        <i class="fas fa-users text-green-600 mr-2"></i>
                        Current Employees
                        <span class="ml-2 text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">@Model.EmployeeCount Active</span>
                    </h3>
                    <p class="text-xs text-gray-500 mt-0.5">Employees currently assigned to this branch</p>
                </div>
                <button onclick="showAssignEmployeeModal(@Model.Id)" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-medium rounded-lg transition flex items-center gap-1 shadow-sm">
                    <i class="fas fa-plus-circle text-xs"></i> Assign Employee
                </button>
            </div>
            <div class="p-5">
                @if (Model.CurrentEmployees != null && Model.CurrentEmployees.Any())
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        @foreach (var emp in Model.CurrentEmployees)
                        {
                            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border border-gray-100 hover:border-green-200 hover:bg-green-50 transition group">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 rounded-full bg-gradient-to-r from-green-400 to-green-600 flex items-center justify-center text-white font-bold text-sm shadow-sm">
                                        @emp.Initials
                                    </div>
                                    <div>
                                        <div class="font-medium text-gray-800">@emp.Name</div>
                                        <div class="text-xs text-gray-500">@emp.Position</div>
                                        @if (emp.AssignedSince.HasValue)
                                        {
                                            <div class="text-[10px] text-green-600 mt-0.5">
                                                <i class="fas fa-calendar-alt mr-1"></i> Since @emp.AssignedSince.Value.ToString("MMM dd, yyyy")
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="flex items-center gap-1">
                                    <a href="@Url.Action("Details", "Employee", new { id = emp.Id })" class="p-1.5 text-blue-500 hover:text-blue-700 rounded-lg transition opacity-0 group-hover:opacity-100" title="View Employee">
                                        <i class="fas fa-eye text-xs"></i>
                                    </a>
                                    <button onclick="endAssignment(@emp.Id, '@emp.Name.Replace("'", "\\'")')" 
                                            class="p-1.5 text-red-500 hover:text-red-700 rounded-lg transition opacity-0 group-hover:opacity-100" title="End Assignment">
                                        <i class="fas fa-times-circle text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12">
                        <div class="w-16 h-16 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-3">
                            <i class="fas fa-user-plus text-2xl text-gray-400"></i>
                        </div>
                        <p class="text-gray-500 font-medium">No employees assigned</p>
                        <p class="text-xs text-gray-400 mt-1">Click "Assign Employee" to add staff to this branch</p>
                    </div>
                }
            </div>
        </div>

        <!-- Assignment History Section - Enhanced -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b bg-gradient-to-r from-blue-50 to-white">
                <h3 class="text-lg font-semibold text-gray-800 flex items-center">
                    <i class="fas fa-history text-blue-600 mr-2"></i>
                    Assignment History
                </h3>
                <p class="text-xs text-gray-500 mt-0.5">Complete history of employee assignments to this branch</p>
            </div>
            <div class="p-5">
                <div id="assignmentHistoryContent" class="text-center py-8">
                    <div class="flex justify-center items-center gap-2">
                        <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                        <span class="text-gray-500 text-sm">Loading history...</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Tasks Section - Enhanced with Detailed Report -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b bg-gradient-to-r from-purple-50 to-white">
                <div class="flex justify-between items-center">
                    <div>
                        <h3 class="text-lg font-semibold text-gray-800 flex items-center">
                            <i class="fas fa-tasks text-purple-600 mr-2"></i>
                            Recent Tasks
                        </h3>
                        <p class="text-xs text-gray-500 mt-0.5">Last 10 tasks for this branch</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="text-right">
                            <div class="text-sm font-bold text-purple-600">@recentCompletionRate%</div>
                            <div class="text-[10px] text-gray-400">Completion Rate</div>
                        </div>
                        <div class="w-px h-8 bg-gray-200"></div>
                        <div class="text-right">
                            <div class="text-sm font-bold text-green-600">@completedRecentTasks</div>
                            <div class="text-[10px] text-gray-400">Completed</div>
                        </div>
                        <div class="w-px h-8 bg-gray-200"></div>
                        <div class="text-right">
                            <div class="text-sm font-bold text-yellow-600">@(recentTasksList.Count - completedRecentTasks)</div>
                            <div class="text-[10px] text-gray-400">Pending</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="p-5">
                @if (recentTasksList.Any())
                {
                    <!-- Summary Cards -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
                        <!-- Completed Tasks Summary -->
                        <div class="bg-green-50 rounded-lg p-3 border border-green-200">
                            <div class="flex items-center justify-between">
                                <div>
                                    <div class="text-xs text-green-600 font-medium">Recently Completed</div>
                                    <div class="text-2xl font-bold text-green-700">@completedTasks.Count</div>
                                </div>
                                <div class="w-8 h-8 bg-green-200 rounded-full flex items-center justify-center">
                                    <i class="fas fa-check-circle text-green-600 text-sm"></i>
                                </div>
                            </div>
                            @if (completedTasks.Any())
                            {
                                <div class="mt-2 text-[10px] text-green-600">
                                    Latest: @completedTasks.First().Date.ToString("MMM dd")
                                </div>
                            }
                        </div>
                        <!-- Pending Tasks Summary -->
                        <div class="bg-yellow-50 rounded-lg p-3 border border-yellow-200">
                            <div class="flex items-center justify-between">
                                <div>
                                    <div class="text-xs text-yellow-600 font-medium">Pending Tasks</div>
                                    <div class="text-2xl font-bold text-yellow-700">@pendingTasks.Count</div>
                                </div>
                                <div class="w-8 h-8 bg-yellow-200 rounded-full flex items-center justify-center">
                                    <i class="fas fa-clock text-yellow-600 text-sm"></i>
                                </div>
                            </div>
                            @if (pendingTasks.Any())
                            {
                                <div class="mt-2 text-[10px] text-yellow-600">
                                    Oldest: @pendingTasks.First().Date.ToString("MMM dd")
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Tabs for Completed/Pending Tasks -->
                    <div class="border-b border-gray-200 mb-4">
                        <div class="flex space-x-4">
                            <button onclick="showTab('completed')" id="completedTabBtn" class="py-2 px-1 text-sm font-medium text-purple-600 border-b-2 border-purple-600 transition">
                                <i class="fas fa-check-circle mr-1 text-xs"></i> Completed (@completedTasks.Count)
                            </button>
                            <button onclick="showTab('pending')" id="pendingTabBtn" class="py-2 px-1 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition">
                                <i class="fas fa-clock mr-1 text-xs"></i> Pending (@pendingTasks.Count)
                            </button>
                        </div>
                    </div>

                    <!-- Completed Tasks List -->
                    <div id="completedTasksList" class="space-y-2">
                        @if (completedTasks.Any())
                        {
                            foreach (var task in completedTasks)
                            {
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-green-50 transition border-l-4 border-green-500">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
                                            <i class="fas fa-check-circle text-green-600 text-xs"></i>
                                        </div>
                                        <div>
                                            <div class="font-medium text-gray-800 text-sm">@task.TaskName</div>
                                            <div class="text-xs text-gray-500">@task.Date.ToString("dddd, MMMM d, yyyy")</div>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-[10px] font-medium">
                                            <i class="fas fa-check mr-0.5"></i> Completed
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-6 text-gray-400 text-sm">
                                <i class="fas fa-check-circle text-2xl mb-2"></i>
                                <p>No completed tasks in recent history</p>
                            </div>
                        }
                    </div>

                    <!-- Pending Tasks List -->
                    <div id="pendingTasksList" class="space-y-2 hidden">
                        @if (pendingTasks.Any())
                        {
                            foreach (var task in pendingTasks)
                            {
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-yellow-50 transition border-l-4 border-yellow-500">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-yellow-100 flex items-center justify-center">
                                            <i class="fas fa-clock text-yellow-600 text-xs"></i>
                                        </div>
                                        <div>
                                            <div class="font-medium text-gray-800 text-sm">@task.TaskName</div>
                                            <div class="text-xs text-gray-500">@task.Date.ToString("dddd, MMMM d, yyyy")</div>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="px-2 py-1 bg-yellow-100 text-yellow-700 rounded-full text-[10px] font-medium">
                                            <i class="fas fa-hourglass-half mr-0.5"></i> Pending
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-6 text-gray-400 text-sm">
                                <i class="fas fa-check-circle text-2xl mb-2 text-green-400"></i>
                                <p>All tasks completed! Great work!</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-12">
                        <div class="w-16 h-16 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-3">
                            <i class="fas fa-tasks text-2xl text-gray-400"></i>
                        </div>
                        <p class="text-gray-500 font-medium">No tasks found</p>
                        <p class="text-xs text-gray-400 mt-1">Tasks will appear here when assigned to this branch</p>
                    </div>
                }
            </div>
        </div>

        <!-- Task Visibility Section -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b bg-gradient-to-r from-indigo-50 to-white">
                <h3 class="text-lg font-semibold text-gray-800 flex items-center">
                    <i class="fas fa-eye text-indigo-600 mr-2"></i>
                    Task Visibility
                </h3>
                <p class="text-xs text-gray-500 mt-0.5">Which tasks are visible for this branch</p>
            </div>
            <div class="p-5">
                <h4 class="text-sm font-medium text-gray-700 mb-2 flex items-center">
                    <i class="fas fa-eye text-green-500 mr-1 text-xs"></i> Visible Tasks
                </h4>
                <div class="flex flex-wrap gap-2 mb-5">
                    @if (ViewBag.AllTasks != null)
                    {
                        var visibleTasks = ((IEnumerable<TaskTracker.Models.ViewModels.TaskListViewModel>)ViewBag.AllTasks)
                        .Where(t => !Model.HiddenTasks.Contains(t.Name));

                        if (visibleTasks.Any())
                        {
                            @foreach (var task in visibleTasks)
                            {
                                <span class="px-3 py-1.5 bg-green-100 text-green-700 rounded-full text-xs font-medium flex items-center gap-1">
                                    <i class="fas fa-check-circle text-[8px]"></i> @task.Name
                                </span>
                            }
                        }
                        else
                        {
                            <p class="text-gray-500 text-sm">No visible tasks</p>
                        }
                    }
                </div>

                @if (Model.HiddenTasks.Any())
                {
                    <h4 class="text-sm font-medium text-gray-700 mb-2 flex items-center">
                        <i class="fas fa-eye-slash text-red-500 mr-1 text-xs"></i> Hidden Tasks
                    </h4>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var task in Model.HiddenTasks)
                        {
                            <span class="px-3 py-1.5 bg-red-100 text-red-700 rounded-full text-xs font-medium flex items-center gap-1">
                                <i class="fas fa-eye-slash text-[8px]"></i> @task
                            </span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Assign Employee Modal -->
<div id="assignModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50 backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md transform transition-all animate-fade-in">
        <div class="bg-gradient-to-r from-green-600 to-green-800 px-5 py-3 rounded-t-xl">
            <h3 class="text-lg font-semibold text-white flex items-center">
                <i class="fas fa-user-plus mr-2"></i> Assign Employee
            </h3>
        </div>
        <div class="p-5">
            <input type="hidden" id="assignBranchId" value="@Model.Id">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Select Employee</label>
                <select id="assignEmployeeId" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                    <option value="">Loading employees...</option>
                </select>
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Start Date</label>
                <input type="date" id="assignStartDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500" value="@DateTime.Today.ToString("yyyy-MM-dd")">
            </div>
            <div class="bg-blue-50 p-3 rounded-lg text-xs text-blue-700">
                <i class="fas fa-info-circle mr-1"></i> Employee will be able to complete tasks for this branch from the start date.
            </div>
        </div>
        <div class="px-5 py-3 border-t border-gray-200 flex justify-end gap-2 rounded-b-xl">
            <button onclick="closeAssignModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 transition">Cancel</button>
            <button onclick="saveAssignment()" class="px-4 py-2 bg-green-600 text-white rounded-lg text-sm hover:bg-green-700 transition flex items-center gap-1">
                <i class="fas fa-save"></i> Assign
            </button>
        </div>
    </div>
</div>

<!-- End Assignment Confirmation Modal -->
<div id="endAssignmentModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50 backdrop-blur-sm">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md transform transition-all animate-fade-in">
        <div class="bg-gradient-to-r from-red-600 to-red-800 px-5 py-3 rounded-t-xl">
            <h3 class="text-lg font-semibold text-white flex items-center">
                <i class="fas fa-user-minus mr-2"></i> End Assignment
            </h3>
        </div>
        <div class="p-5">
            <p id="endAssignmentMessage" class="text-gray-700">Are you sure you want to end this assignment?</p>
            <p class="text-xs text-red-500 mt-2">The employee will no longer have access to this branch's tasks.</p>
            <input type="hidden" id="endAssignmentId" />
            <input type="hidden" id="endEmployeeName" />
        </div>
        <div class="px-5 py-3 border-t border-gray-200 flex justify-end gap-2 rounded-b-xl">
            <button onclick="closeEndAssignmentModal()" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 transition">Cancel</button>
            <button onclick="confirmEndAssignment()" class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm hover:bg-red-700 transition flex items-center gap-1">
                <i class="fas fa-check"></i> End Assignment
            </button>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    let currentBranchId = @Model.Id;
    let pendingEndAssignmentId = null;
    let pendingEndEmployeeName = null;

    $(document).ready(function() {
        loadAssignmentHistory();
    });

    // Tab switching for Recent Tasks
    function showTab(tab) {
        if (tab === 'completed') {
            $('#completedTasksList').removeClass('hidden');
            $('#pendingTasksList').addClass('hidden');
            $('#completedTabBtn').addClass('text-purple-600 border-purple-600').removeClass('text-gray-500 border-transparent');
            $('#pendingTabBtn').removeClass('text-purple-600 border-purple-600').addClass('text-gray-500 border-transparent');
        } else {
            $('#completedTasksList').addClass('hidden');
            $('#pendingTasksList').removeClass('hidden');
            $('#pendingTabBtn').addClass('text-purple-600 border-purple-600').removeClass('text-gray-500 border-transparent');
            $('#completedTabBtn').removeClass('text-purple-600 border-purple-600').addClass('text-gray-500 border-transparent');
        }
    }

    // Load Assignment History
    async function loadAssignmentHistory() {
        try {
            const response = await fetch(`@Url.Action("GetAssignmentHistory", "Branch")/${currentBranchId}`);
            const history = await response.json();
            displayAssignmentHistory(history);
        } catch (error) {
            console.error('Error loading assignment history:', error);
            $('#assignmentHistoryContent').html('<div class="text-center py-8 text-red-500"><i class="fas fa-exclamation-circle text-2xl mb-2"></i><p>Error loading history</p></div>');
        }
    }

    function displayAssignmentHistory(history) {
        if (!history || history.length === 0) {
            $('#assignmentHistoryContent').html(`
                <div class="text-center py-12">
                    <div class="w-16 h-16 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-3">
                        <i class="fas fa-history text-2xl text-gray-400"></i>
                    </div>
                    <p class="text-gray-500 font-medium">No assignment history</p>
                    <p class="text-xs text-gray-400 mt-1">Assign employees to see history here</p>
                </div>
            `);
            return;
        }

        let html = '<div class="space-y-3 max-h-96 overflow-y-auto pr-2">';
        for (let i = 0; i < history.length; i++) {
            const item = history[i];
            const isActive = item.isActive;
            html += `
                <div class="flex items-center justify-between p-3 ${isActive ? 'bg-green-50 border border-green-200' : 'bg-gray-50 border border-gray-200'} rounded-lg hover:shadow-sm transition">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full ${isActive ? 'bg-green-200' : 'bg-gray-300'} flex items-center justify-center">
                            <i class="fas fa-user ${isActive ? 'text-green-600' : 'text-gray-500'} text-sm"></i>
                        </div>
                        <div>
                            <div class="font-medium text-gray-800 text-sm">${escapeHtml(item.employeeName)}</div>
                            <div class="text-xs text-gray-500">Employee ID: ${escapeHtml(item.employeeId)}</div>
                            <div class="text-xs text-gray-400 mt-1">
                                <i class="fas fa-calendar-alt mr-1 text-[10px]"></i>
                                ${item.startDate} → ${item.endDate || 'Present'}
                                <span class="ml-2 text-gray-400">(${item.duration} days)</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        ${isActive ? '<span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-[10px] font-medium"><i class="fas fa-circle text-[6px] mr-1"></i>Active</span>' : '<span class="px-2 py-1 bg-gray-200 text-gray-600 rounded-full text-[10px] font-medium">Ended</span>'}
                    </div>
                </div>
            `;
        }
        html += '</div>';
        $('#assignmentHistoryContent').html(html);
    }

    // Assign Employee Functions
    async function showAssignEmployeeModal(branchId) {
        $('#assignBranchId').val(branchId);
        $('#assignModal').removeClass('hidden').addClass('flex');
        
        try {
            const response = await fetch(`@Url.Action("GetAvailableEmployees", "Branch")?branchId=${branchId}`);
            const employees = await response.json();
            
            let options = '<option value="">Select an employee...</option>';
            for (const emp of employees) {
                options += `<option value="${emp.id}">${escapeHtml(emp.name)} - ${escapeHtml(emp.position || 'No position')} (${emp.employeeId})</option>`;
            }
            $('#assignEmployeeId').html(options);
        } catch (error) {
            console.error('Error loading employees:', error);
            $('#assignEmployeeId').html('<option value="">Error loading employees</option>');
        }
    }

    function closeAssignModal() {
        $('#assignModal').addClass('hidden').removeClass('flex');
        $('#assignEmployeeId').val('');
        $('#assignStartDate').val(new Date().toISOString().split('T')[0]);
    }

    async function saveAssignment() {
        const branchId = $('#assignBranchId').val();
        const employeeId = $('#assignEmployeeId').val();
        const startDate = $('#assignStartDate').val();
        const token = $('#requestVerificationToken').val();

        if (!employeeId) {
            showNotification('Please select an employee', 'error');
            return;
        }

        if (!startDate) {
            showNotification('Please select a start date', 'error');
            return;
        }

        const btn = $('#assignModal .bg-green-600');
        const originalText = btn.html();
        btn.html('<i class="fas fa-spinner fa-spin mr-1"></i> Assigning...').prop('disabled', true);

        try {
            const response = await $.ajax({
                url: '@Url.Action("AssignEmployee", "Branch")',
                type: 'POST',
                data: { branchId: branchId, employeeId: employeeId, startDate: startDate },
                headers: { 'RequestVerificationToken': token }
            });

            if (response.success) {
                showNotification(response.message, 'success');
                closeAssignModal();
                setTimeout(() => location.reload(), 1500);
            } else {
                showNotification(response.message, 'error');
                btn.html(originalText).prop('disabled', false);
            }
        } catch (error) {
            showNotification('Error assigning employee', 'error');
            btn.html(originalText).prop('disabled', false);
        }
    }

    // End Assignment Functions
    function endAssignment(assignmentId, employeeName) {
        pendingEndAssignmentId = assignmentId;
        pendingEndEmployeeName = employeeName;
        $('#endAssignmentMessage').html(`End assignment for <strong>${escapeHtml(employeeName)}</strong>?`);
        $('#endAssignmentModal').removeClass('hidden').addClass('flex');
    }

    function closeEndAssignmentModal() {
        $('#endAssignmentModal').addClass('hidden').removeClass('flex');
        pendingEndAssignmentId = null;
        pendingEndEmployeeName = null;
    }

    async function confirmEndAssignment() {
        if (!pendingEndAssignmentId) return;
        
        const token = $('#requestVerificationToken').val();
        const btn = $('#endAssignmentModal .bg-red-600');
        const originalText = btn.html();
        btn.html('<i class="fas fa-spinner fa-spin mr-1"></i> Ending...').prop('disabled', true);

        try {
            const response = await $.ajax({
                url: '@Url.Action("EndAssignment", "Branch")/' + pendingEndAssignmentId,
                type: 'POST',
                headers: { 'RequestVerificationToken': token }
            });

            if (response.success) {
                showNotification(response.message, 'success');
                closeEndAssignmentModal();
                setTimeout(() => location.reload(), 1500);
            } else {
                showNotification(response.message, 'error');
                btn.html(originalText).prop('disabled', false);
                closeEndAssignmentModal();
            }
        } catch (error) {
            showNotification('Error ending assignment', 'error');
            btn.html(originalText).prop('disabled', false);
            closeEndAssignmentModal();
        }
    }

    // Notification Helper
    function showNotification(message, type) {
        const colors = { success: 'bg-green-500', error: 'bg-red-500', info: 'bg-blue-500', warning: 'bg-yellow-500' };
        $('.custom-notification').remove();
        const notification = $(`<div class="custom-notification fixed top-4 right-4 z-50 px-4 py-2 rounded-lg shadow-lg text-sm text-white ${colors[type]} animate-slide-in">${message}</div>`);
        $('body').append(notification);
        setTimeout(() => notification.fadeOut(300, () => notification.remove()), 3000);
    }

    // HTML Escape
    function escapeHtml(text) {
        if (!text) return text;
        return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
</script>

<style>
    .animate-slide-in { animation: slideIn 0.3s ease-out; }
    .animate-fade-in { animation: fadeIn 0.2s ease-out; }
    @@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    @@keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    .sticky { position: sticky; }
</style>