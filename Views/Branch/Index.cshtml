@model IEnumerable<TaskTracker.Models.ViewModels.BranchListViewModel>
@{
    ViewData["Title"] = "Branches";
    
    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }
    
    var totalBranches = Model?.Count() ?? 0;
    var activeBranches = Model?.Count(b => b.IsActive) ?? 0;
    var avgCompletionRate = Model != null && Model.Any() ? Math.Round(Model.Average(b => b.CompletionRate), 1) : 0;
    var totalEmployees = ViewBag.TotalEmployees ?? 0;
}

<div class="space-y-6 animate-fade-up">
    <input type="hidden" id="requestVerificationToken" value="@token" />

    <!-- Header -->
    <div class="flex flex-wrap justify-between items-start gap-4">
        <div>
            <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #10b981, #059669);">
                    <i class="fas fa-store text-white text-sm"></i>
                </div>
                Branch Management
            </h1>
            <p class="text-slate-400 mt-1 ml-13">Manage your branch locations and track performance</p>
        </div>
        <a href="@Url.Action("Create")" class="btn-primary">
            <i class="fas fa-plus-circle"></i>Add Branch
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="glass-card p-5 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full rounded-l-[0.875rem]" style="background: linear-gradient(180deg, #6366f1, #7c3aed);"></div>
            <div class="flex items-center justify-between pl-3">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Total Branches</p>
                    <p class="text-3xl font-bold text-white mt-1">@totalBranches</p>
                </div>
                <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background: rgba(99,102,241,0.15);">
                    <i class="fas fa-store text-indigo-400"></i>
                </div>
            </div>
        </div>
        <div class="glass-card p-5 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full rounded-l-[0.875rem]" style="background: linear-gradient(180deg, #10b981, #059669);"></div>
            <div class="flex items-center justify-between pl-3">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Active</p>
                    <p class="text-3xl font-bold text-emerald-400 mt-1">@activeBranches</p>
                </div>
                <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background: rgba(16,185,129,0.15);">
                    <i class="fas fa-check-circle text-emerald-400"></i>
                </div>
            </div>
        </div>
        <div class="glass-card p-5 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full rounded-l-[0.875rem]" style="background: linear-gradient(180deg, #7c3aed, #6366f1);"></div>
            <div class="flex items-center justify-between pl-3">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Total Employees</p>
                    <p class="text-3xl font-bold text-violet-400 mt-1">@totalEmployees</p>
                </div>
                <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background: rgba(124,58,237,0.15);">
                    <i class="fas fa-users text-violet-400"></i>
                </div>
            </div>
        </div>
        <div class="glass-card p-5 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full rounded-l-[0.875rem]" style="background: linear-gradient(180deg, #f59e0b, #d97706);"></div>
            <div class="flex items-center justify-between pl-3">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Avg Completion</p>
                    <p class="text-3xl font-bold text-amber-400 mt-1">@avgCompletionRate%</p>
                </div>
                <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background: rgba(245,158,11,0.15);">
                    <i class="fas fa-chart-line text-amber-400"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="glass-card p-4">
        <div class="flex flex-wrap gap-3">
            <div class="flex-1 min-w-[200px] relative">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-sm pointer-events-none"></i>
                <input type="text" id="searchInput" placeholder="Search by name, code, or department..."
                       class="dark-input pl-9" />
            </div>
            <select id="departmentFilter" class="dark-input w-auto px-4">
                <option value="">All Departments</option>
                @if (ViewBag.Departments != null)
                {
                    @foreach (var dept in ViewBag.Departments)
                    {
                        <option value="@dept.Name">@dept.Name</option>
                    }
                }
            </select>
            <select id="statusFilter" class="dark-input w-auto px-4">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
            <button onclick="resetFilters()" class="px-4 py-2 rounded-xl border border-white/10 text-slate-400 hover:text-white hover:bg-white/5 transition text-sm flex items-center gap-2">
                <i class="fas fa-undo-alt"></i>Reset
            </button>
        </div>
    </div>

    <!-- Branches Table -->
    <div class="glass-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full dark-table" id="branchesTable">
                <thead>
                    <tr>
                        <th>Branch</th>
                        <th>Code</th>
                        <th>Department</th>
                        <th>Address</th>
                        <th class="text-center">Employees</th>
                        <th class="text-center">Completion Rate</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody id="branchTableBody">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var branch in Model.OrderBy(b => b.Name))
                        {
                            var completionRate = branch.CompletionRate;
                            var barColor = completionRate >= 80 ? "#10b981" : completionRate >= 60 ? "#f59e0b" : "#ef4444";
                            var branchInitials = string.IsNullOrEmpty(branch.Name) ? "?" : branch.Name.Length > 1 ? branch.Name.Substring(0, 2).ToUpper() : branch.Name[0].ToString().ToUpper();
                            
                            <tr class="branch-row"
                                data-name="@branch.Name.ToLower()"
                                data-code="@branch.Code.ToLower()"
                                data-department="@branch.Department"
                                data-status="@(branch.IsActive ? "active" : "inactive")"
                                data-branch-id="@branch.Id">
                                <td>
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-xl flex items-center justify-center text-white text-xs font-bold flex-shrink-0"
                                             style="background: linear-gradient(135deg, #10b981, #6366f1);">
                                            @branchInitials
                                        </div>
                                        <div>
                                            <p class="font-semibold text-white">@branch.Name</p>
                                            <p class="text-xs text-slate-500">@branch.Code</p>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="font-mono text-slate-300 text-xs">@branch.Code</span></td>
                                <td>
                                    <span class="stat-badge" style="background: rgba(99,102,241,0.15); color: #a5b4fc;">
                                        @branch.Department
                                    </span>
                                </td>
                                <td>
                                    <span class="text-sm text-slate-400 truncate max-w-[160px] block" title="@branch.Address">
                                        @(string.IsNullOrEmpty(branch.Address) ? "—" : branch.Address)
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="text-sm font-semibold text-white">@branch.EmployeeCount</span>
                                </td>
                                <td class="text-center">
                                    <div class="flex flex-col items-center gap-1">
                                        <span class="text-sm font-bold" style="color: @barColor">@completionRate%</span>
                                        <div class="w-16 bg-white/10 rounded-full h-1.5">
                                            <div class="h-1.5 rounded-full transition-all" style="width: @completionRate%; background-color: @barColor"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (branch.IsActive)
                                    {
                                        <span class="stat-badge" style="background: rgba(16,185,129,0.15); color: #6ee7b7;">
                                            <i class="fas fa-circle text-[8px] text-emerald-400"></i>Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="stat-badge" style="background: rgba(239,68,68,0.15); color: #fca5a5;">
                                            <i class="fas fa-circle text-[8px] text-red-400"></i>Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="flex items-center justify-center gap-1">
                                        <a href="@Url.Action("Details", new { id = branch.Id })"
                                           class="w-8 h-8 rounded-lg flex items-center justify-center text-indigo-400 hover:bg-indigo-400/10 transition" title="View Details">
                                            <i class="fas fa-eye text-sm"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = branch.Id })"
                                           class="w-8 h-8 rounded-lg flex items-center justify-center text-emerald-400 hover:bg-emerald-400/10 transition" title="Edit">
                                            <i class="fas fa-edit text-sm"></i>
                                        </a>
                                        <a href="@Url.Action("BranchPerformance", "Report", new { branchId = branch.Id })"
                                           class="w-8 h-8 rounded-lg flex items-center justify-center text-violet-400 hover:bg-violet-400/10 transition" title="Performance Report">
                                            <i class="fas fa-chart-bar text-sm"></i>
                                        </a>
                                        <button onclick="deleteBranch(@branch.Id, '@branch.Name.Replace("'", "\\'")' )"
                                                class="w-8 h-8 rounded-lg flex items-center justify-center text-red-400 hover:bg-red-400/10 transition" title="Delete">
                                            <i class="fas fa-trash text-sm"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="py-16 text-center">
                                <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4"
                                     style="background: rgba(16,185,129,0.1);">
                                    <i class="fas fa-store text-emerald-400 text-2xl"></i>
                                </div>
                                <p class="text-slate-300 font-semibold mb-1">No branches found</p>
                                <p class="text-slate-500 text-sm mb-4">Get started by adding your first branch.</p>
                                <a href="@Url.Action("Create")" class="btn-primary">
                                    <i class="fas fa-plus-circle"></i>Add Branch
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model != null && Model.Any())
        {
            <div class="px-5 py-3 border-t text-xs text-slate-500" style="border-color: rgba(255,255,255,0.06);">
                Showing @Model.Count() branch@(Model.Count() != 1 ? "es" : "")
            </div>
        }
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="w-full max-w-md rounded-2xl overflow-hidden border animate-fade-up shadow-2xl"
         style="background: #1a1a2e; border-color: rgba(239,68,68,0.3);">
        <div class="px-6 py-4 flex items-center gap-3" style="background: linear-gradient(135deg, #dc2626, #b91c1c);">
            <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center">
                <i class="fas fa-exclamation-triangle text-white text-sm"></i>
            </div>
            <h3 class="text-white font-semibold">Delete Branch</h3>
        </div>
        <div class="p-6">
            <p class="text-slate-300 text-sm" id="deleteMessage">Are you sure you want to delete this branch?</p>
            <p class="text-xs text-red-400 mt-2" id="deleteWarning"></p>
            <input type="hidden" id="deleteBranchId" />
        </div>
        <div class="px-6 py-4 border-t flex justify-end gap-3" style="border-color: rgba(255,255,255,0.06);">
            <button onclick="closeDeleteModal()" class="px-4 py-2 rounded-lg text-sm text-slate-300 border border-white/10 hover:bg-white/5 transition">Cancel</button>
            <button onclick="confirmDelete()" class="px-4 py-2 rounded-lg text-sm bg-red-600 text-white hover:bg-red-700 transition flex items-center gap-2">
                <i class="fas fa-trash"></i>Delete
            </button>
        </div>
    </div>
</div>

<script>
    let pendingDeleteId = null;
    let pendingDeleteName = null;

    $(document).ready(function() {
        $('#searchInput').on('keyup', filterTable);
        $('#departmentFilter, #statusFilter').on('change', filterTable);
    });

    function filterTable() {
        var searchTerm = $('#searchInput').val().toLowerCase();
        var department = $('#departmentFilter').val();
        var status = $('#statusFilter').val();
        var visibleCount = 0;

        $('#branchTableBody tr.branch-row').each(function() {
            var name = $(this).data('name') || '';
            var code = $(this).data('code') || '';
            var branchDepartment = $(this).data('department') || '';
            var branchStatus = $(this).data('status') || '';

            var show = (searchTerm === '' || name.indexOf(searchTerm) !== -1 || code.indexOf(searchTerm) !== -1) &&
                       (department === '' || branchDepartment === department) &&
                       (status === '' || branchStatus === status);

            $(this).toggle(show);
            if (show) visibleCount++;
        });

        if (visibleCount === 0 && $('#branchTableBody tr.branch-row').length > 0) {
            if ($('#noResultsRow').length === 0) {
                $('#branchTableBody').append('<tr id="noResultsRow"><td colspan="8" class="py-12 text-center text-slate-500"><i class="fas fa-search text-3xl mb-3 text-slate-600 block"></i>No branches match your filters<br><button onclick="resetFilters()" class="mt-2 text-indigo-400 hover:underline text-sm">Clear filters</button></td></tr>');
            }
        } else {
            $('#noResultsRow').remove();
        }
    }

    function resetFilters() {
        $('#searchInput').val('');
        $('#departmentFilter, #statusFilter').val('');
        filterTable();
    }

    function deleteBranch(id, name) {
        pendingDeleteId = id;
        pendingDeleteName = name;
        $('#deleteMessage').text(`Are you sure you want to delete "${name}"?`);
        $('#deleteWarning').text('This will deactivate the branch. Active employee assignments must be ended first.');
        $('#deleteModal').removeClass('hidden').addClass('flex');
    }

    function closeDeleteModal() {
        $('#deleteModal').addClass('hidden').removeClass('flex');
        pendingDeleteId = null;
    }

    async function confirmDelete() {
        if (!pendingDeleteId) return;
        const token = $('#requestVerificationToken').val();
        try {
            const response = await $.ajax({
                url: '@Url.Action("Delete", "Branch")/' + pendingDeleteId,
                type: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            if (response.success) {
                if (window.TaskTracker) TaskTracker.showNotification(response.message, 'success');
                closeDeleteModal();
                setTimeout(() => location.reload(), 1500);
            } else {
                if (window.TaskTracker) TaskTracker.showNotification(response.message, 'error');
                closeDeleteModal();
            }
        } catch (error) {
            let errorMsg = 'Error deleting branch';
            try { const r = JSON.parse(error.responseText); errorMsg = r.message || errorMsg; } catch(e) {}
            if (window.TaskTracker) TaskTracker.showNotification(errorMsg, 'error');
            closeDeleteModal();
        }
    }
</script>