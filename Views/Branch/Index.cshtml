@model IEnumerable<TaskTracker.Models.ViewModels.BranchListViewModel>
@{
    ViewData["Title"] = "Branches";
    
    // Get anti-forgery token for AJAX calls
    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }
    
    // Calculate stats safely
    var totalBranches = Model?.Count() ?? 0;
    var activeBranches = Model?.Count(b => b.IsActive) ?? 0;
    var avgCompletionRate = Model != null && Model.Any() ? Math.Round(Model.Average(b => b.CompletionRate), 1) : 0;
    var totalEmployees = ViewBag.TotalEmployees ?? 0;
}

<div class="space-y-6">
    <!-- Hidden anti-forgery token -->
    <input type="hidden" id="requestVerificationToken" value="@token" />

    <!-- Header -->
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Branch Management</h1>
            <p class="text-gray-500 mt-1">Manage your branch locations and track performance</p>
        </div>
        <a href="@Url.Action("Create")" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium flex items-center transition">
            <i class="fas fa-plus-circle mr-2"></i>Add Branch
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Total Branches</p>
                    <p class="text-2xl font-bold text-gray-800">@totalBranches</p>
                </div>
                <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-store text-blue-600"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Active Branches</p>
                    <p class="text-2xl font-bold text-green-600">@activeBranches</p>
                </div>
                <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-check-circle text-green-600"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Total Employees</p>
                    <p class="text-2xl font-bold text-purple-600">@totalEmployees</p>
                </div>
                <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-users text-purple-600"></i>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Avg Completion</p>
                    <p class="text-2xl font-bold text-yellow-600">@avgCompletionRate%</p>
                </div>
                <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-chart-line text-yellow-600"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Bar -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
        <div class="flex flex-wrap gap-4">
            <div class="flex-1 min-w-[200px]">
                <div class="relative">
                    <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-sm"></i>
                    <input type="text" id="searchInput" placeholder="Search by name, code, or department..." 
                           class="w-full pl-9 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
            </div>
            <div>
                <select id="departmentFilter" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">All Departments</option>
                    @if (ViewBag.Departments != null)
                    {
                        @foreach (var dept in ViewBag.Departments)
                        {
                            <option value="@dept.Name">@dept.Name</option>
                        }
                    }
                </select>
            </div>
            <div>
                <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">All Status</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            <div>
                <button onclick="resetFilters()" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition">
                    <i class="fas fa-undo-alt mr-2"></i>Reset
                </button>
            </div>
        </div>
    </div>

    <!-- Branches Table -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm" id="branchesTable">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-3 text-left font-semibold text-gray-600">Branch</th>
                        <th class="px-6 py-3 text-left font-semibold text-gray-600">Code</th>
                        <th class="px-6 py-3 text-left font-semibold text-gray-600">Department</th>
                        <th class="px-6 py-3 text-left font-semibold text-gray-600">Address</th>
                        <th class="px-6 py-3 text-center font-semibold text-gray-600">Employees</th>
                        <th class="px-6 py-3 text-center font-semibold text-gray-600">Completion Rate</th>
                        <th class="px-6 py-3 text-center font-semibold text-gray-600">Status</th>
                        <th class="px-6 py-3 text-center font-semibold text-gray-600">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200" id="branchTableBody">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var branch in Model.OrderBy(b => b.Name))
                        {
                            var completionRate = branch.CompletionRate;
                            var completionColor = completionRate >= 80 ? "green" : (completionRate >= 60 ? "yellow" : "red");
                            
                            <tr class="hover:bg-gray-50 transition branch-row" 
                                data-name="@branch.Name.ToLower()" 
                                data-code="@branch.Code.ToLower()"
                                data-department="@branch.Department"
                                data-status="@(branch.IsActive ? "active" : "inactive")"
                                data-branch-id="@branch.Id">
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-3">
                                        <div class="w-10 h-10 rounded-full bg-gradient-to-r from-blue-500 to-green-500 flex items-center justify-center text-white font-bold">
                                            @{
                                                var branchInitials = string.IsNullOrEmpty(branch.Name) ? "?" : branch.Name.Length > 1 ? branch.Name.Substring(0, 2).ToUpper() : branch.Name.Substring(0, 1).ToUpper();
                                            }
                                            @branchInitials
                                        </div>
                                        <div>
                                            <p class="font-medium text-gray-900">@branch.Name</p>
                                            <p class="text-xs text-gray-500">@branch.Code</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 font-mono text-sm">@branch.Code</td>
                                <td class="px-6 py-4">
                                    <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded-full text-xs">@branch.Department</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-sm truncate max-w-[200px] block" title="@branch.Address">
                                        @(string.IsNullOrEmpty(branch.Address) ? "—" : branch.Address)
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex items-center justify-center">
                                        <span class="text-sm font-medium">@branch.EmployeeCount</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex flex-col items-center">
                                        <div class="flex items-center gap-1 mb-1">
                                            <span class="font-bold text-@(completionColor)-600">@completionRate%</span>
                                        </div>
                                        <div class="w-16 bg-gray-200 rounded-full h-1.5">
                                            <div class="bg-@(completionColor)-500 h-1.5 rounded-full" style="width: @completionRate%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if (branch.IsActive)
                                    {
                                        <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">
                                            <i class="fas fa-circle text-green-500 mr-1 text-xs"></i>Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs font-medium">
                                            <i class="fas fa-circle text-red-500 mr-1 text-xs"></i>Inactive
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex items-center justify-center space-x-2">
                                        <a href="@Url.Action("Details", new { id = branch.Id })" 
                                           class="p-1.5 text-blue-600 hover:bg-blue-50 rounded-lg transition" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = branch.Id })" 
                                           class="p-1.5 text-green-600 hover:bg-green-50 rounded-lg transition" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("BranchPerformance", "Report", new { branchId = branch.Id })" 
                                           class="p-1.5 text-purple-600 hover:bg-purple-50 rounded-lg transition" title="Performance Report">
                                            <i class="fas fa-chart-bar"></i>
                                        </a>
                                        <button onclick="deleteBranch(@branch.Id, '@branch.Name')" 
                                                class="p-1.5 text-red-600 hover:bg-red-50 rounded-lg transition" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="px-6 py-12 text-center text-gray-500">
                                <i class="fas fa-store text-4xl mb-3 text-gray-300"></i>
                                <p class="text-lg font-medium">No branches found</p>
                                <p class="text-sm mt-1">Get started by adding your first branch.</p>
                                <a href="@Url.Action("Create")" class="inline-flex items-center mt-3 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
                                    <i class="fas fa-plus-circle mr-2"></i>Add Branch
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination Info -->
        @if (Model != null && Model.Any())
        {
            <div class="px-6 py-3 border-t border-gray-200 bg-gray-50 text-sm text-gray-500">
                Showing @Model.Count() branch@(Model.Count() != 1 ? "es" : "")
            </div>
        }
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        console.log('Branch index page loaded');
        
        // Setup event listeners for filters
        $('#searchInput').on('keyup', filterTable);
        $('#departmentFilter').on('change', filterTable);
        $('#statusFilter').on('change', filterTable);
    });

    // Filter table function
    function filterTable() {
        var searchTerm = $('#searchInput').val().toLowerCase();
        var department = $('#departmentFilter').val();
        var status = $('#statusFilter').val();

        var visibleCount = 0;
        
        $('#branchTableBody tr').each(function() {
            var name = $(this).data('name') || '';
            var code = $(this).data('code') || '';
            var branchDepartment = $(this).data('department') || '';
            var branchStatus = $(this).data('status') || '';

            var matchesSearch = searchTerm === '' || 
                name.indexOf(searchTerm) !== -1 || 
                code.indexOf(searchTerm) !== -1;
            
            var matchesDepartment = department === '' || branchDepartment === department;
            var matchesStatus = status === '' || branchStatus === status;

            if (matchesSearch && matchesDepartment && matchesStatus) {
                $(this).show();
                visibleCount++;
            } else {
                $(this).hide();
            }
        });
        
        // Update visible count
        if (visibleCount === 0) {
            if ($('#branchTableBody tr:visible').length === 0 && $('#branchTableBody tr').length > 0) {
                if ($('#noResultsRow').length === 0) {
                    $('#branchTableBody').append('<tr id="noResultsRow"><td colspan="8" class="px-6 py-12 text-center text-gray-500"><i class="fas fa-search text-3xl mb-2 text-gray-300"></i><p>No branches match your filters</p><button onclick="resetFilters()" class="mt-2 text-blue-600 hover:underline">Clear filters</button></td></tr>');
                }
            } else {
                $('#noResultsRow').remove();
            }
        } else {
            $('#noResultsRow').remove();
        }
    }

    function resetFilters() {
        $('#searchInput').val('');
        $('#departmentFilter').val('');
        $('#statusFilter').val('');
        filterTable();
        showNotification('Filters reset', 'info');
    }

    // Delete branch function
    function deleteBranch(id, name) {
        if (confirm(`Are you sure you want to delete ${name}? This will deactivate the branch.`)) {
            var token = $('#requestVerificationToken').val();
            
            $.ajax({
                url: '@Url.Action("Delete", "Branch")/' + id,
                type: 'POST',
                headers: { 'RequestVerificationToken': token },
                success: function(response) {
                    if (response.success) {
                        showNotification(response.message, 'success');
                        setTimeout(function() { location.reload(); }, 1500);
                    } else {
                        showNotification(response.message, 'error');
                    }
                },
                error: function(xhr) {
                    var errorMsg = 'Error deleting branch';
                    try {
                        var response = JSON.parse(xhr.responseText);
                        errorMsg = response.message || errorMsg;
                    } catch(e) {}
                    showNotification(errorMsg, 'error');
                }
            });
        }
    }

    // Notification function
    function showNotification(message, type) {
        var colors = {
            success: 'bg-green-500',
            error: 'bg-red-500',
            info: 'bg-blue-500',
            warning: 'bg-yellow-500'
        };
        
        $('.custom-notification').remove();
        var notification = $('<div class="custom-notification fixed top-4 right-4 z-50 px-4 py-2 rounded-lg shadow-lg text-sm font-medium text-white ' + colors[type] + ' animate-slide-in flex items-center">' +
            '<i class="fas ' + (type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle') + ' mr-2"></i>' +
            '<span>' + message + '</span>' +
            '</div>');
        
        $('body').append(notification);
        setTimeout(function() { 
            notification.fadeOut(300, function() { $(this).remove(); }); 
        }, 3000);
    }
</script>

<style>
    .animate-slide-in {
        animation: slideIn 0.3s ease-out;
    }
    
    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
    
    .branch-row {
        transition: background-color 0.2s ease;
    }
    
    .branch-row:hover {
        background-color: #f9fafb;
    }
    
    .max-w-[200px] {
        max-width: 200px;
    }
    
    .truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>