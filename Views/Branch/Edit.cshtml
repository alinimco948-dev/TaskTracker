@model TaskTracker.Models.ViewModels.BranchViewModel
@{
    ViewData["Title"] = "Edit Branch";
}

<div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-green-600 to-green-800 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">Edit Branch</h2>
            <p class="text-green-100 text-sm mt-1">Update branch information</p>
        </div>

        <form asp-action="Edit" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Left Column -->
                <div class="space-y-4">
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                            Branch Name <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" />
                        <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Code" class="block text-sm font-medium text-gray-700 mb-1">
                            Branch Code
                        </label>
                        <input asp-for="Code" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" />
                    </div>

                    <div>
                        <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1">
                            Address
                        </label>
                        <input asp-for="Address" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" />
                    </div>

                    <div>
                        <label asp-for="DepartmentId" class="block text-sm font-medium text-gray-700 mb-1">
                            Department
                        </label>
                        <select asp-for="DepartmentId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition">
                            <option value="">Select Department (Optional)</option>
                            @if (ViewBag.Departments != null)
                            {
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.Id" selected="@(dept.Id == Model.DepartmentId ? "selected" : null)">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="space-y-4">
                    <div>
                        <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1">
                            Phone Number
                        </label>
                        <input asp-for="Phone" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" />
                    </div>

                    <div>
                        <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">
                            Email Address
                        </label>
                        <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition" />
                        <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Notes" class="block text-sm font-medium text-gray-700 mb-1">
                            Notes
                        </label>
                        <textarea asp-for="Notes" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition">@Model.Notes</textarea>
                    </div>

                    <div class="bg-gray-50 p-4 rounded-lg">
                        <label class="flex items-center space-x-3">
                            <input asp-for="IsActive" type="checkbox" class="w-4 h-4 text-green-600 border-gray-300 rounded focus:ring-green-500" />
                            <span class="text-sm font-medium text-gray-700">Active Branch</span>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Hidden Tasks Section -->
            <div class="mt-6 pt-6 border-t border-gray-200">
                <h3 class="text-lg font-medium text-gray-900 mb-3">Hidden Tasks</h3>
                <p class="text-sm text-gray-600 mb-4">Select tasks that should NOT be visible for this branch:</p>

                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
                    @if (ViewBag.Tasks != null)
                    {
                        @foreach (var task in ViewBag.Tasks)
                        {
                            var isHidden = ViewBag.HiddenTaskNames != null && ((List<string>)ViewBag.HiddenTaskNames).Contains(task.Name);
                            <label class="flex items-center space-x-2 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer transition">
                                <input type="checkbox" name="hiddenTaskIds" value="@task.Id" class="w-4 h-4 text-green-600 border-gray-300 rounded focus:ring-green-500"
                                       @(isHidden ? "" : "checked") />
                                <span class="text-sm text-gray-700">@task.Name</span>
                            </label>
                        }
                    }
                </div>
                <p class="text-xs text-gray-500 mt-3">
                    <i class="fas fa-info-circle mr-1"></i>
                    Checked = Visible, Unchecked = Hidden
                </p>
            </div>

            <!-- Form Actions -->
            <div class="flex justify-end space-x-3 mt-6 pt-4 border-t">
                <a href="@Url.Action("Index")" class="px-6 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition duration-200">
                    <i class="fas fa-times mr-2"></i>Cancel
                </a>
                <button type="submit" class="px-6 py-2 bg-green-600 text-white rounded-lg text-sm font-medium hover:bg-green-700 transition duration-200 flex items-center">
                    <i class="fas fa-save mr-2"></i>Update Branch
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}