@model TaskTracker.Models.ViewModels.BranchViewModel
@{
    ViewData["Title"] = "Create Branch";
}

<div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-green-600 to-green-800 px-6 py-4">
            <h2 class="text-xl font-semibold text-white">Create New Branch</h2>
            <p class="text-green-100 text-sm mt-1">Add a new branch location to the system</p>
        </div>

        <form asp-action="Create" method="post" class="p-6">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 text-red-700 rounded-lg text-sm border border-red-200"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Left Column -->
                <div class="space-y-4">
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">
                            Branch Name <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
                               placeholder="e.g., Ambassador, Waheen, Gabiley" />
                        <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block"></span>
                        <p class="text-xs text-gray-400 mt-1">Branch name must be unique</p>
                    </div>

                    <div>
                        <label asp-for="Code" class="block text-sm font-medium text-gray-700 mb-1">
                            Branch Code
                        </label>
                        <input asp-for="Code" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
                               placeholder="e.g., AMB-001, WAH-002" />
                        <p class="text-xs text-gray-500 mt-1">Unique identifier for the branch (optional)</p>
                    </div>

                    <div>
                        <label asp-for="Address" class="block text-sm font-medium text-gray-700 mb-1">
                            Address
                        </label>
                        <input asp-for="Address" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
                               placeholder="Street address, city, etc." />
                    </div>

                    <div>
                        <label asp-for="DepartmentId" class="block text-sm font-medium text-gray-700 mb-1">
                            Department
                        </label>
                        <select asp-for="DepartmentId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">
                            <option value="">Select Department (Optional)</option>
                            @if (ViewBag.Departments != null)
                            {
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="space-y-4">
                    <div>
                        <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1">
                            Phone Number
                        </label>
                        <input asp-for="Phone" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
                               placeholder="+1234567890" />
                    </div>

                    <div>
                        <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">
                            Email Address
                        </label>
                        <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
                               placeholder="branch@example.com" />
                        <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Notes" class="block text-sm font-medium text-gray-700 mb-1">
                            Notes
                        </label>
                        <textarea asp-for="Notes" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition"
                                  placeholder="Additional information about this branch..."></textarea>
                    </div>

                    <div class="bg-gray-50 p-4 rounded-lg">
                        <label class="flex items-center space-x-3">
                            <input asp-for="IsActive" type="checkbox" class="w-4 h-4 text-green-600 border-gray-300 rounded focus:ring-green-500" checked />
                            <span class="text-sm font-medium text-gray-700">Active Branch</span>
                        </label>
                        <p class="text-xs text-gray-500 mt-1 ml-7">Inactive branches won't appear in dropdown menus and daily tasks</p>
                    </div>
                </div>
            </div>

            <!-- Hidden Tasks Section -->
            <div class="mt-6 pt-6 border-t border-gray-200">
                <h3 class="text-lg font-medium text-gray-900 mb-3">Task Visibility</h3>
                <p class="text-sm text-gray-600 mb-4">Select tasks that should be VISIBLE for this branch:</p>

                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
                    @if (ViewBag.Tasks != null)
                    {
                        @foreach (var task in ViewBag.Tasks)
                        {
                            <label class="flex items-center space-x-2 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer transition">
                                <input type="checkbox" name="hiddenTaskIds" value="@task.Id" class="w-4 h-4 text-green-600 border-gray-300 rounded focus:ring-green-500" checked />
                                <span class="text-sm text-gray-700">@task.Name</span>
                            </label>
                        }
                    }
                </div>
                <p class="text-xs text-gray-500 mt-3">
                    <i class="fas fa-info-circle mr-1"></i>
                    <span class="text-green-600">Checked = Visible</span> | 
                    <span class="text-gray-400">Unchecked = Hidden</span>
                </p>
            </div>

            <!-- Form Actions -->
            <div class="flex justify-end space-x-3 mt-6 pt-4 border-t">
                <a href="@Url.Action("Index")" class="px-6 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition duration-200">
                    <i class="fas fa-times mr-2"></i>Cancel
                </a>
                <button type="submit" class="px-6 py-2 bg-green-600 text-white rounded-lg text-sm font-medium hover:bg-green-700 transition duration-200 flex items-center">
                    <i class="fas fa-save mr-2"></i>Create Branch
                </button>
            </div>
        </form>
    </div>

    <!-- Help Card -->
    <div class="mt-6 bg-green-50 border border-green-200 rounded-lg p-4">
        <div class="flex items-start space-x-3">
            <div class="flex-shrink-0">
                <i class="fas fa-info-circle text-green-600 mt-1"></i>
            </div>
            <div class="text-sm text-green-800">
                <p class="font-medium mb-1">About Branches</p>
                <p>Branches represent physical locations where tasks are performed.</p>
                <ul class="list-disc list-inside mt-2 text-green-700">
                    <li>Branch names must be unique</li>
                    <li>You can assign employees to branches after creation</li>
                    <li>Checked tasks will be visible, unchecked tasks will be hidden</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}