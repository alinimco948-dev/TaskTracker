@model TaskTracker.Models.ViewModels.BranchViewModel
@{
    ViewData["Title"] = "Create Branch";
}

<div class="max-w-3xl mx-auto animate-fade-up">
    <div class="glass-card overflow-hidden">
        <!-- Header -->
        <div class="px-6 py-5 flex items-center gap-4" style="background: linear-gradient(135deg, rgba(16,185,129,0.25), rgba(99,102,241,0.15)); border-bottom: 1px solid rgba(255,255,255,0.08);">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 4px 15px rgba(16,185,129,0.4);">
                <i class="fas fa-store text-white"></i>
            </div>
            <div>
                <h2 class="text-xl font-bold text-white">Create New Branch</h2>
                <p class="text-slate-400 text-sm mt-0.5">Add a new branch location to the system</p>
            </div>
        </div>

        <form asp-action="Create" method="post" class="p-6">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert-error rounded-xl p-4 mb-6 text-sm"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Left Column -->
                <div class="space-y-5">
                    <div>
                        <label asp-for="Name" class="block text-sm font-semibold text-slate-300 mb-2">
                            Branch Name <span class="text-red-400">*</span>
                        </label>
                        <input asp-for="Name" class="dark-input" placeholder="e.g., Ambassador, Waheen, Gabiley" />
                        <span asp-validation-for="Name" class="text-xs text-red-400 mt-1 block"></span>
                        <p class="text-xs text-slate-500 mt-1">Branch name must be unique</p>
                    </div>

                    <div>
                        <label asp-for="Code" class="block text-sm font-semibold text-slate-300 mb-2">Branch Code</label>
                        <input asp-for="Code" class="dark-input" placeholder="e.g., AMB-001, WAH-002" />
                        <p class="text-xs text-slate-500 mt-1">Unique identifier for the branch (optional)</p>
                    </div>

                    <div>
                        <label asp-for="Address" class="block text-sm font-semibold text-slate-300 mb-2">Address</label>
                        <input asp-for="Address" class="dark-input" placeholder="Street address, city, etc." />
                    </div>

                    <div>
                        <label asp-for="DepartmentId" class="block text-sm font-semibold text-slate-300 mb-2">Department</label>
                        <select asp-for="DepartmentId" class="dark-input">
                            <option value="">Select Department (Optional)</option>
                            @if (ViewBag.Departments != null)
                            {
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="space-y-5">
                    <div>
                        <label asp-for="Phone" class="block text-sm font-semibold text-slate-300 mb-2">Phone Number</label>
                        <input asp-for="Phone" class="dark-input" placeholder="+1234567890" />
                    </div>

                    <div>
                        <label asp-for="Email" class="block text-sm font-semibold text-slate-300 mb-2">Email Address</label>
                        <input asp-for="Email" type="email" class="dark-input" placeholder="branch@example.com" />
                        <span asp-validation-for="Email" class="text-xs text-red-400 mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Notes" class="block text-sm font-semibold text-slate-300 mb-2">Notes</label>
                        <textarea asp-for="Notes" rows="3" class="dark-input resize-none"
                                  placeholder="Additional information about this branch..."></textarea>
                    </div>

                    <div class="rounded-xl p-4 flex items-center gap-4" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                        <input asp-for="IsActive" type="checkbox" class="w-4 h-4 accent-emerald-500 cursor-pointer" checked />
                        <div>
                            <span class="text-sm font-semibold text-slate-200">Active Branch</span>
                            <p class="text-xs text-slate-500 mt-0.5">Inactive branches won't appear in dropdown menus and daily tasks</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Task Visibility -->
            <div class="mt-6 pt-6 border-t" style="border-color: rgba(255,255,255,0.06);">
                <h3 class="text-base font-bold text-white mb-1">Task Visibility</h3>
                <p class="text-sm text-slate-400 mb-4">Select tasks that should be <span class="text-emerald-400 font-medium">VISIBLE</span> for this branch:</p>

                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
                    @if (ViewBag.Tasks != null)
                    {
                        @foreach (var task in ViewBag.Tasks)
                        {
                            <label class="flex items-center gap-2 p-3 rounded-xl cursor-pointer transition"
                                   style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);"
                                   onmouseover="this.style.borderColor='rgba(99,102,241,0.4)'"
                                   onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'">
                                <input type="checkbox" name="hiddenTaskIds" value="@task.Id"
                                       class="w-4 h-4 accent-emerald-500" checked />
                                <span class="text-sm text-slate-300">@task.Name</span>
                            </label>
                        }
                    }
                </div>
                <p class="text-xs text-slate-500 mt-3">
                    <i class="fas fa-info-circle mr-1 text-indigo-400"></i>
                    <span class="text-emerald-400">Checked = Visible</span> |
                    <span class="text-slate-500">Unchecked = Hidden</span>
                </p>
            </div>

            <!-- Form Actions -->
            <div class="flex justify-end gap-3 mt-6 pt-5 border-t" style="border-color: rgba(255,255,255,0.06);">
                <a href="@Url.Action("Index")" class="px-5 py-2.5 rounded-xl border border-white/10 text-slate-300 hover:bg-white/5 transition text-sm font-medium flex items-center gap-2">
                    <i class="fas fa-times"></i>Cancel
                </a>
                <button type="submit" class="btn-primary" style="background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 4px 15px rgba(16,185,129,0.3);">
                    <i class="fas fa-save"></i>Create Branch
                </button>
            </div>
        </form>
    </div>

    <!-- Help Card -->
    <div class="mt-5 glass-card p-5" style="border-color: rgba(16,185,129,0.2);">
        <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(16,185,129,0.15);">
                <i class="fas fa-info-circle text-emerald-400 text-sm"></i>
            </div>
            <div class="text-sm text-slate-400">
                <p class="font-semibold text-slate-300 mb-1">About Branches</p>
                <p>Branches represent physical locations where tasks are performed.</p>
                <ul class="mt-2 space-y-1 text-xs text-slate-500 list-disc list-inside">
                    <li>Branch names must be unique</li>
                    <li>You can assign employees to branches after creation</li>
                    <li>Checked tasks will be visible, unchecked tasks will be hidden</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}