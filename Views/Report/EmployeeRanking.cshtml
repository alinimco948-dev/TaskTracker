@model TaskTracker.Models.ViewModels.EmployeeRankingReportViewModel
@using TaskTracker.Models.ViewModels
@{
    ViewData["Title"] = "Employee Performance Ranking";
    bool isGenerated = Model?.IsGenerated ?? false;
}

<div class="space-y-6 animate-fade-up">

    <!-- Header -->
    <div class="flex flex-wrap justify-between items-start gap-4">
        <div>
            <h1 class="text-2xl font-bold text-white flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                    <i class="fas fa-trophy text-white text-sm"></i>
                </div>
                Employee Performance Ranking
            </h1>
            <p class="text-slate-400 mt-1">Weighted score: 70% completion + 30% on-time</p>
        </div>
        <div class="flex gap-2">
            @if (isGenerated && Model.Rankings.Any())
            {
                <div class="flex gap-2">
                    <a href="@Url.Action("ExportRanking", new { startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, format = "excel" })" 
                       class="px-3 py-2 rounded-xl text-xs font-medium text-white flex items-center gap-1.5"
                       style="background: linear-gradient(135deg, #059669, #10b981);">
                        <i class="fas fa-file-excel"></i>Export
                    </a>
                </div>
            }
            <button onclick="window.print()" class="px-3 py-2 rounded-xl text-xs font-medium text-slate-300 border border-white/10 hover:bg-white/5 transition flex items-center gap-1.5">
                <i class="fas fa-print"></i>Print
            </button>
        </div>
    </div>

    <!-- Filter -->
    <div class="glass-card overflow-hidden">
        <form method="get" class="p-5">
            <input type="hidden" name="generate" value="true" />
            <div class="flex flex-wrap items-end gap-3">
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Start Date</label>
                    <input type="date" name="startDate" class="dark-input" value="@ViewBag.StartDate" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">End Date</label>
                    <input type="date" name="endDate" class="dark-input" value="@ViewBag.EndDate" />
                </div>
                <button type="submit" class="btn-primary">
                    <i class="fas fa-play text-xs mr-1"></i>Generate Ranking
                </button>
                <div class="ml-auto flex items-center gap-2 text-[10px] text-slate-500 bg-white/5 px-3 py-1.5 rounded-lg border border-white/5">
                    <i class="fas fa-calculator"></i>
                    <span>Weighted Score = (Completion × 70%) + (On-Time × 30%)</span>
                </div>
            </div>
        </form>
    </div>

    @if (isGenerated)
    {
        <!-- Stats Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Total Evaluated</p>
                    <p class="text-2xl font-bold text-white">@Model.TotalEmployees</p>
                </div>
                <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center border border-blue-500/20">
                    <i class="fas fa-users text-blue-400"></i>
                </div>
            </div>
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Average Score</p>
                    <p class="text-2xl font-bold text-white">@Model.AverageScore%</p>
                </div>
                <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center border border-purple-500/20">
                    <i class="fas fa-chart-line text-purple-400"></i>
                </div>
            </div>
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Top Score</p>
                    <p class="text-2xl font-bold text-emerald-400">@Model.TopScore%</p>
                </div>
                <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center border border-emerald-500/20">
                    <i class="fas fa-trophy text-emerald-400"></i>
                </div>
            </div>
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Range</p>
                    <p class="text-sm font-bold text-white">@Model.StartDate.ToString("MMM d") - @Model.EndDate.ToString("MMM d")</p>
                </div>
                <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center border border-amber-500/20">
                    <i class="fas fa-calendar-alt text-amber-400"></i>
                </div>
            </div>
        </div>

        <!-- Top 3 Performers Highlight -->
        @if (Model.Rankings.Any())
        {
            var top3 = Model.Rankings.Take(3).ToList();
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                @foreach (var emp in top3)
                {
                    var rankColor = emp.Rank == 1 ? "from-amber-500/20 to-amber-600/5 border-amber-500/30" : 
                                  emp.Rank == 2 ? "from-slate-400/20 to-slate-500/5 border-slate-400/30" : 
                                  "from-orange-500/20 to-orange-600/5 border-orange-500/30";
                    var badgeColor = emp.Rank == 1 ? "bg-amber-500" : emp.Rank == 2 ? "bg-slate-400" : "bg-orange-500";
                    
                    <div class="glass-card p-5 relative overflow-hidden bg-gradient-to-br @rankColor">
                        <div class="absolute -right-4 -top-4 w-24 h-24 rounded-full opacity-10 bg-white"></div>
                        <div class="flex items-center justify-between relative z-10">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 @badgeColor rounded-full flex items-center justify-center text-white shadow-lg">
                                    <i class="fas @(emp.Rank == 1 ? "fa-crown" : emp.Rank == 2 ? "fa-medal" : "fa-award")"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-white">@emp.Name</h3>
                                    <p class="text-xs text-slate-400 uppercase tracking-wider">@emp.Position</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="text-2xl font-bold text-white">@emp.PerformanceScore%</div>
                                <div class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">Score</div>
                            </div>
                        </div>
                        <div class="mt-4 pt-4 border-t border-white/5 flex justify-between items-center text-xs">
                            <span class="text-slate-400"><i class="fas fa-building mr-1"></i>@emp.Department</span>
                            <span class="px-2 py-0.5 rounded-full bg-white/5 text-white font-bold border border-white/10">RANK #@emp.Rank</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Ranking Table -->
            <div class="glass-card overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full dark-table">
                        <thead>
                            <tr>
                                <th class="pl-5 text-center w-16">Rank</th>
                                <th class="text-left">Employee</th>
                                <th class="text-left">ID</th>
                                <th class="text-left">Department</th>
                                <th class="text-center">Score</th>
                                <th class="text-center">Completion</th>
                                <th class="text-center">On-Time</th>
                                <th class="text-center">Tasks</th>
                                <th class="text-center pr-5">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model.Rankings)
                            {
                                var isTop3 = emp.Rank <= 3;
                                <tr class="@(isTop3 ? "bg-white/[0.02]" : "")">
                                    <td class="pl-5 text-center">
                                        @if (isTop3)
                                        {
                                            var medalColor = emp.Rank == 1 ? "text-amber-400" : emp.Rank == 2 ? "text-slate-400" : "text-orange-400";
                                            <span class="font-bold @medalColor">#@emp.Rank</span>
                                        }
                                        else
                                        {
                                            <span class="text-slate-500">#@emp.Rank</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-white font-bold text-xs border border-white/10">
                                                @TaskTracker.Models.ViewModels.ViewHelpers.GetInitials(emp.Name)
                                            </div>
                                            <span class="font-semibold text-slate-200">@emp.Name</span>
                                        </div>
                                    </td>
                                    <td class="font-mono text-xs text-slate-400">#88@emp.Id</td>
                                    <td><span class="px-2 py-0.5 rounded bg-white/5 text-slate-400 text-[10px] border border-white/5">@emp.Department</span></td>
                                    <td class="text-center">
                                        @{
                                            var scoreColor = emp.PerformanceScore >= 90 ? "text-emerald-400" : emp.PerformanceScore >= 75 ? "text-blue-400" : "text-amber-400";
                                            var barColor = emp.PerformanceScore >= 90 ? "bg-emerald-500" : emp.PerformanceScore >= 75 ? "bg-blue-500" : "bg-amber-500";
                                        }
                                        <div class="inline-flex flex-col items-center">
                                            <span class="font-bold @scoreColor">@emp.PerformanceScore%</span>
                                            <div class="w-12 h-1 bg-white/5 rounded-full mt-1">
                                                <div class="@barColor h-full rounded-full" style="width: @emp.PerformanceScore%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="inline-flex flex-col items-center">
                                            <span class="text-xs font-semibold text-slate-300">@emp.CompletionRate%</span>
                                            <span class="text-[9px] text-slate-500">@emp.CompletedTasks/@emp.TotalTasks</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="inline-flex flex-col items-center">
                                            <span class="text-xs font-semibold text-slate-300">@emp.OnTimeRate%</span>
                                            <span class="text-[9px] text-slate-500">@emp.OnTimeTasks on-time</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="text-xs">
                                            <span class="text-emerald-400 font-bold">@emp.CompletedTasks</span>
                                            <span class="text-slate-600 mx-0.5">/</span>
                                            <span class="text-slate-400">@emp.TotalTasks</span>
                                        </div>
                                    </td>
                                    <td class="text-center pr-5">
                                        <a href="@Url.Action("Details", "Employee", new { id = emp.Id })" 
                                           class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/10 transition">
                                            <i class="fas fa-chevron-right text-xs"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination (if applicable) -->
            @if (Model.TotalPages > 1)
            {
                <div class="flex justify-center gap-2 mt-6">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a href="@Url.Action("EmployeeRanking", new { startDate = Model.StartDate, endDate = Model.EndDate, page = i, generate = true })" 
                           class="w-10 h-10 rounded-xl flex items-center justify-center transition @(Model.CurrentPage == i ? "bg-white text-black font-bold" : "bg-white/5 text-slate-400 hover:bg-white/10")">
                            @i
                        </a>
                    }
                </div>
            }
        }
        else
        {
            <div class="glass-card p-12 text-center">
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: rgba(239,68,68,0.1);">
                    <i class="fas fa-exclamation-triangle text-red-400 text-2xl"></i>
                </div>
                <h3 class="font-semibold text-slate-300 mb-1">No Data Found</h3>
                <p class="text-slate-500">No performance records found for the selected period.</p>
            </div>
        }
    }
    else
    {
        <div class="glass-card p-12 text-center flex flex-col items-center justify-center space-y-4 min-h-[400px]">
            <div class="w-20 h-20 rounded-full bg-slate-800/50 flex items-center justify-center text-3xl text-slate-600">
                <i class="fas fa-list-ol"></i>
            </div>
            <h2 class="text-2xl font-bold text-white">Ranking Report Ready</h2>
            <p class="text-slate-400 max-w-md mx-auto">
                Generate the leaderboard to see top performing employees based on weighted completion and punctuality metrics.
            </p>
        </div>
    }
</div>