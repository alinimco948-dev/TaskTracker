@model TaskTracker.Models.ViewModels.EmployeeComparisonViewModel
@{
    ViewData["Title"] = "Employee Performance Comparison";
}

<div class="max-w-7xl mx-auto px-4 py-6 space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-xl font-bold text-gray-800">Employee Performance Comparison</h1>
            <p class="text-sm text-gray-500">Compare performance metrics across employees</p>
        </div>
        <div class="flex gap-2">
            <button onclick="exportReport('excel')" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm transition flex items-center gap-1">
                <i class="fas fa-file-excel text-xs"></i> Export
            </button>
            <button onclick="window.print()" class="px-3 py-1.5 bg-gray-600 hover:bg-gray-700 text-white rounded-lg text-sm transition flex items-center gap-1">
                <i class="fas fa-print text-xs"></i> Print
            </button>
        </div>
    </div>

    <!-- Sleek Filter Bar -->
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
        <form method="get" id="comparisonForm">
            <div class="p-4">
                <div class="flex flex-wrap items-end gap-3">
                    <!-- Mode Selector -->
                    <div class="w-48">
                        <label class="block text-xs font-medium text-gray-600 mb-1">Compare by</label>
                        <div class="relative">
                            <select name="comparisonMode" id="comparisonMode" 
                                    class="w-full px-3 py-2 pr-8 border border-gray-300 rounded-lg text-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 appearance-none bg-white">
                                <option value="branch" selected="@(Model.ComparisonMode == "branch")">🏢 Branch</option>
                                <option value="selected" selected="@(Model.ComparisonMode == "selected")">👥 Specific Employees</option>
                            </select>
                            <i class="fas fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                        </div>
                    </div>

                    <!-- Branch Selector (shown when mode = branch) -->
                    <div id="branchSelector" class="w-64">
                        <label class="block text-xs font-medium text-gray-600 mb-1">Select Branch</label>
                        <div class="relative">
                            <i class="fas fa-store absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                            <select name="branchId" id="branchSelect" 
                                    class="w-full pl-8 pr-8 py-2 border border-gray-300 rounded-lg text-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500 appearance-none bg-white">
                                <option value="">All Branches</option>
                                @foreach (var branch in ViewBag.Branches)
                                {
                                    <option value="@branch.Id" selected="@(ViewBag.SelectedBranchId == branch.Id)">@branch.Name</option>
                                }
                            </select>
                            <i class="fas fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                        </div>
                    </div>

                    <!-- Employee Selector (shown when mode = selected) -->
                    <div id="employeeSelector" class="w-80" style="display: none;">
                        <label class="block text-xs font-medium text-gray-600 mb-1">Select Employees to Compare</label>
                        <div class="relative">
                            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
                            <input type="text" id="employeeSearch" placeholder="Search employees..." 
                                   class="w-full pl-8 pr-3 py-2 border border-gray-300 rounded-t-lg text-sm focus:ring-1 focus:ring-blue-500 focus:border-blue-500">
                        </div>
                        <div class="border border-t-0 border-gray-300 rounded-b-lg max-h-40 overflow-y-auto">
                            <select name="employeeIds" id="employeeIds" multiple class="w-full text-sm border-0" size="5">
                                @foreach (var emp in ViewBag.AllEmployees)
                                {
                                    <option value="@emp.Id" class="py-1.5 px-3 hover:bg-blue-50 transition">@emp.Name - @emp.Position</option>
                                }
                            </select>
                        </div>
                        <div class="flex justify-between items-center mt-1.5">
                            <button type="button" onclick="selectAllEmployees()" class="text-xs text-blue-600 hover:text-blue-700">Select All</button>
                            <button type="button" onclick="clearAllEmployees()" class="text-xs text-gray-500 hover:text-gray-700">Clear</button>
                            <span id="selectedCount" class="text-xs text-gray-500">0 selected</span>
                        </div>
                    </div>

                    <!-- Date Range -->
                    <div class="w-36">
                        <label class="block text-xs font-medium text-gray-600 mb-1">From</label>
                        <input type="date" name="startDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-1 focus:ring-blue-500" value="@ViewBag.StartDate">
                    </div>

                    <div class="w-36">
                        <label class="block text-xs font-medium text-gray-600 mb-1">To</label>
                        <input type="date" name="endDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-1 focus:ring-blue-500" value="@ViewBag.EndDate">
                    </div>

                    <!-- Generate Button -->
                    <div>
                        <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition flex items-center gap-2 shadow-sm">
                            <i class="fas fa-chart-line text-xs"></i> Generate
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @if (Model.Employees.Any())
    {
        <!-- Quick Stats -->
        <div class="grid grid-cols-5 gap-3">
            <div class="bg-white rounded-lg border border-gray-200 p-3 text-center shadow-sm">
                <div class="text-2xl font-bold text-blue-600">@Model.TotalEmployeesCompared</div>
                <div class="text-xs text-gray-500">Employees</div>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-3 text-center shadow-sm">
                <div class="text-2xl font-bold text-green-600">@Model.AverageScore%</div>
                <div class="text-xs text-gray-500">Avg Score</div>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-3 text-center shadow-sm">
                <div class="text-2xl font-bold text-yellow-600">@Model.HighestScore%</div>
                <div class="text-xs text-gray-500">Highest</div>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-3 text-center shadow-sm">
                <div class="text-2xl font-bold text-red-600">@Model.LowestScore%</div>
                <div class="text-xs text-gray-500">Lowest</div>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-3 text-center shadow-sm">
                <div class="text-2xl font-bold text-purple-600">@Math.Round(Model.HighestScore - Model.LowestScore, 1)%</div>
                <div class="text-xs text-gray-500">Gap</div>
            </div>
        </div>

        <!-- Performance Table -->
        <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
            <div class="px-4 py-3 border-b bg-gray-50">
                <div class="flex justify-between items-center">
                    <h3 class="font-medium text-gray-800 text-sm">Performance Ranking</h3>
                    <div class="text-xs text-gray-500">@Model.Employees.Count employees ranked</div>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">#</th>
                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Employee</th>
                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Position</th>
                            <th class="px-4 py-2 text-center text-xs font-medium text-gray-500">Score</th>
                            <th class="px-4 py-2 text-center text-xs font-medium text-gray-500">Completion</th>
                            <th class="px-4 py-2 text-center text-xs font-medium text-gray-500">On-Time</th>
                            <th class="px-4 py-2 text-center text-xs font-medium text-gray-500">Tasks</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        @foreach (var emp in Model.Employees.OrderByDescending(e => e.PerformanceScore))
                        {
                            var scoreClass = emp.PerformanceScore >= 90 ? "text-green-600" : emp.PerformanceScore >= 75 ? "text-blue-600" : emp.PerformanceScore >= 60 ? "text-yellow-600" : "text-red-600";
                            <tr class="hover:bg-gray-50">
                                <td class="px-4 py-2 text-center font-medium">
                                    @if (emp.Rank == 1) { <span>🏆</span> }
                                    else if (emp.Rank == 2) { <span>🥈</span> }
                                    else if (emp.Rank == 3) { <span>🥉</span> }
                                    else { <span class="text-gray-400">@emp.Rank</span> }
                                 </td>
                                <td class="px-4 py-2">
                                    <div class="flex items-center gap-2">
                                        <div class="w-7 h-7 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold">@(emp.Name.Substring(0,1).ToUpper())</div>
                                        <span class="font-medium">@emp.Name</span>
                                    </div>
                                 </td>
                                <td class="px-4 py-2 text-gray-500 text-xs">@emp.Position</td>
                                <td class="px-4 py-2 text-center font-semibold @scoreClass">@emp.PerformanceScore%</td>
                                <td class="px-4 py-2 text-center">
                                    <div class="inline-flex items-center gap-1">
                                        <div class="w-10 bg-gray-200 rounded-full h-1">
                                            <div class="bg-green-500 h-1 rounded-full" style="width: @emp.CompletionRate%"></div>
                                        </div>
                                        <span class="text-xs">@emp.CompletionRate%</span>
                                    </div>
                                 </td>
                                <td class="px-4 py-2 text-center">
                                    <div class="inline-flex items-center gap-1">
                                        <div class="w-10 bg-gray-200 rounded-full h-1">
                                            <div class="bg-blue-500 h-1 rounded-full" style="width: @emp.OnTimeRate%"></div>
                                        </div>
                                        <span class="text-xs">@emp.OnTimeRate%</span>
                                    </div>
                                 </td>
                                <td class="px-4 py-2 text-center text-gray-600">@emp.TotalTasks</td>
                             </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Comparison Matrix & Insights Side by Side -->
        <div class="grid grid-cols-2 gap-4">
            <!-- Comparison Matrix -->
            <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                <div class="px-4 py-2 border-b bg-gray-50">
                    <h3 class="font-medium text-gray-800 text-sm">Comparison Matrix</h3>
                </div>
                <div class="p-3">
                    <table class="w-full text-xs">
                        <thead>
                            <tr class="border-b">
                                <th class="py-1.5 text-left text-gray-500">Metric</th>
                                @foreach (var emp in Model.Employees.OrderByDescending(e => e.PerformanceScore).Take(4))
                                {
                                    <th class="py-1.5 text-center text-gray-500">@emp.Name.Split(' ').First()</th>
                                }
                                <th class="py-1.5 text-center bg-gray-50 text-gray-500">Avg</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b">
                                <td class="py-1.5 font-medium">Score</td>
                                @foreach (var emp in Model.Employees.OrderByDescending(e => e.PerformanceScore).Take(4))
                                {
                                    <td class="py-1.5 text-center font-semibold @(emp.PerformanceScore == Model.Employees.Max(e => e.PerformanceScore) ? "text-green-600" : "")">@emp.PerformanceScore%</td>
                                }
                                <td class="py-1.5 text-center bg-gray-50">@Model.AverageScore%</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-1.5">Completion</td>
                                @foreach (var emp in Model.Employees.OrderByDescending(e => e.PerformanceScore).Take(4))
                                {
                                    <td class="py-1.5 text-center">@emp.CompletionRate%</td>
                                }
                                <td class="py-1.5 text-center bg-gray-50">@Model.Employees.Average(e => e.CompletionRate).ToString("F1")%</td>
                            </tr>
                            <tr class="border-b">
                                <td class="py-1.5">On-Time</td>
                                @foreach (var emp in Model.Employees.OrderByDescending(e => e.PerformanceScore).Take(4))
                                {
                                    <td class="py-1.5 text-center">@emp.OnTimeRate%</td>
                                }
                                <td class="py-1.5 text-center bg-gray-50">@Model.Employees.Average(e => e.OnTimeRate).ToString("F1")%</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Insights Panel -->
            <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                <div class="px-4 py-2 border-b bg-gray-50">
                    <h3 class="font-medium text-gray-800 text-sm">Key Insights</h3>
                </div>
                <div class="p-3 space-y-3">
                    <div>
                        <div class="flex items-center gap-1 mb-1">
                            <i class="fas fa-check-circle text-green-500 text-xs"></i>
                            <span class="text-xs font-medium text-green-700">Strengths</span>
                        </div>
                        <div class="flex flex-wrap gap-1">
                            @if (Model.ComparisonResult.CommonStrengths.Any())
                            {
                                foreach (var s in Model.ComparisonResult.CommonStrengths.Take(2))
                                {
                                    <span class="text-xs px-2 py-0.5 bg-green-50 text-green-700 rounded">@s</span>
                                }
                            }
                            else
                            {
                                <span class="text-xs px-2 py-0.5 bg-green-50 text-green-700 rounded">High completion rate</span>
                            }
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center gap-1 mb-1">
                            <i class="fas fa-chart-line text-red-500 text-xs"></i>
                            <span class="text-xs font-medium text-red-700">Focus Areas</span>
                        </div>
                        <div class="flex flex-wrap gap-1">
                            @if (Model.ComparisonResult.CommonWeaknesses.Any())
                            {
                                foreach (var w in Model.ComparisonResult.CommonWeaknesses.Take(2))
                                {
                                    <span class="text-xs px-2 py-0.5 bg-red-50 text-red-700 rounded">@w</span>
                                }
                            }
                            else
                            {
                                <span class="text-xs px-2 py-0.5 bg-red-50 text-red-700 rounded">Punctuality improvement</span>
                            }
                        </div>
                    </div>
                    <div class="pt-2 border-t">
                        <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500">Top performer:</span>
                            <span class="font-medium text-green-600">@Model.ComparisonResult.BestPerformer?.Name (@Model.ComparisonResult.BestPerformer?.PerformanceScore%)</span>
                        </div>
                        <div class="flex justify-between items-center text-xs mt-1">
                            <span class="text-gray-500">Development need:</span>
                            <span class="font-medium text-red-600">@Model.ComparisonResult.WorstPerformer?.Name (@Model.ComparisonResult.WorstPerformer?.PerformanceScore%)</span>
                        </div>
                        <div class="flex justify-between items-center text-xs mt-1 pt-1 border-t">
                            <span class="text-gray-500">Performance gap:</span>
                            <span class="font-medium text-purple-600">@Model.ComparisonResult.ScoreDifference% points</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actionable Recommendation -->
        <div class="bg-blue-50 rounded-lg border border-blue-200 p-3">
            <div class="flex items-center gap-2">
                <i class="fas fa-lightbulb text-yellow-500 text-sm"></i>
                <span class="text-xs text-blue-800">
                    <strong>Recommendation:</strong> 
                    @if (Model.ComparisonResult.ScoreDifference > 15)
                    {
                        <text>Pair @Model.ComparisonResult.BestPerformer?.Name with @Model.ComparisonResult.WorstPerformer?.Name for peer mentoring to close the @Model.ComparisonResult.ScoreDifference% performance gap.</text>
                    }
                    else if (Model.Employees.Any(e => e.OnTimeRate < 70))
                    {
                        <text>Focus on time management training for employees with &lt;70% on-time rate.</text>
                    }
                    else
                    {
                        <text>Maintain current performance levels and recognize top performers.</text>
                    }
                </span>
            </div>
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
            <i class="fas fa-chart-line text-4xl text-gray-300 mb-3"></i>
            <p class="text-gray-500 text-sm">Select a branch or employees to view comparison</p>
        </div>
    }
</div>

<script>
    $(document).ready(function() {
        // Initialize: Show/hide based on current mode
        function toggleSelectors() {
            var mode = $('#comparisonMode').val();
            if (mode === 'selected') {
                $('#branchSelector').hide();
                $('#employeeSelector').show();
            } else {
                $('#branchSelector').show();
                $('#employeeSelector').hide();
            }
        }
        
        // Bind change event
        $('#comparisonMode').on('change', toggleSelectors);
        
        // Run on load
        toggleSelectors();
        
        // Employee search filter
        $('#employeeSearch').on('keyup', function() {
            var term = $(this).val().toLowerCase();
            $('#employeeIds option').each(function() {
                var text = $(this).text().toLowerCase();
                $(this).toggle(text.indexOf(term) !== -1);
            });
        });
        
        // Update selected count
        $('#employeeIds').on('change', updateSelectedCount);
        updateSelectedCount();
    });
    
    function updateSelectedCount() {
        var count = $('#employeeIds option:selected').length;
        $('#selectedCount').text(count + ' selected');
    }
    
    function selectAllEmployees() {
        $('#employeeIds option').prop('selected', true);
        updateSelectedCount();
    }
    
    function clearAllEmployees() {
        $('#employeeIds option').prop('selected', false);
        updateSelectedCount();
    }
    
    function exportReport(format) {
        var mode = $('#comparisonMode').val();
        var branchId = $('#branchSelect').val() || '';
        var employeeIds = $('#employeeIds').val() || [];
        var startDate = $('input[name="startDate"]').val();
        var endDate = $('input[name="endDate"]').val();
        
        var url = '@Url.Action("ExportEmployeeComparison", "Report")?format=' + format + 
                  '&comparisonMode=' + mode + 
                  '&branchId=' + branchId + 
                  '&startDate=' + startDate + 
                  '&endDate=' + endDate;
        
        for (var i = 0; i < employeeIds.length; i++) {
            url += '&employeeIds=' + employeeIds[i];
        }
        
        window.location.href = url;
    }
</script>