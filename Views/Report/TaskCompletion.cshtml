@model TaskTracker.Models.ViewModels.TaskCompletionViewModel
@{
    ViewData["Title"] = "Task Completion Report";

    var onTimePercentage = Model.OnTimeRate;
    var latePercentage = Model.Completed > 0 ? Math.Round((double)Model.Late / Model.Completed * 100, 1) : 0;
    var pendingPercentage = Model.TotalAssignments > 0 ? Math.Round((double)Model.Pending / Model.TotalAssignments * 100, 1) : 0;

    string performanceRating;
    string ratingIcon;
    if (Model.CompletionRate >= 90 && Model.OnTimeRate >= 90) { performanceRating = "Excellent"; ratingIcon = "fa-trophy"; }
    else if (Model.CompletionRate >= 75 && Model.OnTimeRate >= 75) { performanceRating = "Good"; ratingIcon = "fa-thumbs-up"; }
    else if (Model.CompletionRate >= 60 || Model.OnTimeRate >= 60) { performanceRating = "Average"; ratingIcon = "fa-chart-line"; }
    else { performanceRating = "Needs Improvement"; ratingIcon = "fa-exclamation-triangle"; }

    var topBranch = Model.BranchStats?.OrderByDescending(b => b.Value.CompletionRate).FirstOrDefault();
    var bottomBranch = Model.BranchStats?.OrderBy(b => b.Value.CompletionRate).FirstOrDefault();
    var topEmployee = Model.EmployeeStats?.OrderByDescending(e => e.Value.CompletionRate).FirstOrDefault();
    var bottomEmployee = Model.EmployeeStats?.OrderBy(e => e.Value.CompletionRate).FirstOrDefault();
    var avgDailyCompletions = Model.DailyCompletions?.Any() == true ? Math.Round(Model.DailyCompletions.Values.Average(), 1) : 0;
    var currentModel = Model;
}

<div class="space-y-6 animate-fade-up">

    <!-- Filter -->
    <div class="glass-card p-5">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <div class="flex-1 min-w-[200px]">
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Select Task</label>
                <select name="taskId" class="dark-input">
                    <option value="">Choose a task...</option>
                    @foreach (var task in ViewBag.Tasks)
                    {
                        <option value="@task.Id" selected="@(task.Id == Model?.TaskId)">@task.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Start Date</label>
                <input type="date" name="startDate" class="dark-input" value="@ViewBag.StartDate">
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">End Date</label>
                <input type="date" name="endDate" class="dark-input" value="@ViewBag.EndDate">
            </div>
            <button type="submit" class="btn-primary"><i class="fas fa-sync-alt"></i>Generate</button>
            @if (Model != null && Model.TaskId > 0)
            {
                <button onclick="exportReport()" type="button" class="px-4 py-2 rounded-xl text-xs font-semibold text-white transition flex items-center gap-1.5"
                        style="background: linear-gradient(135deg, #059669, #10b981);">
                    <i class="fas fa-download"></i>Export
                </button>
            }
        </form>
    </div>

    @if (Model != null && Model.TaskId > 0)
    {
        <!-- Header -->
        <div class="glass-card p-5 overflow-hidden relative">
            <div class="absolute inset-0 opacity-30" style="background: linear-gradient(135deg, #4f46e5, #7c3aed);"></div>
            <div class="relative z-10 flex items-center justify-between flex-wrap gap-4">
                <div>
                    <div class="flex items-center gap-2 mb-1">
                        <i class="fas fa-tasks text-indigo-300 text-lg"></i>
                        <span class="text-indigo-200 text-xs uppercase tracking-wide">Task Performance Report</span>
                    </div>
                    <h2 class="text-2xl font-bold text-white">@Model.TaskName</h2>
                    <p class="text-indigo-200 text-sm mt-0.5">
                        Deadline: @Model.Deadline.ToString(@"hh\:mm") | @(Model.IsSameDay ? "Same Day" : "Next Day")
                    </p>
                </div>
                <div class="text-center">
                    <div class="text-xs text-indigo-200 mb-1">Performance Rating</div>
                    <div class="flex items-center gap-2">
                        <i class="fas @ratingIcon text-3xl text-white"></i>
                        <div class="text-3xl font-bold text-white">@performanceRating</div>
                    </div>
                    <div class="text-xs text-indigo-200 mt-1">@Model.StartDate.ToString("MMM dd, yyyy") — @Model.EndDate.ToString("MMM dd, yyyy")</div>
                </div>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <div class="text-xs text-slate-500">Total Assignments</div>
                    <div class="text-2xl font-bold text-white mt-0.5">@Model.TotalAssignments</div>
                    <div class="text-xs text-slate-600 mt-0.5">@((Model.EndDate - Model.StartDate).Days + 1) day period</div>
                </div>
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(99,102,241,0.15);">
                    <i class="fas fa-calendar-alt text-indigo-400"></i>
                </div>
            </div>
            <div class="glass-card p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-xs text-slate-500">Completion Rate</div>
                        <div class="text-2xl font-bold text-emerald-400 mt-0.5">@Model.CompletionRate%</div>
                        <div class="text-xs text-slate-600">@Model.Completed/@Model.TotalAssignments done</div>
                    </div>
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(16,185,129,0.15);">
                        <i class="fas fa-check-circle text-emerald-400"></i>
                    </div>
                </div>
                <div class="mt-2 w-full rounded-full h-1.5" style="background: rgba(255,255,255,0.08);">
                    <div class="bg-emerald-500 h-1.5 rounded-full" style="width: @Model.CompletionRate%"></div>
                </div>
            </div>
            <div class="glass-card p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-xs text-slate-500">On-Time Rate</div>
                        <div class="text-2xl font-bold text-cyan-400 mt-0.5">@Model.OnTimeRate%</div>
                        <div class="text-xs text-slate-600">@Model.OnTime/@Model.Completed on time</div>
                    </div>
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(6,182,212,0.15);">
                        <i class="fas fa-clock text-cyan-400"></i>
                    </div>
                </div>
                <div class="mt-2 w-full rounded-full h-1.5" style="background: rgba(255,255,255,0.08);">
                    <div class="bg-cyan-500 h-1.5 rounded-full" style="width: @Model.OnTimeRate%"></div>
                </div>
            </div>
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <div class="text-xs text-slate-500">Pending</div>
                    <div class="text-2xl font-bold text-amber-400 mt-0.5">@Model.Pending</div>
                    <div class="text-xs text-slate-600">@pendingPercentage% of total</div>
                </div>
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(245,158,11,0.15);">
                    <i class="fas fa-hourglass-half text-amber-400"></i>
                </div>
            </div>
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <div class="text-xs text-slate-500">Daily Avg</div>
                    <div class="text-2xl font-bold text-violet-400 mt-0.5">@avgDailyCompletions</div>
                    <div class="text-xs text-slate-600">completions/day</div>
                </div>
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(124,58,237,0.15);">
                    <i class="fas fa-chart-line text-violet-400"></i>
                </div>
            </div>
        </div>

        <!-- Timing Stats -->
        @if (Model.AverageCompletionTime.HasValue)
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="glass-card p-4 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(255,255,255,0.06);">
                        <i class="fas fa-chart-simple text-slate-400"></i>
                    </div>
                    <div>
                        <div class="text-xs text-slate-500">Average Completion Time</div>
                        <div class="text-xl font-bold text-white">@Model.AverageCompletionTime.Value.ToString(@"hh\:mm")</div>
                    </div>
                </div>
                <div class="glass-card p-4 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(16,185,129,0.15);">
                        <i class="fas fa-rocket text-emerald-400"></i>
                    </div>
                    <div>
                        <div class="text-xs text-slate-500">Fastest Completion</div>
                        <div class="text-xl font-bold text-emerald-400">@Model.FastestCompletion?.ToString(@"hh\:mm")</div>
                    </div>
                </div>
                <div class="glass-card p-4 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(239,68,68,0.15);">
                        <i class="fas fa-turtle text-red-400"></i>
                    </div>
                    <div>
                        <div class="text-xs text-slate-500">Slowest Completion</div>
                        <div class="text-xl font-bold text-red-400">@Model.SlowestCompletion?.ToString(@"hh\:mm")</div>
                    </div>
                </div>
            </div>
        }

        <!-- Charts -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            <div class="glass-card overflow-hidden">
                <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(99,102,241,0.08);">
                    <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-chart-pie text-indigo-400"></i>Status Distribution</h3>
                    <p class="text-xs text-slate-500 mt-0.5">Overall task completion breakdown</p>
                </div>
                <div class="p-5" style="height: 260px;"><canvas id="statusChart"></canvas></div>
                <div class="grid grid-cols-3 gap-2 text-center px-5 pb-5">
                    <div><div class="text-2xl font-bold text-emerald-400">@Model.Completed</div><div class="text-xs text-slate-500">Completed</div></div>
                    <div><div class="text-2xl font-bold text-cyan-400">@Model.OnTime</div><div class="text-xs text-slate-500">On Time</div></div>
                    <div><div class="text-2xl font-bold text-amber-400">@Model.Pending</div><div class="text-xs text-slate-500">Pending</div></div>
                </div>
            </div>

            <div class="glass-card overflow-hidden">
                <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(124,58,237,0.08);">
                    <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-chart-line text-violet-400"></i>Daily Completion Trend</h3>
                    <p class="text-xs text-slate-500 mt-0.5">Completions per day over the period</p>
                </div>
                <div class="p-5" style="height: 300px;"><canvas id="dailyTrendChart"></canvas></div>
            </div>
        </div>

        <!-- Branch vs Employee -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            <div class="glass-card overflow-hidden">
                <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(6,182,212,0.08);">
                    <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-store text-cyan-400"></i>Branch Performance</h3>
                </div>
                <div class="p-5 space-y-3">
                    @if (Model.BranchStats != null && Model.BranchStats.Any())
                    {
                        @foreach (var branch in Model.BranchStats.OrderByDescending(b => b.Value.CompletionRate))
                        {
                            var isTop = branch.Key == topBranch?.Key;
                            var isBottom = branch.Key == bottomBranch?.Key;
                            var pctColor = branch.Value.CompletionRate >= 80 ? "#10b981" : branch.Value.CompletionRate >= 60 ? "#f59e0b" : "#ef4444";
                            <div class="rounded-xl p-3" style="background: @(isTop ? "rgba(16,185,129,0.08)" : isBottom ? "rgba(239,68,68,0.06)" : "rgba(255,255,255,0.04)"); border: 1px solid @(isTop ? "rgba(16,185,129,0.25)" : isBottom ? "rgba(239,68,68,0.15)" : "rgba(255,255,255,0.06)");">
                                <div class="flex justify-between items-center mb-1">
                                    <div class="flex items-center gap-1.5">
                                        <span class="font-medium text-slate-200 text-sm">@branch.Key</span>
                                        @if (isTop) { <span class="stat-badge" style="background: rgba(16,185,129,0.15);color:#6ee7b7;font-size:10px;"><i class="fas fa-trophy mr-0.5"></i>Best</span> }
                                        @if (isBottom && !isTop) { <span class="stat-badge" style="background: rgba(239,68,68,0.12);color:#fca5a5;font-size:10px;">Needs Work</span> }
                                    </div>
                                    <span class="text-sm font-bold" style="color: @pctColor;">@branch.Value.CompletionRate%</span>
                                </div>
                                <div class="text-xs text-slate-500 mb-1">Completed: @branch.Value.Completed/@branch.Value.Total</div>
                                <div class="w-full rounded-full h-1.5" style="background: rgba(255,255,255,0.08);">
                                    <div class="h-1.5 rounded-full" style="width: @branch.Value.CompletionRate%; background: @pctColor;"></div>
                                </div>
                            </div>
                        }
                        @if (topBranch.HasValue && bottomBranch.HasValue && topBranch.Value.Key != bottomBranch.Value.Key)
                        {
                            var gap = topBranch.Value.Value.CompletionRate - bottomBranch.Value.Value.CompletionRate;
                            <div class="rounded-xl p-3 mt-1" style="background: rgba(99,102,241,0.06); border: 1px solid rgba(99,102,241,0.12);">
                                <div class="flex items-center justify-between text-xs">
                                    <span class="text-slate-500"><i class="fas fa-chart-line text-indigo-400 mr-1"></i>Performance Gap: <strong class="@(gap > 30 ? "text-red-400" : "text-amber-400")">@gap%</strong></span>
                                    <span class="text-slate-600">@topBranch.Value.Key leads by @gap pts</span>
                                </div>
                            </div>
                        }
                    }
                    else { <div class="text-center py-6 text-slate-500 text-sm">No branch data available</div> }
                </div>
            </div>

            <div class="glass-card overflow-hidden">
                <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(16,185,129,0.08);">
                    <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-users text-emerald-400"></i>Employee Performance</h3>
                </div>
                <div class="p-5 space-y-3">
                    @if (Model.EmployeeStats != null && Model.EmployeeStats.Any())
                    {
                        @foreach (var emp in Model.EmployeeStats.OrderByDescending(e => e.Value.CompletionRate).Take(10))
                        {
                            var isTop = emp.Key == topEmployee?.Key;
                            var isBottom = emp.Key == bottomEmployee?.Key;
                            var pctColor = emp.Value.CompletionRate >= 80 ? "#10b981" : emp.Value.CompletionRate >= 60 ? "#f59e0b" : "#ef4444";
                            var initials = GetInitials(emp.Key);
                            <div class="rounded-xl p-3" style="background: @(isTop ? "rgba(16,185,129,0.08)" : isBottom ? "rgba(239,68,68,0.06)" : "rgba(255,255,255,0.04)"); border: 1px solid @(isTop ? "rgba(16,185,129,0.2)" : isBottom ? "rgba(239,68,68,0.12)" : "rgba(255,255,255,0.06)");">
                                <div class="flex items-center gap-2">
                                    <div class="w-8 h-8 rounded-xl flex items-center justify-center text-white font-bold text-xs flex-shrink-0"
                                         style="background: linear-gradient(135deg, #6366f1, #7c3aed);">@initials</div>
                                    <div class="flex-1">
                                        <div class="flex justify-between items-center">
                                            <span class="font-medium text-slate-200 text-sm">@emp.Key</span>
                                            <span class="text-sm font-bold" style="color: @pctColor;">@emp.Value.CompletionRate%</span>
                                        </div>
                                        <div class="text-xs text-slate-500">@emp.Value.Completed/@emp.Value.Total completed</div>
                                        <div class="w-full rounded-full h-1 mt-1" style="background: rgba(255,255,255,0.08);">
                                            <div class="h-1 rounded-full" style="width: @emp.Value.CompletionRate%; background: @pctColor;"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (Model.EmployeeStats.Count > 10) { <div class="text-xs text-slate-600 text-center">+@(Model.EmployeeStats.Count - 10) more employees</div> }
                    }
                    else { <div class="text-center py-6 text-slate-500 text-sm">No employee data available</div> }
                </div>
            </div>
        </div>

        <!-- Insights & Recommendations -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="rounded-xl p-5" style="background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(6,182,212,0.06)); border: 1px solid rgba(99,102,241,0.15);">
                <div class="flex items-start gap-3">
                    <i class="fas fa-lightbulb text-amber-400 text-lg flex-shrink-0"></i>
                    <div>
                        <h4 class="font-bold text-white mb-2">📊 Key Insights</h4>
                        <div class="space-y-1 text-xs">
                            @if (Model.CompletionRate >= 90) { <p class="text-emerald-400">✅ <strong>Excellent completion rate!</strong> This task is being completed consistently.</p> }
                            else if (Model.CompletionRate >= 70) { <p class="text-cyan-400">📈 <strong>Good completion rate.</strong> Slight room for improvement.</p> }
                            else { <p class="text-red-400">⚠️ <strong>Low completion rate.</strong> This task needs attention.</p> }
                            @if (Model.OnTimeRate >= 90) { <p class="text-emerald-400">⏰ <strong>Excellent punctuality!</strong> Most completions are on time.</p> }
                            else if (Model.OnTimeRate >= 70) { <p class="text-cyan-400">📊 <strong>Good punctuality.</strong> Most completions meet deadlines.</p> }
                            else { <p class="text-red-400">⌛ <strong>Punctuality needs improvement.</strong> Many completions are late.</p> }
                            @if (topBranch.HasValue) { <p class="text-slate-400">🏆 <strong class="text-slate-200">Top Branch:</strong> @topBranch.Value.Key (@topBranch.Value.Value.CompletionRate%)</p> }
                            @if (topEmployee.HasValue) { <p class="text-slate-400">⭐ <strong class="text-slate-200">Top Performer:</strong> @topEmployee.Value.Key (@topEmployee.Value.Value.CompletionRate%)</p> }
                        </div>
                    </div>
                </div>
            </div>
            <div class="rounded-xl p-5" style="background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(16,185,129,0.06)); border: 1px solid rgba(124,58,237,0.15);">
                <div class="flex items-start gap-3">
                    <i class="fas fa-clipboard-list text-violet-400 text-lg flex-shrink-0"></i>
                    <div>
                        <h4 class="font-bold text-white mb-2">🎯 Recommendations</h4>
                        <div class="space-y-1 text-xs text-slate-400">
                            @if (Model.CompletionRate < 70) { <p>• Review why this task isn't being completed consistently</p><p>• Consider adjusting deadline or providing additional training</p> }
                            @if (Model.OnTimeRate < 70 && Model.Completed > 0) { <p>• Start this task earlier in the day to meet deadlines</p><p>• Set reminders 30 minutes before deadline</p> }
                            @if (Model.Pending > Model.Completed) { <p>• Prioritize this task over others when assigned</p> }
                            @if (topBranch.HasValue && bottomBranch.HasValue && topBranch.Value.Key != bottomBranch.Value.Key) { <p>• Share best practices from @topBranch.Value.Key with @bottomBranch.Value.Key</p> }
                            @if (topEmployee.HasValue && bottomEmployee.HasValue && topEmployee.Value.Key != bottomEmployee.Value.Key) { <p>• Pair @topEmployee.Value.Key with @bottomEmployee.Value.Key for mentoring</p> }
                            @if (Model.CompletionRate >= 90 && Model.OnTimeRate >= 90) { <p class="text-emerald-400">🌟 Well-managed task. Consider using it as a template.</p> }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Detailed Breakdown Tables -->
        <div class="glass-card overflow-hidden">
            <div class="px-5 py-4 border-b flex items-center justify-between flex-wrap gap-3" style="border-color: rgba(255,255,255,0.06);">
                <div>
                    <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-table text-slate-400"></i>Detailed Breakdown</h3>
                    <p class="text-xs text-slate-500 mt-0.5">Branch and employee performance details</p>
                </div>
                <div class="flex gap-2">
                    <button onclick="toggleTable('branchTable')" id="btn-branchTable"
                            class="px-3 py-1.5 rounded-xl text-xs font-medium transition table-toggle-btn active-tab"
                            style="background: rgba(6,182,212,0.2); color: #67e8f9;">
                        <i class="fas fa-store mr-1"></i>Branches
                    </button>
                    <button onclick="toggleTable('employeeTable')" id="btn-employeeTable"
                            class="px-3 py-1.5 rounded-xl text-xs font-medium transition table-toggle-btn"
                            style="background: rgba(255,255,255,0.06); color: #94a3b8;">
                        <i class="fas fa-users mr-1"></i>Employees
                    </button>
                    <button onclick="toggleTable('dailyTable')" id="btn-dailyTable"
                            class="px-3 py-1.5 rounded-xl text-xs font-medium transition table-toggle-btn"
                            style="background: rgba(255,255,255,0.06); color: #94a3b8;">
                        <i class="fas fa-calendar-day mr-1"></i>Daily
                    </button>
                </div>
            </div>

            <!-- Branch Table -->
            <div id="branchTable" class="overflow-x-auto">
                @if (Model.BranchStats != null && Model.BranchStats.Any())
                {
                    <table class="w-full dark-table">
                        <thead>
                            <tr>
                                <th>Branch</th>
                                <th class="text-center">Total</th>
                                <th class="text-center">Completed</th>
                                <th class="text-center">Completion Rate</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Trend</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var branch in Model.BranchStats.OrderByDescending(b => b.Value.CompletionRate))
                            {
                                var trend = branch.Value.CompletionRate >= 80 ? "↑ Excellent" : branch.Value.CompletionRate >= 60 ? "→ Average" : "↓ Needs Work";
                                var trendColor = branch.Value.CompletionRate >= 80 ? "text-emerald-400" : branch.Value.CompletionRate >= 60 ? "text-amber-400" : "text-red-400";
                                <tr>
                                    <td class="font-semibold text-white">@branch.Key</td>
                                    <td class="text-center text-slate-400">@branch.Value.Total</td>
                                    <td class="text-center text-emerald-400 font-semibold">@branch.Value.Completed</td>
                                    <td class="text-center">
                                        <div class="flex items-center justify-center gap-2">
                                            <div class="w-16 rounded-full h-1.5" style="background: rgba(255,255,255,0.08);">
                                                <div class="bg-indigo-500 h-1.5 rounded-full" style="width: @branch.Value.CompletionRate%"></div>
                                            </div>
                                            <span class="text-xs font-medium text-slate-300">@branch.Value.CompletionRate%</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="stat-badge" style="font-size:10px; @(branch.Value.CompletionRate >= 80 ? "background:rgba(16,185,129,0.15);color:#6ee7b7;" : branch.Value.CompletionRate >= 60 ? "background:rgba(245,158,11,0.15);color:#fcd34d;" : "background:rgba(239,68,68,0.12);color:#fca5a5;")">
                                            @(branch.Value.CompletionRate >= 80 ? "Good" : branch.Value.CompletionRate >= 60 ? "Average" : "Poor")
                                        </span>
                                    </td>
                                    <td class="text-center @trendColor text-xs">@trend</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else { <div class="text-center py-8 text-slate-500 text-sm p-5">No branch data available</div> }
            </div>

            <!-- Employee Table (hidden by default) -->
            <div id="employeeTable" class="overflow-x-auto hidden">
                @if (Model.EmployeeStats != null && Model.EmployeeStats.Any())
                {
                    <table class="w-full dark-table">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th class="text-center">Total</th>
                                <th class="text-center">Completed</th>
                                <th class="text-center">Completion Rate</th>
                                <th class="text-center">Rank</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var emp in Model.EmployeeStats.OrderByDescending(e => e.Value.CompletionRate))
                            {
                                <tr>
                                    <td class="font-semibold text-white">@emp.Key</td>
                                    <td class="text-center text-slate-400">@emp.Value.Total</td>
                                    <td class="text-center text-emerald-400 font-semibold">@emp.Value.Completed</td>
                                    <td class="text-center">
                                        <div class="flex items-center justify-center gap-2">
                                            <div class="w-16 rounded-full h-1.5" style="background: rgba(255,255,255,0.08);">
                                                <div class="bg-emerald-500 h-1.5 rounded-full" style="width: @emp.Value.CompletionRate%"></div>
                                            </div>
                                            <span class="text-xs font-medium text-slate-300">@emp.Value.CompletionRate%</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (rank == 1) { <span>🏆 1st</span> }
                                        else if (rank == 2) { <span class="text-slate-400">🥈 2nd</span> }
                                        else if (rank == 3) { <span>🥉 3rd</span> }
                                        else { <span class="text-slate-500">@rank th</span> }
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                }
                else { <div class="text-center py-8 text-slate-500 text-sm p-5">No employee data</div> }
            </div>

            <!-- Daily Table (hidden by default) -->
            <div id="dailyTable" class="overflow-x-auto hidden">
                @if (Model.DailyCompletions != null && Model.DailyCompletions.Any())
                {
                    <table class="w-full dark-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th class="text-center">Completions</th>
                                <th class="text-center">vs Average</th>
                                <th class="text-center">Performance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var day in Model.DailyCompletions.OrderBy(d => d.Key))
                            {
                                var vsAvg = day.Value - avgDailyCompletions;
                                var vsColor = vsAvg >= 0 ? "text-emerald-400" : "text-red-400";
                                var vsIcon = vsAvg >= 0 ? "fa-arrow-up" : "fa-arrow-down";
                                <tr>
                                    <td class="text-slate-300">@DateTime.Parse(day.Key).ToString("MMM dd, yyyy")</td>
                                    <td class="text-center font-bold text-white">@day.Value</td>
                                    <td class="text-center @vsColor text-xs"><i class="fas @vsIcon mr-0.5"></i>@(vsAvg >= 0 ? "+" : "")@Math.Round(vsAvg, 1)</td>
                                    <td class="text-center">
                                        <div class="w-full rounded-full h-1.5 max-w-[80px] mx-auto" style="background: rgba(255,255,255,0.08);">
                                            <div class="@(day.Value >= avgDailyCompletions ? "bg-emerald-500" : "bg-red-500") h-1.5 rounded-full"
                                                 style="width: @Math.Min(100, day.Value / (avgDailyCompletions > 0 ? avgDailyCompletions : 1) * 100)%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else { <div class="text-center py-8 text-slate-500 text-sm p-5">No daily data</div> }
            </div>
        </div>

        <!-- Footer -->
        <div class="rounded-xl p-3 text-center text-xs text-slate-600" style="background: rgba(255,255,255,0.03);">
            <i class="fas fa-chart-simple mr-2"></i>
            Report generated @DateTime.Now.ToString("MMM dd, yyyy HH:mm") | Task "@Model.TaskName" from @Model.StartDate.ToString("MMM dd, yyyy") to @Model.EndDate.ToString("MMM dd, yyyy")
        </div>
    }
    else
    {
        <div class="glass-card p-12 text-center">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: rgba(99,102,241,0.1);">
                <i class="fas fa-tasks text-indigo-400 text-2xl"></i>
            </div>
            <h3 class="font-semibold text-slate-300 mb-1">No Task Selected</h3>
            <p class="text-slate-500 text-sm">Please select a task and date range to view completion report</p>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const statusCtx = document.getElementById('statusChart');
        if (statusCtx) {
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Completed', 'Pending'],
                    datasets: [{ data: [@(Model?.Completed ?? 0), @(Model?.Pending ?? 0)], backgroundColor: ['#10b981', 'rgba(245,158,11,0.6)'], borderWidth: 0, borderRadius: 4 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8', boxWidth: 10 } } } }
            });
        }

        const dailyCtx = document.getElementById('dailyTrendChart');
        if (dailyCtx) {
            @{
                var dailyCompletions = (Model?.DailyCompletions ?? new Dictionary<string, int>());
                var sortedDates = dailyCompletions.Keys.OrderBy(k => k).ToList();
                var sortedValues = dailyCompletions.OrderBy(kvp => kvp.Key).Select(kvp => kvp.Value).ToList();
                var avgVal = (double)avgDailyCompletions;
            }
            const dailyDates = @Html.Raw(Json.Serialize(sortedDates));
            const dailyValues = @Html.Raw(Json.Serialize(sortedValues));
            const avgValue = @avgVal;
            new Chart(dailyCtx, {
                type: 'line',
                data: {
                    labels: dailyDates.map(d => { const p = d.split('-'); return p[1] + '/' + p[2]; }),
                    datasets: [
                        { label: 'Daily Completions', data: dailyValues, borderColor: '#7c3aed', backgroundColor: 'rgba(124,58,237,0.12)', tension: 0.4, fill: true, pointRadius: 4, pointBackgroundColor: '#7c3aed', pointBorderColor: '#0b0b18' },
                        { label: 'Daily Average', data: Array(dailyValues.length).fill(avgValue), borderColor: '#f59e0b', borderWidth: 2, borderDash: [5, 5], fill: false, pointRadius: 0 }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'top', labels: { color: '#94a3b8', boxWidth: 10 } }, tooltip: { callbacks: { label: ctx => ctx.dataset.label === 'Daily Average' ? 'Average: ' + ctx.raw.toFixed(1) : ctx.dataset.label + ': ' + ctx.raw } } },
                    scales: { y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#64748b' } }, x: { grid: { display: false }, ticks: { color: '#64748b', maxRotation: 45, minRotation: 45 } } }
                }
            });
        }

        function toggleTable(tableId) {
            ['branchTable', 'employeeTable', 'dailyTable'].forEach(id => {
                document.getElementById(id).classList.add('hidden');
                const btn = document.getElementById('btn-' + id);
                if (btn) { btn.style.background = 'rgba(255,255,255,0.06)'; btn.style.color = '#94a3b8'; }
            });
            document.getElementById(tableId).classList.remove('hidden');
            const activeBtn = document.getElementById('btn-' + tableId);
            if (activeBtn) { activeBtn.style.background = 'rgba(6,182,212,0.2)'; activeBtn.style.color = '#67e8f9'; }
        }

        function exportReport() {
            const format = prompt('Export format? (excel/csv/pdf)', 'excel');
            if (format && ['excel', 'csv', 'pdf'].includes(format)) {
                window.location.href = '@Url.Action("ExportTaskReport", "Report")?taskId=' + @(currentModel?.TaskId ?? 0) +
                    '&startDate=' + '@(currentModel?.StartDate.ToString("yyyy-MM-dd"))' +
                    '&endDate=' + '@(currentModel?.EndDate.ToString("yyyy-MM-dd"))' +
                    '&format=' + format;
            } else if (format) { alert('Invalid format. Use excel, csv, or pdf'); }
        }

        function showNotification(message, type) {
            const colors = { success: '#10b981', error: '#ef4444', info: '#6366f1' };
            $('.custom-notification').remove();
            const n = $(`<div class="custom-notification fixed top-4 right-4 z-50 px-4 py-2 rounded-xl shadow-lg text-sm font-medium text-white flex items-center gap-2" style="background: ${colors[type]}; backdrop-filter: blur(12px);">
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i><span>${message}</span></div>`);
            $('body').append(n);
            setTimeout(() => n.fadeOut(300, function() { $(this).remove(); }), 3000);
        }
    </script>
}

@functions {
    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }
}