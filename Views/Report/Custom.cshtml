@model TaskTracker.Models.ViewModels.CustomReportRequest
@{
    ViewData["Title"] = "Custom Report Builder";
}

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sticky top-4">
            <h3 class="font-semibold mb-4">Report Filters</h3>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date Range</label>
                    <div class="space-y-2">
                        <input type="date" id="startDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                        <input type="date" id="endDate" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Branches</label>
                    <select id="branches" multiple class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm h-32">
                        @foreach (var branch in ViewBag.Branches)
                        {
                            <option value="@branch.Id">@branch.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tasks</label>
                    <select id="tasks" multiple class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm h-32">
                        @foreach (var task in ViewBag.Tasks)
                        {
                            <option value="@task.Id">@task.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Employees</label>
                    <select id="employees" multiple class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm h-32">
                        @foreach (var emp in ViewBag.Employees)
                        {
                            <option value="@emp.Id">@emp.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select id="status" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                        <option value="All">All</option>
                        <option value="Completed">Completed Only</option>
                        <option value="Pending">Pending Only</option>
                    </select>
                </div>

                <button onclick="generateReport()" class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">
                    <i class="fas fa-play mr-2"></i>Generate Report
                </button>
            </div>
        </div>
    </div>

    <div class="lg:col-span-3">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200">
            <div class="p-4 border-b border-gray-200 flex justify-between items-center">
                <h3 class="font-semibold">Report Results</h3>
                <div class="text-sm text-gray-500" id="resultCount">0 records</div>
            </div>
            <div class="overflow-x-auto p-4" id="resultsContainer">
                <div class="text-center py-12 text-gray-400">
                    <i class="fas fa-chart-bar text-4xl mb-3"></i>
                    <p>Apply filters and click Generate Report to see results</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function generateReport() {
        const filters = {
            startDate: $('#startDate').val(),
            endDate: $('#endDate').val(),
            branchIds: $('#branches').val() || [],
            taskIds: $('#tasks').val() || [],
            employeeIds: $('#employees').val() || [],
            status: $('#status').val()
        };

        $('#resultsContainer').html('<div class="text-center py-12"><i class="fas fa-spinner fa-spin text-blue-600 text-2xl"></i><p class="mt-2 text-gray-500">Generating report...</p></div>');

        $.ajax({
            url: '@Url.Action("GenerateCustom", "Report")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(filters),
            success: function(response) {
                if (response.success) {
                    displayResults(response.data);
                } else {
                    showNotification(response.message, 'error');
                }
            }
        });
    }

    function displayResults(data) {
        if (!data || data.length === 0) {
            $('#resultsContainer').html('<div class="text-center py-12 text-gray-400"><i class="fas fa-database text-4xl mb-3"></i><p>No data found</p></div>');
            $('#resultCount').text('0 records');
            return;
        }

        let html = '<table class="w-full text-sm">';
        html += '<thead><tr class="bg-gray-50">';

        // Headers
        const headers = Object.keys(data[0]);
        headers.forEach(h => html += `<th class="px-4 py-2 text-left font-medium">${h}</th>`);
        html += '</tr></thead><tbody>';

        // Data
        data.forEach(row => {
            html += '<tr class="border-t hover:bg-gray-50">';
            headers.forEach(h => html += `<td class="px-4 py-2">${row[h] || '—'}</td>`);
            html += '</tr>';
        });

        html += '</tbody></table>';
        $('#resultsContainer').html(html);
        $('#resultCount').text(`${data.length} records`);
    }
</script>