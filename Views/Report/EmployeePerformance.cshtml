@using TaskTracker.Models.ViewModels
@model EmployeePerformanceViewModel
@{
    ViewData["Title"] = "Employee Performance Report";
    
    // Calculate additional metrics
    var hasStruggleTasks = Model.TaskBreakdown != null && Model.TaskBreakdown.Any(t => t.Value.CompletionRate < 60 || t.Value.OnTimeRate < 50 || t.Value.Pending > 0);
    var highPriorityTasks = Model.TaskBreakdown?.Where(t => t.Value.Pending >= 3 || t.Value.Late >= 3 || t.Value.CompletionRate < 40).ToList() ?? new List<KeyValuePair<string, TaskPerformanceStats>>();
    var needsImprovementTasks = Model.TaskBreakdown?.Where(t => t.Value.CompletionRate >= 40 && t.Value.CompletionRate < 70).ToList() ?? new List<KeyValuePair<string, TaskPerformanceStats>>();
    var strongTasks = Model.TaskBreakdown?.Where(t => t.Value.CompletionRate >= 90 && t.Value.OnTimeRate >= 85).ToList() ?? new List<KeyValuePair<string, TaskPerformanceStats>>();
    
    // Group late tasks
    var lateTasks = Model.DailyBreakdown?.Where(d => d.Status == "Completed" && !d.IsOnTime).ToList() ?? new List<DailyPerformance>();
    var pendingTasks = Model.DailyBreakdown?.Where(d => d.Status != "Completed").ToList() ?? new List<DailyPerformance>();
    var completedOnTime = Model.DailyBreakdown?.Where(d => d.Status == "Completed" && d.IsOnTime).ToList() ?? new List<DailyPerformance>();
    
    // Group by task for cover sheet summary
    var pendingByTask = pendingTasks.GroupBy(t => t.TaskName).Select(g => new {
        TaskName = g.Key,
        Count = g.Count(),
        Dates = g.Select(t => t.Date.ToString("MMM dd")).Distinct().OrderBy(d => d).ToList(),
        DateObjects = g.Select(t => t.Date).Distinct().OrderBy(d => d).ToList(),
        Details = g.OrderByDescending(t => t.Date).ToList()
    }).OrderByDescending(t => t.Count).ToList();
    
    var lateByTask = lateTasks.GroupBy(t => t.TaskName).Select(g => new {
        TaskName = g.Key,
        Count = g.Count(),
        Dates = g.Select(t => t.Date.ToString("MMM dd")).Distinct().OrderBy(d => d).ToList(),
        DateObjects = g.Select(t => t.Date).Distinct().OrderBy(d => d).ToList(),
        Details = g.OrderByDescending(t => t.Date).ToList()
    }).OrderByDescending(t => t.Count).ToList();
    
    // Helper function to format delay text
    string GetDelayText(DateTime deadline, DateTime? completionTime)
    {
        if (!completionTime.HasValue) return "Pending";
        
        var completedTime = completionTime.Value;
        
        if (completedTime < deadline)
        {
            var diff = deadline - completedTime;
            if (diff.TotalDays >= 1) return $"{diff.TotalDays:F0}d early";
            if (diff.TotalHours >= 1) return $"{diff.TotalHours:F0}h early";
            if (diff.TotalMinutes >= 1) return $"{diff.TotalMinutes:F0}m early";
            return "Early";
        }
        
        if (completedTime <= deadline.AddSeconds(30)) return "On time";
        
        var lateDiff = completedTime - deadline;
        if (lateDiff.TotalMinutes < 60) return $"{lateDiff.TotalMinutes:F0}m late";
        if (lateDiff.TotalHours < 24) return $"{lateDiff.TotalHours:F0}h late";
        return $"{lateDiff.TotalDays:F0}d late";
    }
    

}

<div class="space-y-6">
    <!-- Filter Section - Redesigned -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <form method="get" class="flex flex-wrap items-end gap-4">
            <div class="flex-1 min-w-[240px]">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Select Employee</label>
                <select name="employeeId" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 bg-white">
                    <option value="">Choose an employee...</option>
                    @if (ViewBag.Employees != null)
                    {
                        @foreach (var emp in ViewBag.Employees)
                        {
                            <option value="@emp.Id" selected="@(emp.Id == Model?.EmployeeId)">@emp.Name - @emp.Position</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Start Date</label>
                <input type="date" name="startDate" class="px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200" value="@ViewBag.StartDate">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">End Date</label>
                <input type="date" name="endDate" class="px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200" value="@ViewBag.EndDate">
            </div>
            <div>
                <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-xl text-sm font-semibold hover:bg-blue-700 transition-all duration-200 shadow-sm hover:shadow-md flex items-center gap-2">
                    <i class="fas fa-chart-line"></i>
                    <span>Generate Report</span>
                </button>
            </div>
        </form>
    </div>

    @if (Model != null && Model.EmployeeId > 0 && Model.DailyBreakdown != null && Model.DailyBreakdown.Any())
    {
        <!-- Employee Profile Header - Redesigned -->
        <div class="bg-gradient-to-r from-orange-800 to-gray-900 rounded-xl shadow-lg p-5 text-white">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white opacity-5 rounded-full -mr-32 -mt-32"></div>
            <div class="absolute bottom-0 left-0 w-48 h-48 bg-white opacity-5 rounded-full -ml-24 -mb-24"></div>
            
            <div class="flex flex-col md:flex-row items-center justify-between gap-6 relative z-10">
                <div class="flex items-center space-x-5">
                    <div class="w-20 h-20 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center border-2 border-white shadow-lg">
                        @{
                            var initials = "?";
                            if (!string.IsNullOrEmpty(Model.EmployeeName))
                            {
                                var nameParts = Model.EmployeeName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                if (nameParts.Length == 1)
                                {
                                    initials = nameParts[0].Substring(0, 1).ToUpper();
                                }
                                else if (nameParts.Length >= 2)
                                {
                                    initials = (nameParts[0][0].ToString() + nameParts[^1][0].ToString()).ToUpper();
                                }
                            }
                        }
                        <span class="text-3xl font-bold text-white">@initials</span>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold">@Model.EmployeeName</h2>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <span class="px-2 py-1 bg-white/20 rounded-lg text-sm">📋 @Model.EmployeeIdNumber</span>
                            <span class="px-2 py-1 bg-white/20 rounded-lg text-sm">🏢 @Model.Department</span>
                            <span class="px-2 py-1 bg-white/20 rounded-lg text-sm">💼 @Model.Position</span>
                        </div>
                        <p class="text-blue-100 text-sm mt-2">
                            <i class="far fa-calendar-alt mr-1"></i> @Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")
                        </p>
                    </div>
                </div>
                <div class="text-center">
                    <div class="text-sm text-blue-100 mb-1 font-medium">Overall Performance Score</div>
                    <div class="text-5xl font-bold">@Math.Round(Model.OverallScore, 2)%</div>
                    <div class="mt-2">
                        @if (Model.OverallScore >= 90)
                        {
                            <span class="px-3 py-1 bg-emerald-500/30 rounded-full text-sm font-medium">🏆 Excellent - Top Performer</span>
                        }
                        else if (Model.OverallScore >= 75)
                        {
                            <span class="px-3 py-1 bg-blue-500/30 rounded-full text-sm font-medium">⭐ Good - Above Average</span>
                        }
                        else if (Model.OverallScore >= 60)
                        {
                            <span class="px-3 py-1 bg-yellow-500/30 rounded-full text-sm font-medium">📈 Satisfactory - Meets Expectations</span>
                        }
                        else
                        {
                            <span class="px-3 py-1 bg-red-500/30 rounded-full text-sm font-medium">⚠️ Needs Improvement</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- KPI Cards - Redesigned -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <!-- Total Tasks -->
    <div class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md transition-shadow duration-200">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Total Tasks</p>
                <p class="text-2xl font-bold text-gray-900 mt-1">@Model.TotalTasks</p>
            </div>
            <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center">
                <i class="fas fa-tasks text-blue-500 text-lg"></i>
            </div>
        </div>
    </div>

    <!-- Completed -->
    <div class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md transition-shadow duration-200">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Completed</p>
                <p class="text-2xl font-bold text-gray-900 mt-1">@Model.CompletedTasks</p>
            </div>
            <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center">
                <i class="fas fa-check-circle text-green-500 text-lg"></i>
            </div>
        </div>
        <div class="mt-3">
            <div class="flex items-center justify-between text-xs mb-1">
                <span class="text-gray-500">Completion Rate</span>
                <span class="font-medium text-green-600">@Model.CompletionRate%</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="bg-green-500 h-1.5 rounded-full transition-all duration-500" style="width: @Model.CompletionRate%"></div>
            </div>
        </div>
    </div>

    <!-- On Time -->
    <div class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md transition-shadow duration-200">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">On Time</p>
                <p class="text-2xl font-bold text-gray-900 mt-1">@Model.OnTimeTasks</p>
            </div>
            <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center">
                <i class="fas fa-clock text-blue-500 text-lg"></i>
            </div>
        </div>
        <div class="mt-3">
            <div class="flex items-center justify-between text-xs mb-1">
                <span class="text-gray-500">On-Time Rate</span>
                <span class="font-medium text-blue-600">@Model.OnTimeRate%</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="bg-blue-500 h-1.5 rounded-full transition-all duration-500" style="width: @Model.OnTimeRate%"></div>
            </div>
        </div>
    </div>

    <!-- Pending -->
    <div class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md transition-shadow duration-200">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Pending</p>
                <p class="text-2xl font-bold text-gray-900 mt-1">@Model.PendingTasks</p>
            </div>
            <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center">
                <i class="fas fa-hourglass-half text-amber-500 text-lg"></i>
            </div>
        </div>
    </div>
</div>

        <!-- Performance Trend Chart - Redesigned -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-lg font-semibold text-gray-800">Performance Trend</h3>
                        <p class="text-xs text-gray-500 mt-0.5">Daily completion and on-time rates over time</p>
                    </div>
                    <div class="flex gap-3">
                        <div class="flex items-center gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                            <span class="text-xs text-gray-600">Completion Rate</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-blue-500"></div>
                            <span class="text-xs text-gray-600">On-Time Rate</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="p-6">
                <canvas id="performanceTrendChart" height="300"></canvas>
            </div>
        </div>

        <!-- Two Column Layout for Task Analysis -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Task Performance Matrix -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gradient-to-r from-indigo-50 to-purple-50">
                    <div class="flex items-center gap-2">
                        <i class="fas fa-chart-pie text-indigo-600 text-lg"></i>
                        <h3 class="text-lg font-semibold text-gray-800">Task Performance Matrix</h3>
                    </div>
                    <p class="text-xs text-gray-500 mt-0.5 ml-7">Performance breakdown by task type</p>
                </div>
                <div class="p-5">
                    @if (Model.TaskBreakdown != null && Model.TaskBreakdown.Any())
                    {
                        <div class="space-y-4">
                            @foreach (var task in Model.TaskBreakdown.OrderBy(t => t.Key))
                            {
                                var stats = task.Value;
                                var completionPercent = stats.CompletionRate;
                                var onTimePercent = stats.OnTimeRate;
                                var isStruggle = stats.CompletionRate < 60 || stats.OnTimeRate < 50;
                                
                                <div class="group">
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="font-semibold text-gray-800 text-sm">@task.Key</span>
                                        <span class="text-xs text-gray-500">@stats.Completed/@stats.Total completed (@completionPercent%)</span>
                                    </div>
                                    <div class="relative">
                                        <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                                            <div class="bg-green-500 h-2.5 rounded-l-full transition-all duration-500" style="width: @completionPercent%"></div>
                                        </div>
                                    </div>
                                    <div class="flex justify-between items-center mt-2">
                                        <div class="flex gap-3">
                                            @if (stats.Pending > 0)
                                            {
                                                <span class="text-xs text-amber-600"><i class="fas fa-clock mr-1"></i>@stats.Pending pending</span>
                                            }
                                            @if (stats.Late > 0)
                                            {
                                                <span class="text-xs text-red-500"><i class="fas fa-exclamation-triangle mr-1"></i>@stats.Late late</span>
                                            }
                                        </div>
                                        @if (stats.OnTime > 0)
                                        {
                                            <span class="text-xs text-blue-600"><i class="fas fa-tachometer-alt mr-1"></i>@onTimePercent% on time</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-8">
                            <i class="fas fa-inbox text-4xl text-gray-300 mb-3"></i>
                            <p class="text-gray-500">No task data available</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Strengths & Weaknesses Combined -->
            <div class="space-y-6">
                <!-- Weaknesses -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="px-5 py-4 border-b border-gray-100 bg-gradient-to-r from-red-50 to-orange-50">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-exclamation-triangle text-red-600 text-lg"></i>
                            <h3 class="text-lg font-semibold text-gray-800">Areas Needing Improvement</h3>
                        </div>
                        <p class="text-xs text-gray-500 mt-0.5 ml-7">Tasks where performance needs attention</p>
                    </div>
                    <div class="p-5">
                        @if (highPriorityTasks.Any() || needsImprovementTasks.Any())
                        {
                            <div class="space-y-4">
                                @if (highPriorityTasks.Any())
                                {
                                    <div>
                                        <h4 class="text-sm font-bold text-red-700 mb-3 flex items-center gap-2">
                                            <span class="w-2 h-2 bg-red-500 rounded-full"></span>
                                            High Priority - Immediate Attention
                                        </h4>
                                        <div class="space-y-3">
                                            @foreach (var task in highPriorityTasks)
                                            {
                                                <div class="bg-red-50 border border-red-200 rounded-xl p-3">
                                                    <div class="flex justify-between items-start mb-2">
                                                        <div>
                                                            <div class="font-semibold text-gray-800">@task.Key</div>
                                                            <div class="text-xs text-gray-500 mt-1">@task.Value.Completed/@task.Value.Total completed</div>
                                                        </div>
                                                        <div class="text-right">
                                                            <div class="text-lg font-bold text-red-600">@task.Value.CompletionRate%</div>
                                                            <div class="text-xs text-gray-500">completion rate</div>
                                                        </div>
                                                    </div>
                                                    <div class="flex flex-wrap gap-3 text-xs">
                                                        @if (task.Value.Pending > 0)
                                                        {
                                                            <span class="text-amber-600"><i class="fas fa-clock mr-1"></i>@task.Value.Pending pending</span>
                                                        }
                                                        @if (task.Value.Late > 0)
                                                        {
                                                            <span class="text-red-600"><i class="fas fa-hourglass-half mr-1"></i>@task.Value.Late late</span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (needsImprovementTasks.Any())
                                {
                                    <div>
                                        <h4 class="text-sm font-bold text-amber-700 mb-3 flex items-center gap-2">
                                            <span class="w-2 h-2 bg-amber-500 rounded-full"></span>
                                            Needs Improvement - Monitor Progress
                                        </h4>
                                        <div class="space-y-3">
                                            @foreach (var task in needsImprovementTasks)
                                            {
                                                <div class="bg-amber-50 border border-amber-200 rounded-xl p-3">
                                                    <div class="flex justify-between items-center mb-2">
                                                        <span class="font-medium text-gray-800">@task.Key</span>
                                                        <span class="text-sm font-bold text-amber-700">@task.Value.CompletionRate%</span>
                                                    </div>
                                                    <div class="w-full bg-gray-200 rounded-full h-1.5">
                                                        <div class="bg-amber-500 h-1.5 rounded-full transition-all duration-500" style="width: @task.Value.CompletionRate%"></div>
                                                    </div>
                                                    <div class="text-xs text-gray-500 mt-2">
                                                        @task.Value.Completed/@task.Value.Total | @task.Value.Late late | @task.Value.Pending pending
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-6">
                                <i class="fas fa-check-circle text-4xl text-green-500 mb-3"></i>
                                <p class="font-medium text-gray-700">No Struggle Tasks Identified!</p>
                                <p class="text-xs text-gray-500 mt-1">Employee is performing well across all task types</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Strengths -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                    <div class="px-5 py-4 border-b border-gray-100 bg-gradient-to-r from-green-50 to-emerald-50">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-trophy text-green-600 text-lg"></i>
                            <h3 class="text-lg font-semibold text-gray-800">Strengths & Strong Performance</h3>
                        </div>
                        <p class="text-xs text-gray-500 mt-0.5 ml-7">Tasks where employee excels</p>
                    </div>
                    <div class="p-5">
                        @if (strongTasks.Any())
                        {
                            <div class="grid gap-3">
                                @foreach (var task in strongTasks)
                                {
                                    <div class="bg-green-50 border border-green-200 rounded-xl p-3">
                                        <div class="flex justify-between items-start">
                                            <div>
                                                <div class="font-semibold text-gray-800">@task.Key</div>
                                                <div class="text-xs text-gray-500 mt-1">@task.Value.Completed/@task.Value.Total completed</div>
                                            </div>
                                            <div class="text-right">
                                                <div class="text-lg font-bold text-green-600">@task.Value.CompletionRate%</div>
                                                <div class="text-xs text-gray-500">completion rate</div>
                                            </div>
                                        </div>
                                        <div class="mt-2">
                                            <span class="text-xs text-green-600"><i class="fas fa-check-circle mr-1"></i>@task.Value.OnTime on time</span>
                                            @if (task.Value.OnTimeRate >= 90)
                                            {
                                                <span class="text-xs text-blue-600 ml-3"><i class="fas fa-rocket mr-1"></i>@task.Value.OnTimeRate% on time</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-6">
                                <i class="fas fa-chart-line text-4xl text-gray-300 mb-3"></i>
                                <p class="text-gray-500">No strong performance identified yet</p>
                                <p class="text-xs text-gray-400 mt-1">Keep working to build consistency</p>
                            </div>
                        }

                        @if (Model.Strengths != null && Model.Strengths.Any())
                        {
                            <div class="mt-4 pt-3 border-t border-gray-200">
                                <h4 class="text-xs font-semibold text-gray-700 mb-2 uppercase tracking-wide">Key Strengths</h4>
                                <div class="flex flex-wrap gap-2">
                                    @foreach (var strength in Model.Strengths)
                                    {
                                        <span class="text-xs px-2 py-1 bg-gray-100 text-gray-700 rounded-full">@strength</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Cover Sheet Reports - Accordion Style -->
        <div class="space-y-4">
            <!-- Pending Tasks Accordion -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <button onclick="toggleAccordion('pendingAccordion')" class="w-full px-5 py-4 flex items-center justify-between bg-gradient-to-r from-amber-50 to-yellow-50 hover:from-amber-100 hover:to-yellow-100 transition-all duration-200">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-amber-500 rounded-xl flex items-center justify-center">
                            <i class="fas fa-clock text-white text-lg"></i>
                        </div>
                        <div class="text-left">
                            <h3 class="text-lg font-bold text-amber-800">PENDING TASKS REPORT</h3>
                            <p class="text-xs text-amber-600">Cover Sheet Summary - Tasks awaiting completion</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-2xl font-bold text-amber-600">@pendingTasks.Count</span>
                        <i class="fas fa-chevron-down text-amber-600 transition-transform duration-200" id="pendingAccordionIcon"></i>
                    </div>
                </button>
                <div id="pendingAccordionContent" class="hidden p-5 border-t border-amber-100">
                    @if (pendingByTask.Any())
                    {
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            @foreach (var task in pendingByTask)
                            {
                                <div class="border border-amber-200 rounded-xl overflow-hidden hover:shadow-md transition-shadow bg-white">
                                    <div class="bg-gradient-to-r from-amber-500 to-yellow-500 px-4 py-3 text-white">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-2">
                                                <i class="fas fa-tasks"></i>
                                                <span class="text-xs font-semibold uppercase tracking-wide">COVER SHEET</span>
                                            </div>
                                            <span class="text-xs bg-white/20 px-2 py-0.5 rounded-full">@task.Count pending</span>
                                        </div>
                                        <h4 class="text-base font-bold mt-1 truncate">@task.TaskName</h4>
                                    </div>
                                    <div class="p-4">
                                        <div class="mb-3 pb-2 border-b border-gray-100">
                                            <div class="text-xs text-gray-500 mb-1">📅 PENDING DATES</div>
                                            <div class="flex flex-wrap gap-1">
                                                @foreach (var date in task.DateObjects.Take(5))
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                                                        @date.ToString("MMM dd")
                                                    </span>
                                                }
                                                @if (task.DateObjects.Count > 5)
                                                {
                                                    <span class="text-xs text-gray-400">+@(task.DateObjects.Count - 5) more</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs text-gray-500">Status:</span>
                                            <span class="px-2 py-0.5 bg-amber-100 text-amber-700 rounded-full text-xs font-medium">⏳ Pending</span>
                                        </div>
                                    </div>
                                    <div class="border-t border-gray-100 bg-gray-50">
                                        <button onclick="toggleTaskDetails('pending-details-@task.TaskName.Replace(" ", "_")')" 
                                                class="w-full px-4 py-2 text-left text-xs font-medium text-gray-600 hover:bg-gray-100 flex justify-between items-center">
                                            <span><i class="fas fa-list-ul mr-1"></i> View Details (@task.Count occurrences)</span>
                                            <i class="fas fa-chevron-down text-gray-400 text-xs transition-transform" id="pending-icon-@task.TaskName.Replace(" ", "_")"></i>
                                        </button>
                                        <div id="pending-details-@task.TaskName.Replace(" ", "_")" class="hidden p-3 bg-white border-t border-gray-100">
                                            <div class="space-y-2 max-h-48 overflow-y-auto">
                                                @foreach (var detail in task.Details)
                                                {
                                                    <div class="flex justify-between items-center p-2 bg-gray-50 rounded-lg text-sm">
                                                        <div>
                                                            <span class="font-medium">@detail.Date.ToString("dddd, MMM dd")</span>
                                                            <span class="text-xs text-gray-500 ml-2">@detail.BranchName</span>
                                                        </div>
                                                        <span class="text-xs text-amber-600">Pending</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-8">
                            <i class="fas fa-check-circle text-5xl text-green-500 mb-3"></i>
                            <p class="text-lg font-medium text-gray-700">No Pending Tasks!</p>
                            <p class="text-sm text-gray-500">All tasks completed on time</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Late Tasks Accordion -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <button onclick="toggleAccordion('lateAccordion')" class="w-full px-5 py-4 flex items-center justify-between bg-gradient-to-r from-red-50 to-orange-50 hover:from-red-100 hover:to-orange-100 transition-all duration-200">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-red-500 rounded-xl flex items-center justify-center">
                            <i class="fas fa-hourglass-half text-white text-lg"></i>
                        </div>
                        <div class="text-left">
                            <h3 class="text-lg font-bold text-red-800">LATE TASKS REPORT</h3>
                            <p class="text-xs text-red-600">Cover Sheet Summary - Tasks completed after deadline</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-2xl font-bold text-red-600">@lateTasks.Count</span>
                        <i class="fas fa-chevron-down text-red-600 transition-transform duration-200" id="lateAccordionIcon"></i>
                    </div>
                </button>
                <div id="lateAccordionContent" class="hidden p-5 border-t border-red-100">
                    @if (lateByTask.Any())
                    {
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            @foreach (var task in lateByTask)
                            {
                                <div class="border border-red-200 rounded-xl overflow-hidden hover:shadow-md transition-shadow bg-white">
                                    <div class="bg-gradient-to-r from-red-500 to-orange-500 px-4 py-3 text-white">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-2">
                                                <i class="fas fa-tasks"></i>
                                                <span class="text-xs font-semibold uppercase tracking-wide">COVER SHEET</span>
                                            </div>
                                            <span class="text-xs bg-white/20 px-2 py-0.5 rounded-full">@task.Count late</span>
                                        </div>
                                        <h4 class="text-base font-bold mt-1 truncate">@task.TaskName</h4>
                                    </div>
                                    <div class="p-4">
                                        <div class="mb-3 pb-2 border-b border-gray-100">
                                            <div class="text-xs text-gray-500 mb-1">📅 LATE DATES</div>
                                            <div class="flex flex-wrap gap-1">
                                                @foreach (var date in task.DateObjects.Take(5))
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                                        @date.ToString("MMM dd")
                                                    </span>
                                                }
                                                @if (task.DateObjects.Count > 5)
                                                {
                                                    <span class="text-xs text-gray-400">+@(task.DateObjects.Count - 5) more</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs text-gray-500">Status:</span>
                                            <span class="px-2 py-0.5 bg-red-100 text-red-700 rounded-full text-xs font-medium">⚠️ Late</span>
                                        </div>
                                    </div>
                                    <div class="border-t border-gray-100 bg-gray-50">
                                        <button onclick="toggleTaskDetails('late-details-@task.TaskName.Replace(" ", "_")')" 
                                                class="w-full px-4 py-2 text-left text-xs font-medium text-gray-600 hover:bg-gray-100 flex justify-between items-center">
                                            <span><i class="fas fa-list-ul mr-1"></i> View Details (@task.Count occurrences)</span>
                                            <i class="fas fa-chevron-down text-gray-400 text-xs transition-transform" id="late-icon-@task.TaskName.Replace(" ", "_")"></i>
                                        </button>
                                        <div id="late-details-@task.TaskName.Replace(" ", "_")" class="hidden p-3 bg-white border-t border-gray-100">
                                            <div class="space-y-2 max-h-48 overflow-y-auto">
                                                @foreach (var detail in task.Details)
                                                {
                                                    var delayText = GetDelayText(detail.DeadlineDateTime, detail.CompletionDateTime);
                                                    <div class="flex justify-between items-center p-2 bg-gray-50 rounded-lg text-sm">
                                                        <div>
                                                            <span class="font-medium">@detail.Date.ToString("dddd, MMM dd")</span>
                                                            <span class="text-xs text-gray-500 ml-2">@detail.BranchName</span>
                                                        </div>
                                                        <span class="text-xs text-red-600 font-medium">@delayText</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-8">
                            <i class="fas fa-check-circle text-5xl text-green-500 mb-3"></i>
                            <p class="text-lg font-medium text-gray-700">No Late Tasks!</p>
                            <p class="text-sm text-gray-500">All tasks completed on time</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Completed On Time Summary - Redesigned -->
        @if (completedOnTime.Any())
        {
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-5 py-4 border-b border-gray-100 bg-gradient-to-r from-green-50 to-emerald-50">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-check-circle text-green-600 text-lg"></i>
                            <h3 class="text-lg font-semibold text-gray-800">Completed On Time</h3>
                        </div>
                        <div class="text-2xl font-bold text-green-600">@completedOnTime.Count</div>
                    </div>
                    <p class="text-xs text-gray-500 mt-0.5 ml-7">Tasks completed before or on deadline</p>
                </div>
                <div class="p-5">
                    <div class="flex flex-wrap gap-2">
                        @{
                            var completedByTaskSimple = completedOnTime.GroupBy(t => t.TaskName).Select(g => new { TaskName = g.Key, Count = g.Count() }).OrderByDescending(t => t.Count).ToList();
                        }
                        @foreach (var task in completedByTaskSimple.Take(12))
                        {
                            <div class="bg-green-50 border border-green-200 rounded-lg px-3 py-2 text-center min-w-[80px]">
                                <div class="text-sm font-medium text-green-700 truncate max-w-[120px]" title="@task.TaskName">@task.TaskName</div>
                                <div class="text-xs text-gray-500">@task.Count time@(task.Count != 1 ? "s" : "")</div>
                            </div>
                        }
                        @if (completedByTaskSimple.Count > 12)
                        {
                            <div class="bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-center">
                                <div class="text-sm text-gray-500">+@(completedByTaskSimple.Count - 12) more</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Insights & Recommendations - Redesigned -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl border border-blue-100 p-5">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 bg-yellow-500 rounded-xl flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-lightbulb text-white text-lg"></i>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-bold text-gray-800 mb-3 text-lg">Performance Insights</h4>
                        <div class="space-y-2">
                            @if (Model.Insights != null && Model.Insights.Any())
                            {
                                foreach (var insight in Model.Insights)
                                {
                                    <p class="text-sm text-gray-700 flex items-start gap-2">
                                        <span class="text-blue-500 mt-0.5">•</span>
                                        <span>@insight</span>
                                    </p>
                                }
                            }
                            else
                            {
                                <p class="text-sm text-gray-700">• Completion Rate: <strong class="text-green-600">@Model.CompletionRate%</strong></p>
                                <p class="text-sm text-gray-700">• On Time Rate: <strong class="text-blue-600">@Model.OnTimeRate%</strong></p>
                                @if (Model.PendingTasks > 0)
                                {
                                    <p class="text-sm text-amber-600">• @Model.PendingTasks pending tasks need attention</p>
                                }
                                @if (Model.LateTasks > 0)
                                {
                                    <p class="text-sm text-red-600">• @Model.LateTasks tasks completed late</p>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl border border-purple-100 p-5">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 bg-purple-500 rounded-xl flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-clipboard-list text-white text-lg"></i>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-bold text-gray-800 mb-3 text-lg">Recommendations</h4>
                        <div class="space-y-2">
                            @if (Model.Recommendations != null && Model.Recommendations.Any())
                            {
                                foreach (var rec in Model.Recommendations)
                                {
                                    <p class="text-sm text-gray-700 flex items-start gap-2">
                                        <span class="text-purple-500 mt-0.5">•</span>
                                        <span>@rec</span>
                                    </p>
                                }
                            }
                            else
                            {
                                @if (Model.PendingTasks > 0)
                                {
                                    <p class="text-sm text-gray-700">• Prioritize pending tasks: @string.Join(", ", pendingTasks.Select(t => t.TaskName).Distinct().Take(3))</p>
                                }
                                @if (Model.LateTasks > 0)
                                {
                                    <p class="text-sm text-gray-700">• Review deadlines and time management for tasks with late submissions</p>
                                }
                                @if (Model.OnTimeRate < 70)
                                {
                                    <p class="text-sm text-gray-700">• Start tasks earlier in the day to meet deadlines</p>
                                }
                                <p class="text-sm text-gray-700">• Schedule regular check-ins to address any challenges</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Summary Footer -->
        <div class="bg-gray-50 rounded-xl p-4 text-center">
            <p class="text-xs text-gray-500">
                <i class="fas fa-chart-simple mr-2"></i>
                Report generated on @DateTime.Now.ToString("MMM dd, yyyy HH:mm") | 
                Data reflects performance for @Model.EmployeeName from @Model.StartDate.ToString("MMM dd, yyyy") to @Model.EndDate.ToString("MMM dd, yyyy")
            </p>
        </div>
    }
    else if (Model != null && Model.EmployeeId > 0 && (Model.DailyBreakdown == null || !Model.DailyBreakdown.Any()))
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-chart-line text-3xl text-gray-400"></i>
            </div>
            <h3 class="text-xl font-medium text-gray-700 mb-2">No Data Found</h3>
            <p class="text-gray-500">No task data available for the selected employee and date range.</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-user-circle text-3xl text-gray-400"></i>
            </div>
            <h3 class="text-xl font-medium text-gray-700 mb-2">No Employee Selected</h3>
            <p class="text-gray-500">Please select an employee and date range to view performance report</p>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
       // Performance Trend Chart
var ctx = document.getElementById('performanceTrendChart').getContext('2d');
var trendDates = @Html.Raw(Json.Serialize(Model?.DailyTrendDates ?? new List<string>()));
var completionRates = @Html.Raw(Json.Serialize(Model?.DailyCompletionRates ?? new List<double>()));
var onTimeRates = @Html.Raw(Json.Serialize(Model?.DailyOnTimeRates ?? new List<double>()));

new Chart(ctx, {
    type: 'line',
    data: {
        labels: trendDates,
        datasets: [
            {
                label: 'Completion Rate (%)',
                data: completionRates,
                borderColor: 'rgb(34, 197, 94)',
                backgroundColor: 'rgba(34, 197, 94, 0.1)',
                borderWidth: 2,
                tension: 0.4,
                fill: true,
                pointRadius: 3,
                pointHoverRadius: 5,
                pointBackgroundColor: 'rgb(34, 197, 94)'
            },
            {
                label: 'On Time Rate (%)',
                data: onTimeRates,
                borderColor: 'rgb(59, 130, 246)',
                backgroundColor: 'rgba(59, 130, 246, 0.1)',
                borderWidth: 2,
                tension: 0.4,
                fill: true,
                pointRadius: 3,
                pointHoverRadius: 5,
                pointBackgroundColor: 'rgb(59, 130, 246)'
            }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { 
                position: 'top',
                labels: { boxWidth: 12, padding: 10 }
            },
            tooltip: { 
                mode: 'index',
                intersect: false
            }
        },
        scales: {
            y: { 
                beginAtZero: true, 
                max: 100,
                grid: { color: 'rgba(0, 0, 0, 0.05)' },
                title: { display: true, text: 'Percentage (%)', font: { size: 11 } }
            },
            x: { 
                grid: { display: false },
                title: { display: true, text: 'Date', font: { size: 11 } }
            }
        }
    }
});
    </script>
}

<style>
    .animate-slide-in {
        animation: slideIn 0.3s ease-out;
    }
    
    @@keyframes slideIn {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
    
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
    
    @@media print {
        .bg-gradient-to-r, .shadow-sm, .border, button, form {
            print-color-adjust: exact;
            -webkit-print-color-adjust: exact;
        }
        .hidden {
            display: block !important;
        }
        button, .no-print {
            display: none !important;
        }
    }
    
    .truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    
    ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }
    
    ::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }
    
    ::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 10px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }
</style>