@using TaskTracker.Models.ViewModels
@model EmployeePerformanceViewModel
@{
    ViewData["Title"] = "Employee Performance Report";

    var isGenerated = Model?.IsGenerated ?? false;
    
    // Groupings only if generated
    List<DailyPerformance> lateTasks = new();
    List<DailyPerformance> pendingTasks = new();
    List<DailyPerformance> completedOnTime = new();
    dynamic pendingByTask = new List<dynamic>();
    dynamic lateByTask = new List<dynamic>();

    if (isGenerated && Model.DailyBreakdown != null)
    {
        lateTasks = Model.DailyBreakdown.Where(d => d.Status == "Completed" && !d.IsOnTime).ToList();
        pendingTasks = Model.DailyBreakdown.Where(d => d.Status != "Completed").ToList();
        completedOnTime = Model.DailyBreakdown.Where(d => d.Status == "Completed" && d.IsOnTime).ToList();

        pendingByTask = pendingTasks.GroupBy(t => t.TaskName).Select(g => new {
            TaskName = g.Key, Count = g.Count(),
            Dates = g.Select(t => t.Date.ToString("MMM dd")).Distinct().OrderBy(d => d).ToList(),
            DateObjects = g.Select(t => t.Date).Distinct().OrderBy(d => d).ToList(),
            Details = g.OrderByDescending(t => t.Date).ToList()
        }).OrderByDescending(t => t.Count).ToList();

        lateByTask = lateTasks.GroupBy(t => t.TaskName).Select(g => new {
            TaskName = g.Key, Count = g.Count(),
            Dates = g.Select(t => t.Date.ToString("MMM dd")).Distinct().OrderBy(d => d).ToList(),
            DateObjects = g.Select(t => t.Date).Distinct().OrderBy(d => d).ToList(),
            Details = g.OrderByDescending(t => t.Date).ToList()
        }).OrderByDescending(t => t.Count).ToList();
    }
}

<div class="space-y-6 animate-fade-up">

    <!-- Filter -->
    <div class="glass-card p-5">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <input type="hidden" name="generate" value="true" />
            <div class="flex-1 min-w-[240px]">
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Select Employee</label>
                <select name="employeeId" class="dark-input">
                    <option value="">Choose an employee...</option>
                    @if (ViewBag.Employees != null)
                    {
                        @foreach (var emp in ViewBag.Employees)
                        {
                            <option value="@emp.Id" selected="@(emp.Id == Model?.EmployeeId)">@emp.Name - @emp.Position</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Start Date</label>
                <input type="date" name="startDate" class="dark-input" value="@ViewBag.StartDate">
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">End Date</label>
                <input type="date" name="endDate" class="dark-input" value="@ViewBag.EndDate">
            </div>
            <button type="submit" class="btn-primary"><i class="fas fa-play text-xs mr-1"></i>Generate Report</button>
        </form>
    </div>

    @if (Model.IsGenerated)
    {
        var initials = "?";
        if (!string.IsNullOrEmpty(Model.EmployeeName)) {
            var nameParts = Model.EmployeeName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            initials = nameParts.Length == 1 ? nameParts[0].Substring(0, 1).ToUpper() : (nameParts[0][0].ToString() + nameParts[^1][0].ToString()).ToUpper();
        }

        <!-- Employee Profile Header -->
        <div class="glass-card p-5 overflow-hidden relative">
            <div class="absolute top-0 right-0 w-48 h-48 rounded-full -mr-16 -mt-16"
                 style="background: radial-gradient(circle, rgba(249,115,22,0.15), transparent);"></div>
            <div class="flex flex-col md:flex-row items-center justify-between gap-5 relative z-10">
                <div class="flex items-center gap-4">
                    <div class="w-20 h-20 rounded-2xl flex items-center justify-center text-white font-bold text-3xl"
                         style="background: linear-gradient(135deg, #ea580c, #1e1b4b);">
                        @initials
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold text-white">@Model.EmployeeName</h2>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <span class="stat-badge" style="background: rgba(255,255,255,0.1); color: #94a3b8;">📋 @Model.EmployeeIdNumber</span>
                            <span class="stat-badge" style="background: rgba(255,255,255,0.1); color: #94a3b8;">🏢 @Model.Department</span>
                            <span class="stat-badge" style="background: rgba(255,255,255,0.1); color: #94a3b8;">💼 @Model.Position</span>
                        </div>
                        <p class="text-slate-400 text-sm mt-1"><i class="far fa-calendar-alt mr-1"></i>@Model.StartDate.ToString("MMM dd, yyyy") — @Model.EndDate.ToString("MMM dd, yyyy")</p>
                    </div>
                </div>
                <div class="text-center">
                    <div class="text-xs text-slate-400 mb-1">Overall Performance Score</div>
                    <div class="text-5xl font-bold text-white">@Math.Round(Model.OverallScore, 2)%</div>
                    <div class="mt-2">
                        @if (Model.OverallScore >= 90) { <span class="stat-badge" style="background: rgba(16,185,129,0.2); color: #6ee7b7;">🏆 Excellent – Top Performer</span> }
                        else if (Model.OverallScore >= 75) { <span class="stat-badge" style="background: rgba(6,182,212,0.2); color: #67e8f9;">⭐ Good – Above Average</span> }
                        else if (Model.OverallScore >= 60) { <span class="stat-badge" style="background: rgba(245,158,11,0.2); color: #fcd34d;">📈 Satisfactory</span> }
                        else { <span class="stat-badge" style="background: rgba(239,68,68,0.2); color: #fca5a5;">⚠️ Needs Improvement</span> }
                    </div>
                </div>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Total Tasks</p>
                    <p class="text-2xl font-bold text-white mt-0.5">@Model.TotalTasks</p>
                </div>
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(99,102,241,0.15);">
                    <i class="fas fa-tasks text-indigo-400"></i>
                </div>
            </div>
            <div class="glass-card p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Completed</p>
                        <p class="text-2xl font-bold text-white mt-0.5">@Model.CompletedTasks</p>
                    </div>
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(16,185,129,0.15);">
                        <i class="fas fa-check-circle text-emerald-400"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <div class="flex justify-between text-xs mb-1">
                        <span class="text-slate-500">Completion Rate</span>
                        <span class="font-semibold text-emerald-400">@Model.CompletionRate.ToString("F2")%</span>
                    </div>
                    <div class="w-full rounded-full h-1.5" style="background: rgba(255,255,255,0.08);">
                        <div class="bg-emerald-500 h-1.5 rounded-full" style="width: @Math.Min(Model.CompletionRate, 100)%"></div>
                    </div>
                </div>
            </div>
            <div class="glass-card p-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">On Time</p>
                        <p class="text-2xl font-bold text-white mt-0.5">@Model.OnTimeTasks</p>
                    </div>
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(6,182,212,0.15);">
                        <i class="fas fa-clock text-cyan-400"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <div class="flex justify-between text-xs mb-1">
                        <span class="text-slate-500">On-Time Rate</span>
                        <span class="font-semibold text-cyan-400">@Model.OnTimeRate.ToString("F2")%</span>
                    </div>
                    <div class="w-full rounded-full h-1.5" style="background: rgba(255,255,255,0.08);">
                        <div class="bg-cyan-500 h-1.5 rounded-full" style="width: @Math.Min(Model.OnTimeRate, 100)%"></div>
                    </div>
                </div>
            </div>
            <div class="glass-card p-4 flex items-center justify-between">
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Pending</p>
                    <p class="text-2xl font-bold text-white mt-0.5">@Model.PendingTasks</p>
                </div>
                <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(245,158,11,0.15);">
                    <i class="fas fa-hourglass-half text-amber-400"></i>
                </div>
            </div>
        </div>

        <!-- Performance Trend Chart -->
        <div class="glass-card overflow-hidden">
            <div class="px-5 py-4 border-b flex items-center justify-between" style="border-color: rgba(255,255,255,0.06); background: rgba(99,102,241,0.08);">
                <div>
                    <h3 class="font-bold text-white">Performance Trend</h3>
                    <p class="text-xs text-slate-500 mt-0.5">Daily completion and on-time rates over time</p>
                </div>
                <div class="flex gap-4">
                    <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-emerald-500"></div><span class="text-xs text-slate-400">Completion</span></div>
                    <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-cyan-500"></div><span class="text-xs text-slate-400">On-Time</span></div>
                </div>
            </div>
            <div class="p-5" style="height: 280px;">
                <canvas id="performanceTrendChart"></canvas>
            </div>
        </div>

        <!-- Task Performance Matrix & Strengths/Weaknesses -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            <!-- Task Performance Matrix -->
            <div class="glass-card overflow-hidden">
                <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(99,102,241,0.08);">
                    <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-chart-pie text-indigo-400"></i>Task Performance Matrix</h3>
                    <p class="text-xs text-slate-500 mt-0.5">Breakdown by task type</p>
                </div>
                <div class="p-5">
                    @if (Model.TaskBreakdown != null && Model.TaskBreakdown.Any())
                    {
                        <div class="space-y-4">
                            @foreach (var task in Model.TaskBreakdown.OrderBy(t => t.Key))
                            {
                                var stats = task.Value;
                                var completionPercent = stats.CompletionRate;
                                var barColor = completionPercent >= 80 ? "#10b981" : completionPercent >= 60 ? "#f59e0b" : "#ef4444";
                                <div>
                                    <div class="flex justify-between items-center mb-1">
                                        <span class="font-semibold text-slate-200 text-sm">@task.Key</span>
                                        <span class="text-xs text-slate-500">@stats.Completed/@stats.Total (@completionPercent%)</span>
                                    </div>
                                    <div class="w-full rounded-full h-2" style="background: rgba(255,255,255,0.08);">
                                        <div class="h-2 rounded-full" style="width: @completionPercent%; background: @barColor;"></div>
                                    </div>
                                    <div class="flex justify-between items-center mt-1">
                                        <div class="flex gap-3">
                                            @if (stats.Pending > 0) { <span class="text-xs text-amber-400"><i class="fas fa-clock mr-1"></i>@stats.Pending pending</span> }
                                            @if (stats.Late > 0) { <span class="text-xs text-red-400"><i class="fas fa-exclamation-triangle mr-1"></i>@stats.Late late</span> }
                                        </div>
                                        @if (stats.OnTime > 0) { <span class="text-xs text-cyan-400">@stats.OnTimeRate.ToString("F2")% on time</span> }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-8"><i class="fas fa-inbox text-3xl text-slate-600 mb-2"></i><p class="text-slate-500 text-sm">No task data</p></div>
                    }
                </div>
            </div>

            <!-- Strengths & Weaknesses -->
            <div class="space-y-5">
                <!-- Weaknesses -->
                <div class="glass-card overflow-hidden">
                    <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(239,68,68,0.06);">
                        <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-exclamation-triangle text-red-400"></i>Areas Needing Improvement</h3>
                    </div>
                    <div class="p-5">
                        @if (Model.HighPriorityTasks.Any() || Model.NeedsImprovementTasks.Any())
                        {
                            <div class="space-y-3">
                                @if (Model.HighPriorityTasks.Any())
                                {
                                    <h4 class="text-xs font-bold text-red-400 uppercase tracking-wider flex items-center gap-1.5">
                                        <span class="w-2 h-2 bg-red-500 rounded-full"></span>High Priority
                                    </h4>
                                    <div class="space-y-2">
                                        @foreach (var task in Model.HighPriorityTasks.Take(3))
                                        {
                                            <div class="rounded-xl p-3" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15);">
                                                <div class="flex justify-between items-start mb-1">
                                                    <div>
                                                        <div class="font-semibold text-slate-200 text-sm">@task.Key</div>
                                                        <div class="text-xs text-slate-500">@task.Value.Completed/@task.Value.Total completed</div>
                                                    </div>
                                                    <div class="text-right">
                                                        <div class="font-bold text-red-400">@task.Value.CompletionRate%</div>
                                                        <div class="text-[10px] text-slate-500">completion</div>
                                                    </div>
                                                </div>
                                                <div class="flex gap-3 text-xs">
                                                    @if (task.Value.Pending > 0) { <span class="text-amber-400"><i class="fas fa-clock mr-0.5"></i>@task.Value.Pending pending</span> }
                                                    @if (task.Value.Late > 0) { <span class="text-red-400"><i class="fas fa-hourglass-half mr-0.5"></i>@task.Value.Late late</span> }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                @if (Model.NeedsImprovementTasks.Any())
                                {
                                    <h4 class="text-xs font-bold text-amber-400 uppercase tracking-wider flex items-center gap-1.5 mt-3">
                                        <span class="w-2 h-2 bg-amber-500 rounded-full"></span>Monitor Progress
                                    </h4>
                                    <div class="space-y-2">
                                        @foreach (var task in Model.NeedsImprovementTasks.Take(3))
                                        {
                                            <div class="rounded-xl p-3" style="background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.15);">
                                                <div class="flex justify-between items-center mb-1">
                                                    <span class="font-medium text-slate-200 text-sm">@task.Key</span>
                                                    <span class="font-bold text-amber-400">@task.Value.CompletionRate.ToString("F2")%</span>
                                                </div>
                                                <div class="w-full rounded-full h-1" style="background: rgba(255,255,255,0.08);">
                                                    <div class="bg-amber-500 h-1 rounded-full" style="width: @task.Value.CompletionRate%"></div>
                                                </div>
                                                <div class="text-xs text-slate-500 mt-1">@task.Value.Completed/@task.Value.Total | @task.Value.Late late | @task.Value.Pending pending</div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-check-circle text-3xl text-emerald-400 mb-2"></i>
                                <p class="font-medium text-slate-300 text-sm">No Struggle Tasks!</p>
                                <p class="text-xs text-slate-500 mt-0.5">Employee is performing well across all task types</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Strengths -->
                <div class="glass-card overflow-hidden">
                    <div class="px-5 py-4 border-b" style="border-color: rgba(255,255,255,0.06); background: rgba(16,185,129,0.08);">
                        <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-trophy text-amber-400"></i>Strengths & Strong Performance</h3>
                    </div>
                    <div class="p-5">
                        @if (Model.HasStruggleTasks)
                        {
                            <div class="space-y-2">
                                @foreach (var task in Model.StrongTasks.Take(3))
                                {
                                    <div class="rounded-xl p-3" style="background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2);">
                                        <div class="flex justify-between items-start">
                                            <div>
                                                <div class="font-semibold text-slate-200 text-sm">@task.Key</div>
                                                <div class="text-xs text-slate-500">@task.Value.Completed/@task.Value.Total completed</div>
                                            </div>
                                            <div class="font-bold text-emerald-400">@task.Value.CompletionRate%</div>
                                        </div>
                                        <div class="mt-1 flex gap-2 text-xs">
                                            <span class="text-emerald-400"><i class="fas fa-check-circle mr-0.5"></i>@task.Value.OnTime on time</span>
                                            @if (task.Value.OnTimeRate >= 90) { <span class="text-cyan-400"><i class="fas fa-rocket mr-0.5"></i>@task.Value.OnTimeRate% on-time rate</span> }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-chart-line text-3xl text-slate-600 mb-2"></i>
                                <p class="text-slate-500 text-sm">No strong performance identified yet</p>
                            </div>
                        }
                        @if (Model.Strengths != null && Model.Strengths.Any())
                        {
                            <div class="mt-3 pt-3 border-t" style="border-color: rgba(255,255,255,0.06);">
                                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Key Strengths</h4>
                                <div class="flex flex-wrap gap-1.5">
                                    @foreach (var strength in Model.Strengths)
                                    {
                                        <span class="text-xs px-2 py-0.5 rounded-lg" style="background: rgba(255,255,255,0.06); color: #94a3b8;">@strength</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Pending Tasks Accordion -->
        <div class="glass-card overflow-hidden">
            <button onclick="toggleAccordion('pendingAccordion')"
                    class="w-full px-5 py-4 flex items-center justify-between transition hover:bg-white/5"
                    style="background: rgba(245,158,11,0.08);">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(245,158,11,0.3);">
                        <i class="fas fa-clock text-amber-400"></i>
                    </div>
                    <div class="text-left">
                        <h3 class="font-bold text-amber-300">PENDING TASKS REPORT</h3>
                        <p class="text-xs text-amber-400/70">Cover Sheet Summary — Tasks awaiting completion</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-2xl font-bold text-amber-400">@Model.PendingTasksList.Count</span>
                    <i class="fas fa-chevron-down text-amber-400 transition-transform duration-200" id="pendingAccordionIcon"></i>
                </div>
            </button>
            <div id="pendingAccordionContent" class="hidden p-5 border-t" style="border-color: rgba(245,158,11,0.15);">
                @if (Model.PendingTasksList.Any())
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        @foreach (var task in Model.PendingTasksList)
                        {
                            <div class="rounded-xl overflow-hidden" style="border: 1px solid rgba(245,158,11,0.2);">
                                <div class="px-4 py-3 text-white" style="background: linear-gradient(135deg, #d97706, #b45309);">
                                    <div class="flex justify-between items-center">
                                        <span class="text-xs font-bold uppercase tracking-wide">COVER SHEET</span>
                                        <span class="text-xs px-2 py-0.5 rounded-full" style="background: rgba(255,255,255,0.2);">@task.Count pending</span>
                                    </div>
                                    <h4 class="font-bold mt-1 truncate">@task.TaskName</h4>
                                </div>
                                <div class="p-4" style="background: rgba(245,158,11,0.04);">
                                    <div class="text-xs text-slate-500 mb-1">📅 PENDING DATES</div>
                                    <div class="flex flex-wrap gap-1 mb-3">
                                        @foreach (var date in task.DateObjects.Take(5))
                                        {
                                            <span class="text-xs px-2 py-0.5 rounded-full" style="background: rgba(245,158,11,0.15); color: #fcd34d;">@date.ToString("MMM dd")</span>
                                        }
                                        @if (task.DateObjects.Count > 5) { <span class="text-xs text-slate-500">+@(task.DateObjects.Count - 5) more</span> }
                                    </div>
                                    <button onclick="toggleTaskDetails('pending-details-@task.TaskName.Replace(" ", "_")')"
                                            class="w-full text-left text-xs text-slate-400 hover:text-slate-200 flex justify-between items-center py-2 border-t"
                                            style="border-color: rgba(255,255,255,0.06);">
                                        <span><i class="fas fa-list-ul mr-1"></i>View Details (@task.Count occurrences)</span>
                                        <i class="fas fa-chevron-down text-xs transition-transform" id="pending-icon-@task.TaskName.Replace(" ", "_")"></i>
                                    </button>
                                    <div id="pending-details-@task.TaskName.Replace(" ", "_")" class="hidden mt-2 space-y-1 max-h-40 overflow-y-auto">
                                        @foreach (var detail in task.Details)
                                        {
                                            <div class="flex justify-between items-center p-2 rounded-lg text-xs" style="background: rgba(255,255,255,0.04);">
                                                <span class="text-slate-300">@detail.Date.ToString("dddd, MMM dd")</span>
                                                <span class="text-amber-400">Pending</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-6">
                        <i class="fas fa-check-circle text-4xl text-emerald-400 mb-2"></i>
                        <p class="font-medium text-slate-300">No Pending Tasks!</p>
                        <p class="text-xs text-slate-500 mt-1">All tasks completed on time</p>
                    </div>
                }
            </div>
        </div>

        <!-- Late Tasks Accordion -->
        <div class="glass-card overflow-hidden">
            <button onclick="toggleAccordion('lateAccordion')"
                    class="w-full px-5 py-4 flex items-center justify-between transition hover:bg-white/5"
                    style="background: rgba(239,68,68,0.06);">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(239,68,68,0.2);">
                        <i class="fas fa-hourglass-half text-red-400"></i>
                    </div>
                    <div class="text-left">
                        <h3 class="font-bold text-red-300">LATE TASKS REPORT</h3>
                        <p class="text-xs text-red-400/70">Cover Sheet Summary — Tasks completed after deadline</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-2xl font-bold text-red-400">@Model.LateTasksList.Count</span>
                    <i class="fas fa-chevron-down text-red-400 transition-transform duration-200" id="lateAccordionIcon"></i>
                </div>
            </button>
            <div id="lateAccordionContent" class="hidden p-5 border-t" style="border-color: rgba(239,68,68,0.15);">
                @if (Model.LateTasksList.Any())
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        @foreach (var task in Model.LateTasksList)
                        {
                            <div class="rounded-xl overflow-hidden" style="border: 1px solid rgba(239,68,68,0.2);">
                                <div class="px-4 py-3 text-white" style="background: linear-gradient(135deg, #dc2626, #ea580c);">
                                    <div class="flex justify-between items-center">
                                        <span class="text-xs font-bold uppercase tracking-wide">COVER SHEET</span>
                                        <span class="text-xs px-2 py-0.5 rounded-full" style="background: rgba(255,255,255,0.2);">@task.Count late</span>
                                    </div>
                                    <h4 class="font-bold mt-1 truncate">@task.TaskName</h4>
                                </div>
                                <div class="p-4" style="background: rgba(239,68,68,0.04);">
                                    <div class="text-xs text-slate-500 mb-1">📅 LATE DATES</div>
                                    <div class="flex flex-wrap gap-1 mb-3">
                                        @foreach (var date in task.DateObjects.Take(5))
                                        {
                                            <span class="text-xs px-2 py-0.5 rounded-full" style="background: rgba(239,68,68,0.12); color: #fca5a5;">@date.ToString("MMM dd")</span>
                                        }
                                        @if (task.DateObjects.Count > 5) { <span class="text-xs text-slate-500">+@(task.DateObjects.Count - 5) more</span> }
                                    </div>
                                    <button onclick="toggleTaskDetails('late-details-@task.TaskName.Replace(" ", "_")')"
                                            class="w-full text-left text-xs text-slate-400 hover:text-slate-200 flex justify-between items-center py-2 border-t"
                                            style="border-color: rgba(255,255,255,0.06);">
                                        <span><i class="fas fa-list-ul mr-1"></i>View Details (@task.Count occurrences)</span>
                                        <i class="fas fa-chevron-down text-xs transition-transform" id="late-icon-@task.TaskName.Replace(" ", "_")"></i>
                                    </button>
                                    <div id="late-details-@task.TaskName.Replace(" ", "_")" class="hidden mt-2 space-y-1 max-h-40 overflow-y-auto">
                                        @foreach (var item in task.Details)
                                        {
                                            <div class="flex justify-between items-center p-2 rounded-lg text-xs" style="background: rgba(255,255,255,0.04);">
                                                <span class="text-slate-300">@item.Date.ToString("dddd, MMM dd")</span>
                                                <span class="text-red-400 font-medium">@item.DelayText</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-6">
                        <i class="fas fa-check-circle text-4xl text-emerald-400 mb-2"></i>
                        <p class="font-medium text-slate-300">No Late Tasks!</p>
                        <p class="text-xs text-slate-500 mt-1">All tasks completed on time</p>
                    </div>
                }
            </div>
        </div>

        <!-- Completed On Time Summary -->
        @if (completedOnTime.Any())
        {
            <div class="glass-card overflow-hidden">
                <div class="px-5 py-4 border-b flex items-center justify-between" style="border-color: rgba(255,255,255,0.06); background: rgba(16,185,129,0.08);">
                    <h3 class="font-bold text-white flex items-center gap-2"><i class="fas fa-check-circle text-emerald-400"></i>Completed On Time</h3>
                    <div class="text-2xl font-bold text-emerald-400">@completedOnTime.Count</div>
                </div>
                <div class="p-5 flex flex-wrap gap-2">
                    @{
                        var completedByTaskSimple = completedOnTime.GroupBy(t => t.TaskName).Select(g => new { TaskName = g.Key, Count = g.Count() }).OrderByDescending(t => t.Count).ToList();
                    }
                    @foreach (var task in completedByTaskSimple.Take(12))
                    {
                        <div class="rounded-xl px-3 py-2 text-center" style="min-width: 80px; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2);">
                            <div class="text-xs font-medium text-emerald-300 truncate max-w-[120px]" title="@task.TaskName">@task.TaskName</div>
                            <div class="text-[10px] text-slate-500">@task.Count time@(task.Count != 1 ? "s" : "")</div>
                        </div>
                    }
                    @if (completedByTaskSimple.Count > 12)
                    {
                        <div class="rounded-xl px-3 py-2 text-center" style="background: rgba(255,255,255,0.04);">
                            <div class="text-xs text-slate-500">+@(completedByTaskSimple.Count - 12) more</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Insights & Recommendations -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="rounded-xl p-5" style="background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(6,182,212,0.06)); border: 1px solid rgba(99,102,241,0.15);">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(245,158,11,0.2);">
                        <i class="fas fa-lightbulb text-amber-400"></i>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-bold text-white mb-2">Performance Insights</h4>
                        <div class="space-y-1">
                            @if (Model.Insights != null && Model.Insights.Any())
                            {
                                foreach (var insight in Model.Insights)
                                {
                                    <p class="text-sm text-slate-400 flex items-start gap-1.5"><span class="text-indigo-400 mt-0.5">•</span><span>@insight</span></p>
                                }
                            }
                            else
                            {
                                <p class="text-sm text-slate-400">• Completion Rate: <strong class="text-emerald-400">@Model.CompletionRate.ToString("F2")%</strong></p>
                                <p class="text-sm text-slate-400">• On Time Rate: <strong class="text-cyan-400">@Model.OnTimeRate.ToString("F2")%</strong></p>
                                @if (Model.PendingTasks > 0) { <p class="text-sm text-amber-400">• @Model.PendingTasks pending tasks need attention</p> }
                                @if (Model.LateTasks > 0) { <p class="text-sm text-red-400">• @Model.LateTasks tasks completed late</p> }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="rounded-xl p-5" style="background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(16,185,129,0.06)); border: 1px solid rgba(124,58,237,0.15);">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(124,58,237,0.2);">
                        <i class="fas fa-clipboard-list text-violet-400"></i>
                    </div>
                    <div class="flex-1">
                        <h4 class="font-bold text-white mb-2">Recommendations</h4>
                        <div class="space-y-1">
                            @if (Model.Recommendations != null && Model.Recommendations.Any())
                            {
                                foreach (var rec in Model.Recommendations)
                                {
                                    <p class="text-sm text-slate-400 flex items-start gap-1.5"><span class="text-violet-400 mt-0.5">•</span><span>@rec</span></p>
                                }
                            }
                            else
                            {
                                @if (Model.PendingTasks > 0) { <p class="text-sm text-slate-400">• Prioritize pending tasks: @string.Join(", ", pendingTasks.Select(t => t.TaskName).Distinct().Take(3))</p> }
                                @if (Model.LateTasks > 0) { <p class="text-sm text-slate-400">• Review deadlines and time management for late submissions</p> }
                                @if (Model.OnTimeRate < 70) { <p class="text-sm text-slate-400">• Start tasks earlier in the day to meet deadlines</p> }
                                <p class="text-sm text-slate-400">• Schedule regular check-ins to address any challenges</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="rounded-xl p-3 text-center text-xs text-slate-600" style="background: rgba(255,255,255,0.03);">
            <i class="fas fa-chart-simple mr-2"></i>
            Report generated on @DateTime.Now.ToString("MMM dd, yyyy HH:mm") | Data for @Model.EmployeeName from @Model.StartDate.ToString("MMM dd, yyyy") to @Model.EndDate.ToString("MMM dd, yyyy")
        </div>
    }
    else if (Model != null && Model.EmployeeId > 0 && (Model.DailyBreakdown == null || !Model.DailyBreakdown.Any()))
    {
        <div class="glass-card p-12 text-center">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: rgba(255,255,255,0.04);">
                <i class="fas fa-chart-line text-slate-500 text-2xl"></i>
            </div>
            <h3 class="font-semibold text-slate-300 mb-1">No Data Found</h3>
            <p class="text-slate-500 text-sm">No task data for the selected employee and date range.</p>
        </div>
    }
    else
    {
        <div class="glass-card p-12 text-center">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: rgba(99,102,241,0.1);">
                <i class="fas fa-user-circle text-indigo-400 text-2xl"></i>
            </div>
            <h3 class="font-semibold text-slate-300 mb-1">No Employee Selected</h3>
            <p class="text-slate-500 text-sm">Please select an employee and date range to view performance report</p>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const trendCtx = document.getElementById('performanceTrendChart');
        if (trendCtx) {
            const trendDates = @Html.Raw(Json.Serialize(Model?.DailyTrendDates ?? new List<string>()));
            const completionRates = @Html.Raw(Json.Serialize(Model?.DailyCompletionRates ?? new List<double>()));
            const onTimeRates = @Html.Raw(Json.Serialize(Model?.DailyOnTimeRates ?? new List<double>()));
            const dpr = window.devicePixelRatio || 1;

            new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: trendDates,
                    datasets: [
                        { 
                            label: 'Completion Rate (%)', 
                            data: completionRates, 
                            borderColor: '#10b981', 
                            backgroundColor: 'rgba(16,185,129,0.1)', 
                            borderWidth: 2, 
                            tension: 0.4, 
                            fill: true, 
                            pointRadius: 4, 
                            pointHoverRadius: 7, 
                            pointBackgroundColor: '#10b981', 
                            pointBorderColor: '#0b0b18',
                            pointBorderWidth: 2
                        },
                        { 
                            label: 'On Time Rate (%)', 
                            data: onTimeRates, 
                            borderColor: '#06b6d4', 
                            backgroundColor: 'rgba(6,182,212,0.1)', 
                            borderWidth: 2, 
                            tension: 0.4, 
                            fill: true, 
                            pointRadius: 4, 
                            pointHoverRadius: 7, 
                            pointBackgroundColor: '#06b6d4', 
                            pointBorderColor: '#0b0b18',
                            pointBorderWidth: 2
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    devicePixelRatio: dpr,
                    animation: { duration: 0 },
                    interaction: { mode: 'index', intersect: false },
                    plugins: { 
                        legend: { 
                            position: 'top', 
                            labels: { 
                                color: '#94a3b8', 
                                boxWidth: 10,
                                padding: 20,
                                usePointStyle: true,
                                font: { weight: '500' }
                            } 
                        }, 
                        tooltip: { 
                            mode: 'index', 
                            intersect: false,
                            backgroundColor: 'rgba(26,26,46,0.95)',
                            titleColor: '#fff',
                            bodyColor: '#94a3b8',
                            borderColor: 'rgba(255,255,255,0.1)',
                            borderWidth: 1,
                            padding: 12,
                            cornerRadius: 8
                        } 
                    },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            max: 100, 
                            grid: { color: 'rgba(255,255,255,0.05)' }, 
                            ticks: { 
                                color: '#94a3b8',
                                callback: function(value) { return value + '%'; },
                                font: { size: 11 }
                            } 
                        },
                        x: { 
                            grid: { display: false }, 
                            ticks: { 
                                color: '#94a3b8',
                                font: { size: 11 },
                                maxRotation: 45
                            } 
                        }
                    }
                }
            });
        }

        function toggleAccordion(id) {
            const content = document.getElementById(id + 'Content');
            const icon = document.getElementById(id + 'Icon');
            content.classList.toggle('hidden');
            icon.classList.toggle('rotate-180');
        }

        function toggleTaskDetails(id) {
            const el = document.getElementById(id);
            const baseName = id.replace('pending-details-', '').replace('late-details-', '');
            const prefix = id.startsWith('pending') ? 'pending' : 'late';
            const icon = document.getElementById(prefix + '-icon-' + baseName);
            el.classList.toggle('hidden');
            if (icon) icon.classList.toggle('rotate-180');
        }
    </script>
}