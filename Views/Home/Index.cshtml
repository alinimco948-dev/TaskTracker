                    <input type="hidden" id="adjustmentDate">
                    <div class="bg-amber-50 p-2 rounded text-center mb-3">
                        <span class="text-xl font-bold text-amber-600" id="currentAdjustmentDisplay">0</span>
                        <span class="text-xs text-gray-500 ml-1">minutes added to deadline</span>
                    </div>
                    <div class="grid grid-cols-4 gap-1 mb-3">
                        <button type="button" onclick="addAdjustment(5)" class="py-1.5 bg-blue-100 text-blue-700 text-xs rounded hover:bg-blue-200">+5</button>
                        <button type="button" onclick="addAdjustment(10)" class="py-1.5 bg-blue-100 text-blue-700 text-xs rounded hover:bg-blue-200">+10</button>
                        <button type="button" onclick="addAdjustment(15)" class="py-1.5 bg-blue-100 text-blue-700 text-xs rounded hover:bg-blue-200">+15</button>
                        <button type="button" onclick="addAdjustment(30)" class="py-1.5 bg-blue-100 text-blue-700 text-xs rounded hover:bg-blue-200">+30</button>
                        <button type="button" onclick="addAdjustment(60)" class="py-1.5 bg-blue-100 text-blue-700 text-xs rounded hover:bg-blue-200">+60</button>
                        <button type="button" onclick="addAdjustment(120)" class="py-1.5 bg-blue-100 text-blue-700 text-xs rounded hover:bg-blue-200">+120</button>
                        <button type="button" onclick="addAdjustment(240)" class="py-1.5 bg-blue-100 text-blue-700 text-xs rounded hover:bg-blue-200">+240</button>
                        <button type="button" onclick="addAdjustment(480)" class="py-1.5 bg-blue-100 text-blue-700 text-xs rounded hover:bg-blue-200">+480</button>
                    </div>
                    <input type="number" id="adjustmentMinutes" min="0" value="0" class="w-full px-3 py-2 text-xs border rounded-lg mb-3" placeholder="Custom minutes">
                    <textarea id="adjustmentReason" rows="2" class="w-full px-3 py-2 text-xs border rounded-lg mb-2" placeholder="Reason for adjustment (optional)"></textarea>
                    <div class="text-[10px] text-amber-600 bg-amber-50 p-2 rounded">
                        <i class="fas fa-info-circle mr-1"></i> Adding minutes extends the deadline. Set to 0 to remove adjustment.
                    </div>
                </div>
                <div class="px-4 py-3 bg-gray-50 flex justify-end gap-2 rounded-b-xl">
                    <button type="button" onclick="closeAdjustmentModal()" class="px-3 py-1.5 text-xs border rounded-lg hover:bg-gray-100">Cancel</button>
                    <button type="button" onclick="clearAdjustment()" class="px-3 py-1.5 text-xs bg-gray-500 text-white rounded-lg hover:bg-gray-600">Clear</button>
                    <button type="button" onclick="saveAdjustment()" class="px-3 py-1.5 text-xs bg-amber-500 text-white rounded-lg hover:bg-amber-600">Save</button>
                </div>
            </div>
        </div>

        <!-- Notes Modal -->
        <div id="notesModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50 backdrop-blur-sm">
            <div class="bg-white rounded-xl shadow-2xl w-96 transform transition-all">
                <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-4 py-3 rounded-t-xl">
                    <h3 class="text-base font-semibold text-white flex items-center">
                        <i class="fas fa-sticky-note mr-2"></i>Branch Notes
                    </h3>
                    <p class="text-blue-100 text-[10px] mt-0.5" id="notesBranchName"></p>
                </div>
                <div class="p-4">
                    <input type="hidden" id="notesBranchId">
                    <textarea id="notesContent" rows="4" class="w-full px-3 py-2 text-xs border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Enter notes for this branch..."></textarea>
                </div>
                <div class="px-4 py-3 bg-gray-50 flex justify-end gap-2 rounded-b-xl">
                    <button type="button" onclick="closeNotesModal()" class="px-3 py-1.5 text-xs border rounded-lg hover:bg-gray-100">Cancel</button>
                    <button type="button" onclick="saveNotes()" class="px-3 py-1.5 text-xs bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save Notes</button>
