@model TaskTracker.Models.ViewModels.DashboardViewModel
@using TaskTracker.Models.Entities
@{
    ViewData["Title"] = "Dashboard";
    
    // Helper function for safe date arithmetic
    DateTime SafeDate(DateTime date)
    {
        if (date == DateTime.MinValue || date == DateTime.MaxValue)
            date = DateTime.UtcNow;
        if (date.Kind == DateTimeKind.Unspecified)
            date = DateTime.SpecifyKind(date, DateTimeKind.Local);
        return date;
    }
    
    DateTime SafeAddDays(DateTime date, int days)
    {
        try
        {
            return SafeDate(date).AddDays(days);
        }
        catch
        {
            return SafeDate(date);
        }
    }
    
    var safeCurrentDate = SafeDate(Model.CurrentDate);
    var dateKey = safeCurrentDate.ToString("yyyy-MM-dd");
    var previousDate = SafeAddDays(safeCurrentDate, -1);
    var previousDateKey = previousDate.ToString("yyyy-MM-dd");
    
    var hiddenTasksDict = ViewBag.HiddenTasks as Dictionary<int, List<string>> ?? new Dictionary<int, List<string>>();

    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }
    
    var notesDict = Model.NotesData ?? new Dictionary<string, string>();
    var completedTasks = Model.TaskData.Values.Count(v => v?.IsCompleted == true);

    // Dynamic stats for pending
    var totalVisibleAssignments = 0;
    foreach (var branch in Model.Branches)
    {
        var hiddenNames = hiddenTasksDict.ContainsKey(branch.Id) ? hiddenTasksDict[branch.Id] : new List<string>();
        totalVisibleAssignments += Model.Tasks.Count(t => !hiddenNames.Contains(t.Name));
    }
    var pendingTasksCount = totalVisibleAssignments - completedTasks;
}

@section Styles {
    <style>
        .dark-table {
            border-collapse: separate;
            border-spacing: 0 4px;
        }

        .dark-table thead th {
            background: rgba(255, 255, 255, 0.02);
            padding: 1rem 0.5rem;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-size: 0.7rem;
            border-bottom: 2px solid var(--border);
        }

        .sticky-col {
            position: sticky;
            left: 0;
            background: #0b0b18 !important;
            z-index: 20;
            border-right: 1px solid var(--border) !important;
        }

        .task-button {
            width: 100%;
            height: 32px;
            border-radius: 6px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            font-weight: 700;
            transition: all 0.15s;
            border: 1px solid rgba(255,255,255,0.05);
            background: rgba(255,255,255,0.03);
            color: #64748b;
        }

        .task-button:hover:not(:disabled) {
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.15);
        }

        /* Status Colors */
        .status-early { background: rgba(16, 185, 129, 0.15) !important; color: #10b981 !important; border-color: rgba(16,185,129,0.3) !important; }
        .status-on-time { background: rgba(59, 130, 246, 0.15) !important; color: #3b82f6 !important; border-color: rgba(59,130,246,0.3) !important; }
        .status-late-min { background: rgba(245, 158, 11, 0.15) !important; color: #f59e0b !important; border-color: rgba(245,158,11,0.3) !important; }
        .status-late-hour { background: rgba(249, 115, 22, 0.15) !important; color: #f97316 !important; border-color: rgba(249,115,22,0.3) !important; }
        .status-late-day { background: rgba(239, 68, 68, 0.15) !important; color: #ef4444 !important; border-color: rgba(239,68,68,0.3) !important; }

        @@media print {
            .no-print { display: none !important; }
            body { background: white !important; color: black !important; }
            .glass-card { border: 1px solid #ddd; background: none; backdrop-filter: none; }
        }
    </style>
}

<div class="animate-fade-up space-y-6">
    <input type="hidden" id="requestVerificationToken" value="@token" />
    <input type="hidden" id="currentDate" value="@dateKey" />
    <input type="hidden" id="isHoliday" value="@Model.IsHoliday.ToString().ToLower()" />
    <input type="hidden" id="holidayName" value="@Model.HolidayName" />
    <input type="hidden" id="previousDate" value="@previousDateKey" />

    <!-- Header Section -->
    <div class="glass-card overflow-hidden no-print">
        <div class="px-6 py-5 flex flex-wrap justify-between items-center gap-4">
            <div>
                <div class="flex items-center gap-2 mb-1">
                    <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Live Operations Monitor</span>
                </div>
                <h1 class="text-3xl font-black text-white tracking-tight"> Dashboard</h1>
                <div class="flex items-center gap-3 mt-1.5">
                    <span class="text-xs text-slate-400 flex items-center gap-1">
                        <i class="far fa-calendar-alt text-indigo-400"></i>
                        @safeCurrentDate.ToString("dddd, MMMM d, yyyy")
                    </span>
                    @if (Model.IsHoliday)
                    {
                        <span class="px-2.5 py-0.5 bg-violet-500/10 text-violet-400 border border-violet-500/20 rounded-full text-[10px] font-bold">
                            <i class="fas fa-gift mr-1"></i> HOLIDAY: @Model.HolidayName
                        </span>
                    }
                </div>
            </div>

            <div class="flex items-center gap-3">
                <div class="flex items-center bg-white/5 border border-white/10 rounded-xl p-1">
                    <button onclick="changeDate(-1)" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/10 rounded-lg transition" title="Prev Day (A)">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </button>
                    <div class="px-4 text-xs font-bold text-slate-200 border-x border-white/10">
                        @safeCurrentDate.ToString("MMM dd")
                    </div>
                    <button onclick="changeDate(1)" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/10 rounded-lg transition" title="Next Day (D)">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </button>
                </div>
                <input type="date" id="datePicker" value="@safeCurrentDate.ToString("yyyy-MM-dd")"
                       class="bg-white/5 text-slate-200 border border-white/10 rounded-xl px-3 py-2 text-xs focus:ring-2 focus:ring-indigo-500 outline-none transition"
                       style="color-scheme: dark;" />

                @if (!Model.IsHoliday)
                {
                    <button onclick="openBulkUpdateModal()" class="btn-action btn-primary">
                        <i class="fas fa-layer-group"></i> <span>Bulk</span>
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Action Bar -->
    <div class="flex justify-end gap-2 no-print">
        <button onclick="openBulkUpdateModal()" class="px-3 py-1.5 bg-purple-500/10 text-purple-400 border border-purple-500/20 hover:bg-purple-500/20 rounded-lg text-xs font-bold transition">
            <i class="fas fa-layer-group mr-1"></i> BULK
        </button>
        <button onclick="exportDashboardToExcel()" class="px-3 py-1.5 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/20 rounded-lg text-xs font-bold transition">
            <i class="fas fa-file-excel mr-1"></i> EXCEL
        </button>
        <button onclick="window.print()" class="px-3 py-1.5 bg-slate-500/10 text-slate-400 border border-slate-500/20 hover:bg-slate-500/20 rounded-lg text-xs font-bold transition">
            <i class="fas fa-print mr-1"></i> PRINT
        </button>
        <button onclick="showKeyboardShortcuts()" class="px-3 py-1.5 bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 hover:bg-indigo-500/20 rounded-lg text-xs font-bold transition">
            <i class="fas fa-keyboard mr-1"></i> SHORTCUT
        </button>
    </div>

    <!-- KPI Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="glass-card p-4">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Branches</p>
                    <h3 class="text-2xl font-black text-white" id="totalBranches">@Model.Branches.Count</h3>
                </div>
                <div class="w-10 h-10 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400">
                    <i class="fas fa-store"></i>
                </div>
            </div>
        </div>
        <div class="glass-card p-4">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Total Tasks</p>
                    <h3 class="text-2xl font-black text-white" id="totalTasksCount">@Model.Tasks.Count</h3>
                </div>
                <div class="w-10 h-10 rounded-xl bg-violet-500/10 flex items-center justify-center text-violet-400">
                    <i class="fas fa-tasks"></i>
                </div>
            </div>
        </div>
        <div class="glass-card p-4">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Completed</p>
                    <h3 class="text-2xl font-black text-emerald-400" id="completedCount">@completedTasks</h3>
                </div>
                <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
            <div id="completedTrend" class="mt-2 text-[10px] text-slate-500"><i class="fas fa-chart-line mr-1"></i> <span id="completedTrendValue">Calculated...</span></div>
        </div>
        <div class="glass-card p-4">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Pending</p>
                    <h3 class="text-2xl font-black text-amber-500" id="pendingCount">@pendingTasksCount</h3>
                </div>
                <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500">
                    <i class="fas fa-clock"></i>
                </div>
            </div>
            <div id="pendingTrend" class="mt-2 text-[10px] text-slate-500"><i class="fas fa-chart-line mr-1"></i> <span id="pendingTrendValue">Calculated...</span></div>
        </div>
    </div>

    <!-- Overall Progress Card -->
    <div class="glass-card p-4">
        <div class="flex items-center justify-between mb-3">
            <div class="flex gap-6">
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase mb-0.5">Completion Rate</p>
                    <p class="text-xl font-black text-indigo-400" id="overallCompletionRate">0%</p>
                </div>
                <div class="w-px h-8 bg-white/10"></div>
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase mb-0.5">On-Time Reliability</p>
                    <p class="text-xl font-black text-emerald-400" id="onTimeRate">0%</p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-[10px] text-slate-500 font-medium" id="trendText">Analyzing live stream...</p>
            </div>
        </div>
        <div class="w-full bg-white/5 rounded-full h-2 overflow-hidden">
            <div id="completionBar" class="h-full bg-gradient-to-r from-indigo-500 to-violet-500 transition-all duration-1000 ease-out" style="width: 0%"></div>
        </div>
    </div>

    <!-- Loading State -->
    <div id="skeletonLoader" class="glass-card p-8 text-center space-y-4">
        <div class="inline-flex items-center gap-3 text-indigo-400">
            <i class="fas fa-circle-notch fa-spin text-2xl"></i>
            <span class="font-bold tracking-tight">Initializing Enterprise Grid...</span>
        </div>
        <div class="grid grid-cols-1 gap-2 max-w-2xl mx-auto opacity-20">
            <div class="h-4 bg-white/10 rounded w-full"></div>
            <div class="h-4 bg-white/10 rounded w-5/6"></div>
            <div class="h-4 bg-white/10 rounded w-4/6"></div>
        </div>
    </div>

    <!-- Main Grid Container -->
    <div id="dashboardContainer" class="glass-card overflow-hidden" style="display: none;">
        <div class="overflow-x-auto">
            <table class="w-full dark-table" id="dashboardTable">
                <thead>
                    <tr>
                        <th class="sticky-col px-4 text-left">Branch Name</th>
                        @foreach (var task in Model.Tasks.OrderBy(t => t.DisplayOrder))
                        {
                            <th class="text-center min-w-[100px]" data-task-id="@task.Id">
                                <div class="flex flex-col items-center">
                                    <span class="text-white">@task.Name</span>
                                    <span class="text-[10px] text-indigo-400 mt-0.5 font-mono">@task.Deadline.ToString(@"hh\:mm")</span>
                                    @if (!Model.IsHoliday)
                                    {
                                        <div class="flex gap-1 mt-2">
                                            <button type="button" onclick="completeAllForTask(@task.Id, '@task.Name', event)" class="w-7 h-4 bg-emerald-500/10 text-emerald-500 text-[8px] rounded uppercase hover:bg-emerald-500 hover:text-white transition">All</button>
                                            <button type="button" onclick="resetAllForTask(@task.Id, '@task.Name', event)" class="w-7 h-4 bg-red-500/10 text-red-500 text-[8px] rounded uppercase hover:bg-red-500 hover:text-white transition">Clr</button>
                                        </div>
                                    }
                                </div>
                            </th>
                        }
                        <th class="w-32 text-center text-slate-300">Activity / Info</th>
                    </tr>
                </thead>
                <tbody id="dashboardTableBody">
                    @foreach (var branch in Model.Branches.OrderBy(b => b.Name))
                    {
                        var hiddenTaskNames = hiddenTasksDict.ContainsKey(branch.Id) ? hiddenTasksDict[branch.Id] : new List<string>();
                        var bNotes = (Model.NotesData != null && Model.NotesData.ContainsKey(branch.Id.ToString())) ? (Model.NotesData[branch.Id.ToString()] ?? "") : "";
                        
                        var visibleTasks = Model.Tasks.Where(t => !hiddenTaskNames.Contains(t.Name)).ToList();
                        var currentDone = visibleTasks.Count(t => Model.TaskData.ContainsKey($"{branch.Id}_{t.Id}") && Model.TaskData[$"{branch.Id}_{t.Id}"].IsCompleted);
                        var prog = visibleTasks.Count > 0 ? (currentDone * 100 / visibleTasks.Count) : 0;

                        <tr class="branch-row" data-branch-id="@branch.Id" data-branch-name="@branch.Name.ToLower()" data-progress="@prog">
                            <td class="sticky-col px-4 border-r border-white/5">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 rounded-full @(branch.IsActive ? "bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]" : "bg-red-500")"></div>
                                    <span class="text-xs font-bold text-white truncate max-w-[120px]" title="@branch.Name">@branch.Name</span>
                                </div>
                                <div class="text-[9px] text-slate-500 mt-1 flex items-center gap-1" id="assignedTo-@branch.Id">
                                    @if (Model.BranchAssignments != null && Model.BranchAssignments.ContainsKey(branch.Id))
                                    {
                                        <i class="fas fa-user-tag text-indigo-400"></i>
                                        <span class="truncate">@Model.BranchAssignments[branch.Id]</span>
                                    }
                                </div>
                            </td>

                            @foreach (var task in Model.Tasks.OrderBy(t => t.DisplayOrder))
                            {
                                if (hiddenTaskNames.Contains(task.Name))
                                {
                                    <td class="bg-white/[0.02] text-center opacity-20">
                                        <span class="text-[10px]">—</span>
                                    </td>
                                }
                                else
                                {
                                    <td class="p-1 text-center task-cell" id="cell-@branch.Id-@task.Id" data-branch="@branch.Id" data-task="@task.Id" data-date="@dateKey" data-task-name="@task.Name">
                                        <div class="relative group/task">
                                            @if (Model.IsHoliday)
                                            {
                                                <button type="button" class="task-button opacity-50 cursor-not-allowed" disabled>
                                                    <span class="font-mono text-[9px]">--:--</span>
                                                    <span class="text-[8px] text-slate-600 block">Holiday</span>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" onclick="quickComplete(@branch.Id, @task.Id, '@dateKey', this)" class="task-button flex flex-col items-center justify-center">
                                                    <span class="font-mono text-[9px] time-display">--:--</span>
                                                    <span class="text-[7px] uppercase tracking-tighter status-display">Pending</span>
                                                </button>
                                                <div class="absolute -top-1.5 -right-1.5 hidden group-hover/task:flex gap-0.5 z-30">
                                                    <button type="button" onclick="event.stopPropagation(); openAdjustmentModal(@branch.Id, @task.Id, '@task.Name', '@dateKey', this)" class="w-4 h-4 rounded-full bg-indigo-500 text-white text-[7px] flex items-center justify-center hover:scale-110 shadow-lg" title="Adjust Time"><i class="fas fa-clock"></i></button>
                                                    <button type="button" onclick="event.stopPropagation(); openTimePicker(@branch.Id, @task.Id, '@dateKey', this)" class="w-4 h-4 rounded-full bg-amber-500 text-white text-[7px] flex items-center justify-center hover:scale-110 shadow-lg" title="Edit Time"><i class="fas fa-edit"></i></button>
                                                    <button type="button" onclick="event.stopPropagation(); resetSingle(@branch.Id, @task.Id, '@dateKey', event, this)" class="w-4 h-4 rounded-full bg-red-500 text-white text-[7px] flex items-center justify-center hover:scale-110 shadow-lg" title="Reset Task"><i class="fas fa-trash"></i></button>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                }
                            }

                            <td class="px-2">
                                <div class="flex items-center justify-center gap-2" id="progress-cell-@branch.Id">
                                    <div class="relative w-8 h-8 flex items-center justify-center">
                                        <svg class="w-full h-full -rotate-90">
                                            <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="3" fill="transparent" class="text-white/5"></circle>
                                            <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="3" fill="transparent" class="text-indigo-500 transition-all duration-700" stroke-dasharray="88" stroke-dashoffset="@(88 - (88 * prog / 100))"></circle>
                                        </svg>
                                        <span class="absolute text-[8px] font-bold text-slate-300 progress-percent">@prog%</span>
                                    </div>
                                    <button type="button" data-branch-id="@branch.Id" data-branch-name="@branch.Name" data-branch-notes="@bNotes" onclick="openNotesModalFromData(this)" class="w-7 h-7 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:text-indigo-400 hover:bg-white/10 transition notes-btn-@branch.Id">
                                        <i class="fas @(string.IsNullOrEmpty(bNotes) ? "fa-plus text-[10px]" : "fa-sticky-note")"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Legend -->
    <div class="glass-card p-4 no-print border-indigo-500/10">
        <div class="flex flex-wrap justify-between items-center gap-4">
            <div class="flex flex-wrap gap-4 text-[10px] font-bold tracking-tight text-slate-500 uppercase">
                <span class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-emerald-500"></div> Early</span>
                <span class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-blue-500"></div> On Time</span>
                <span class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-amber-500"></div> Late</span>
                <span class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-red-500"></div> Critical</span>
                <span class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-white/10"></div> Hidden</span>
            </div>
            <div class="text-[9px] text-slate-600 font-medium">
                <i class="fas fa-keyboard mr-1"></i> [A] Prev | [D] Next | [T] Today | [F] Search | [B] Bulk | [H] Help
            </div>
        </div>
    </div>
</div>

<!-- Modals -->
<div id="timePickerModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="glass-card w-full max-w-sm m-4 overflow-hidden" style="background: #1a1a2e; border-color: rgba(255,255,255,0.1);">
        <div class="px-6 py-4 border-b border-white/5 bg-gradient-to-r from-indigo-500/10 to-transparent">
            <h3 class="text-white font-black flex items-center gap-2 tracking-tight"><i class="fas fa-clock text-indigo-400"></i> Sync Operations</h3>
            <p id="timePickerTaskInfo" class="text-[10px] text-slate-500 mt-1 uppercase font-bold tracking-wider"></p>
        </div>
        <div class="p-6 space-y-4">
            <input type="hidden" id="timePickerBranchId"><input type="hidden" id="timePickerTaskId"><input type="hidden" id="timePickerDate">
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-2">Precise Time Capture</label>
                <input type="datetime-local" id="timePickerDateTime" class="dark-input">
            </div>
            <div class="grid grid-cols-3 gap-2">
                <button type="button" onclick="setTimePreset('now')" class="py-2 bg-white/5 text-[10px] font-bold rounded-lg hover:bg-white/10 transition border border-white/5">NOW</button>
                <button type="button" onclick="setTimePreset('morning')" class="py-2 bg-white/5 text-[10px] font-bold rounded-lg hover:bg-white/10 transition border border-white/5">8AM</button>
                <button type="button" onclick="setTimePreset('noon')" class="py-2 bg-white/5 text-[10px] font-bold rounded-lg hover:bg-white/10 transition border border-white/5">12PM</button>
            </div>
            <div id="timePickerPreview" class="text-[10px] p-3 rounded-lg bg-indigo-500/5 text-indigo-300 italic border border-indigo-500/10">Ready to sync...</div>
        </div>
        <div class="px-6 py-4 bg-black/20 border-t border-white/5 flex justify-end gap-3">
            <button type="button" onclick="closeTimePicker()" class="px-4 py-2 text-xs font-bold text-slate-400 hover:text-white transition">Cancel</button>
            <button type="button" onclick="saveTaskTime()" class="px-5 py-2 btn-primary rounded-xl text-xs font-black">CONFIRM SYNC</button>
        </div>
    </div>
</div>

<div id="notesModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="glass-card w-full max-w-md m-4 overflow-hidden" style="background: #1a1a2e; border-color: rgba(255,255,255,0.1);">
        <div class="px-6 py-4 border-b border-white/5 bg-gradient-to-r from-emerald-500/10 to-transparent">
            <h3 class="text-white font-black flex items-center gap-2 tracking-tight"><i class="fas fa-sticky-note text-emerald-400"></i> Field Intelligence</h3>
            <p id="notesBranchName" class="text-[10px] text-slate-500 mt-1 uppercase font-bold tracking-wider"></p>
        </div>
        <div class="p-6">
            <input type="hidden" id="notesBranchId">
            <textarea id="notesContent" rows="5" class="dark-input" placeholder="Capture critical observations..."></textarea>
        </div>
        <div class="px-6 py-4 bg-black/20 border-t border-white/5 flex justify-end gap-3">
            <button type="button" onclick="closeNotesModal()" class="px-4 py-2 text-xs font-bold text-slate-400 hover:text-white transition">Dismiss</button>
            <button type="button" onclick="saveNotes()" class="px-5 py-2 btn-primary rounded-xl text-xs font-black" style="background: linear-gradient(135deg, #10b981, #059669);">LOG INTEL</button>
        </div>
    </div>
</div>

<div id="bulkUpdateModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="glass-card w-full max-w-sm m-4 overflow-hidden" style="background: #1a1a2e; border-color: rgba(255,255,255,0.1);">
        <div class="px-6 py-4 border-b border-white/5 bg-gradient-to-r from-purple-500/10 to-transparent">
            <h3 class="text-white font-black flex items-center gap-2 tracking-tight"><i class="fas fa-layer-group text-purple-400"></i> Industrial Bulk</h3>
        </div>
        <div class="p-6 space-y-4">
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-2">Target Task</label>
                <select id="bulkTaskId" class="dark-input">
                    <option value="">Select task...</option>
                    @foreach (var task in Model.Tasks.OrderBy(t => t.DisplayOrder))
                    {
                        <option value="@task.Id">@task.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-2">Sync Point</label>
                <input type="datetime-local" id="bulkCompletionTime" class="dark-input">
            </div>
            <div class="grid grid-cols-3 gap-2">
                <button type="button" onclick="setBulkTime('now')" class="py-2 bg-white/5 text-[10px] font-bold rounded-lg border border-white/5">NOW</button>
                <button type="button" onclick="setBulkTime('morning')" class="py-2 bg-white/5 text-[10px] font-bold rounded-lg border border-white/5">8AM</button>
                <button type="button" onclick="setBulkTime('noon')" class="py-2 bg-white/5 text-[10px] font-bold rounded-lg border border-white/5">12PM</button>
            </div>
        </div>
        <div class="px-6 py-4 bg-black/20 border-t border-white/5 flex justify-end gap-3">
            <button type="button" onclick="closeBulkUpdateModal()" class="px-4 py-2 text-xs font-bold text-slate-400">Abort</button>
            <button type="button" onclick="executeBulkUpdate()" class="px-5 py-2 btn-primary rounded-xl text-xs font-black" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">EXECUTE BATCH</button>
        </div>
    </div>
</div>

<div id="adjustmentModal" class="fixed inset-0 modal-backdrop hidden items-center justify-center z-50">
    <div class="glass-card w-full max-w-sm m-4 overflow-hidden" style="background: #1a1a2e; border-color: rgba(255,255,255,0.1);">
        <div class="px-6 py-4 border-b border-white/5 bg-gradient-to-r from-amber-500/10 to-transparent">
            <h3 id="adjustmentModalTitle" class="text-white font-black flex items-center gap-2 tracking-tight"><i class="fas fa-clock text-amber-500"></i> Task Adjustment</h3>
        </div>
        <div class="p-6 space-y-4">
            <input type="hidden" id="adjustmentBranchId">
            <input type="hidden" id="adjustmentTaskId">
            <input type="hidden" id="adjustmentDate">
            
            <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-white/5">
                <div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase">Current Buffer</p>
                    <p class="text-2xl font-black text-amber-500"><span id="currentAdjustmentDisplay">0</span><span class="text-xs ml-1">MIN</span></p>
                </div>
                <button type="button" onclick="clearAdjustment()" class="text-[10px] font-bold text-red-400 hover:text-red-300 transition">CLEAR</button>
            </div>

            <input type="hidden" id="adjustmentMinutes" value="0">
            
            <div class="grid grid-cols-4 gap-2">
                <button type="button" onclick="addAdjustment(5)" class="py-2 bg-emerald-500/10 text-emerald-400 text-[10px] font-bold rounded-lg border border-emerald-500/20 hover:bg-emerald-500/20 transition">+5m</button>
                <button type="button" onclick="addAdjustment(10)" class="py-2 bg-emerald-500/10 text-emerald-400 text-[10px] font-bold rounded-lg border border-emerald-500/20 hover:bg-emerald-500/20 transition">+10m</button>
                <button type="button" onclick="addAdjustment(-5)" class="py-2 bg-red-500/10 text-red-400 text-[10px] font-bold rounded-lg border border-red-500/20 hover:bg-red-500/20 transition">-5m</button>
                <button type="button" onclick="addAdjustment(-10)" class="py-2 bg-red-500/10 text-red-400 text-[10px] font-bold rounded-lg border border-red-500/20 hover:bg-red-500/20 transition">-10m</button>
            </div>

            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-2">Adjustment Reason</label>
                <textarea id="adjustmentReason" class="dark-input h-20 resize-none" placeholder="Reason for adjustment..."></textarea>
            </div>
        </div>
        <div class="px-6 py-4 bg-black/20 border-t border-white/5 flex justify-end gap-3">
            <button type="button" onclick="closeAdjustmentModal()" class="px-4 py-2 text-xs font-bold text-slate-400 hover:text-white transition">Cancel</button>
            <button type="button" onclick="saveAdjustment()" class="px-5 py-2 btn-primary rounded-xl text-xs font-black" style="background: linear-gradient(135deg, #f59e0b, #d97706);">APPLY BUFFER</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Critical Initialization: Branch Notes
        window.branchNotes = @Html.Raw(Json.Serialize(notesDict));
        
        // Ensure DashboardState and apiService are ready 
        $(document).ready(function() {
            // Logic handled by dashboard.js
        });
    </script>
    <script src="~/js/dashboard.js"></script>
}