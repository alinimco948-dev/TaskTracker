                            <button type="button" onclick="setTimePreset('morning')" class="py-1.5 bg-gray-100 text-gray-700 text-xs rounded hover:bg-gray-200">8 AM</button>
                            <button type="button" onclick="setTimePreset('noon')" class="py-1.5 bg-gray-100 text-gray-700 text-xs rounded hover:bg-gray-200">12 PM</button>
