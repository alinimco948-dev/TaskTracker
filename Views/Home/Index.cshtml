@model TaskTracker.Models.ViewModels.DashboardViewModel
@using TaskTracker.Models.Entities
@{
    ViewData["Title"] = "Dashboard";
    
    // Helper function for safe date arithmetic
    DateTime SafeDate(DateTime date)
    {
        if (date == DateTime.MinValue || date == DateTime.MaxValue)
            date = DateTime.UtcNow;
        if (date.Kind == DateTimeKind.Unspecified)
            date = DateTime.SpecifyKind(date, DateTimeKind.Local);
        return date;
    }
    
    DateTime SafeAddDays(DateTime date, int days)
    {
        try
        {
            return SafeDate(date).AddDays(days);
        }
        catch
        {
            return SafeDate(date);
        }
    }
    
    var safeCurrentDate = SafeDate(Model.CurrentDate);
    var dateKey = safeCurrentDate.ToString("yyyy-MM-dd");
    var previousDate = SafeAddDays(safeCurrentDate, -1);
    var previousDateKey = previousDate.ToString("yyyy-MM-dd");
    
    var hiddenTasksDict = ViewBag.HiddenTasks as Dictionary<int, List<string>> ?? new Dictionary<int, List<string>>();

    var token = "";
    if (Context != null)
    {
        var antiforgery = Context.RequestServices?.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        if (antiforgery != null)
        {
            var tokens = antiforgery.GetAndStoreTokens(Context);
            token = tokens.RequestToken ?? "";
        }
    }
    
    var notesDict = Model.NotesData ?? new Dictionary<string, string>();
    
    // Calculate completed tasks count only (on-time rate will be calculated client-side)
    var completedTasks = Model.TaskData.Count(kvp => kvp.Value?.IsCompleted == true);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskTracker</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-100">
    <div class="container mx-auto px-4 py-4 max-w-7xl">
        <input type="hidden" id="requestVerificationToken" value="@token" />
        <input type="hidden" id="currentDate" value="@dateKey" />
        <input type="hidden" id="isHoliday" value="@Model.IsHoliday.ToString().ToLower()" />
        <input type="hidden" id="holidayName" value="@Model.HolidayName" />
        <input type="hidden" id="previousDate" value="@previousDateKey" />

        <script>
            var branchNotes = @Html.Raw(Json.Serialize(notesDict));
        </script>

        <!-- Header with Holiday Warning -->
        <div class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 rounded-xl shadow-xl mb-4 overflow-hidden">
            <div class="px-6 py-5">
                <div class="flex flex-wrap justify-between items-center">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                            <span class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Live Dashboard</span>
                        </div>
                        <h1 class="text-2xl font-bold text-white">Task Dashboard</h1>
                        <div class="flex items-center gap-2 mt-1">
                            <span class="text-xs text-gray-400">
                                <i class="far fa-calendar-alt mr-1"></i>@safeCurrentDate.ToString("dddd, MMMM d, yyyy")
                            </span>
                            @if (Model.IsHoliday)
                            {
                                <span class="px-2 py-0.5 bg-purple-500/30 text-purple-300 rounded-full text-[10px]">
                                    <i class="fas fa-calendar-alt mr-1"></i>@Model.HolidayName
                                </span>
                            }
                        </div>
                    </div>

                    <div class="flex items-center gap-3">
                        <div class="flex items-center bg-white/5 border border-gray-700 rounded-lg">
                            <button type="button" onclick="changeDate(-1)" 
                                    class="px-3 py-2 text-gray-400 hover:text-white hover:bg-white/5 rounded-l-lg transition">
                                <i class="fas fa-chevron-left text-xs"></i>
                            </button>
                            <div class="px-2 py-1 text-xs font-medium text-gray-300 border-x border-gray-700">
                                @safeCurrentDate.ToString("MMM dd")
                            </div>
                            <button type="button" onclick="changeDate(1)" 
                                    class="px-3 py-2 text-gray-400 hover:text-white hover:bg-white/5 rounded-r-lg transition">
                                <i class="fas fa-chevron-right text-xs"></i>
                            </button>
                        </div>
                        <input type="date" id="datePicker" value="@safeCurrentDate.ToString("yyyy-MM-dd")"
                               class="text-xs bg-gray-800 text-gray-300 border border-gray-700 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                               style="color-scheme: dark;" />

                        @if (!Model.IsHoliday)
                        {
                            <button type="button" onclick="openBulkUpdateModal()" 
                                    class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium rounded-lg transition shadow-sm flex items-center gap-2">
                                <i class="fas fa-layer-group text-[10px]"></i> Bulk
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Export Buttons -->
        <div class="flex justify-end gap-2 mb-3">
            <button onclick="exportDashboardToExcel()" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs rounded-lg flex items-center transition">
                <i class="fas fa-file-excel mr-1"></i> Excel
            </button>
            
            <button onclick="window.print()" class="px-3 py-1.5 bg-gray-600 hover:bg-gray-700 text-white text-xs rounded-lg flex items-center transition">
                <i class="fas fa-print mr-1"></i> Print
            </button>
            <button onclick="showKeyboardShortcuts()" class="px-3 py-1.5 bg-gray-500 hover:bg-gray-600 text-white text-xs rounded-lg flex items-center transition" title="Keyboard Shortcuts">
                <i class="fas fa-keyboard mr-1"></i> Shortcuts
            </button>
        </div>

        <!-- Filter Bar -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-3 mb-4">
            <div class="flex flex-wrap gap-3 items-center">
                <div class="flex-1 min-w-[200px]">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 text-xs"></i>
                        <input type="text" id="branchSearch" placeholder="Search branch..." 
                               class="w-full pl-8 pr-3 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>
                <div>
                    <select id="statusFilter" class="px-3 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="all">All Tasks</option>
                        <option value="completed">Completed Only</option>
                        <option value="pending">Pending Only</option>
                        <option value="late">Late Only</option>
                    </select>
                </div>
                <div>
                    <select id="taskFilter" class="px-3 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="all">All Tasks</option>
                        @foreach (var task in Model.Tasks.OrderBy(t => t.DisplayOrder))
                        {
                            <option value="@task.Id">@task.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="flex items-center gap-2 text-xs">
                        <input type="checkbox" id="myTasksOnly" class="rounded">
                        <span>My assigned tasks only</span>
                    </label>
                </div>
                <button onclick="resetFilters()" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs rounded-lg transition">
                    <i class="fas fa-undo-alt mr-1"></i> Reset
                </button>
                <button onclick="clearAllFilters()" class="px-3 py-1.5 bg-red-100 hover:bg-red-200 text-red-700 text-xs rounded-lg transition">
                    <i class="fas fa-trash-alt mr-1"></i> Clear All
                </button>
            </div>
            <div class="text-xs text-gray-500 mt-2" id="filterStats">
                Showing <span id="visibleBranchesCount">0</span> branches, <span id="visibleTasksCount">0</span> tasks
            </div>
        </div>

        <!-- Stats Cards with Trend Indicators -->
        <div class="grid grid-cols-4 gap-2 mb-4">
            <div class="bg-white rounded-md shadow-sm p-2 border-l-4 border-blue-500">
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-[9px] text-gray-500 uppercase tracking-wider">Branches</div>
                        <div class="text-base font-bold text-gray-800" id="totalBranches">@Model.Branches.Count</div>
                    </div>
                    <div class="w-7 h-7 bg-blue-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-store text-blue-600 text-xs"></i>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-md shadow-sm p-2 border-l-4 border-green-500">
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-[9px] text-gray-500 uppercase tracking-wider">Tasks</div>
                        <div class="text-base font-bold text-gray-800" id="totalTasksCount">@Model.Tasks.Count</div>
                    </div>
                    <div class="w-7 h-7 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-tasks text-green-600 text-xs"></i>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-md shadow-sm p-2 border-l-4 border-green-500">
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-[9px] text-gray-500 uppercase tracking-wider">Completed</div>
                        <p class="text-base font-bold text-green-600" id="completedCount">
                            @completedTasks
                        </p>
                        <div class="text-[8px] text-green-500" id="completedTrend">
                            <i class="fas fa-chart-line"></i> <span id="completedTrendValue">--</span>
                        </div>
                    </div>
                    <div class="w-7 h-7 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-check-circle text-green-600 text-xs"></i>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-md shadow-sm p-2 border-l-4 border-yellow-500">
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-[9px] text-gray-500 uppercase tracking-wider">Pending</div>
                        <p class="text-base font-bold text-yellow-600" id="pendingCount">
                            @{
                                var totalVisibleTasks = 0;
                                foreach (var branch in Model.Branches)
                                {
                                    var hiddenTaskNames = hiddenTasksDict.ContainsKey(branch.Id)
                                    ? hiddenTasksDict[branch.Id]
                                    : new List<string>();
                                    var visibleTasksCount = Model.Tasks.Count(t => !hiddenTaskNames.Contains(t.Name));
                                    totalVisibleTasks += visibleTasksCount;
                                }
                                var pendingTasks = totalVisibleTasks - completedTasks;
                            }
                            @pendingTasks
                        </p>
                        <div class="text-[8px] text-red-500" id="pendingTrend">
                            <i class="fas fa-chart-line"></i> <span id="pendingTrendValue">--</span>
                        </div>
                    </div>
                    <div class="w-7 h-7 bg-yellow-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-clock text-yellow-600 text-xs"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Completion Rate Card with Trend -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-3 mb-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div>
                        <div class="text-[10px] text-gray-500">Overall Completion Rate</div>
                        <div class="text-xl font-bold text-blue-600" id="overallCompletionRate">0%</div>
                    </div>
                    <div class="w-px h-8 bg-gray-200"></div>
                    <div>
                        <div class="text-[10px] text-gray-500">On-Time Rate</div>
                        <div class="text-xl font-bold text-green-600" id="onTimeRate">0%</div>
                    </div>
                </div>
                <div class="text-right">
                    <div class="text-[9px] text-gray-400" id="trendText">Loading trend data...</div>
                </div>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-1.5 mt-2">
                <div class="bg-blue-500 h-1.5 rounded-full transition-all duration-500" id="completionBar" style="width: 0%"></div>
            </div>
        </div>

        <!-- Skeleton Loader -->
        <div id="skeletonLoader" class="bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden mb-6">
            <div class="animate-pulse">
                <div class="h-10 bg-gray-200 mb-2"></div>
                <div class="space-y-2 p-4">
                    @for (int i = 0; i < 5; i++)
                    {
                        <div class="flex gap-2">
                            <div class="h-8 bg-gray-200 rounded w-32"></div>
                            @for (int j = 0; j < Model.Tasks.Count; j++)
                            {
                                <div class="h-8 bg-gray-200 rounded flex-1"></div>
                            }
                            <div class="h-8 bg-gray-200 rounded w-24"></div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Main Dashboard Table -->
        <div id="dashboardContainer" class="bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden mb-6" style="display: none;">
            <div class="overflow-x-auto">
                <table class="w-full text-xs table-fixed" id="dashboardTable">
                    <thead class="bg-gradient-to-r from-gray-50 to-gray-100 border-b-2 border-gray-200">
                        <tr>
                            <th class="px-3 py-3 text-left font-semibold text-gray-700 w-32">Branch</th>
                            @foreach (var task in Model.Tasks.OrderBy(t => t.DisplayOrder))
                            {
                                <th class="px-1 py-3 text-center font-semibold text-gray-700 task-header" data-task-id="@task.Id" style="min-width: 80px;">
                                    <div class="flex flex-col items-center">
                                        <span class="text-xs">@task.Name</span>
                                        <span class="text-[9px] text-gray-500 mt-0.5">@task.Deadline.ToString(@"hh\:mm")</span>
                                        @if (!Model.IsHoliday)
                                        {
                                            <div class="flex gap-1 mt-1 w-full">
                                                <button type="button" onclick="completeAllForTask(@task.Id, '@task.Name', event)"
                                                        class="text-[8px] bg-green-500 text-white px-2 py-0.5 rounded-full hover:bg-green-600 transition flex-1">
                                                    All
                                                </button>
                                                <button type="button" onclick="resetAllForTask(@task.Id, '@task.Name', event)"
                                                        class="text-[8px] bg-red-500 text-white px-2 py-0.5 rounded-full hover:bg-red-600 transition flex-1">
                                                    Reset
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </th>
                            }
                            <th class="px-3 py-3 text-center font-semibold text-gray-700 w-28">% / Notes</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200" id="dashboardTableBody">
                        @foreach (var branch in Model.Branches.OrderBy(b => b.Name))
                        {
                            var hiddenTaskNames = hiddenTasksDict.ContainsKey(branch.Id)
                            ? hiddenTasksDict[branch.Id]
                            : new List<string>();
                            var branchNotes = Model.NotesData.ContainsKey(branch.Id.ToString()) ? Model.NotesData[branch.Id.ToString()] : "";
                            var visibleTasksCount = Model.Tasks.Count(t => !hiddenTaskNames.Contains(t.Name));
                            var completedCountLocal = 0;
                            foreach (var task in Model.Tasks.Where(t => !hiddenTaskNames.Contains(t.Name)))
                            {
                                if (Model.TaskData.ContainsKey($"{branch.Id}_{task.Id}") &&
                                    Model.TaskData[$"{branch.Id}_{task.Id}"].IsCompleted)
                                {
                                    completedCountLocal++;
                                }
                            }
                            var progress = visibleTasksCount > 0 ? (completedCountLocal * 100 / visibleTasksCount) : 0;

                            <tr class="hover:bg-gray-50 transition group branch-row" data-branch-id="@branch.Id" data-branch-name="@branch.Name.ToLower()" data-progress="@progress">
                                <td class="px-3 py-2 font-medium sticky left-0 bg-white border-r group-hover:bg-gray-50">
                                    <div class="flex items-center">
                                        <span class="w-2 h-2 rounded-full @(branch.IsActive ? "bg-green-500" : "bg-red-500") mr-2"></span>
                                        <span class="text-xs truncate" style="max-width: 90px;" title="@branch.Name">@branch.Name</span>
                                    </div>
                                    <div class="text-[8px] text-gray-400 mt-0.5" id="assignedTo-@branch.Id">
                                        @if (Model.BranchAssignments != null && Model.BranchAssignments.ContainsKey(branch.Id))
                                        {
                                            <i class="fas fa-user mr-0.5"></i>@Model.BranchAssignments[branch.Id]
                                        }
                                    </div>
                                </td>

                                @foreach (var task in Model.Tasks.OrderBy(t => t.DisplayOrder))
                                {
                                    var isHidden = hiddenTaskNames.Contains(task.Name);

                                    if (isHidden)
                                    {
                                        <td class="px-1 py-2 text-center bg-gray-50">
                                            <span class="text-gray-400 text-[9px]">—</span>
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="px-1 py-1 text-center relative group/task task-cell" 
                                            id="cell-@branch.Id-@task.Id"
                                            data-branch="@branch.Id" 
                                            data-task="@task.Id" 
                                            data-date="@dateKey" 
                                            data-task-name="@task.Name">
                                            <div class="relative inline-block w-full">
                                                @if (Model.IsHoliday)
                                                {
                                                    <button type="button"
                                                            class="w-full px-1 py-2 rounded text-[9px] font-medium bg-purple-100 text-purple-700 cursor-default flex items-center justify-between gap-0.5 border border-purple-200 opacity-75"
                                                            disabled
                                                            title="Today is a holiday - No tasks required">
                                                        <span class="font-mono font-bold flex-1">--:--</span>
                                                        <span class="flex-1 text-[8px] truncate px-0.5">🎉 Holiday</span>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button"
                                                            onclick="quickComplete(@branch.Id, @task.Id, '@dateKey', this)"
                                                            class="w-full px-1 py-2 rounded text-[9px] font-medium bg-gray-50 text-gray-600 hover:opacity-90 transition-all flex items-center justify-between gap-0.5 border border-gray-200 task-button"
                                                            title="Click to complete with current time"
                                                            data-task-id="@task.Id"
                                                            data-branch-id="@branch.Id"
                                                            data-date="@dateKey">
                                                        <span class="font-mono font-bold flex-1 time-display">--:--</span>
                                                        <span class="flex-1 text-[8px] truncate px-0.5 status-display">Pending</span>
                                                    </button>
                                                    <div class="absolute -top-2 -right-2 hidden group-hover/task:flex space-x-0.5 z-20">
                                                        <button type="button"
                                                                onclick="event.stopPropagation(); openTimePicker(@branch.Id, @task.Id, '@dateKey', this)"
                                                                class="w-4 h-4 bg-amber-500 text-white rounded-full text-[6px] flex items-center justify-center hover:bg-amber-600 shadow-sm"
                                                                title="Edit completion time">
                                                            <i class="fas fa-clock"></i>
                                                        </button>
                                                        <button type="button"
                                                                onclick="event.stopPropagation(); resetSingle(@branch.Id, @task.Id, '@dateKey', event, this)"
                                                                class="w-4 h-4 bg-red-500 text-white rounded-full text-[6px] flex items-center justify-center hover:bg-red-600 shadow-sm"
                                                                title="Reset this specific task">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                        <button type="button"
                                                                onclick="event.stopPropagation(); openAdjustmentModal(@branch.Id, @task.Id, '@task.Name', '@dateKey', this)"
                                                                class="w-4 h-4 bg-amber-400 text-white rounded-full text-[6px] flex items-center justify-center hover:bg-amber-500 shadow-sm"
                                                                title="Add adjustment">
                                                            <i class="fas fa-plus"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    }
                                }

                                <td class="px-2 py-2 text-center">
                                    <div class="flex items-center justify-center gap-2" id="progress-cell-@branch.Id">
                                        <div class="w-12 bg-gray-200 rounded-full h-2">
                                            <div class="bg-blue-500 h-2 rounded-full" style="width: @progress%"></div>
                                        </div>
                                        <span class="text-[10px] font-medium text-gray-600 progress-percent">@progress%</span>
                                        <button type="button" 
                                                onclick="openNotesModal(@branch.Id, '@branch.Name', '@Html.Raw(Json.Serialize(branchNotes).ToString().Replace("\"", "&quot;"))')"
                                                class="w-6 h-6 flex items-center justify-center rounded-full transition notes-btn-@branch.Id hover:scale-110"
                                                title="View/Edit notes">
                                            @if (!string.IsNullOrEmpty(branchNotes))
                                            {
                                                <i class="fas fa-sticky-note text-sm text-blue-500"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-plus-circle text-sm text-gray-400 hover:text-blue-500"></i>
                                            }
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Legend -->
        <div class="bg-white rounded-lg shadow-md p-3 mb-6">
            <div class="flex flex-wrap items-center gap-3 text-[9px]">
                @if (Model.IsHoliday)
                {
                    <span class="flex items-center"><span class="w-2 h-2 bg-purple-500 rounded-full mr-1"></span> Holiday - No tasks required</span>
                }
                else
                {
                    <span class="flex items-center"><span class="w-2 h-2 bg-blue-500 rounded-full mr-1"></span> Early</span>
                    <span class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-1"></span> On Time</span>
                    <span class="flex items-center"><span class="w-2 h-2 bg-yellow-500 rounded-full mr-1"></span> Minutes Late (1-59 min)</span>
                    <span class="flex items-center"><span class="w-2 h-2 bg-orange-500 rounded-full mr-1"></span> Hours Late (1-23 hrs)</span>
                    <span class="flex items-center"><span class="w-2 h-2 bg-red-500 rounded-full mr-1"></span> Days Late (1+ days)</span>
                    <span class="flex items-center"><span class="w-2 h-2 bg-gray-300 rounded-full mr-1"></span> Hidden</span>
                    <span class="flex items-center"><i class="fas fa-clock text-amber-500 text-[8px] mr-1"></i> Edit Time</span>
                    <span class="flex items-center"><i class="fas fa-times text-red-500 text-[8px] mr-1"></i> Reset Single</span>
                    <span class="flex items-center"><i class="fas fa-plus text-amber-600 text-[8px] mr-1"></i> Add Adjustment</span>
                    <span class="flex items-center"><i class="fas fa-undo-alt text-red-500 text-[8px] mr-1"></i> Reset All</span>
                    <span class="flex items-center"><i class="fas fa-sticky-note text-blue-500 text-sm mr-1"></i> Notes</span>
                }
            </div>
            <div class="text-[8px] text-gray-400 mt-2 text-center">
                <i class="fas fa-sync-alt text-green-500 mr-1"></i> All updates happen instantly - No refresh needed
                <span class="mx-2">|</span>
                <i class="fas fa-keyboard text-gray-400 mr-1"></i> Ctrl+D: Next day | Ctrl+A: Prev day | Ctrl+T: Today | Ctrl+F: Search | Ctrl+B: Bulk
            </div>
        </div>

        <!-- Time Picker Modal -->
        <div id="timePickerModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50 backdrop-blur-sm">
            <div class="bg-white rounded-xl shadow-2xl w-80 transform transition-all">
                <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-4 py-3 rounded-t-xl">
                    <h3 class="text-base font-semibold text-white flex items-center">
                        <i class="fas fa-clock mr-2"></i>Edit Completion Time
                    </h3>
