        </div>

        <!-- Adjustment Modal -->
        <div id="adjustmentModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50 backdrop-blur-sm">
            <div class="bg-white rounded-xl shadow-2xl w-80 transform transition-all">
                <div class="bg-gradient-to-r from-amber-600 to-amber-800 px-4 py-3 rounded-t-xl">
                    <h3 class="text-base font-semibold text-white" id="adjustmentModalTitle">Adjust Task Time</h3>
                </div>
                <div class="p-4">
                    <input type="hidden" id="adjustmentBranchId">
